---
// src/pages/portal/dashboard.astro
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import DashboardUI from '../../components/portal/DashboardUI.astro';

// Protección de Ruta
const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/login');
---

<PortalLayout title="Console | Flouvia OS">
    <DashboardUI lang="es" />
</PortalLayout>