---
// src/pages/portal/login.astro
// Servido en flouvia.com/login vía rewrite de Vercel.
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import LoginUI from '../../components/portal/LoginUI.astro';

const { userId } = await Astro.locals.auth();
if (userId) {
  // Una vez autenticado, mandamos al subdominio del portal.
  return Astro.redirect('https://os.flouvia.com/dashboard');
}
---

<PortalLayout title="Acceso Privado | Flouvia">
    <LoginUI lang="es" />
</PortalLayout>
