---
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import EntornoUI from '../../components/portal/EntornoUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/en/login');
---
<PortalLayout title="Environment | Flouvia OS">
    <EntornoUI lang="en" />
</PortalLayout>
