---
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import BovedaUploadUI from '../../components/portal/BovedaUploadUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/en/login');
---
<PortalLayout title="Upload File | Flouvia OS">
    <BovedaUploadUI lang="en" />
</PortalLayout>
