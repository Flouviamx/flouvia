{
  "redirects": [
    {
      "source": "/portal/:path*",
      "has": [{ "type": "host", "value": "flouvia.com" }],
      "destination": "https://os.flouvia.com/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "os.flouvia.com" }],
      "destination": "/portal/:path*"
    }
  ]
}
