---
export const prerender = false;
import PortalLayout from '../layouts/PortalLayout.astro';
import PrivacidadPortalUI from '../components/portal/PrivacidadPortalUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/login');
---
<PortalLayout title="Privacidad de Datos | Flouvia OS">
  <PrivacidadPortalUI lang="es" />
</PortalLayout>
