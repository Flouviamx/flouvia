---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';
import { casos } from '../../data/casos';

export function getStaticPaths() {
  return casos.map(c => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const caso     = casos.find(c => c.slug === slug)!;
const idx      = casos.indexOf(caso);
const next     = casos[(idx + 1) % casos.length];
const isEn     = Astro.url.pathname.startsWith('/en/');
const t        = (obj: { es: string; en: string }) => isEn ? obj.en : obj.es;
const casosUrl = isEn ? '/en/casos' : '/casos';
---

<Layout title={`${caso.brand} | Flouvia`}>
  <Navbar />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">

  <main class="cs-root">

    <!-- ═══ TOPBAR ═══ -->
    <div class="cs-topbar" id="cs-topbar">
      <a href={casosUrl} class="cs-back">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8"><polyline points="15 18 9 12 15 6"/></svg>
        {isEn ? 'Cases' : 'Casos'}
      </a>
      <div class="cs-topbar-mid">
        <span class="cs-topnum">/{ caso.num }</span>
        <span class="cs-topsep">·</span>
        <span class="cs-topbrand">{ caso.brand }</span>
      </div>
      <a href={caso.liveUrl} target="_blank" rel="noopener" class="cs-live-link">
        { caso.liveDomain }
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>

    <!-- ═══ HERO ═══ -->
    <section class="cs-hero">
      <div class="cs-container">
        <div class="cs-hero-inner" id="cs-hero-inner">
          <p class="cs-eyebrow" id="cs-eyebrow">{ t(caso.category) }</p>
          <h1 class="cs-brand" id="cs-brand">{ caso.brand }.</h1>
          <p class="cs-tagline" id="cs-tagline">{ t(caso.tagline) }</p>
          <p class="cs-desc" id="cs-desc">{ t(caso.desc) }</p>
        </div>

        <!-- Metrics strip -->
        <div class="cs-metrics" id="cs-metrics">
          { caso.metrics.map(m => (
            <div class="cs-metric">
              <span class="cs-metric-val">{ m.val }</span>
              <span class="cs-metric-lbl">{ t(m.label) }</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ IMAGEN CASO ═══ -->
    <section class="cs-visual-section">
      <div class="cs-container">
        <div class="cs-visual-wrap" id="cs-visual">
          <img src={caso.image} alt={`${caso.brand} — Flouvia`} class="cs-visual-img" />
        </div>
      </div>
    </section>

    <!-- ═══ CUERPO: RETO + SOLUCIÓN ═══ -->
    <section class="cs-body-section">
      <div class="cs-container">
        <div class="cs-body-grid">

          <div class="cs-col-left" id="cs-challenge">
            <span class="cs-col-label">{ isEn ? 'The Challenge' : 'El Reto' }</span>
            <div class="cs-col-rule"></div>
            <p class="cs-challenge-text">{ t(caso.challenge) }</p>
          </div>

          <div class="cs-col-right" id="cs-solution">
            <span class="cs-col-label">{ isEn ? 'The Solution' : 'La Solución' }</span>
            <div class="cs-col-rule"></div>
            <ul class="cs-solution-list">
              { caso.solutionPoints.map(pt => (
                <li class="cs-solution-item">
                  <span class="cs-bullet"></span>
                  <span>{ t(pt) }</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ STACK ═══ -->
    <section class="cs-stack-section">
      <div class="cs-container">
        <div class="cs-stack-inner" id="cs-stack">
          <span class="cs-col-label">{ isEn ? 'Tech Stack' : 'Stack Utilizado' }</span>
          <div class="cs-stack-pills">
            { caso.stack.map(tech => (
              <span class="cs-pill">{ tech }</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ RESULTADOS (dark) ═══ -->
    <section class="cs-results-section" id="cs-results">
      <div class="cs-container">
        <p class="cs-results-eyebrow">{ isEn ? 'RESULTS' : 'RESULTADOS' }</p>
        <div class="cs-results-grid">
          { caso.results.map(r => (
            <div class="cs-result-card">
              <span class="cs-result-val" data-val={r.val}>{ r.val }</span>
              <span class="cs-result-label">{ t(r.label) }</span>
              <p class="cs-result-desc">{ t(r.desc) }</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ NAVEGACIÓN ENTRE CASOS ═══ -->
    <section class="cs-nav-section">
      <div class="cs-container">
        <div class="cs-nav-bar">
          <a href={casosUrl} class="cs-nav-all">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            { isEn ? 'All cases' : 'Todos los casos' }
          </a>
          <a href={`${casosUrl}/${next.slug}`} class="cs-nav-next">
            <div class="cs-nav-next-info">
              <span class="cs-nav-next-label">{ isEn ? 'Next case' : 'Siguiente caso' }</span>
              <span class="cs-nav-next-brand">{ next.brand }</span>
            </div>
            <div class="cs-nav-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="cs-cta-section">
      <div class="cs-container">
        <div class="cs-cta-card" id="cs-cta">
          <div class="cs-cta-noise"></div>
          <div class="cs-cta-inner">
            <div>
              <p class="cs-cta-eyebrow">{ isEn ? 'THE NEXT STEP' : 'EL SIGUIENTE PASO' }</p>
              <h2 class="cs-cta-title">
                { isEn ? 'Build your' : 'Construyamos' }
                <em class="cs-cta-serif">{ isEn ? 'edge.' : 'su ventaja.' }</em>
              </h2>
            </div>
            <a href={ isEn ? '/en/contacto' : '/contacto' } class="cs-cta-btn">
              <span>{ isEn ? 'Start Architecture' : 'Iniciar Arquitectura' }</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <WhatsApp />
</Layout>

<style>
/* ══════════════════════════════════════════════════
   TOKENS & ROOT
══════════════════════════════════════════════════ */
.cs-root {
  --blue:    #0a192f;
  --muted:   #6b7280;
  --border:  rgba(0,0,0,0.07);
  --ease:    cubic-bezier(0.16, 1, 0.3, 1);
  --spring:  cubic-bezier(0.175, 0.885, 0.32, 1.05);
  --serif:   'Instrument Serif', Georgia, serif;
  --mono:    'JetBrains Mono', monospace;

  background: #fff;
  color: #050505;
  font-family: 'Inter', system-ui, sans-serif;
  overflow-x: clip;
}

.cs-container {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 5%;
}

/* ══════════════════════════════════════════════════
   TOPBAR
══════════════════════════════════════════════════ */
.cs-topbar {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.9rem 5%;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--border);
  opacity: 0;
}

.cs-back {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--muted);
  text-decoration: none;
  transition: color .2s;
  flex-shrink: 0;
}
.cs-back:hover { color: #050505; }

.cs-topbar-mid {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.8rem;
  font-weight: 600;
}
.cs-topnum   { font-family: var(--mono); color: var(--muted); }
.cs-topsep   { color: var(--border); }
.cs-topbrand { color: #050505; }

.cs-live-link {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.75rem;
  font-weight: 600;
  font-family: var(--mono);
  color: var(--muted);
  text-decoration: none;
  transition: color .2s;
  flex-shrink: 0;
}
.cs-live-link:hover { color: #050505; }

/* ══════════════════════════════════════════════════
   HERO
══════════════════════════════════════════════════ */
.cs-hero {
  padding: 9rem 0 4rem;
  background: #fff;
}

.cs-hero-inner { margin-bottom: 5rem; }

.cs-eyebrow {
  font-size: 0.62rem;
  font-weight: 800;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--muted);
  margin: 0 0 2rem;
  opacity: 0;
}

.cs-brand {
  font-size: clamp(4.5rem, 11vw, 10rem);
  font-weight: 800;
  letter-spacing: -4px;
  line-height: 0.88;
  margin: 0 0 2.5rem;
  color: #050505;
  overflow: hidden;
}

.cs-tagline {
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  font-weight: 400;
  letter-spacing: -0.5px;
  color: #222;
  margin: 0 0 1.5rem;
  line-height: 1.2;
  opacity: 0;
}

.cs-desc {
  font-size: 1.1rem;
  color: var(--muted);
  max-width: 640px;
  line-height: 1.65;
  margin: 0;
  opacity: 0;
}

/* Metrics strip */
.cs-metrics {
  display: flex;
  gap: 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  opacity: 0;
}

.cs-metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  padding: 1.8rem 2rem;
  border-right: 1px solid var(--border);
  transition: background .3s var(--ease);
}
.cs-metric:last-child { border-right: none; }
.cs-metric:hover { background: rgba(0,0,0,0.018); }

.cs-metric-val {
  font-family: var(--mono);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 700;
  color: var(--blue);
  line-height: 1;
  letter-spacing: -1px;
}

.cs-metric-lbl {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
}

/* ══════════════════════════════════════════════════
   IMAGEN CASO
══════════════════════════════════════════════════ */
.cs-visual-section {
  padding: 5rem 0;
  background: #f8f9fb;
}

.cs-visual-wrap {
  border-radius: 28px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 420px;
  transform: scale(0.97);
  opacity: 0;
}

.cs-visual-img {
  width: 100%;
  height: auto;
  display: block;
  max-height: 560px;
  object-fit: cover;
}

/* ══════════════════════════════════════════════════
   CUERPO: RETO + SOLUCIÓN
══════════════════════════════════════════════════ */
.cs-body-section {
  padding: 7rem 0;
  background: #fff;
}

.cs-body-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: start;
}

.cs-col-label {
  display: block;
  font-size: 0.58rem;
  font-weight: 800;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #bbb;
  margin-bottom: 1rem;
}

.cs-col-rule {
  height: 2px;
  background: #050505;
  width: 32px;
  margin-bottom: 2rem;
  transform: scaleX(0);
  transform-origin: left;
}

.cs-col-left { opacity: 0; transform: translateX(-30px); }
.cs-col-right { opacity: 0; transform: translateX(30px); }

.cs-challenge-text {
  font-size: 1.15rem;
  line-height: 1.75;
  color: #333;
  margin: 0;
  font-style: italic;
  font-family: var(--serif);
  font-weight: 400;
}

.cs-solution-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}

.cs-solution-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  font-size: 1rem;
  line-height: 1.6;
  color: #1a1a1a;
}

.cs-bullet {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--blue);
  flex-shrink: 0;
  margin-top: 0.55rem;
}

/* ══════════════════════════════════════════════════
   STACK
══════════════════════════════════════════════════ */
.cs-stack-section {
  padding: 0 0 7rem;
  background: #fff;
}

.cs-stack-inner {
  border-top: 1px solid var(--border);
  padding-top: 3rem;
  opacity: 0;
}

.cs-stack-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  margin-top: 1.5rem;
}

.cs-pill {
  display: inline-flex;
  align-items: center;
  font-family: var(--mono);
  font-size: 0.72rem;
  font-weight: 600;
  color: #050505;
  background: rgba(0,0,0,0.04);
  border: 1px solid rgba(0,0,0,0.08);
  padding: 0.5rem 1rem;
  border-radius: 100px;
  letter-spacing: 0.02em;
  transition: all .3s var(--ease);
}
.cs-pill:hover {
  background: var(--blue);
  color: #fff;
  border-color: var(--blue);
  transform: translateY(-2px);
}

/* ══════════════════════════════════════════════════
   RESULTADOS (dark)
══════════════════════════════════════════════════ */
.cs-results-section {
  background: radial-gradient(120% 100% at 50% 0%, #152744 0%, #060c18 100%);
  padding: 7rem 0;
  position: relative;
  overflow: hidden;
}

.cs-results-section::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: 0.035;
  mix-blend-mode: overlay;
  pointer-events: none;
}

.cs-results-eyebrow {
  font-size: 0.6rem;
  font-weight: 800;
  letter-spacing: 4px;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
  margin: 0 0 4rem;
  position: relative;
}

.cs-results-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20px;
  overflow: hidden;
  position: relative;
}

.cs-result-card {
  padding: 3rem 2.5rem;
  background: transparent;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  opacity: 0;
  transform: translateY(30px);
  transition: background .3s var(--ease);
}
.cs-result-card:hover { background: rgba(255,255,255,0.04); }

.cs-result-val {
  font-family: var(--mono);
  font-size: clamp(2.8rem, 5vw, 4.5rem);
  font-weight: 700;
  color: #fff;
  line-height: 1;
  letter-spacing: -2px;
}

.cs-result-label {
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255,255,255,0.45);
  margin-bottom: 0.8rem;
}

.cs-result-desc {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.6;
  margin: 0;
}

/* ══════════════════════════════════════════════════
   NAVEGACIÓN ENTRE CASOS
══════════════════════════════════════════════════ */
.cs-nav-section {
  padding: 5rem 0;
  background: #fff;
  border-top: 1px solid var(--border);
}

.cs-nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 2rem;
}

.cs-nav-all {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--muted);
  text-decoration: none;
  transition: color .2s, gap .3s var(--ease);
  flex-direction: row-reverse;
}
.cs-nav-all svg { transform: rotate(180deg); transition: transform .3s var(--ease); }
.cs-nav-all:hover { color: #050505; gap: 12px; }

.cs-nav-next {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  text-decoration: none;
  color: #050505;
  group: true;
  transition: gap .3s var(--ease);
}
.cs-nav-next:hover { gap: 2rem; }

.cs-nav-next-info {
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.cs-nav-next-label {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
}

.cs-nav-next-brand {
  font-size: 1.8rem;
  font-weight: 800;
  letter-spacing: -1px;
  color: #050505;
  line-height: 1;
}

.cs-nav-arrow {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: 1.5px solid rgba(0,0,0,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .4s var(--spring);
  flex-shrink: 0;
}
.cs-nav-next:hover .cs-nav-arrow {
  background: var(--blue);
  border-color: var(--blue);
  color: #fff;
  transform: rotate(-45deg) scale(1.08);
}

/* ══════════════════════════════════════════════════
   CTA
══════════════════════════════════════════════════ */
.cs-cta-section {
  padding: 0 0 7rem;
  background: #fff;
}

.cs-cta-card {
  position: relative;
  background: radial-gradient(100% 100% at 50% 100%, #152744 0%, #0a192f 100%);
  border-radius: 32px;
  overflow: hidden;
  padding: 5rem 6rem;
  box-shadow: 0 20px 40px rgba(5,11,20,0.15), 0 50px 100px rgba(5,11,20,0.15);
  opacity: 0;
  transform: scale(0.97);
}

.cs-cta-noise {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: 0.04;
  mix-blend-mode: overlay;
  pointer-events: none;
}

.cs-cta-inner {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 3rem;
}

.cs-cta-eyebrow {
  font-size: 0.6rem;
  font-weight: 800;
  letter-spacing: 4px;
  color: rgba(255,255,255,0.4);
  margin: 0 0 1rem;
}

.cs-cta-title {
  font-size: clamp(2.5rem, 4vw, 3.8rem);
  font-weight: 800;
  color: #fff;
  line-height: 1.05;
  letter-spacing: -1.5px;
  margin: 0;
}

.cs-cta-serif {
  display: block;
  font-family: var(--serif);
  font-style: italic;
  font-weight: 400;
  color: rgba(255,255,255,0.75);
  font-size: 1.05em;
}

.cs-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  color: var(--blue);
  padding: 1.1rem 2.2rem;
  border-radius: 100px;
  font-size: 0.95rem;
  font-weight: 700;
  text-decoration: none;
  transition: all .45s var(--spring);
  white-space: nowrap;
  flex-shrink: 0;
  border: 1px solid transparent;
  box-shadow: inset 0 0 0 1px rgba(0,0,0,0.08);
}
.cs-cta-btn svg { transition: transform .4s var(--spring); }
.cs-cta-btn:hover {
  transform: translateY(-4px);
  box-shadow: 0 14px 28px rgba(255,255,255,0.12), 0 28px 56px rgba(255,255,255,0.08);
  background: transparent;
  color: #fff;
  border-color: rgba(255,255,255,0.3);
}
.cs-cta-btn:hover svg { transform: translateX(4px); }

/* ══════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .cs-body-grid { gap: 4rem; }
  .cs-cta-card  { padding: 4rem; }
}

@media (max-width: 768px) {
  .cs-hero      { padding: 7rem 0 3rem; }
  .cs-brand     { letter-spacing: -2px; }
  .cs-hero-inner{ margin-bottom: 3.5rem; }

  .cs-metrics   { flex-direction: column; }
  .cs-metric    { border-right: none; border-bottom: 1px solid var(--border); padding: 1.4rem 0; }
  .cs-metric:last-child { border-bottom: none; }

  .cs-visual-section { padding: 3rem 0; }
  .cs-visual-wrap    { min-height: 260px; border-radius: 20px; }

  .cs-body-section { padding: 5rem 0; }
  .cs-body-grid    { grid-template-columns: 1fr; gap: 4rem; }
  .cs-col-left, .cs-col-right { opacity: 1 !important; transform: none !important; }

  .cs-stack-section { padding: 0 0 5rem; }

  .cs-results-section { padding: 5rem 0; }
  .cs-results-grid    { grid-template-columns: 1fr; }
  .cs-result-card     { padding: 2.5rem 2rem; }

  .cs-nav-bar { flex-direction: column; align-items: flex-start; gap: 2.5rem; }
  .cs-nav-next { flex-direction: row-reverse; width: 100%; justify-content: space-between; }
  .cs-nav-next-info { text-align: left; }

  .cs-cta-section { padding: 0 0 5rem; }
  .cs-cta-card    { padding: 3.5rem 2rem; border-radius: 24px; }
  .cs-cta-inner   { flex-direction: column; align-items: flex-start; gap: 2.5rem; }
  .cs-cta-btn     { width: 100%; justify-content: center; }

  .cs-topbar-mid { display: none; }
}

@media (max-width: 480px) {
  .cs-pill { font-size: 0.65rem; }
  .cs-result-val { font-size: 2.8rem; }
  .cs-nav-next-brand { font-size: 1.5rem; }
}
</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import { SplitText } from 'gsap/SplitText';
gsap.registerPlugin(ScrollTrigger, SplitText);

document.addEventListener('DOMContentLoaded', () => {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── TOPBAR IN ── */
  gsap.to('#cs-topbar', { opacity: 1, duration: 0.8, ease: 'expo.out', delay: 0.1 });

  if (reduced) {
    /* Fallback: everything visible */
    document.querySelectorAll<HTMLElement>(
      '.cs-eyebrow, .cs-brand, .cs-tagline, .cs-desc, .cs-metrics, .cs-col-left, .cs-col-right, .cs-stack-inner, .cs-result-card, .cs-cta-card'
    ).forEach(el => { el.style.opacity = '1'; el.style.transform = 'none'; });
    document.querySelectorAll<HTMLElement>('.cs-col-rule').forEach(r => { r.style.transform = 'scaleX(1)'; });
    return;
  }

  /* ── HERO ENTRANCE ── */
  const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

  // Eyebrow
  tl.to('#cs-eyebrow', { opacity: 1, y: 0, duration: 0.8 }, 0.2);
  gsap.set('#cs-eyebrow', { y: 12 });

  // Brand name — SplitText chars stagger up (line mask)
  const brandEl = document.querySelector<HTMLElement>('#cs-brand');
  if (brandEl) {
    const split = SplitText.create(brandEl, { type: 'chars,words', charsClass: 'cs-char' });
    gsap.set(split.chars, { yPercent: 110, opacity: 0 });
    tl.to(split.chars, {
      yPercent: 0, opacity: 1,
      duration: 1.1, stagger: { amount: 0.5, from: 'start' },
      ease: 'expo.out',
    }, 0.35);
  }

  // Tagline + desc
  gsap.set('#cs-tagline', { y: 16 });
  gsap.set('#cs-desc',    { y: 12 });
  tl.to('#cs-tagline', { opacity: 1, y: 0, duration: 0.9 }, 0.85);
  tl.to('#cs-desc',    { opacity: 1, y: 0, duration: 0.9 }, 1.0);

  // Metrics strip
  tl.to('#cs-metrics', { opacity: 1, duration: 0.8 }, 1.1);

  // Metric val counter
  document.querySelectorAll<HTMLElement>('.cs-metric-val').forEach((el, i) => {
    tl.from(el, { opacity: 0, y: 10, duration: 0.5, ease: 'power3.out' }, 1.1 + i * 0.07);
  });

  /* ── HERO PARALLAX ── */
  const heroInner = document.getElementById('cs-hero-inner');
  if (heroInner) {
    gsap.to(heroInner, {
      yPercent: 20, opacity: 0.2, ease: 'none',
      scrollTrigger: { trigger: '.cs-hero', start: 'top top', end: 'bottom top', scrub: 0.8 },
    });
  }

  /* ── VISUAL IMAGE ── */
  const visual = document.getElementById('cs-visual');
  if (visual) {
    gsap.to(visual, {
      scale: 1, opacity: 1, duration: 1.2, ease: 'expo.out',
      scrollTrigger: { trigger: visual, start: 'top 80%' },
    });
    // Parallax on image inside
    const img = visual.querySelector<HTMLElement>('.cs-visual-img');
    if (img) {
      gsap.to(img, {
        yPercent: -8, ease: 'none',
        scrollTrigger: { trigger: visual, start: 'top bottom', end: 'bottom top', scrub: 1 },
      });
    }
  }

  /* ── BODY: RETO + SOLUCIÓN ── */
  const colLeft  = document.getElementById('cs-challenge');
  const colRight = document.getElementById('cs-solution');

  if (colLeft) {
    gsap.to(colLeft, {
      opacity: 1, x: 0, duration: 1.0, ease: 'expo.out',
      scrollTrigger: { trigger: colLeft, start: 'top 80%' },
    });
    const rule = colLeft.querySelector<HTMLElement>('.cs-col-rule');
    if (rule) gsap.to(rule, { scaleX: 1, duration: 0.9, ease: 'power3.out', scrollTrigger: { trigger: colLeft, start: 'top 78%' } });
  }

  if (colRight) {
    gsap.to(colRight, {
      opacity: 1, x: 0, duration: 1.0, ease: 'expo.out',
      scrollTrigger: { trigger: colRight, start: 'top 80%' },
    });
    const rule2 = colRight.querySelector<HTMLElement>('.cs-col-rule');
    if (rule2) gsap.to(rule2, { scaleX: 1, duration: 0.9, ease: 'power3.out', delay: 0.1, scrollTrigger: { trigger: colRight, start: 'top 78%' } });

    // Solution items stagger
    gsap.from('.cs-solution-item', {
      opacity: 0, x: 16, duration: 0.6, stagger: 0.07, ease: 'power3.out',
      scrollTrigger: { trigger: colRight, start: 'top 75%' },
    });
  }

  /* ── STACK PILLS ── */
  const stackInner = document.getElementById('cs-stack');
  if (stackInner) {
    gsap.to(stackInner, {
      opacity: 1, duration: 0.8, ease: 'expo.out',
      scrollTrigger: { trigger: stackInner, start: 'top 85%' },
    });
    gsap.from('.cs-pill', {
      opacity: 0, y: 14, scale: 0.9, duration: 0.55, stagger: 0.06, ease: 'back.out(1.8)',
      scrollTrigger: { trigger: stackInner, start: 'top 82%' },
    });
  }

  /* ── RESULTS ── */
  gsap.utils.toArray<HTMLElement>('.cs-result-card').forEach((card, i) => {
    gsap.to(card, {
      opacity: 1, y: 0, duration: 0.9, ease: 'expo.out', delay: i * 0.1,
      scrollTrigger: { trigger: card, start: 'top 85%' },
    });
  });

  /* ── CTA ── */
  const ctaCard = document.getElementById('cs-cta');
  if (ctaCard) {
    gsap.to(ctaCard, {
      opacity: 1, scale: 1, duration: 1.1, ease: 'expo.out',
      scrollTrigger: { trigger: ctaCard, start: 'top 80%' },
    });
  }
});
</script>
