---
export const prerender = true;

import PlantillaCaso from '../../components/PlantillaCaso.astro';
import { casos } from '../../data/casos';

export function getStaticPaths() {
  return casos.map(c => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const caso = casos.find(c => c.slug === slug)!;
const idx  = casos.indexOf(caso);
const next = casos[(idx + 1) % casos.length];
---

<PlantillaCaso caso={caso} next={next} isEn={false} root="" />
