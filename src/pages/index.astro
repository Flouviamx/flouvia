---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsApp from '../components/WhatsApp.astro';
---

<Layout title="Flouvia | Estudio de Ingeniería Digital y Growth">
    <Navbar />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

	<main class="flouvia-masterpiece">

        <section class="hero-grand">
            <div class="container hero-container">
                <div class="hero-content">
                    <div class="hero-text-zone">
                        <p class="eyebrow reveal-blur" style="--delay: 0.1s;">
                            PRIVATE GROWTH BOUTIQUE
                        </p>
                        <h1 class="hero-title reveal-blur" style="--delay: 0.2s;">
                            Arquitectura digital<br>
                            <span class="editorial">para escalar operaciones.</span>
                        </h1>
                    </div>
                    
                    <div class="hero-bottom reveal-blur" style="--delay: 0.4s;">
                        <p class="hero-desc">
                            Construimos ecosistemas E-commerce y B2B. Eliminamos fricción, automatizamos inventarios y optimizamos la conversión de marcas líderes.
                        </p>
                        <div class="hero-action">
                            <a href="#contacto" class="btn-luxe">
                                <span>Agendar Auditoría</span>
                                <div class="btn-shimmer"></div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="tech-partners">
            <div class="container">
                <div class="partners-header reveal-blur">
                    <div class="header-text">
                        <h2 class="section-heading">Nuestra <span class="editorial">tecnología.</span></h2>
                        <p class="section-sub">Desplegamos infraestructura de grado corporativo con las herramientas más potentes del ecosistema digital.</p>
                    </div>
                    <div class="header-action">
                        <a href="#contacto" class="btn-outline">SISTEMAS ↗</a>
                    </div>
                </div>

                <div class="partners-grid">
                    <div class="partner-item reveal-blur" style="--delay: 0.1s;">
                        <div class="partner-logo">
                            <svg viewBox="0 0 140 30" width="130" height="30" fill="currentColor"><path d="M21 7.5L12 2.3 3 7.5v9l9 5.2 9-5.2v-9zm-9-3l6.5 3.8-6.5 3.8-6.5-3.8L12 4.5zM4.5 9l6.5 3.8v7.5L4.5 16.5V9zm15 7.5l-6.5 3.8v-7.5L19.5 9v7.5z"/><text x="28" y="19" font-family="Inter" font-weight="800" font-size="16">shopify<tspan font-weight="400">plus</tspan></text></svg>
                        </div>
                        <p class="partner-desc">Nuestra plataforma base. Ecosistemas transaccionales de extremo a extremo diseñados para volumen y conversión.</p>
                    </div>

                    <div class="partner-item reveal-blur" style="--delay: 0.2s;">
                        <div class="partner-logo">
                            <svg viewBox="0 0 120 30" width="110" height="30" fill="currentColor"><path d="M6.5 4.5l5.5 3 5.5-3-5.5-3-5.5 3zm11 11l-5.5 3-5.5-3v-6l5.5 3 5.5-3v6z"/><text x="28" y="19" font-family="Inter" font-weight="800" font-size="16">Airtable</text></svg>
                        </div>
                        <p class="partner-desc">Bases de datos relacionales operativas. Estructuramos la logística, inventarios B2B y data de clientes.</p>
                    </div>

                    <div class="partner-item reveal-blur" style="--delay: 0.3s;">
                        <div class="partner-logo">
                            <svg viewBox="0 0 100 30" width="90" height="30" fill="currentColor"><circle cx="6" cy="12" r="3"/><circle cx="18" cy="12" r="3"/><path d="M9 12h6" stroke="currentColor" stroke-width="2"/><text x="30" y="19" font-family="Inter" font-weight="800" font-size="18">make</text></svg>
                        </div>
                        <p class="partner-desc">Automatización de flujos críticos (ETL). Conectamos tu E-commerce con tu ERP eliminando el error humano.</p>
                    </div>

                    <div class="partner-item reveal-blur" style="--delay: 0.4s;">
                        <div class="partner-logo">
                            <svg viewBox="0 0 160 30" width="150" height="30" fill="currentColor"><polyline points="6 18 12 12 6 6" fill="none" stroke="currentColor" stroke-width="2"/><polyline points="18 18 12 12 18 6" fill="none" stroke="currentColor" stroke-width="2" transform="translate(10,0)"/><text x="40" y="19" font-family="Inter" font-weight="800" font-size="16">Custom Code</text></svg>
                        </div>
                        <p class="partner-desc">Desarrollo a medida y arquitecturas Headless para experiencias inmersivas con velocidades de carga sub-1s.</p>
                    </div>

                    <div class="partner-item reveal-blur" style="--delay: 0.5s;">
                        <div class="partner-logo">
                            <svg viewBox="0 0 100 30" width="90" height="30" fill="currentColor"><text x="0" y="22" font-family="Inter" font-weight="800" font-size="24" letter-spacing="-1">stripe</text></svg>
                        </div>
                        <p class="partner-desc">Infraestructura financiera. Pasarelas de pago seguras, B2B wholesale y gestión de suscripciones.</p>
                    </div>

                    <div class="partner-item reveal-blur" style="--delay: 0.6s;">
                        <div class="partner-logo">
                            <svg viewBox="0 0 120 30" width="110" height="30" fill="currentColor"><text x="0" y="22" font-family="Instrument Serif" font-style="italic" font-weight="400" font-size="28">Klaviyo</text></svg>
                        </div>
                        <p class="partner-desc">Retención de clientes y escalamiento del LTV. Automatización basada en la data transaccional del usuario.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="clients-vertical-carousel">
            <div class="container">
                <div class="section-header reveal-blur" style="--delay: 0s;">
                    <div class="header-flex">
                        <div>
                            <p class="eyebrow" style="color: #64748b;">NUESTROS SISTEMAS</p>
                            <h2 class="section-heading">Casos de <span class="editorial">Ingeniería.</span></h2>
                        </div>
                        <div class="carousel-nav">
                            <span class="nav-hint">Desliza →</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="carousel-track-wrapper reveal-blur" style="--delay: 0.2s;">
                <div class="carousel-track">
                    
                    <a href="/casos/el-zarco" class="vertical-card">
                        <div class="card-bg"><span class="placeholder-text">[ EL ZARCO B2B ]</span></div>
                        <div class="card-overlay">
                            <span class="v-tag">Arquitectura B2B</span>
                            <h3>El Zarco</h3>
                        </div>
                    </a>

                    <a href="/casos/setnpet" class="vertical-card">
                        <div class="card-bg"><span class="placeholder-text">[ SETNPET D2C ]</span></div>
                        <div class="card-overlay">
                            <span class="v-tag">CRO & E-commerce</span>
                            <h3>Setnpet</h3>
                        </div>
                    </a>

                    <a href="#contacto" class="vertical-card cta-vertical">
                        <div class="cta-inner">
                            <h3>Tu proyecto<br><span class="editorial">aquí.</span></h3>
                            <span class="btn-text-only">Iniciar arquitectura</span>
                        </div>
                    </a>

                </div>
            </div>
        </section>

        <section class="services-rows">
            <div class="container">
                <div class="section-header reveal-blur" style="--delay: 0s;">
                    <p class="eyebrow">CAPACIDADES TÉCNICAS</p>
                    <h2 class="section-heading">Nuestra <span class="editorial">Infraestructura.</span></h2>
                </div>

                <div class="rows-wrapper">
                    <div class="service-row reveal-blur" style="--delay: 0.1s;">
                        <div class="row-num">/01</div>
                        <div class="row-content">
                            <h3>E-commerce Engineering</h3>
                            <p>Construimos tiendas transaccionales en Shopify Plus y Webflow. Maximizamos el AOV mediante arquitectura CRO y flujos nativos de upsell.</p>
                        </div>
                        <div class="row-action">
                            <div class="arrow-circle">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                        <div class="row-border-hover"></div>
                    </div>

                    <div class="service-row reveal-blur" style="--delay: 0.2s;">
                        <div class="row-num">/02</div>
                        <div class="row-content">
                            <h3>B2B Digital Architecture</h3>
                            <p>Digitalizamos operaciones mayoristas. Desarrollamos portales B2B cerrados, reglas de precios dinámicos, catálogos protegidos y pedidos integrados.</p>
                        </div>
                        <div class="row-action">
                            <div class="arrow-circle">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                        <div class="row-border-hover"></div>
                    </div>

                    <div class="service-row reveal-blur" style="--delay: 0.3s; border-bottom: none;">
                        <div class="row-num">/03</div>
                        <div class="row-content">
                            <h3>Business Automation</h3>
                            <p>Eliminamos la fricción y el error humano. Integramos tu E-commerce con tu ERP y bases de datos para sincronizar inventarios en tiempo real.</p>
                        </div>
                        <div class="row-action">
                            <div class="arrow-circle">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                        <div class="row-border-hover"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="protocol-section">
            <div class="container">
                <div class="process-header reveal-blur">
                    <p class="eyebrow">METODOLOGÍA DE TRABAJO</p>
                    <h2 class="section-heading">Protocolo <span class="editorial">de Ejecución.</span></h2>
                </div>

                <div class="protocol-list">
                    <div class="protocol-row reveal-blur" style="--delay: 0.1s;">
                        <div class="p-num">01</div>
                        <div class="p-text">
                            <h4>Auditoría y Diagnóstico</h4>
                            <p>Analizamos la infraestructura actual, bases de datos y flujos de usuario para identificar los cuellos de botella en la operación y conversión.</p>
                        </div>
                    </div>
                    <div class="protocol-row reveal-blur" style="--delay: 0.2s;">
                        <div class="p-num">02</div>
                        <div class="p-text">
                            <h4>Arquitectura del Sistema</h4>
                            <p>Diseñamos los planos: desde la lógica de la base de datos y conexiones API, hasta la experiencia de usuario (UX/UI) de alta conversión.</p>
                        </div>
                    </div>
                    <div class="protocol-row reveal-blur" style="--delay: 0.3s;">
                        <div class="p-num">03</div>
                        <div class="p-text">
                            <h4>Desarrollo Full-Stack</h4>
                            <p>Programación a medida. Escribimos código limpio, montamos el ecosistema y conectamos las herramientas de automatización de datos.</p>
                        </div>
                    </div>
                    <div class="protocol-row reveal-blur" style="--delay: 0.4s; border-bottom: none;">
                        <div class="p-num">04</div>
                        <div class="p-text">
                            <h4>Despliegue y Escalado</h4>
                            <p>Lanzamiento a producción con monitoreo activo de servidores y velocidad de carga, asegurando una transición perfecta y estable.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="cta-integrated reveal-blur" style="--delay: 0.1s;">
            <div class="container">
                <div class="cta-card-blue">
                    <div class="cta-inner-flex">
                        <div class="cta-text-side">
                            <p class="eyebrow" style="color: #64748b;">EL SIGUIENTE PASO</p>
                            <h2 class="cta-title-luxe">Escale su <span class="editorial" style="color: #cbd5e1;">operación.</span></h2>
                        </div>
                        <div class="cta-action-side">
                            <a href="#contacto" class="btn-glow-blue">
                                <span>Agendar Diagnóstico VIP</span>
                                <div class="glow-effect"></div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

	</main>

	<Footer />
	<WhatsApp />
</Layout>

<style is:global>
    /* VARIABLES: LUXURY MINIMALISM */
    :root {
        --color-bg: #ffffff;
        --color-bg-soft: #f5f5f2; /* Arena Premium */
        --color-blue-icy: #eff4f9; /* Pizarra / Azul hielo */
        --color-blue-deep: #0a192f;
        
        --color-text: #050505;
        --color-text-muted: #666666;
        --color-border: rgba(0, 0, 0, 0.08); 
        --color-border-hover: rgba(0, 0, 0, 0.4);
        --color-placeholder: #eaeaea;
        
        --font-sans: 'Inter', system-ui, sans-serif;
        --font-serif: 'Instrument Serif', serif;
        
        --ease-luxe: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-elastic: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    body { background-color: var(--color-bg); color: var(--color-text); font-family: var(--font-sans); margin: 0; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 5%; position: relative; }
    .editorial { font-family: var(--font-serif); font-style: italic; font-weight: 400; color: #444; }
    .eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; color: #888; text-transform: uppercase; margin-bottom: 1rem; }
    
    /* ANIMACIÓN BLUR REVEAL SÚPER FLUIDA */
    .reveal-blur { opacity: 0; transform: translateY(12px); filter: blur(4px); animation: reveal 1s var(--ease-luxe) forwards; animation-play-state: paused; animation-delay: var(--delay, 0s); }
    .reveal-blur.active { animation-play-state: running; }
    @keyframes reveal { to { opacity: 1; transform: translateY(0); filter: blur(0); } }

    /* BOTONES LUXURY CON SHIMMER */
    .btn-luxe { 
        position: relative; display: inline-flex; background: var(--color-text); color: #fff; 
        padding: 16px 38px; border-radius: 100px; text-decoration: none; font-size: 0.9rem; 
        font-weight: 600; transition: all 0.4s var(--ease-luxe); overflow: hidden;
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transform: skewX(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 12px 24px rgba(0,0,0,0.15); }
    .btn-luxe:hover .btn-shimmer { left: 200%; transition: left 0.8s ease; }
</style>

<style>
    /* 1. HERO */
    .hero-grand { padding: 12rem 0 6rem 0; min-height: 70vh; display: flex; align-items: center; background: var(--color-bg); }
    .hero-title { font-size: clamp(3rem, 7vw, 6.5rem); line-height: 0.9; font-weight: 800; letter-spacing: -3px; margin-bottom: 3rem; }
    .hero-bottom { display: flex; justify-content: space-between; align-items: flex-end; gap: 4rem; border-top: 1px solid var(--color-border); padding-top: 2rem; }
    .hero-desc { font-size: 1.15rem; color: var(--color-text-muted); max-width: 500px; line-height: 1.5; margin: 0; }

    /* 2. TECNOLOGÍA */
    .tech-partners { padding: 6rem 0; background: var(--color-bg); }
    .partners-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; }
    .header-text { max-width: 600px; }
    .section-heading { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; letter-spacing: -1.5px; margin: 0 0 0.5rem 0; line-height: 1; }
    .section-sub { font-size: 1.05rem; color: var(--color-text-muted); margin: 0; line-height: 1.5;}
    
    .btn-outline { font-size: 0.75rem; font-weight: 800; color: var(--color-text); text-decoration: none; border: 1px solid var(--color-text); padding: 10px 20px; border-radius: 50px; transition: all 0.3s; letter-spacing: 1px;}
    .btn-outline:hover { background: var(--color-text); color: #fff; }

    .partners-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem 2rem; margin-top: 0;}
    .partner-item { display: flex; flex-direction: column; gap: 0.8rem; overflow: visible; }
    .partner-logo { height: 35px; color: var(--color-text); display: flex; align-items: center; margin-left: -4px; transition: opacity 0.4s ease; opacity: 0.8;} 
    .partner-item:hover .partner-logo { opacity: 1; transform: scale(1.02); }
    .partner-desc { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.5; margin: 0; }

    /* 3. CARRUSEL (Animaciones Profundas) */
    .clients-vertical-carousel { padding: 7rem 0 6rem 0; background-color: var(--color-blue-icy); }
    .header-flex { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 4rem; }
    .nav-hint { font-size: 0.75rem; font-weight: 700; color: #64748b; border: 1px solid rgba(0,0,0,0.1); padding: 8px 16px; border-radius: 50px; background: rgba(255,255,255,0.5);}

    .carousel-track-wrapper { 
        width: 100%; overflow-x: auto; padding-bottom: 2rem;
        padding-left: max(5%, calc((100vw - 1200px) / 2)); padding-right: 5%;
        scroll-snap-type: x mandatory; scrollbar-width: none;
    }
    .carousel-track-wrapper::-webkit-scrollbar { display: none; }
    .carousel-track { display: flex; gap: 2rem; width: max-content; }
    
    .vertical-card { width: 360px; height: 500px; scroll-snap-align: start; border-radius: 12px; position: relative; overflow: hidden; text-decoration: none; border: 1px solid rgba(0,0,0,0.05); transition: all 0.5s var(--ease-luxe);}
    .vertical-card:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    
    .card-bg { position: absolute; width: 100%; height: 100%; background: #eaeaea; display: flex; align-items: center; justify-content: center; transition: transform 1.2s var(--ease-luxe);}
    .vertical-card:hover .card-bg { transform: scale(1.08); }
    .placeholder-text { font-size: 0.7rem; font-weight: 700; color: #aaa; letter-spacing: 1px; }
    
    .card-overlay { position: absolute; bottom: 0; width: 100%; padding: 4rem 2rem 2rem 2rem; background: linear-gradient(transparent, rgba(0,0,0,0.8)); color: #fff; transition: transform 0.5s var(--ease-luxe); }
    .vertical-card:hover .card-overlay { transform: translateY(-5px); }
    .card-overlay h3 { font-size: 1.8rem; font-weight: 800; margin: 0; }
    .v-tag { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; color: #ccc; letter-spacing: 1px;}
    
    .cta-vertical { background: var(--color-blue-deep); display: flex; align-items: center; justify-content: center; text-align: center; color: #fff; }
    .cta-inner { transition: transform 0.4s var(--ease-luxe); }
    .cta-vertical:hover .cta-inner { transform: scale(1.05); }
    .cta-inner h3 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
    .btn-text-only { font-size: 0.9rem; font-weight: 700; border-bottom: 1px solid #fff; padding-bottom: 2px;}

    /* 4. SERVICIOS (Micro-interacción de Flecha) */
    .services-rows { padding: 6rem 0 3rem 0; background: var(--color-bg); }
    .rows-wrapper { margin-top: 4rem; border-top: 1px solid var(--color-border); }
    .service-row { display: grid; grid-template-columns: 60px 1fr auto; gap: 4rem; padding: 4rem 0; border-bottom: 1px solid var(--color-border); position: relative; cursor: pointer; align-items: center; overflow: hidden; }
    
    .row-num { font-size: 0.85rem; font-weight: 700; color: #ccc; transition: 0.4s; }
    .service-row:hover .row-num { color: var(--color-text); }
    
    .row-content h3 { font-size: 2.2rem; font-weight: 800; letter-spacing: -1px; margin: 0 0 1rem 0; transition: transform 0.5s var(--ease-luxe); }
    .service-row:hover .row-content h3 { transform: translateX(12px); }
    .row-content p { font-size: 1.1rem; color: var(--color-text-muted); line-height: 1.6; margin: 0; max-width: 650px; transition: transform 0.5s var(--ease-luxe); }
    .service-row:hover .row-content p { transform: translateX(12px); }
    
    .arrow-circle { width: 50px; height: 50px; border: 1px solid var(--color-border); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.5s var(--ease-elastic); }
    .icon-arrow { transition: transform 0.4s var(--ease-luxe); }
    .service-row:hover .arrow-circle { background: #000; color: #fff; border-color: #000; }
    .service-row:hover .icon-arrow { transform: rotate(-45deg) translate(2px, -2px); }
    
    .row-border-hover { position: absolute; bottom: -1px; left: 0; width: 100%; height: 1px; background: #000; transform: scaleX(0); transition: 0.7s var(--ease-luxe); transform-origin: left; }
    .service-row:hover .row-border-hover { transform: scaleX(1); }

    /* 5. PROTOCOLO (Highlight Hover) */
    .protocol-section { padding: 6rem 0 5rem 0; background: var(--color-bg-soft); }
    .process-header { margin-bottom: 3rem; }
    .protocol-row { display: grid; grid-template-columns: 80px 1fr; gap: 1rem; padding: 2.5rem 0; border-bottom: 1px solid rgba(0,0,0,0.06); transition: background 0.4s ease;}
    .protocol-row:hover { background: rgba(255,255,255,0.5); border-radius: 8px; padding-left: 1rem; margin-left: -1rem; margin-right: -1rem; border-bottom-color: transparent;}
    
    .p-num { font-size: 1.1rem; font-weight: 800; font-family: var(--font-serif); font-style: italic; color: #aaa; transition: color 0.3s;}
    .protocol-row:hover .p-num { color: var(--color-text); }
    .p-text h4 { font-size: 1.4rem; font-weight: 800; margin: 0 0 0.5rem 0; letter-spacing: -0.5px;}
    .p-text p { font-size: 1.05rem; color: var(--color-text-muted); margin: 0; max-width: 650px;}

    /* 6. CTA INTEGRADO AZUL (Padding Inferior Amplio) */
    .cta-integrated { padding: 6rem 0 10rem 0; background: var(--color-bg); border: none; }
    .cta-card-blue { background: var(--color-blue-deep); border-radius: 16px; padding: 3.5rem 4rem; box-shadow: 0 20px 40px rgba(10,25,47,0.15); transition: transform 0.5s var(--ease-luxe); }
    .cta-card-blue:hover { transform: scale(1.01); }
    .cta-inner-flex { display: flex; justify-content: space-between; align-items: center; gap: 3rem; }
    .cta-text-side { flex: 1; }
    .cta-title-luxe { font-size: clamp(2.2rem, 4vw, 3.2rem); font-weight: 800; color: #fff; line-height: 1.1; letter-spacing: -1px; margin: 0; }
    
