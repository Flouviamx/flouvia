---
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import ChangelogUI from '../../components/portal/ChangelogUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/login');
---
<PortalLayout title="Changelog | Flouvia OS">
  <ChangelogUI lang="en" />
</PortalLayout>
