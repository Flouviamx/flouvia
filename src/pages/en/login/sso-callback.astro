---
export const prerender = false;
import PortalLayout from '../../../layouts/PortalLayout.astro';
import { SignIn } from '@clerk/astro/components';
---

<PortalLayout title="Access | Flouvia">
    <div class="callback-wrapper">
        <SignIn routing="path" path="/en/login" />
    </div>
</PortalLayout>

<style>
    .callback-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: var(--color-bg-soft, #fcfcfc);
    }
</style>
