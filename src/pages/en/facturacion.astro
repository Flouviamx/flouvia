---
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import FacturacionUI from '../../components/portal/FacturacionUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/en/login');
---
<PortalLayout title="Billing | Flouvia OS">
    <FacturacionUI lang="en" />
</PortalLayout>
