---
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import SoporteUI from '../../components/portal/SoporteUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/en/login');
---
<PortalLayout title="VIP Support | Flouvia OS">
    <SoporteUI lang="en" />
</PortalLayout>
