---
// src/pages/en/portal/dashboard.astro
export const prerender = false;
import PortalLayout from '../../../layouts/PortalLayout.astro'; 
import DashboardUI from '../../../components/portal/DashboardUI.astro';

// Protección de Ruta
const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('/en/portal/login');
---

<PortalLayout title="Console | Flouvia OS">
    <DashboardUI lang="en" />
</PortalLayout>