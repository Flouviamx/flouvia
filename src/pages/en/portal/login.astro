---
// src/pages/en/portal/login.astro
// Served at flouvia.com/en/login via Vercel rewrite.
export const prerender = false;
import PortalLayout from '../../../layouts/PortalLayout.astro';
import LoginUI from '../../../components/portal/LoginUI.astro';

const { userId } = await Astro.locals.auth();
if (userId) {
  return Astro.redirect('https://os.flouvia.com/en/dashboard');
}
---

<PortalLayout title="Private Access | Flouvia">
    <LoginUI lang="en" />
</PortalLayout>
