---
// src/pages/en/portal/login.astro
export const prerender = false;
import PortalLayout from '../../../layouts/PortalLayout.astro';
import LoginUI from '../../../components/portal/LoginUI.astro';

// Redirección si ya está logueado
const { userId } = await Astro.locals.auth();
if (userId) {
  return Astro.redirect('/en/portal/dashboard');
}
---

<PortalLayout title="Private Access | Flouvia">
    <LoginUI lang="en" />
</PortalLayout>