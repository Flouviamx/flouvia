---
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import LoginUI from '../../components/portal/LoginUI.astro';

const host = Astro.request.headers.get('host') || Astro.url.hostname;
if (host === 'flouvia.com' || host === 'www.flouvia.com') {
  return Astro.redirect('https://os.flouvia.com/en/login', 302);
}

const { userId } = await Astro.locals.auth();
if (userId) {
  return Astro.redirect('/en/dashboard');
}
---

<PortalLayout title="Private Access | Flouvia">
    <LoginUI lang="en" />
</PortalLayout>
