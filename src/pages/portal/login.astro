---
// src/pages/portal/login.astro
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import LoginUI from '../../components/portal/LoginUI.astro';

// Redirección si ya está logueado
const { userId } = await Astro.locals.auth();
if (userId) {
  return Astro.redirect('/portal/dashboard');
}
---

<PortalLayout title="Acceso Privado | Flouvia">
    <LoginUI lang="es" />
</PortalLayout>