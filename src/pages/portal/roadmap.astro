---
// src/pages/portal/roadmap.astro
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import RoadmapUI from '../../components/portal/RoadmapUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('https://os.flouvia.com/login');
---

<PortalLayout title="Roadmap | Flouvia OS">
    <RoadmapUI lang="es" />
</PortalLayout>
