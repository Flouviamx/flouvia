---
// src/pages/portal/facturacion.astro
export const prerender = false;
import PortalLayout from '../../layouts/PortalLayout.astro';
import FacturacionUI from '../../components/portal/FacturacionUI.astro';

const { userId } = await Astro.locals.auth();
if (!userId) return Astro.redirect('/portal/login');
---

<PortalLayout title="Facturación | Flouvia OS">
    <FacturacionUI lang="es" />
</PortalLayout>
