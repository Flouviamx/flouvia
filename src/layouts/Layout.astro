---
import { getLangFromUrl } from '../i18n/utils';

interface Props {
    title: string;
    description?: string;
    image?: string;
    noindex?: boolean;
    ogType?: string;
}

const {
    title,
    description = 'Flouvia — infraestructura de revenue para marcas de e-commerce y B2B con operación establecida. Por aplicación: menos de 8 clientes activos al año.',
    image = '/android-touch-icon-512.png',
    noindex = false,
    ogType = 'website',
} = Astro.props;

// Detecta el idioma basado en la URL (/en/ o /)
const lang = getLangFromUrl(Astro.url);

// URLs absolutas para canonical / OG / hreflang
const SITE      = Astro.site ?? new URL('https://flouvia.com');
const pathname  = Astro.url.pathname;
const esPath    = lang === 'en' ? (pathname.replace(/^\/en/, '') || '/') : pathname;
const enPath    = lang === 'es' ? '/en' + (pathname === '/' ? '' : pathname) : pathname;
const canonical = new URL(pathname, SITE).href;
const ogImage   = new URL(image, SITE).href;
const esURL     = new URL(esPath, SITE).href;
const enURL     = new URL(enPath, SITE).href;
const ogLocale  = lang === 'en' ? 'en_US' : 'es_MX';
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />

        <!-- Gate de animación: marca <html> ANTES del primer paint para que los
             elementos animados (hero, navbar) partan ocultos sin flash. Sin JS o
             con reduced-motion, la clase nunca se añade y todo queda visible. -->
        <script is:inline>
            if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                document.documentElement.classList.add('js-anim');
            }
            // Cambio de idioma: si venimos de un switch ES/EN, ocultamos el body antes del
            // paint para restaurar el scroll sin que se vea el salto desde arriba. El navbar
            // revela el body tras posicionar. Failsafe: revelar igual a los 1.5s.
            try {
                if (sessionStorage.getItem('flouviaLangScroll') !== null) {
                    document.documentElement.classList.add('lang-restoring');
                    setTimeout(function () { document.documentElement.classList.remove('lang-restoring'); }, 1500);
                }
            } catch (e) {}
        </script>

        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}

        <!-- hreflang — relaciona las versiones ES/EN de cada página -->
        <link rel="alternate" hreflang="es" href={esURL} />
        <link rel="alternate" hreflang="en" href={enURL} />
        <link rel="alternate" hreflang="x-default" href={esURL} />

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Flouvia" />
        <meta property="og:locale" content={ogLocale} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content={ogImage} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
        
        <!-- Favicon — PNG first so mobile browsers pick it up for tabs -->
        <link rel="icon" type="image/png" sizes="512x512" href="/android-touch-icon-512.png" />
        <link rel="icon" type="image/png" sizes="192x192" href="/android-touch-icon.png" />
        <link id="favicon-tag" rel="icon" type="image/svg+xml" href="/favicon-light.svg" />
        <!-- favicon.ico sigue como último fallback para browsers muy antiguos -->

        <!-- iOS home screen icon (must be PNG, SVG is ignored by Safari) -->
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />


        <script is:inline>
          function updateFavicon() {
            const favicon = document.getElementById('favicon-tag');
            if (!favicon) return;
            favicon.href = window.matchMedia('(prefers-color-scheme: dark)').matches
              ? '/favicon-dark.svg'
              : '/favicon-light.svg';
          }
          updateFavicon();
          window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateFavicon);
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

        <!-- PWA / mobile chrome -->
        <meta name="theme-color" content="#0a192f" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-title" content="Flouvia" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        
        <title>{title}</title>
    </head>
    <body>
        <slot /> 
    </body>
</html>

<style is:global>
    /* Reset ultra limpio. El diseño pesado lo maneja tu index.astro */
    *, *::before, *::after {
        box-sizing: border-box;
    }

    /* Cambio de idioma: oculta el body antes del paint para restaurar el scroll sin
       mostrar el salto desde arriba. El navbar lo revela tras posicionar (o el failsafe). */
    html.lang-restoring body { opacity: 0; }
    
    html, body {
        width: 100%; 
        margin: 0;
        padding: 0;
        position: relative;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        -webkit-tap-highlight-color: transparent;
        background-color: #ffffff;
    }

    ::selection { 
        background: #0a192f; 
        color: #ffffff; 
    }
</style>

