---
import { getLangFromUrl } from '../i18n/utils';

interface Props {
    title: string;
}

const { title } = Astro.props;

// Detecta el idioma basado en la URL (/en/ o /)
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Flouvia Boutique - Engineering & Growth" />
        
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
        
        <!-- Favicon — PNG first so mobile browsers pick it up for tabs -->
        <link rel="icon" type="image/png" sizes="512x512" href="/android-touch-icon-512.png" />
        <link rel="icon" type="image/png" sizes="192x192" href="/android-touch-icon.png" />
        <link id="favicon-tag" rel="icon" type="image/svg+xml" href="/favicon-light.svg" />
        <!-- favicon.ico sigue como último fallback para browsers muy antiguos -->

        <!-- iOS home screen icon (must be PNG, SVG is ignored by Safari) -->
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />


        <script is:inline>
          function updateFavicon() {
            const favicon = document.getElementById('favicon-tag');
            if (!favicon) return;
            favicon.href = window.matchMedia('(prefers-color-scheme: dark)').matches
              ? '/favicon-dark.svg'
              : '/favicon-light.svg';
          }
          updateFavicon();
          window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateFavicon);
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">

        <!-- PWA / mobile chrome -->
        <meta name="theme-color" content="#0a192f" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-title" content="Flouvia" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        
        <title>{title}</title>
    </head>
    <body>
        <slot /> 
    </body>
</html>

<style is:global>
    /* Reset ultra limpio. El diseño pesado lo maneja tu index.astro */
    *, *::before, *::after { 
        box-sizing: border-box; 
    } 
    
    html, body {
        width: 100%; 
        margin: 0;
        padding: 0;
        position: relative;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        -webkit-tap-highlight-color: transparent;
        background-color: #ffffff;
    }

    ::selection { 
        background: #0a192f; 
        color: #ffffff; 
    }
</style>

