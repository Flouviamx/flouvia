---
import { getLangFromUrl } from '../i18n/utils';

interface Props {
    title: string;
}

const { title } = Astro.props;

// Detecta el idioma basado en la URL (/en/ o /)
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Flouvia Boutique - Engineering & Growth" />
        
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
        
        <link id="favicon-tag" rel="icon" type="image/svg+xml" href="/favicon-light.svg" />
<link rel="apple-touch-icon" href="/favicon-light.svg" />

<script is:inline>
  // Función para cambiar el favicon manualmente
  function updateFavicon() {
    const favicon = document.getElementById('favicon-tag');
    const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    
    if (isDark) {
      favicon.href = '/favicon-dark.svg';
    } else {
      favicon.href = '/favicon-light.svg';
    }
  }

  // Ejecutar al cargar la página
  updateFavicon();

  // Escuchar si el usuario cambia el modo mientras tiene la página abierta
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateFavicon);
</script>

<link rel="apple-touch-icon" href="/favicon-light.svg" />
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        
        <meta name="theme-color" content="#ffffff" />
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        
        <title>{title}</title>
    </head>
    <body>
        <slot /> 
    </body>
</html>

<style is:global>
    /* Reset ultra limpio. El diseño pesado lo maneja tu index.astro */
    *, *::before, *::after { 
        box-sizing: border-box; 
    } 
    
    html, body {
        width: 100%; 
        margin: 0;
        padding: 0;
        position: relative;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        -webkit-tap-highlight-color: transparent;
        background-color: #ffffff;
    }

    ::selection { 
        background: #0a192f; 
        color: #ffffff; 
    }
</style>

