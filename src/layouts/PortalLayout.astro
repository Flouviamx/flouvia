---
// src/layouts/PortalLayout.astro
import PortalNavbar from '../components/PortalNavbar.astro';
import PortalFooter from '../components/PortalFooter.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portal de Clientes Flouvia" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Favicon -->
		<link rel="icon" type="image/png" sizes="512x512" href="/android-touch-icon-512.png" />
		<link rel="icon" type="image/png" sizes="192x192" href="/android-touch-icon.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon-light.svg" id="favicon-tag" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

		<!-- PWA — solo el portal se instala como app -->
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#0a192f" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-title" content="Flouvia Portal" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

		<title>{title}</title>

	</head>
	<body>
        <PortalNavbar />

		<main class="portal-main">
			<slot />
		</main>
		<PortalFooter />
	</body>
</html>

<style is:global>
    /* ============================================================
       TU CSS GLOBAL COMPLETO (Recuperado y Blindado)
       ============================================================ */
    *, *::before, *::after { box-sizing: border-box; }

    html, body {
        width: 100%;
        position: relative;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        -webkit-tap-highlight-color: transparent;
    }

    ::selection { background: #0a192f; color: #ffffff; }

    :root {
        --color-bg: #ffffff;
        --color-bg-soft: #fcfcfc;
        --color-blue-icy: #f4f6f9;
        --color-blue-deep: #0a192f;
        --color-glass-blue: rgba(10, 25, 47, 0.85);

        --color-text: #050505;
        --color-text-muted: #555555;
        --color-border: rgba(0, 0, 0, 0.08);

        --font-sans: 'Inter', system-ui, sans-serif;
        --font-serif: 'Instrument Serif', serif;

        --ease-ios: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.05);
        --ease-smooth: cubic-bezier(0.16, 1, 0.3, 1);

        /* Tus físicas de la Navbar para que coincidan */
        --ease-pro: cubic-bezier(0.19, 1, 0.22, 1);
        --ease-morph: cubic-bezier(0.68, -0.6, 0.32, 1.6);
    }

    body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-sans);
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .portal-main {
        flex-grow: 1;
        padding-top: 140px; /* Ajuste para tu Navbar Elite */
        display: flex;
        flex-direction: column;
    }

    /* TUS CLASES DE IDENTIDAD */
    .flouvia-masterpiece { width: 100%; position: relative; overflow-x: clip; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 5%; position: relative; }
    .editorial { font-family: var(--font-serif); font-style: italic; font-weight: 400; color: #222; }
    .eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; color: #888; text-transform: uppercase; margin-bottom: 1rem; }

    /* ANIMACIONES */
    .reveal-blur {
        opacity: 0; transform: translateY(30px) scale(0.98); filter: blur(8px);
        animation: reveal 1s var(--ease-spring) forwards; animation-delay: var(--delay, 0s);
    }
    .reveal-fade {
        opacity: 0; transform: translateY(30px) scale(0.98);
        animation: revealFade 1s var(--ease-spring) forwards; animation-delay: var(--delay, 0s);
    }

    /* Forzamos que corran en el portal */
    .reveal-blur, .reveal-fade { animation-play-state: running !important; }

    @keyframes reveal { to { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); } }
    @keyframes revealFade { to { opacity: 1; transform: translateY(0) scale(1); } }

    .btn-luxe {
        position: relative; display: inline-flex; background: var(--color-text); color: #fff;
        padding: 16px 38px; border-radius: 100px; text-decoration: none; font-size: 0.9rem;
        font-weight: 600; transition: all 0.5s var(--ease-spring); overflow: hidden; justify-content: center;
        box-shadow: 0 4px 6px rgba(0,0,0,0.04), 0 10px 20px rgba(0,0,0,0.08);
    }
    .btn-luxe:hover { transform: translateY(-4px); box-shadow: 0 6px 12px rgba(0,0,0,0.08), 0 15px 30px rgba(0,0,0,0.15); }

    .squircle { border-radius: 24px; transform: translateZ(0); overflow: hidden; }
</style>
