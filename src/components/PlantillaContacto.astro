<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';
    gsap.registerPlugin(ScrollTrigger, SplitText);

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLElement>('.hero-title, .hero-text-zone .eyebrow, .hero-bottom').forEach(el => {
        el.style.animation = 'none';
        el.style.opacity = '1';
        el.style.filter = 'none';
        el.style.transform = 'none';
    });

    if (!reduced) {
        const mm = gsap.matchMedia();

        mm.add('(min-width: 769px)', () => {
            const heroTitle = document.querySelector<HTMLElement>('.hero-title');
            const heroEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const heroBottom = document.querySelector<HTMLElement>('.hero-bottom');

            const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (heroEyebrow) {
                tl.from(heroEyebrow, { opacity: 0, y: 14, letterSpacing: '7px', duration: 1.4 }, 0.1);
            }
            if (heroTitle) {
                const split = SplitText.create(heroTitle, { type: 'lines,words', linesClass: 'lx-line-mask' });
                gsap.set(split.words, { yPercent: 105 });
                tl.to(split.words, {
                    yPercent: 0, duration: 1.5,
                    stagger: { amount: 0.5, from: 'start' },
                }, 0.35);
            }
            if (heroBottom && heroBottom.children.length > 0) {
                tl.from(gsap.utils.toArray<HTMLElement>(heroBottom.children), {
                    opacity: 0, y: 16, duration: 1.1, ease: 'power3.out',
                    stagger: 0.12,
                }, 1.0);
            }

            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 28, opacity: 0.15, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 0.8 },
                });
            }
        });

        mm.add('(max-width: 768px)', () => {
            const mHeroTitle = document.querySelector<HTMLElement>('.hero-title');
            const mEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const mHeroBottom = document.querySelector<HTMLElement>('.hero-bottom');
            const tlm = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (mEyebrow) tlm.from(mEyebrow, { opacity: 0, y: 10, letterSpacing: '6px', duration: 1.1 }, 0.1);
            if (mHeroTitle) tlm.from(mHeroTitle, { opacity: 0, y: 24, duration: 1.2 }, 0.3);
            if (mHeroBottom && mHeroBottom.children.length > 0) {
                tlm.from(gsap.utils.toArray<HTMLElement>(mHeroBottom.children), {
                    opacity: 0, y: 14, duration: 1.0, ease: 'power3.out',
                    stagger: 0.1,
                }, 0.85);
            }
        });
    }
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.4/build/js/intlTelInput.min.js"></script>
<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        
        /* =========================================
           1. FORMATEO PRO DE CAMPOS (NOMBRE, EMAIL)
           ========================================= */
        const nameInput = document.getElementById('name');
        if(nameInput) {
            nameInput.addEventListener('input', function(e) {
                // Elimina números y símbolos, deja solo letras y espacios
                let val = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g, '');
                // Capitaliza automáticamente la primera letra de cada palabra
                val = val.replace(/\b\w/g, char => char.toUpperCase());
                this.value = val;
            });
        }

        const emailInput = document.getElementById('email');
        if(emailInput) {
            emailInput.addEventListener('input', function() {
                // Fuerza minúsculas y elimina espacios
                this.value = this.value.toLowerCase().replace(/\s/g, '');
            });
        }


        /* =========================================
           2. INTL-TEL-INPUT (WHATSAPP)
           ========================================= */
        var itiInstance = null;
        const phoneInput = document.querySelector("#whatsapp");
        if (phoneInput) {
            itiInstance = window.intlTelInput(phoneInput, {
                initialCountry: "auto",
                strictMode: true,
                formatOnDisplay: true,
                geoIpLookup: function(callback) {
                    fetch("https://ipapi.co/json")
                        .then(function(res) { return res.json(); })
                        .then(function(data) { callback(data.country_code); })
                        .catch(function() { callback("mx"); });
                },
                separateDialCode: true,
                dropdownContainer: document.body,
                utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.4/build/js/utils.js",
            });
        }

        /* =========================================
           3. CHIP SELECTION
           ========================================= */
        document.querySelectorAll('.q-chips').forEach(function(group) {
            group.querySelectorAll('.q-chip').forEach(function(chip) {
                chip.addEventListener('click', function() {
                    group.querySelectorAll('.q-chip').forEach(function(c) { c.classList.remove('selected'); });
                    chip.classList.add('selected');
                    var fieldId = 'field-' + group.getAttribute('data-field');
                    var hidden = document.getElementById(fieldId);
                    if (hidden) hidden.value = chip.getAttribute('data-value');
                });
            });
        });

        /* =========================================
           4. ANIMACIONES Y PARALLAX
           ========================================= */
        const reveal = () => {
            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.08 });
            document.querySelectorAll('.reveal-blur, .reveal-fade, .reveal-up').forEach(el => observer.observe(el));
        }
        reveal();

        /* =========================================
           5. TEXTAREA AUTO-RESIZE
           ========================================= */
        const textarea = document.getElementById('problema');
        if (textarea) {
            textarea.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = (this.scrollHeight) + 'px';
            });
        }

        /* =========================================
           6. SUBMIT → MAKE WEBHOOK
           ========================================= */
        const diagForm    = document.querySelector('.diag-form');
        const diagSuccess = document.getElementById('diagSuccess');
        const diagBtn     = document.getElementById('diagSubmitBtn');
        const diagBtnText = document.getElementById('diagBtnText');

        if (diagForm) {
            diagForm.addEventListener('submit', async function(ev) {
                ev.preventDefault();
                if (!diagBtn || !diagBtnText) return;

                diagBtn.disabled = true;
                diagBtnText.textContent = '…';

                var whatsappNumber = '';
                if (itiInstance) {
                    try { whatsappNumber = itiInstance.getNumber(); } catch(e) {}
                }

                var payload = {
                    nombre:       (document.getElementById('name') || {}).value || '',
                    email:        (document.getElementById('email') || {}).value || '',
                    whatsapp:     whatsappNumber,
                    tipo_negocio: (document.getElementById('field-tipo_negocio') || {}).value || '',
                    problema:     (document.getElementById('problema') || {}).value || '',
                    urgencia:     (document.getElementById('field-urgencia') || {}).value || '',
                    presupuesto:  (document.getElementById('field-presupuesto') || {}).value || '',
                    timestamp:    new Date().toISOString(),
                    fuente:       'flouvia.com/contacto',
                };

                try {
                    await fetch('https://hook.us2.make.com/ov4rrddtdx739hnl7dp2mks216171q8m', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                } catch(e) { /* fail silently — no bloqueamos el success */ }

                diagForm.style.opacity = '0';
                diagForm.style.transform = 'translateY(-8px)';
                diagForm.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
                setTimeout(function() {
                    diagForm.classList.add('hidden');
                    if (diagSuccess) {
                        diagSuccess.classList.add('visible');
                        diagSuccess.style.opacity = '0';
                        diagSuccess.style.transform = 'translateY(12px)';
                        diagSuccess.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                        setTimeout(function() {
                            diagSuccess.style.opacity = '1';
                            diagSuccess.style.transform = 'translateY(0)';
                        }, 20);
                    }
                }, 360);
            });
        }

        const updateClock = () => {
            const clockEl = document.getElementById('cdmx-clock');
            if (!clockEl) return;
            
            const now = new Date();
            const options = { 
                timeZone: 'America/Mexico_City',
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit',
                hour12: false
            };
            
            const formatter = new Intl.DateTimeFormat('en-US', options);
            clockEl.textContent = formatter.format(now) + ' CST';
        };
        
        updateClock();
        setInterval(updateClock, 1000);
    });
</script>