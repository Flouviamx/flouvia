</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const robustRefresh = () => {
        const winLoad = new Promise<void>((resolve) => {
            if (document.readyState === 'complete') resolve();
            else window.addEventListener('load', () => resolve(), { once: true });
        });
        const fontsReady = (document as any).fonts?.ready ?? Promise.resolve();
        Promise.all([winLoad, fontsReady]).then(() => {
            setTimeout(() => ScrollTrigger.refresh(), 120);
        });
    };
    robustRefresh();

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) return;

        const EASE = 'power2.out';
        const DUR = 0.9;
        const Y = 14;

        /* ─── HERO — entrada en carga (estándar de la home) ─── */
        const heroAnim = gsap.utils.toArray<HTMLElement>('.hero-anim');
        if (heroAnim.length) {
            gsap.set(heroAnim, { opacity: 0, y: 12 });
            gsap.timeline({ defaults: { ease: EASE } })
                .to('.hero-status',             { opacity: 1, y: 0, duration: 0.9 }, 0)
                .to('.hero-text-zone .eyebrow', { opacity: 1, y: 0, duration: 0.9 }, 0.1)
                .to('.hero-title',              { opacity: 1, y: 0, duration: 1.1 }, 0.2)
                .to('.hero-bottom',             { opacity: 1, y: 0, duration: 1.0 }, 0.42);
        }

        /* ─── Reveal on scroll (patrón anti-parpadeo) ─── */
        const reveal = (
            targets: string | HTMLElement | NodeListOf<Element> | HTMLElement[],
            opts: { trigger?: string | HTMLElement; start?: string; y?: number; dur?: number; stagger?: number; delay?: number } = {}
        ) => {
            const els = gsap.utils.toArray<HTMLElement>(targets as any);
            if (!els.length) return;
            gsap.set(els, { opacity: 0, y: opts.y ?? Y });
            ScrollTrigger.create({
                trigger: opts.trigger ?? els[0],
                start: opts.start ?? 'top 85%',
                once: true,
                onEnter: () => gsap.to(els, {
                    opacity: 1, y: 0, duration: opts.dur ?? DUR, ease: EASE,
                    stagger: opts.stagger ?? 0.08, delay: opts.delay ?? 0,
                    clearProps: 'transform,opacity',
                }),
            });
        };

        reveal('.trust-strip .trust-eyebrow', { trigger: '.trust-strip', y: 12, dur: 0.9, start: 'top 85%' });
        reveal('.trust-strip .trust-metric',  { trigger: '.trust-strip', y: 16, dur: 0.95, stagger: 0.1, start: 'top 82%' });
        reveal('.trust-strip .trust-note',    { trigger: '.trust-strip', y: 12, dur: 0.9, delay: 0.15, start: 'top 82%' });
        reveal('.ec-sidebar', { trigger: '.executive-contact', y: 18, dur: 1.0, start: 'top 82%' });
        reveal('.stepper-head',          { trigger: '.executive-contact', y: 14, dur: 0.95, start: 'top 80%' });

        /* Parallax muy leve del hero (solo desktop) */
        const mm = gsap.matchMedia();
        mm.add('(min-width: 769px)', () => {
            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 4, opacity: 0.85, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 1 },
                });
            }
        });
    });
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.4/build/js/intlTelInput.min.js"></script>
<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {

        var isEn = document.documentElement.lang === 'en';
        var T = {
            continue: isEn ? 'Continue' : 'Continuar',
            send:     isEn ? 'Apply to project' : 'Aplicar a proyecto',
            errFields: isEn ? 'Please complete the fields above.' : 'Completa los campos para continuar.',
            errChoose: isEn ? 'Pick an option to continue.' : 'Selecciona una opción para continuar.',
        };

        /* 1. FORMATEO DE CAMPOS (NOMBRE, EMAIL) */
        var nameInput = document.getElementById('name');
        if (nameInput) {
            nameInput.addEventListener('input', function () {
                var val = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g, '');
                val = val.replace(/\b\w/g, function (c) { return c.toUpperCase(); });
                this.value = val;
            });
        }
        var emailInput = document.getElementById('email');
        if (emailInput) {
            emailInput.addEventListener('input', function () {
                this.value = this.value.toLowerCase().replace(/\s/g, '');
            });
        }

        /* 2. INTL-TEL-INPUT (WHATSAPP) */
        var itiInstance = null;
        var phoneInput = document.querySelector('#whatsapp');
        if (phoneInput) {
            itiInstance = window.intlTelInput(phoneInput, {
                initialCountry: 'auto',
                strictMode: true,
                formatOnDisplay: true,
                geoIpLookup: function (callback) {
                    fetch('https://ipapi.co/json')
                        .then(function (res) { return res.json(); })
                        .then(function (data) { callback(data.country_code); })
                        .catch(function () { callback('mx'); });
                },
                separateDialCode: true,
                dropdownContainer: document.body,
                utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.4/build/js/utils.js',
            });
        }

        /* 3. STEPPER — una pregunta a la vez */
        var form        = document.getElementById('diagForm');
        var steps       = Array.prototype.slice.call(document.querySelectorAll('.dq-step'));
        var total       = steps.length;
        var current     = 0;
        var transitioning = false;

        var spCurrent   = document.querySelector('.sp-current');
        var spFill      = document.querySelector('.sp-fill');
        var spBar       = document.querySelector('.sp-bar');
        var backBtn     = document.getElementById('stepBack');
        var nextBtn     = document.getElementById('stepNext');
        var nextText    = document.getElementById('stepNextText');
        var errorEl     = document.getElementById('stepError');

        function pad(n) { return ('0' + n).slice(-2); }

        function updateUI(animate) {
            if (spCurrent) {
                spCurrent.textContent = pad(current + 1);
                if (animate) {
                    spCurrent.classList.remove('bump');
                    void spCurrent.offsetWidth;
                    spCurrent.classList.add('bump');
                }
            }
            if (spFill) spFill.style.transform = 'scaleX(' + ((current + 1) / total) + ')';
            if (spBar && animate) {
                spBar.classList.remove('pulse');
                void spBar.offsetWidth;
                spBar.classList.add('pulse');
            }
            if (backBtn) backBtn.classList.toggle('is-hidden', current === 0);
            if (nextText) nextText.textContent = (current === total - 1) ? T.send : T.continue;
        }

        function clearError() { if (errorEl) errorEl.classList.remove('show'); }
        function showError(msg) {
            if (!errorEl) return;
            errorEl.textContent = msg;
            errorEl.classList.add('show');
        }

        function focusFirst(stepEl) {
            var field = stepEl.querySelector('input:not([type=hidden]), textarea');
            if (field) { try { field.focus({ preventScroll: true }); } catch (e) { field.focus(); } }
        }

        steps.forEach(function (s) {
            s.querySelectorAll('input, textarea').forEach(function (inp) {
                inp.addEventListener('input', function () { inp.classList.remove('invalid'); clearError(); });
            });
        });

        function validateStep(idx) {
            var stepEl = steps[idx];
            var ok = true;

            stepEl.querySelectorAll('input[required], textarea[required]').forEach(function (inp) {
                var valid = inp.value.trim() !== '' && (typeof inp.checkValidity !== 'function' || inp.checkValidity());
                if (!valid) { inp.classList.add('invalid'); ok = false; }
            });

            stepEl.querySelectorAll('.q-chips').forEach(function (group) {
                if (group.hasAttribute('data-optional')) return;
                var hidden = document.getElementById('field-' + group.getAttribute('data-field'));
                if (!hidden || !hidden.value) { group.classList.add('chips-invalid'); ok = false; }
            });

            if (!ok) {
                var hasChips = stepEl.querySelector('.q-chips:not([data-optional])');
                showError(hasChips ? T.errChoose : T.errFields);
            }
            return ok;
        }

        function goTo(target) {
            if (transitioning || target < 0 || target >= total || target === current) return;
            clearError();
            transitioning = true;

            var outEl = steps[current];
            outEl.classList.remove('is-visible');

            window.setTimeout(function () {
                outEl.classList.remove('is-active');
                var inEl = steps[target];
                inEl.classList.add('is-active');
                void inEl.offsetWidth;
                inEl.classList.add('is-visible');
                current = target;
                updateUI(true);
                focusFirst(inEl);
                window.setTimeout(function () { transitioning = false; }, 380);
            }, 380);
        }

        function next() {
            if (transitioning) return;
            if (!validateStep(current)) return;
            if (current === total - 1) { submitForm(); return; }
            goTo(current + 1);
        }
        function prev() { if (current > 0) goTo(current - 1); }

        if (nextBtn) nextBtn.addEventListener('click', next);
        if (backBtn) backBtn.addEventListener('click', prev);

        steps.forEach(function (s) {
            s.querySelectorAll('input[type=text], input[type=email], input[type=tel]').forEach(function (inp) {
                inp.addEventListener('keydown', function (ev) {
                    if (ev.key === 'Enter') { ev.preventDefault(); next(); }
                });
            });
        });

        if (form) form.addEventListener('submit', function (ev) { ev.preventDefault(); next(); });

        /* 4. CHIPS — badge de tecla + check + selección + auto-avance */
        var CHECK_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';

        document.querySelectorAll('.q-chips').forEach(function (group) {
            group.querySelectorAll('.q-chip').forEach(function (chip, i) {
                // Inyecta estructura: [tecla] etiqueta [check]
                var label = chip.textContent.trim();
                chip.innerHTML =
                    '<span class="chip-key" aria-hidden="true">' + (i + 1) + '</span>' +
                    '<span class="chip-text">' + label + '</span>' +
                    '<span class="chip-check" aria-hidden="true">' + CHECK_SVG + '</span>';

                chip.addEventListener('click', function () {
                    group.querySelectorAll('.q-chip').forEach(function (c) { c.classList.remove('selected'); });
                    chip.classList.add('selected');
                    group.classList.remove('chips-invalid');
                    clearError();

                    var hidden = document.getElementById('field-' + group.getAttribute('data-field'));
                    if (hidden) hidden.value = chip.getAttribute('data-value');

                    var stepEl = chip.closest('.dq-step');
                    var idx = steps.indexOf(stepEl);
                    if (idx === current && idx < total - 1) {
                        window.setTimeout(function () { goTo(current + 1); }, 420);
                    }
                });
            });
        });

        /* Teclado en pasos de chips: 1–9 seleccionan, Enter avanza */
        document.addEventListener('keydown', function (ev) {
            if (transitioning) return;
            var stepEl = steps[current];
            var group = stepEl && stepEl.querySelector('.q-chips');
            if (!group) return; // pasos de texto: el Enter lo maneja el input
            if (ev.key === 'Enter') {
                // si hay un botón enfocado (chip o "Continuar"), deja que él maneje Enter
                if (document.activeElement && document.activeElement.tagName === 'BUTTON') return;
                ev.preventDefault(); next(); return;
            }
            var n = parseInt(ev.key, 10);
            if (!isNaN(n) && n >= 1) {
                var chips = group.querySelectorAll('.q-chip');
                if (n <= chips.length) { ev.preventDefault(); chips[n - 1].click(); }
            }
        });

        /* 5. TEXTAREA AUTO-RESIZE */
        var textarea = document.getElementById('problema');
        if (textarea) {
            textarea.addEventListener('input', function () {
                this.style.height = 'auto';
                this.style.height = this.scrollHeight + 'px';
            });
        }

        /* 6. SUBMIT → MAKE WEBHOOK */
        var diagSuccess = document.getElementById('diagSuccess');

        function submitForm() {
            if (!nextBtn || !nextText) return;
            nextBtn.disabled = true;
            nextText.textContent = '…';

            var whatsappNumber = '';
            if (itiInstance) { try { whatsappNumber = itiInstance.getNumber(); } catch (e) {} }

            var payload = {
                nombre:       (document.getElementById('name') || {}).value || '',
                email:        (document.getElementById('email') || {}).value || '',
                whatsapp:     whatsappNumber,
                tipo_negocio: (document.getElementById('field-tipo_negocio') || {}).value || '',
                problema:     (document.getElementById('problema') || {}).value || '',
                urgencia:     (document.getElementById('field-urgencia') || {}).value || '',
                presupuesto:  (document.getElementById('field-presupuesto') || {}).value || '',
                timestamp:    new Date().toISOString(),
                fuente:       'flouvia.com/contacto',
            };

            fetch('https://hook.us2.make.com/ov4rrddtdx739hnl7dp2mks216171q8m', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            }).catch(function () { /* fail silently */ });

            var formZone = document.querySelector('.ec-form-zone');
            if (formZone) formZone.style.minHeight = form.offsetHeight + 'px';

            form.style.transition = 'opacity 0.38s ease, transform 0.38s ease';
            form.style.opacity = '0';
            form.style.transform = 'translateY(-10px)';

            window.setTimeout(function () {
                form.classList.add('hidden');
                if (!diagSuccess) return;

                var els = [
                    diagSuccess.querySelector('.ds-eyebrow'),
                    diagSuccess.querySelector('.ds-headline'),
                    diagSuccess.querySelector('.ds-rule'),
                    diagSuccess.querySelector('.ds-sub'),
                    diagSuccess.querySelector('.ds-next'),
                ];

                els.forEach(function (el) {
                    if (el) { el.style.opacity = '0'; el.style.transform = 'translateY(18px)'; }
                });
                var rule = els[2];
                if (rule) rule.style.transform = 'scaleX(0)';

                diagSuccess.classList.add('visible');

                var delays = [0, 80, 200, 300, 380];
                els.forEach(function (el, i) {
                    if (!el) return;
                    window.setTimeout(function () {
                        el.style.transition = 'opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1)';
                        el.style.opacity = '1';
                        el.style.transform = i === 2 ? 'scaleX(1)' : 'translateY(0)';
                        if (i === 2) el.style.transformOrigin = 'left';
                    }, delays[i]);
                });
            }, 400);
        }

        updateUI(false);
    });
</script>
