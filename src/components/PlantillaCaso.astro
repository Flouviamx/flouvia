---
// src/components/PlantillaCaso.astro
// Template compartido de un caso de estudio individual. Rendea /casos/{slug}
// y /en/casos/{slug} desde una sola fuente (evita drift ES/EN).
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import type { CaseStudy } from '../data/casos';

interface Props {
  caso: CaseStudy;
  next: CaseStudy;
  isEn: boolean;
  root: string;
}
const { caso, next, isEn, root } = Astro.props;
const t = (o: { es: string; en: string }) => isEn ? o.en : o.es;

// SEO — title/description con métricas si el caso los define (fallback al genérico)
const pageTitle = caso.seoTitle ? t(caso.seoTitle) : `${caso.brand} — ${t(caso.category)} | Flouvia`;
const pageDesc  = caso.seoDesc  ? t(caso.seoDesc)  : t(caso.desc);

// URLs absolutas para schema
const SITE       = (Astro.site ?? new URL('https://flouvia.com')).origin;
const caseUrl    = `${SITE}${root}/casos/${caso.slug}`;
const casosUrl   = `${SITE}${root}/casos`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${caseUrl}#article`,
  headline: pageTitle,
  description: pageDesc,
  datePublished: caso.datePublished,
  dateModified: caso.dateModified ?? caso.datePublished,
  author:    { '@id': `${SITE}/#organization` },
  publisher: { '@id': `${SITE}/#organization` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': caseUrl },
  ...(caso.about ? { about: { '@type': 'Organization', name: caso.about.name, description: caso.about.description, url: caso.about.url } } : {}),
  mentions: caso.stack.map(tech => ({ '@type': 'SoftwareApplication', name: tech })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: isEn ? 'Home' : 'Inicio', item: `${SITE}${root}/` },
    { '@type': 'ListItem', position: 2, name: isEn ? 'Cases' : 'Casos', item: casosUrl },
    { '@type': 'ListItem', position: 3, name: `${caso.brand} — ${t(caso.category)}`, item: caseUrl },
  ],
};
---

<Layout title={pageTitle} description={pageDesc} image={caso.image} ogType="article">
  <Navbar />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <main class="cs-page">

    <!-- ════════════════════ HERO ════════════════════ -->
    <section class="cs-hero">
      <div class="container">

        <!-- Breadcrumb -->
        <div class="cs-breadcrumb" id="cs-breadcrumb">
          <a href={`${root}/casos`} class="cs-back">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8"><polyline points="15 18 9 12 15 6"/></svg>
            {isEn ? 'Cases' : 'Casos'}
          </a>
          <span class="cs-bread-sep">/</span>
          <span class="cs-bread-num">{caso.num}</span>
          <span class="cs-bread-brand">{caso.brand}</span>
          <a href={caso.liveUrl} target="_blank" rel="noopener" class="cs-site-chip">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            {caso.liveDomain}
          </a>
        </div>

        <!-- Hero text -->
        <div class="cs-hero-text" id="cs-hero-text">
          <p class="cs-eyebrow" id="cs-eyebrow">{t(caso.category)}</p>
          <h1 class="cs-brand" id="cs-brand">{caso.brand}.</h1>
          <p class="cs-tagline editorial" id="cs-tagline">{t(caso.tagline)}</p>

          <div class="cs-hero-bottom" id="cs-hero-bottom">
            <p class="cs-desc">{t(caso.desc)}</p>
            <a href={caso.liveUrl} target="_blank" rel="noopener" class="cs-visit-btn">
              <span>{isEn ? 'Visit live site' : 'Visitar sitio'}</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>

        <!-- Metrics strip -->
        <div class="cs-metrics" id="cs-metrics">
          {caso.metrics.map(m => (
            <div class="cs-metric">
              <span class="cs-metric-val">{m.val}</span>
              <span class="cs-metric-lbl">{t(m.label)}</span>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ════════════════════ IMAGEN ════════════════════ -->
    <section class="cs-visual-section">
      <div class="container">
        <div class="cs-visual-wrap" id="cs-visual">
          <img src={caso.image} alt={`${caso.brand} — Flouvia`} class="cs-visual-img" loading="eager" />
        </div>
      </div>
    </section>

    <!-- ════════════════════ CUERPO ════════════════════ -->
    <section class="cs-body-section">
      <div class="container cs-body-grid">

        <div class="cs-col" id="cs-challenge">
          <span class="cs-col-eye">{isEn ? 'THE CHALLENGE' : 'EL RETO'}</span>
          <div class="cs-col-rule"></div>
          <p class="cs-challenge-text editorial">{t(caso.challenge)}</p>
        </div>

        <div class="cs-col" id="cs-solution">
          <span class="cs-col-eye">{isEn ? 'THE SOLUTION' : 'LA SOLUCIÓN'}</span>
          <div class="cs-col-rule"></div>
          <ul class="cs-points">
            {caso.solutionPoints.map(pt => (
              <li class="cs-point">
                <span class="cs-dot"></span>
                <span>{t(pt)}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </section>

    <!-- ════════════════════ STACK ════════════════════ -->
    <section class="cs-stack-section">
      <div class="container">
        <div class="cs-stack-inner" id="cs-stack">
          <span class="cs-col-eye">{isEn ? 'TECH STACK' : 'STACK UTILIZADO'}</span>
          <div class="cs-stack-pills">
            {caso.stack.map(tech => (
              <span class="cs-pill">{tech}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════ RESULTADOS ════════════════════ -->
    <section class="cs-results-section">
      <div class="container">
        <p class="cs-results-eye">{isEn ? 'RESULTS' : 'RESULTADOS'}</p>
        {caso.resultsNote && <p class="cs-results-note" id="cs-results-note">{t(caso.resultsNote)}</p>}
        <div class="cs-results-grid">
          {caso.results.map(r => (
            <div class="cs-result-card">
              <span class="cs-result-val">{r.val}</span>
              <span class="cs-result-lbl">{t(r.label)}</span>
              <p class="cs-result-desc">{t(r.desc)}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════ NAV CASOS ════════════════════ -->
    <section class="cs-case-nav">
      <div class="container">
        <div class="cs-nav-row">
          <a href={`${root}/casos`} class="cs-nav-all">
            <div class="cs-nav-circ">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            {isEn ? 'All cases' : 'Todos los casos'}
          </a>
          <a href={`${root}/casos/${next.slug}`} class="cs-nav-next">
            <div class="cs-nav-next-txt">
              <span class="cs-nav-lbl">{isEn ? 'Next case' : 'Siguiente caso'}</span>
              <span class="cs-nav-brand">{next.brand}</span>
            </div>
            <div class="cs-nav-circ">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ════════════════════ CTA ════════════════════ -->
    <section class="cs-cta-section">
      <div class="container">
        <div class="cs-cta-card cta-squircle texture-noise" id="cs-cta">
          <div class="cs-cta-inner">
            <div class="cs-cta-text">
              <p class="cs-cta-eye">{caso.cta ? t(caso.cta.eyebrow) : (isEn ? 'THE NEXT STEP' : 'EL SIGUIENTE PASO')}</p>
              <h2 class="cs-cta-title">{caso.cta ? t(caso.cta.title) : (isEn ? 'Scale your operation.' : 'Escale su operación.')}</h2>
              {caso.cta && <p class="cs-cta-sub">{t(caso.cta.sub)}</p>}
            </div>
            <div class="cs-cta-action">
              <a href={`${root}/contacto`} class="cs-cta-btn">
                <span>{isEn ? 'Request diagnosis →' : 'Solicitar diagnóstico →'}</span>
                <div class="cs-cta-glow"></div>
              </a>
              <span class="cs-cta-badge"><span class="cs-cta-badge-dot" aria-hidden="true"></span>{isEn ? '2 projects available · Q3' : '2 proyectos disponibles · Q3'}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<!-- ════════════════════════════════════════
     CSS GLOBAL — variables del sistema
════════════════════════════════════════ -->
<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { width: 100%; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: #0a192f; color: #fff; }

  :root {
    --color-bg:        #ffffff;
    --color-bg-soft:   #fcfcfc;
    --color-blue-icy:  #f4f6f9;
    --color-blue-deep: #0a192f;
    --color-text:      #050505;
    --color-text-muted:#555556;
    --color-border:    rgba(0,0,0,0.08);
    --font-sans:       'Inter', system-ui, sans-serif;
    --font-serif:      'Instrument Serif', serif;
    --ease-ios:        cubic-bezier(0.25, 1, 0.5, 1);
    --ease-spring:     cubic-bezier(0.22, 1, 0.36, 1);
    --ease-smooth:     cubic-bezier(0.16, 1, 0.3, 1);
  }

  body { background: var(--color-bg); color: var(--color-text); font-family: var(--font-sans); margin: 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 5%; position: relative; }
  .editorial { font-family: var(--font-serif); font-style: italic; font-weight: 400; }

  /* Gate anti-flash — los elementos del hero parten ocultos SOLO con JS activo
     (clase .js-anim puesta antes del paint). Sin JS / reduced-motion → visibles. */
  .js-anim .cs-breadcrumb,
  .js-anim .cs-eyebrow,
  .js-anim .cs-brand,
  .js-anim .cs-tagline,
  .js-anim .cs-hero-bottom,
  .js-anim .cs-metrics { opacity: 0; }

  /* CTA shared styles */
  .cta-squircle { border-radius: 32px; transform: translateZ(0); overflow: hidden; box-shadow: inset 0 0 0 1px rgba(255,255,255,.08); }
  .texture-noise::before {
    content:""; position:absolute; inset:0;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity:.04; mix-blend-mode:overlay; pointer-events:none; border-radius:inherit;
  }
</style>

<!-- ════════════════════════════════════════
     CSS LOCAL — página de caso
════════════════════════════════════════ -->
<style>
/* ── PAGE WRAPPER ── */
.cs-page { width: 100%; position: relative; overflow-x: clip; }

/* ── HERO ── */
.cs-hero {
  padding: 13rem 0 0;
  background: var(--color-bg);
}

/* Breadcrumb */
.cs-breadcrumb {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 3.5rem; flex-wrap: wrap;
}
.cs-back {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted);
  text-decoration: none; transition: color .2s;
}
.cs-back:hover { color: var(--color-text); }
.cs-bread-sep  { color: rgba(0,0,0,.15); }
.cs-bread-num  { font-family: var(--font-serif); font-style: italic; font-size: 0.95rem; color: #bbb; line-height: 1; }
.cs-bread-brand{ font-size: 0.78rem; font-weight: 700; color: var(--color-text); }
.cs-site-chip {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: var(--font-sans); font-size: 0.66rem; font-weight: 600; letter-spacing: 0.02em;
  color: var(--color-text); text-decoration: none;
  background: rgba(0,0,0,0.04); border: 1px solid var(--color-border);
  padding: 5px 13px; border-radius: 100px;
  transition: all .3s var(--ease-smooth);
  margin-left: auto;
}
.cs-site-chip:hover { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); }

/* Hero text */
.cs-eyebrow {
  font-size: 0.62rem; font-weight: 800; letter-spacing: 3px;
  color: #999; text-transform: uppercase; margin: 0 0 2rem;
}
.cs-brand {
  font-size: clamp(4.5rem, 12vw, 10rem);
  font-weight: 800; letter-spacing: -4px;
  line-height: 0.9; margin: 0 0 2.5rem;
  color: var(--color-text);
}
.cs-tagline {
  font-size: clamp(1.6rem, 3vw, 2.8rem);
  letter-spacing: -0.5px; line-height: 1.2;
  color: #2a2a2a; margin: 0 0 3rem;
  max-width: 760px;
}
.cs-hero-bottom {
  display: flex; justify-content: space-between; align-items: flex-end;
  gap: 3rem; border-top: 1px solid var(--color-border); padding-top: 2.5rem;
}
.cs-desc {
  font-size: 1.05rem; line-height: 1.65;
  color: var(--color-text-muted); margin: 0; max-width: 520px;
}
.cs-visit-btn {
  display: inline-flex; align-items: center; gap: 8px; flex-shrink: 0;
  font-size: 0.85rem; font-weight: 700; color: var(--color-text);
  text-decoration: none; white-space: nowrap;
  padding: 14px 26px; border-radius: 100px;
  border: 1.5px solid rgba(0,0,0,0.12);
  transition: all .4s var(--ease-spring);
}
.cs-visit-btn svg { transition: transform .4s var(--ease-spring); }
.cs-visit-btn:hover {
  background: var(--color-blue-deep); color: #fff;
  border-color: var(--color-blue-deep);
  transform: translateY(-3px);
  box-shadow: 0 12px 28px rgba(10,25,47,0.2);
}
.cs-visit-btn:hover svg { transform: translate(2px,-2px); }

/* Metrics */
.cs-metrics {
  display: grid; grid-template-columns: repeat(4,1fr);
  border-top: 1px solid var(--color-border);
  margin-top: 3.5rem;
}
.cs-metric {
  padding: 2rem 1.5rem; border-right: 1px solid var(--color-border);
  display: flex; flex-direction: column; gap: 0.35rem;
  transition: background .3s var(--ease-smooth);
}
.cs-metric:last-child { border-right: none; }
.cs-metric:hover { background: rgba(0,0,0,.018); }
.cs-metric-val {
  font-family: var(--font-serif); font-style: italic; font-weight: 400;
  font-size: clamp(2rem, 3.2vw, 2.8rem);
  line-height: 1; letter-spacing: -0.5px;
  color: var(--color-blue-deep);
}
.cs-metric-lbl {
  font-size: 0.6rem; font-weight: 800;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--color-text-muted);
}

/* ── IMAGEN ── */
.cs-visual-section { padding: 3rem 0; background: #f5f5f7; }
.cs-visual-wrap {
  border-radius: 24px; overflow: hidden;
  border: 1px solid var(--color-border);
  background: #eceef2;
  display: flex; align-items: center; justify-content: center;
  min-height: 380px;
}
.cs-visual-img { width: 100%; height: auto; display: block; max-height: 580px; object-fit: cover; }

/* ── CUERPO ── */
.cs-body-section { padding: 5rem 0; background: var(--color-bg); }
.cs-body-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 5rem; align-items: start;
}
.cs-col-eye {
  display: block; font-size: 0.56rem; font-weight: 800;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: #ccc; margin-bottom: 1rem;
}
.cs-col-rule {
  height: 2px; width: 32px; background: var(--color-text);
  margin-bottom: 1.8rem; transform: scaleX(0); transform-origin: left;
}
.cs-challenge-text { font-size: 1.1rem; line-height: 1.8; color: #333; margin: 0; }
.cs-points { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
.cs-point {
  display: flex; align-items: flex-start; gap: 1rem;
  font-size: 0.95rem; line-height: 1.65; color: var(--color-text);
}
.cs-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--color-blue-deep); flex-shrink: 0; margin-top: 0.55rem;
}

/* ── STACK ── */
.cs-stack-section { padding: 0 0 5rem; background: var(--color-bg); }
.cs-stack-inner {
  border-top: 1px solid var(--color-border);
  padding-top: 2.5rem;
}
.cs-stack-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.2rem; }
.cs-pill {
  font-family: var(--font-sans); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.02em;
  color: var(--color-text); background: rgba(0,0,0,.035);
  border: 1px solid var(--color-border); padding: 0.45rem 1rem;
  border-radius: 100px;
  transition: all .35s var(--ease-smooth);
}
.cs-pill:hover { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); transform: translateY(-2px); }

/* ── RESULTADOS ── */
.cs-results-section {
  background: radial-gradient(120% 100% at 50% 0%, #152744 0%, #060c18 100%);
  padding: 5rem 0; position: relative; overflow: hidden;
}
.cs-results-section::before {
  content:""; position:absolute; inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity:.035; mix-blend-mode:overlay; pointer-events:none;
}
.cs-results-eye {
  font-size: 0.58rem; font-weight: 800; letter-spacing: 4px;
  color: rgba(255,255,255,.25); text-transform: uppercase;
  margin: 0 0 1rem; position: relative;
}
.cs-results-note {
  font-size: 0.95rem; line-height: 1.6; color: rgba(255,255,255,.55);
  margin: 0 0 2.6rem; max-width: 640px; position: relative;
}
.cs-results-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 1px; background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 20px; overflow: hidden; position: relative;
}
.cs-result-card {
  padding: 3rem 2.5rem; display: flex; flex-direction: column; gap: 0.5rem;
  transition: background .3s var(--ease-smooth);
}
.cs-result-card:hover { background: rgba(255,255,255,.04); }
.cs-result-val {
  font-family: var(--font-serif); font-style: italic; font-weight: 400;
  font-size: clamp(3rem,5.2vw,4.6rem);
  color: #fff; line-height: 1; letter-spacing: -1px;
}
.cs-result-lbl {
  font-size: 0.6rem; font-weight: 800; letter-spacing: 2px;
  text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 0.4rem;
}
.cs-result-desc { font-size: 0.85rem; color: rgba(255,255,255,.5); line-height: 1.6; margin: 0; }

/* ── NAV CASOS ── */
.cs-case-nav {
  padding: 3.5rem 0; background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}
.cs-nav-row { display: flex; justify-content: space-between; align-items: center; gap: 2rem; }
.cs-nav-all {
  display: flex; align-items: center; gap: 12px;
  font-size: 0.82rem; font-weight: 700; color: var(--color-text-muted);
  text-decoration: none; flex-direction: row-reverse;
  transition: color .2s, gap .3s var(--ease-smooth);
}
.cs-nav-all:hover { color: var(--color-text); gap: 16px; }
.cs-nav-all .cs-nav-circ { transform: rotate(180deg); }
.cs-nav-next {
  display: flex; align-items: center; gap: 1.5rem;
  text-decoration: none; color: var(--color-text);
  transition: gap .3s var(--ease-smooth);
}
.cs-nav-next:hover { gap: 2rem; }
.cs-nav-next-txt { text-align: right; display: flex; flex-direction: column; gap: 0.15rem; }
.cs-nav-lbl {
  font-size: 0.58rem; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--color-text-muted);
}
.cs-nav-brand { font-size: 1.7rem; font-weight: 800; letter-spacing: -1px; line-height: 1; }
.cs-nav-circ {
  width: 46px; height: 46px; border-radius: 50%;
  border: 1.5px solid rgba(0,0,0,.12);
  display: flex; align-items: center; justify-content: center;
  transition: all .4s var(--ease-spring); flex-shrink: 0;
  color: var(--color-text);
}
.cs-nav-next:hover .cs-nav-circ {
  background: var(--color-blue-deep); border-color: var(--color-blue-deep);
  color: #fff; transform: rotate(-45deg) scale(1.08);
}

/* ── CTA ── */
.cs-cta-section { padding: 0 0 6rem; background: var(--color-bg-soft); }
.cs-cta-card {
  background: radial-gradient(120% 100% at 50% 0%, #152744 0%, #050b14 100%);
  padding: 5rem 6rem; position: relative;
  box-shadow: 0 20px 40px rgba(5,11,20,.15), 0 50px 100px rgba(5,11,20,.22);
  transition: transform 0.6s var(--ease-spring);
}
.cs-cta-card:hover { transform: scale(1.012); }
.cs-cta-inner {
  display: flex; justify-content: space-between; align-items: center;
  gap: 3rem; position: relative; z-index: 2;
}
.cs-cta-eye {
  font-size: 0.6rem; font-weight: 800; letter-spacing: 4px;
  color: rgba(255,255,255,.3); text-transform: uppercase; margin: 0 0 1rem;
}
.cs-cta-title {
  font-size: clamp(2.2rem,3.4vw,3.1rem); font-weight: 800;
  color: #fff; line-height: 1.08; letter-spacing: -1.2px; margin: 0; max-width: 18ch;
}
.cs-cta-sub {
  margin: 1.3rem 0 0; color: rgba(255,255,255,.66);
  font-size: 1.02rem; line-height: 1.55; max-width: 440px;
}
.cs-cta-action { display: flex; flex-direction: column; align-items: flex-end; gap: 1.1rem; flex-shrink: 0; }
.cs-cta-badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
  color: rgba(255,255,255,.6);
}
.cs-cta-badge-dot {
  width: 6px; height: 6px; border-radius: 50%; background: #10b981;
  box-shadow: 0 0 10px rgba(16,185,129,.6); animation: cs-badge-pulse 2s infinite;
}
@keyframes cs-badge-pulse { 0%,100% { opacity: 1; } 50% { opacity: .4; } }
.cs-cta-btn {
  position: relative; background: #fff; color: var(--color-blue-deep);
  padding: 20px 44px; border-radius: 100px; text-decoration: none;
  font-size: 1rem; font-weight: 700; overflow: hidden;
  transition: .5s var(--ease-spring); display: inline-flex; align-items: center;
  white-space: nowrap; flex-shrink: 0;
  box-shadow: inset 0 0 0 1px rgba(0,0,0,.1), 0 10px 20px rgba(255,255,255,.1);
}
.cs-cta-btn:hover { transform: translateY(-4px); box-shadow: inset 0 0 0 1px rgba(0,0,0,.1), 0 20px 40px rgba(255,255,255,.2); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .cs-metrics { grid-template-columns: repeat(2,1fr); }
  .cs-metric:nth-child(2) { border-right: none; }
  .cs-metric:nth-child(3),
  .cs-metric:nth-child(4) { border-top: 1px solid var(--color-border); }
}

@media (max-width: 768px) {
  .cs-hero       { padding: 10rem 0 0; }
  .cs-breadcrumb { margin-bottom: 2.5rem; }
  .cs-site-chip  { margin-left: 0; }
  .cs-brand      { letter-spacing: -2px; }
  .cs-hero-bottom{ flex-direction: column; align-items: flex-start; gap: 2rem; border-top: none; padding-top: 0; }
  .cs-visit-btn  { width: 100%; justify-content: center; }

  .cs-metrics { grid-template-columns: 1fr 1fr; margin-top: 2.5rem; }
  .cs-metric  { padding: 1.4rem 1rem; }
  .cs-metric:nth-child(2) { border-right: none; }
  .cs-metric:nth-child(3),
  .cs-metric:nth-child(4) { border-top: 1px solid var(--color-border); }

  .cs-visual-section { padding: 2.5rem 0; }
  .cs-visual-wrap    { min-height: 240px; border-radius: 18px; }

  .cs-body-section { padding: 4rem 0; }
  .cs-body-grid    { grid-template-columns: 1fr; gap: 3rem; }

  .cs-stack-section { padding: 0 0 4rem; }

  .cs-results-section { padding: 4rem 0; }
  .cs-results-grid    { grid-template-columns: 1fr; }
  .cs-result-card     { padding: 2rem 1.5rem; }

  .cs-case-nav { padding: 3rem 0; }
  .cs-nav-row  { flex-direction: column; align-items: stretch; gap: 2rem; }
  .cs-nav-next { justify-content: space-between; }
  .cs-nav-next-txt { text-align: left; }
  .cs-nav-brand { font-size: 1.5rem; }

  .cs-cta-section { padding: 0 5% 5rem; }
  .cs-cta-card { padding: 3.5rem 2rem; }
  .cs-cta-inner { flex-direction: column; align-items: center; gap: 2.5rem; width: 100%; }
  .cs-cta-text  { text-align: center; }
  .cs-cta-title { max-width: 100%; }
  .cs-cta-sub   { max-width: 100%; }
  .cs-cta-action { align-items: center; width: 100%; }
  .cs-cta-btn   { width: 100%; justify-content: center; font-size: 0.95rem; padding: 18px 0; }
}

@media (max-width: 480px) {
  .cs-metric-val { font-size: 1.7rem; }
  .cs-breadcrumb { gap: 0.5rem; }
  .cs-bread-brand { display: none; }
  .cs-hero { padding: 8.5rem 0 3rem; }
  .cs-hero-title { font-size: clamp(1.9rem, 9vw, 2.6rem); }
  .cs-cta-card { padding: 3rem 1.5rem; }
}
</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

// Recalcular posiciones tras fuentes + imágenes — mismo patrón que el home.
const robustRefresh = () => {
  const winLoad = new Promise<void>((resolve) => {
    if (document.readyState === 'complete') resolve();
    else window.addEventListener('load', () => resolve(), { once: true });
  });
  const fontsReady = (document as any).fonts?.ready ?? Promise.resolve();
  Promise.all([winLoad, fontsReady]).then(() => {
    setTimeout(() => ScrollTrigger.refresh(), 120);
  });
};
robustRefresh();

document.addEventListener('DOMContentLoaded', () => {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Con reduced-motion la clase .js-anim nunca se añade → todo visible vía CSS.
  if (reduced) return;

  const EASE = 'power2.out';
  const DUR  = 0.9;
  const Y    = 14;

  /* ═══════ HERO — entrada en carga (gate .js-anim) ═══════ */
  const heroSel = ['.cs-breadcrumb', '.cs-eyebrow', '.cs-brand', '.cs-tagline', '.cs-hero-bottom', '.cs-metrics'];
  const heroEls = heroSel
    .map(s => document.querySelector<HTMLElement>(s))
    .filter((el): el is HTMLElement => !!el);
  if (heroEls.length) {
    gsap.set(heroEls, { opacity: 0, y: 12 });
    const tl = gsap.timeline({ defaults: { ease: EASE } });
    heroEls.forEach((el, i) => {
      tl.to(el, { opacity: 1, y: 0, duration: i === 2 ? 1.1 : 0.95 }, i === 0 ? 0 : 0.08 + i * 0.1);
    });
  }

  /* Reveal robusto (sin parpadeo): oculta con gsap.set y revela UNA vez al entrar. */
  const reveal = (
    targets: string | HTMLElement | NodeListOf<Element> | HTMLElement[],
    opts: { trigger?: string | HTMLElement; start?: string; y?: number; dur?: number; stagger?: number; delay?: number } = {}
  ) => {
    const els = gsap.utils.toArray<HTMLElement>(targets as any);
    if (!els.length) return;
    gsap.set(els, { opacity: 0, y: opts.y ?? Y });
    ScrollTrigger.create({
      trigger: opts.trigger ?? els[0],
      start: opts.start ?? 'top 85%',
      once: true,
      onEnter: () => gsap.to(els, {
        opacity: 1, y: 0, duration: opts.dur ?? DUR, ease: EASE,
        stagger: opts.stagger ?? 0.08, delay: opts.delay ?? 0,
        clearProps: 'transform,opacity',
      }),
    });
  };

  const mm = gsap.matchMedia();

  mm.add('(min-width: 769px)', () => {
    /* Parallax muy leve del hero */
    const heroText = document.getElementById('cs-hero-text');
    if (heroText) {
      gsap.to(heroText, {
        yPercent: 4, opacity: 0.85, ease: 'none',
        scrollTrigger: { trigger: '.cs-hero', start: 'top top', end: 'bottom 30%', scrub: 1 },
      });
    }
  });

  /* Reglas que se dibujan bajo los títulos de columna (scrub-free, una vez) */
  const drawRule = (rule: HTMLElement | null, trigger: HTMLElement) => {
    if (!rule) return;
    gsap.set(rule, { scaleX: 0, transformOrigin: 'left center' });
    ScrollTrigger.create({
      trigger, start: 'top 82%', once: true,
      onEnter: () => gsap.to(rule, { scaleX: 1, duration: 0.9, ease: 'power3.inOut' }),
    });
  };

  /* Visual */
  reveal('.cs-visual-wrap', { trigger: '#cs-visual', y: 24, dur: 1.0, start: 'top 86%' });

  /* Reto */
  const colChallenge = document.getElementById('cs-challenge');
  if (colChallenge) {
    reveal(colChallenge.querySelectorAll('.cs-col-eye, .cs-challenge-text'), { trigger: colChallenge, y: 14, stagger: 0.08, start: 'top 84%' });
    drawRule(colChallenge.querySelector('.cs-col-rule'), colChallenge);
  }

  /* Solución */
  const colSolution = document.getElementById('cs-solution');
  if (colSolution) {
    reveal(colSolution.querySelectorAll('.cs-col-eye, .cs-point'), { trigger: colSolution, y: 14, stagger: 0.06, start: 'top 82%' });
    drawRule(colSolution.querySelector('.cs-col-rule'), colSolution);
  }

  /* Stack */
  const stack = document.getElementById('cs-stack');
  if (stack) {
    reveal(stack.querySelectorAll('.cs-col-eye, .cs-pill'), { trigger: stack, y: 10, dur: 0.8, stagger: 0.04, start: 'top 88%' });
  }

  /* Resultados — nota + cards */
  reveal('.cs-results-note', { trigger: '.cs-results-section', y: 12, start: 'top 80%' });
  reveal('.cs-result-card', { trigger: '.cs-results-grid', y: 22, dur: 1.0, stagger: 0.1, start: 'top 85%' });

  /* CTA */
  const ctaCard = document.getElementById('cs-cta');
  if (ctaCard) {
    reveal(ctaCard, { trigger: ctaCard, y: 24, dur: 1.0, start: 'top 84%' });
    reveal(ctaCard.querySelectorAll('.cs-cta-text > *, .cs-cta-action'), { trigger: ctaCard, y: 12, stagger: 0.08, delay: 0.15, start: 'top 84%' });
  }
});
</script>
