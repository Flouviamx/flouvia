        .t-track-wrapper { padding: 2rem 0 3rem 5%; scroll-padding-left: 5%; scroll-behavior: smooth; }
        .t-track { gap: 14px; }
        .t-card-pro {
            width: 80vw; flex-shrink: 0;
            padding: 2.5rem 2rem;
            transform: scale(0.92); opacity: 0.55;
            transform-origin: left center;
            transition: transform 0.5s var(--ease-spring), opacity 0.5s var(--ease-spring);
            min-height: auto;
            scroll-snap-align: start;
        }
        .t-card-pro.is-centered { transform: scale(1); opacity: 1; box-shadow: 0 20px 40px rgba(0,0,0,0.1); z-index: 2; }
        .t-quote-watermark { font-size: 8rem; top: -15px; left: 15px; }
        .t-metric { font-size: 1.15rem; margin-bottom: 1rem; }
        .t-text { font-size: 1.15rem; margin-bottom: 1.5rem; }
