<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';
    gsap.registerPlugin(ScrollTrigger, SplitText);

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLElement>('.hero-title, .hero-text-zone .eyebrow, .hero-bottom').forEach(el => {
        el.style.animation = 'none';
        el.style.opacity = '1';
        el.style.filter = 'none';
        el.style.transform = 'none';
    });

    if (!reduced) {
        const mm = gsap.matchMedia();

        mm.add('(min-width: 769px)', () => {
            const heroTitle = document.querySelector<HTMLElement>('.hero-title');
            const heroEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const heroBottom = document.querySelector<HTMLElement>('.hero-bottom');

            const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (heroEyebrow) {
                tl.from(heroEyebrow, { opacity: 0, y: 14, letterSpacing: '7px', duration: 1.4 }, 0.1);
            }
            if (heroTitle) {
                const split = SplitText.create(heroTitle, { type: 'lines,words', linesClass: 'lx-line-mask' });
                gsap.set(split.words, { yPercent: 105 });
                tl.to(split.words, {
                    yPercent: 0, duration: 1.5,
                    stagger: { amount: 0.5, from: 'start' },
                }, 0.35);
            }
            if (heroBottom && heroBottom.children.length > 0) {
                tl.from(gsap.utils.toArray<HTMLElement>(heroBottom.children), {
                    opacity: 0, y: 16, duration: 1.1, ease: 'power3.out',
                    stagger: 0.12,
                }, 1.0);
            }

            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 28, opacity: 0.15, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 0.8 },
                });
            }
        });

        mm.add('(max-width: 768px)', () => {
            const mHeroTitle = document.querySelector<HTMLElement>('.hero-title');
            const mEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const mHeroBottom = document.querySelector<HTMLElement>('.hero-bottom');
            const tlm = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (mEyebrow) tlm.from(mEyebrow, { opacity: 0, y: 10, letterSpacing: '6px', duration: 1.1 }, 0.1);
            if (mHeroTitle) tlm.from(mHeroTitle, { opacity: 0, y: 24, duration: 1.2 }, 0.3);
            if (mHeroBottom && mHeroBottom.children.length > 0) {
                tlm.from(gsap.utils.toArray<HTMLElement>(mHeroBottom.children), {
                    opacity: 0, y: 14, duration: 1.0, ease: 'power3.out',
                    stagger: 0.1,
                }, 0.85);
            }
        });
    }
</script>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {

        // 1. REVEALS GLOBALES
        if (typeof IntersectionObserver !== 'undefined') {
            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.reveal-blur, .reveal-fade, .reveal-up, .reveal-clip').forEach(el => {
                if (!el.closest('.hero-grand')) observer.observe(el);
            });
        }

        // 2. PARALLAX (imagen manifesto — hero ya lo maneja GSAP)
        window.addEventListener('scroll', () => {
            if (window.innerWidth > 1024) {
                const scrollY = window.scrollY;

                const imgParallax = document.getElementById('manifesto-img');
                if (imgParallax && imgParallax.parentElement) {
                    const rect = imgParallax.parentElement.getBoundingClientRect();
                    if(rect.top < window.innerHeight && rect.bottom > 0) {
                        const yPos = (rect.top - window.innerHeight/2) * -0.05;
                        imgParallax.style.transform = `translateY(${yPos}px)`;
                    }
                }
            }
        });

        // 3. CONTADORES DE MÉTRICAS
        if (typeof IntersectionObserver !== 'undefined') {
            const counters = document.querySelectorAll('.counter');
            const speed = 100; 

            const counterObserver = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const target = entry.target;
                        const endValAttr = target.getAttribute('data-target');
                        if(!endValAttr) return;

                        const endValue = Number(endValAttr);
                        
                        const updateCount = () => {
                            const current = Number(target.innerHTML);
                            const inc = endValue / speed;

                            if (current < endValue) {
                                target.innerHTML = Math.ceil(current + inc).toString();
                                setTimeout(updateCount, 15);
                            } else {
                                target.innerHTML = endValue.toString();
                            }
                        };
                        updateCount();
                        counterObserver.unobserve(target);
                    }
                });
            }, { threshold: 0.5 });

            counters.forEach(counter => counterObserver.observe(counter));
        }

        // 4. CARRUSEL MÓVIL
        const initCarouselPhysics = () => {
            if (typeof IntersectionObserver === 'undefined') return;
            const track = document.querySelector('.t-track-wrapper');
            const cards = document.querySelectorAll('.t-card-pro');
            
            if(!track || cards.length === 0) return;

            const carouselObserver = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        cards.forEach(c => c.classList.remove('is-centered'));
                        entry.target.classList.add('is-centered');
                    }
                });
            }, { 
                root: track, 
                threshold: 0.5 
            });

            cards.forEach(card => carouselObserver.observe(card));
            
            setTimeout(() => {
                if(cards[0]) cards[0].classList.add('is-centered');
            }, 100);
        };

        if (window.innerWidth <= 1024) {
            initCarouselPhysics();
        }
    });
</script>