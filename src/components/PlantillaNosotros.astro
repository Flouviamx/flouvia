    /* ==========================================================
       MEDIA QUERIES
       ========================================================== */
    @media (max-width: 1024px) {
        .hero-bottom { flex-direction: column; align-items: flex-start; gap: 2rem; }
        .desktop-only { display: none; }
        .manifesto-grid { grid-template-columns: 1fr; gap: 4rem; }
        .m-visual-side { order: -1; }
        .image-frame-luxe { aspect-ratio: 16/9; }
        .sticky-text-wrapper { position: relative; top: 0; }
        .monolith-grid { grid-template-columns: 1fr; gap: 2rem; }
        .thin-grid { grid-template-columns: repeat(2, 1fr); gap: 3rem; }
        .adv-banner-flex { flex-direction: column; align-items: flex-start; gap: 2rem; }
