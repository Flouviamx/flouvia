</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Recalcula posiciones tras fuentes + carga para que los ScrollTrigger
    // disparen en el punto correcto desde el inicio.
    const robustRefresh = () => {
        const winLoad = new Promise<void>((resolve) => {
            if (document.readyState === 'complete') resolve();
            else window.addEventListener('load', () => resolve(), { once: true });
        });
        const fontsReady = (document as any).fonts?.ready ?? Promise.resolve();
        Promise.all([winLoad, fontsReady]).then(() => {
            setTimeout(() => ScrollTrigger.refresh(), 120);
        });
    };
    robustRefresh();

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Sin animación: dejar todo visible y salir.
        if (reduced) {
            gsap.set('.reveal-fade, .reveal-up', { opacity: 1, y: 0 });
            initCarousel();
            return;
        }

        /* ─── HERO — entrada en carga (gate .js-anim ya los tiene en opacity:0) ─── */
        const heroAnim = gsap.utils.toArray<HTMLElement>('.hero-anim');
        if (heroAnim.length) {
            gsap.set(heroAnim, { opacity: 0, y: 12 });
            gsap.timeline({ defaults: { ease: 'power2.out' } })
                .to('.hero-status',             { opacity: 1, y: 0, duration: 0.9 }, 0)
                .to('.hero-text-zone .eyebrow', { opacity: 1, y: 0, duration: 0.9 }, 0.1)
                .to('.hero-title',              { opacity: 1, y: 0, duration: 1.1 }, 0.2)
                .to('.hero-bottom',             { opacity: 1, y: 0, duration: 1.0 }, 0.42);
        }

        // ── Estándar único de reveal: fade + leve subida, power2.out ──
        const EASE = 'power2.out';
        const DUR  = 0.9;

        const reveal = (
            targets: string | HTMLElement | NodeListOf<Element> | HTMLElement[],
            opts: { trigger?: string | HTMLElement; start?: string; y?: number; dur?: number; stagger?: number } = {}
        ) => {
            const els = gsap.utils.toArray<HTMLElement>(targets as any);
            if (!els.length) return;
            gsap.set(els, { opacity: 0, y: opts.y ?? 14 });
            ScrollTrigger.create({
                trigger: opts.trigger ?? els[0],
                start: opts.start ?? 'top 85%',
                once: true,
                onEnter: () => gsap.to(els, {
                    opacity: 1, y: 0, duration: opts.dur ?? DUR, ease: EASE,
                    stagger: opts.stagger ?? 0.08,
                    clearProps: 'transform,opacity',
                }),
            });
        };

        const revealEach = (selector: string, opts: { start?: string; y?: number; dur?: number } = {}) => {
            gsap.utils.toArray<HTMLElement>(selector).forEach(el => {
                reveal(el, { trigger: el, start: opts.start, y: opts.y, dur: opts.dur, stagger: 0 });
            });
        };

        const mm = gsap.matchMedia();

        /* ─── DESKTOP ─── */
        mm.add('(min-width: 769px)', () => {
            // Parallax muy leve del hero
            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 4, opacity: 0.85, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 1 },
                });
            }

            // Encabezados + eyebrows + textos
            revealEach('section:not(.hero-grand) .section-heading', { y: 16, dur: 1.0, start: 'top 86%' });
            revealEach('section:not(.hero-grand) .eyebrow',         { y: 10, dur: 0.9, start: 'top 90%' });
            revealEach('.entity-text',  { y: 16, dur: 1.0 });
            revealEach('.m-lead-text',  { y: 14 });
            revealEach('.m-body-text',  { y: 14 });
            revealEach('.m-visual-side',{ y: 18, dur: 1.0 });

            // Tarjetas con stagger por grupo
            reveal('.monolith-card', { trigger: '.monolith-grid', y: 18, stagger: 0.1 });
            reveal('.thin-card',     { trigger: '.thin-grid',     y: 16, stagger: 0.08 });

            reveal('.adv-banner-flex', { y: 18, dur: 1.0 });
            reveal('.t-track-wrapper', { trigger: '.testimonials-slider-pro', y: 18, dur: 1.0, start: 'top 80%' });
            reveal('.cta-box-refined', { y: 20, dur: 1.0, start: 'top 88%' });
        });

        /* ─── MÓVIL ─── */
        mm.add('(max-width: 768px)', () => {
            revealEach('section:not(.hero-grand) .section-heading', { y: 14, dur: 0.9 });
            revealEach('section:not(.hero-grand) .eyebrow',         { y: 10, dur: 0.8 });
            revealEach('.entity-text', { y: 14 });
            revealEach('.m-lead-text', { y: 12 });
            revealEach('.m-body-text', { y: 12 });
            revealEach('.m-visual-side', { y: 16 });
            revealEach('.monolith-card', { y: 14 });
            revealEach('.thin-card', { y: 12 });
            reveal('.adv-banner-flex', { y: 14 });
            reveal('.t-track-wrapper', { trigger: '.testimonials-slider-pro', y: 14, start: 'top 85%' });
            reveal('.cta-box-refined', { y: 16 });
            initCarousel();
        });
    });

    // ── Carrusel móvil: marca la tarjeta centrada (escala/opacidad) ──
    function initCarousel() {
        if (typeof IntersectionObserver === 'undefined') return;
        if (window.innerWidth > 1024) return;
        const track = document.querySelector('.t-track-wrapper');
        const cards = document.querySelectorAll('.t-card-pro');
        if (!track || cards.length === 0) return;

        const obs = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    cards.forEach(c => c.classList.remove('is-centered'));
                    entry.target.classList.add('is-centered');
                }
            });
        }, { root: track, threshold: 0.6 });

        cards.forEach(card => obs.observe(card));
        setTimeout(() => { if (cards[0]) cards[0].classList.add('is-centered'); }, 100);
    }

    // Parallax suave de la imagen del manifiesto (solo desktop)
    document.addEventListener('DOMContentLoaded', () => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const img = document.getElementById('manifesto-img');
        if (!img) return;
        window.addEventListener('scroll', () => {
            if (window.innerWidth <= 1024 || !img.parentElement) return;
            const rect = img.parentElement.getBoundingClientRect();
            if (rect.top < window.innerHeight && rect.bottom > 0) {
                const yPos = (rect.top - window.innerHeight / 2) * -0.05;
                img.style.transform = `translateY(${yPos}px)`;
            }
        }, { passive: true });
    });
</script>
