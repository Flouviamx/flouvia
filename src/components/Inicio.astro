<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Recalcular posiciones después de que carguen fuentes + imágenes, para que
    // los ScrollTrigger disparen en el punto correcto desde el inicio.
    const robustRefresh = () => {
        const winLoad = new Promise<void>((resolve) => {
            if (document.readyState === 'complete') resolve();
            else window.addEventListener('load', () => resolve(), { once: true });
        });
        const fontsReady = (document as any).fonts?.ready ?? Promise.resolve();
        Promise.all([winLoad, fontsReady]).then(() => {
            setTimeout(() => ScrollTrigger.refresh(), 120);
        });
    };
    robustRefresh();

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Con reduced-motion la clase .js-anim nunca se añade (script inline del
        // Layout), así que todo queda visible vía CSS. No animamos nada.
        if (reduced) return;

        /* ═══════ HERO — entrada en carga (compartida desktop/móvil) ═══════
           El CSS (.js-anim .hero-anim) ya los tiene en opacity:0 desde antes del
           primer paint, así que animamos con .to() — sin doble salto, sin flash. */
        const heroAnim = gsap.utils.toArray<HTMLElement>('.hero-anim');
        if (heroAnim.length) {
            gsap.set(heroAnim, { opacity: 0, y: 12 });
            gsap.timeline({ defaults: { ease: 'power2.out' } })
                .to('.hero-status',             { opacity: 1, y: 0, duration: 0.9 }, 0)
                .to('.hero-text-zone .eyebrow', { opacity: 1, y: 0, duration: 0.9 }, 0.1)
                .to('.hero-title',              { opacity: 1, y: 0, duration: 1.1 }, 0.2)
                .to('.hero-bottom',             { opacity: 1, y: 0, duration: 1.0 }, 0.42);
        }

        // ── Estándar único de animación de entrada ──────────────────
        // Mismo lenguaje en todo el sitio: fade + leve subida, suave, sutil.
        const EASE = 'power2.out';
        const DUR  = 0.9;
        const Y    = 14;

        /* Reveal robusto (sin parpadeo): el elemento se OCULTA de entrada con
           gsap.set y solo se revela UNA vez cuando su trigger entra al viewport.
           Antes usábamos gsap.from + immediateRender:false, que dejaba el elemento
           visible hasta el primer scroll y entonces lo "saltaba" a opacity:0 para
           re-animarlo → se veía recargar. Con set+onEnter eso ya no pasa.
           Failsafe anti "invisible para siempre": robustRefresh() recalcula
           posiciones tras fuentes+carga, así que todo trigger ya pasado dispara su
           onEnter; y si no hay JS/hay reduced-motion, el CSS deja todo visible. */
        const reveal = (
            targets: string | HTMLElement | NodeListOf<Element> | HTMLElement[],
            opts: { trigger?: string | HTMLElement; start?: string; y?: number; dur?: number; stagger?: number; delay?: number } = {}
        ) => {
            const els = gsap.utils.toArray<HTMLElement>(targets as any);
            if (!els.length) return;
            const y = opts.y ?? Y;
            gsap.set(els, { opacity: 0, y });
            ScrollTrigger.create({
                trigger: opts.trigger ?? els[0],
                start: opts.start ?? 'top 85%',
                once: true,
                onEnter: () => gsap.to(els, {
                    opacity: 1, y: 0, duration: opts.dur ?? DUR, ease: EASE,
                    stagger: opts.stagger ?? 0.08, delay: opts.delay ?? 0,
                    clearProps: 'transform,opacity',
                }),
            });
        };

        // Reveal por-elemento (cada uno con su propio trigger/posición)
        const revealEach = (
            selector: string,
            opts: { start?: string; y?: number; dur?: number } = {}
        ) => {
            gsap.utils.toArray<HTMLElement>(selector).forEach(el => {
                reveal(el, { trigger: el, start: opts.start, y: opts.y, dur: opts.dur, stagger: 0 });
            });
        };

        const mm = gsap.matchMedia();

        /* ─── DESKTOP ──────────────────────────────────────────────── */
        mm.add('(min-width: 769px)', () => {

            /* Parallax muy leve del hero al hacer scroll */
            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 4, opacity: 0.85, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 1 },
                });
            }

            /* Encabezados + eyebrows */
            revealEach('section:not(.hero-grand) .section-heading', { y: 16, dur: 1.0, start: 'top 86%' });
            revealEach('section:not(.hero-grand) .eyebrow',         { y: 10, dur: 0.9, start: 'top 90%' });

            /* TECH — subtítulo + tira de logos */
            reveal('.tech-spotlight .section-sub', { trigger: '.tech-spotlight', y: 12, dur: 0.9, start: 'top 82%' });
            reveal('.strip-logo', { trigger: '#logo-strip', y: 12, dur: 0.9, stagger: 0.06, start: 'top 85%' });
            reveal('.stack-meta', { trigger: '#logo-strip', y: 10, dur: 0.9, delay: 0.2, start: 'top 85%' });

            /* CASOS — tarjetas (el Ken Burns/elevación es hover en CSS) */
            reveal('.clients-vertical-carousel .vertical-card', {
                trigger: '.clients-vertical-carousel', y: 24, dur: 1.0, stagger: 0.1, start: 'top 78%',
            });

            /* SERVICIOS — filas (reveal sobrio por fila) */
            gsap.utils.toArray<HTMLElement>('.service-row').forEach((row) => {
                reveal(row.querySelectorAll('.row-num, .row-content h3, .row-content p, .arrow-circle'), {
                    trigger: row, y: 14, dur: 0.9, stagger: 0.06, start: 'top 86%',
                });
            });

            /* PROTOCOLO — columna sticky + indicador de progreso */
            reveal('.protocol-sticky-col > *:not(.proto-progress)', {
                trigger: '.protocol-section', y: 16, dur: 1.0, stagger: 0.09, start: 'top 80%',
            });
            reveal('.proto-progress', { trigger: '.protocol-section', y: 14, dur: 1.0, delay: 0.3, start: 'top 78%' });

            /* PROTOCOLO — el track se dibuja con el scroll */
            const timelineTrack = document.querySelector('.timeline-track');
            if (timelineTrack) {
                gsap.set(timelineTrack, { transformOrigin: 'top center', scaleY: 0 });
                gsap.to(timelineTrack, {
                    scaleY: 1, ease: 'none',
                    scrollTrigger: { trigger: '.protocol-section', start: 'top 60%', end: 'bottom 75%', scrub: 0.6 },
                });
            }

            /* PROTOCOLO — barra de progreso se llena con el scroll */
            const progressFill = document.querySelector<HTMLElement>('.proto-progress-fill');
            if (progressFill) {
                gsap.to(progressFill, {
                    scaleX: 1, ease: 'none',
                    scrollTrigger: { trigger: '.protocol-section', start: 'top 50%', end: 'bottom 70%', scrub: 0.4 },
                });
            }

            /* PROTOCOLO — paso activo + contador */
            const protoSteps = gsap.utils.toArray<HTMLElement>('.protocol-step');
            const protoCurrent = document.querySelector<HTMLElement>('.proto-current');
            protoSteps.forEach((step, idx) => {
                ScrollTrigger.create({
                    trigger: step, start: 'top 55%', end: 'bottom 45%',
                    onEnter:     () => { step.classList.add('is-active');    setProtoCount(idx); },
                    onEnterBack: () => { step.classList.add('is-active');    setProtoCount(idx); },
                    onLeave:     () => { step.classList.remove('is-active'); },
                    onLeaveBack: () => { step.classList.remove('is-active'); },
                });
            });
            function setProtoCount(idx: number) {
                if (!protoCurrent) return;
                const next = String(idx + 1).padStart(2, '0');
                if (protoCurrent.textContent === next) return;
                gsap.fromTo(protoCurrent,
                    { y: -8, opacity: 0 },
                    { y: 0, opacity: 1, duration: 0.45, ease: EASE,
                      onStart: () => { protoCurrent.textContent = next; } });
            }

            /* PROTOCOLO — pasos (reveal por paso) */
            protoSteps.forEach((step) => {
                reveal(step.querySelectorAll('.watermark-num, h4, p'), {
                    trigger: step, y: 14, dur: 0.9, stagger: 0.07, start: 'top 86%',
                });
            });

            /* CTA — entrada sutil + glow que sigue el cursor */
            const ctaCard = document.getElementById('cta-card') as HTMLElement | null;
            if (ctaCard) {
                reveal(ctaCard, { trigger: ctaCard, y: 24, dur: 1.0, stagger: 0, start: 'top 82%' });
                reveal(ctaCard.querySelectorAll('.cta-text-side > *, .cta-action-side'), {
                    trigger: ctaCard, y: 12, dur: 0.9, stagger: 0.08, delay: 0.15, start: 'top 82%',
                });

                ctaCard.addEventListener('mousemove', e => {
                    const r = ctaCard.getBoundingClientRect();
                    ctaCard.style.setProperty('--cta-mx', `${((e.clientX - r.left) / r.width) * 100}%`);
                    ctaCard.style.setProperty('--cta-my', `${((e.clientY - r.top) / r.height) * 100}%`);
                });
            }
        });

        /* ─── MOBILE ───────────────────────────────────────────────── */
        mm.add('(max-width: 768px)', () => {

            /* (El hero se anima en el bloque compartido de arriba) */

            /* Encabezados + eyebrows */
            revealEach('section:not(.hero-grand) .section-heading', { y: 16, dur: 1.0, start: 'top 88%' });
            revealEach('section:not(.hero-grand) .eyebrow',         { y: 10, dur: 0.9, start: 'top 92%' });

            /* TECH */
            reveal('.tech-spotlight .section-sub', { trigger: '.tech-spotlight', y: 12, dur: 0.9, start: 'top 86%' });
            reveal('.strip-logo', { trigger: '#logo-strip', y: 10, dur: 0.8, stagger: 0.05, start: 'top 88%' });
            reveal('.stack-meta', { trigger: '#logo-strip', y: 10, dur: 0.85, delay: 0.18, start: 'top 88%' });

            /* CASOS — tarjetas */
            reveal('.clients-vertical-carousel .vertical-card', {
                trigger: '.clients-vertical-carousel', y: 22, dur: 0.95, stagger: 0.08, start: 'top 82%',
            });

            /* SERVICIOS — filas */
            gsap.utils.toArray<HTMLElement>('.service-row').forEach((row) => {
                reveal(row.querySelectorAll('.row-num, .row-content h3, .row-content p, .arrow-circle'), {
                    trigger: row, y: 14, dur: 0.85, stagger: 0.05, start: 'top 90%',
                });
            });

            /* PROTOCOLO — columna sticky + progreso */
            reveal('.protocol-sticky-col > *:not(.proto-progress)', {
                trigger: '.protocol-section', y: 16, dur: 0.95, stagger: 0.1, start: 'top 84%',
            });
            reveal('.proto-progress', { trigger: '.protocol-section', y: 14, dur: 0.9, delay: 0.3, start: 'top 84%' });

            const mTrack = document.querySelector('.timeline-track');
            if (mTrack) {
                gsap.set(mTrack, { transformOrigin: 'top center', scaleY: 0 });
                gsap.to(mTrack, {
                    scaleY: 1, ease: 'none',
                    scrollTrigger: { trigger: '.protocol-section', start: 'top 70%', end: 'bottom 85%', scrub: 0.8 },
                });
            }
            const mProgressFill = document.querySelector<HTMLElement>('.proto-progress-fill');
            if (mProgressFill) {
                gsap.to(mProgressFill, {
                    scaleX: 1, ease: 'none',
                    scrollTrigger: { trigger: '.protocol-section', start: 'top 60%', end: 'bottom 75%', scrub: 0.4 },
                });
            }

            const mProtoSteps = gsap.utils.toArray<HTMLElement>('.protocol-step');
            const mProtoCurrent = document.querySelector<HTMLElement>('.proto-current');
            mProtoSteps.forEach((step, idx) => {
                ScrollTrigger.create({
                    trigger: step, start: 'top 60%', end: 'bottom 50%',
                    onEnter:     () => { step.classList.add('is-active');    setMProtoCount(idx); },
                    onEnterBack: () => { step.classList.add('is-active');    setMProtoCount(idx); },
                    onLeave:     () => { step.classList.remove('is-active'); },
                    onLeaveBack: () => { step.classList.remove('is-active'); },
                });
            });
            function setMProtoCount(idx: number) {
                if (!mProtoCurrent) return;
                const next = String(idx + 1).padStart(2, '0');
                if (mProtoCurrent.textContent === next) return;
                gsap.fromTo(mProtoCurrent,
                    { y: -6, opacity: 0 },
                    { y: 0, opacity: 1, duration: 0.4, ease: EASE,
                      onStart: () => { mProtoCurrent.textContent = next; } });
            }

            mProtoSteps.forEach((step) => {
                reveal(step.querySelectorAll('.watermark-num, h4, p'), {
                    trigger: step, y: 14, dur: 0.85, stagger: 0.06, start: 'top 90%',
                });
            });

            /* CTA */
            const mCtaCard = document.getElementById('cta-card') as HTMLElement | null;
            if (mCtaCard) {
                reveal(mCtaCard, { trigger: mCtaCard, y: 22, dur: 0.95, stagger: 0, start: 'top 86%' });
                reveal(mCtaCard.querySelectorAll('.cta-text-side > *, .cta-action-side'), {
                    trigger: mCtaCard, y: 12, dur: 0.85, stagger: 0.08, delay: 0.12, start: 'top 86%',
                });
            }

            /* CARRUSEL — detección de tarjeta centrada (clase is-centered) */
            const track = document.querySelector('.carousel-track-wrapper');
            const cards = document.querySelectorAll('.vertical-card');
            if (track && cards.length) {
                const observer = new IntersectionObserver(entries => {
                    let best: IntersectionObserverEntry | null = null;
                    for (const entry of entries) {
                        if (!best || entry.intersectionRatio > best.intersectionRatio) best = entry;
                    }
                    if (best && best.intersectionRatio > 0) {
                        cards.forEach(c => c.classList.remove('is-centered'));
                        best.target.classList.add('is-centered');
                    }
                }, { root: track, threshold: [0, 0.25, 0.5, 0.75, 1] });
                cards.forEach(card => observer.observe(card));
                setTimeout(() => { cards[0]?.classList.add('is-centered'); }, 100);
            }
        });
    });
</script>
