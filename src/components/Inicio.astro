        .row-content p { font-size: 1rem; }
        .row-action { display: flex; align-items: flex-start; padding-top: 2px;}
        .arrow-circle { width: 40px; height: 40px; border-color: rgba(0,0,0,0.1);}
        .arrow-circle svg { width: 16px; height: 16px; }
        .service-row:active { transform: scale(0.98); transition: 0.1s;}
        .service-row:active .animated-border { width: 100%; transition: 0.2s; }
        .service-row:active .arrow-circle { background: #000; color: #fff; border-color: #000; transform: rotate(-45deg); }

