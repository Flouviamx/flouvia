</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';

    gsap.registerPlugin(ScrollTrigger, SplitText);

    // Recalculate positions after fonts + images load
    window.addEventListener('load', () => {
        setTimeout(() => ScrollTrigger.refresh(), 120);
    });

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Hero animates on page load (not scroll) — must start visible
        document.querySelectorAll<HTMLElement>('.hero-title, .hero-text-zone .eyebrow, .hero-bottom').forEach(el => {
            el.style.animation = 'none';
            el.style.opacity   = '1';
            el.style.transform = 'none';
            el.style.filter    = 'none';
        });

        if (reduced) return;

        // Key: immediateRender: false — elements stay visible until ScrollTrigger fires.
        // This prevents the "stuck invisible" bug entirely.
        const ir = { immediateRender: false } as const;

        const mm = gsap.matchMedia();

        /* ─── DESKTOP ──────────────────────────────────────────────── */
        mm.add('(min-width: 769px)', () => {

            /* HERO */
            requestAnimationFrame(() => {

            const heroTitle = document.querySelector<HTMLElement>('.hero-title');
            const heroEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const heroBottom = document.querySelector<HTMLElement>('.hero-bottom');

            const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (heroEyebrow) {
                tl.from(heroEyebrow, { opacity: 0, y: 14, letterSpacing: '7px', duration: 1.4 }, 0.1);
            }
            if (heroTitle) {
                const split = SplitText.create(heroTitle, { type: 'lines,words', linesClass: 'lx-line-mask' });
                gsap.set(split.words, { yPercent: 105 });
                tl.to(split.words, {
                    yPercent: 0, duration: 1.5,
                    stagger: { amount: 0.5, from: 'start' },
                }, 0.35);
            }
            if (heroBottom && heroBottom.children.length > 0) {
                tl.from(gsap.utils.toArray<HTMLElement>(heroBottom.children), {
                    opacity: 0, y: 16, duration: 1.1, ease: 'power3.out',
                    stagger: 0.12,
                }, 1.0);
            }

            }); // end requestAnimationFrame

            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 28, opacity: 0.15,
                    ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 0.8 },
                });
            }

            /* ═══════ SECTION HEADINGS — line-mask word reveal (Apple-style) ═══════ */
            gsap.utils.toArray<HTMLElement>('.section-heading').forEach(h => {
                const split = SplitText.create(h, { type: 'lines,words', linesClass: 'lx-line-mask' });
                gsap.set(split.words, { yPercent: 115 });
                gsap.to(split.words, {
                    ...ir, yPercent: 0, duration: 1.4, ease: 'expo.out',
                    stagger: { amount: 0.45, from: 'start' },
                    scrollTrigger: { trigger: h, start: 'top 85%', once: true },
                });
            });

            /* ═══════ EYEBROWS — letter-spacing close + fade ═══════ */
            gsap.utils.toArray<HTMLElement>('section:not(.hero-grand) .eyebrow').forEach(eb => {
                gsap.from(eb, {
                    ...ir, opacity: 0, y: 12, letterSpacing: '8px', duration: 1.3, ease: 'expo.out',
                    scrollTrigger: { trigger: eb, start: 'top 88%', once: true },
                });
            });

            /* ═══════════════════════════════════════════════════
                              TECH SECTION
               ═══════════════════════════════════════════════════ */

            /* Header rule draw */
            const techRule = document.getElementById('tech-rule');
            if (techRule) {
                gsap.to(techRule, {
                    scaleX: 1, duration: 1.6, ease: 'power3.inOut',
                    scrollTrigger: { trigger: '.tech-spotlight', start: 'top 78%', once: true },
                });
            }

            /* Counter count-up */
            const techCounter = document.getElementById('tech-counter');
            if (techCounter) {
                ScrollTrigger.create({
                    trigger: '.tech-spotlight', start: 'top 78%', once: true,
                    onEnter: () => {
                        const obj = { val: 0 };
                        gsap.to(obj, {
                            val: 8, duration: 1.8, ease: 'power3.out', delay: 0.3,
                            onUpdate: () => { techCounter.textContent = String(Math.round(obj.val)).padStart(2, '0'); },
                        });
                    },
                });
            }

            /* Sub-text fade */
            gsap.from('.tech-spotlight .section-sub', {
                ...ir, opacity: 0, y: 16, duration: 1.1, ease: 'expo.out',
                scrollTrigger: { trigger: '.tech-spotlight', start: 'top 80%', once: true },
            });

            /* Cards: clip-path reveal from bottom + subtle blur lift */
            gsap.set('.tech-spotlight .tech-card', { clipPath: 'inset(0 0 100% 0)' });
            gsap.utils.toArray<HTMLElement>('.tech-spotlight .tech-card').forEach((card, i) => {
                const logo = card.querySelector<HTMLElement>('.tc-logo');
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: '.spotlight-grid', start: 'top 80%', once: true },
                    delay: i * 0.07,
                });
                tl.to(card, {
                    ...ir, clipPath: 'inset(0 0 0% 0)', duration: 1.3, ease: 'expo.out',
                    onComplete: () => { (card as HTMLElement).style.clipPath = 'none'; },
                });
                if (logo) {
                    gsap.set(logo, { y: 14, opacity: 0 });
                    tl.to(logo, {
                        ...ir, y: 0, opacity: 0.55, duration: 1.0, ease: 'expo.out',
                    }, '-=0.9');
                }
            });

            /* Watermark slow parallax */
            gsap.to('.tech-watermark', {
                yPercent: -18, ease: 'none',
                scrollTrigger: { trigger: '.tech-spotlight', start: 'top bottom', end: 'bottom top', scrub: 0.8 },
            });

            /* Grid glow follows cursor */
            const techGrid = document.getElementById('tech-grid');
            if (techGrid) {
                techGrid.addEventListener('mousemove', e => {
                    const r = techGrid.getBoundingClientRect();
                    techGrid.style.setProperty('--grid-mx', `${((e.clientX - r.left) / r.width) * 100}%`);
                    techGrid.style.setProperty('--grid-my', `${((e.clientY - r.top) / r.height) * 100}%`);
                });
            }

            /* Per-card radial glow */
            document.querySelectorAll<HTMLElement>('.tech-card').forEach(card => {
                card.addEventListener('mousemove', e => {
                    const rect = card.getBoundingClientRect();
                    card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
                    card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
                });
            });

            /* ═══════════════════════════════════════════════════
                              CASOS SECTION
               ═══════════════════════════════════════════════════ */

            /* Background text parallax */
            gsap.to('.casos-bg-text', {
                yPercent: -22, ease: 'none',
                scrollTrigger: { trigger: '.clients-vertical-carousel', start: 'top bottom', end: 'bottom top', scrub: 0.9 },
            });

            /* Cards: orchestrated reveal — clip wipe + Ken Burns image + overlay slide */
            gsap.utils.toArray<HTMLElement>('.clients-vertical-carousel .vertical-card').forEach((card, i) => {
                const img     = card.querySelector<HTMLElement>('.carousel-image');
                const overlay = card.querySelector<HTMLElement>('.card-overlay');
                const num     = card.querySelector<HTMLElement>('.card-num-luxury');
                const ctaInner = card.querySelector<HTMLElement>('.cta-inner');

                gsap.set(card, { clipPath: 'inset(0 0 100% 0)' });
                if (img)      gsap.set(img,     { scale: 1.25 });
                if (overlay)  gsap.set(overlay, { yPercent: 60, opacity: 0 });
                if (num)      gsap.set(num,     { opacity: 0, x: -8 });
                if (ctaInner) gsap.set(ctaInner.children, { opacity: 0, y: 18 });

                const tl = gsap.timeline({
                    scrollTrigger: { trigger: '.clients-vertical-carousel', start: 'top 72%', once: true },
                    delay: 0.15 + i * 0.13,
                });

                tl.to(card,    { ...ir, clipPath: 'inset(0 0 0% 0)', duration: 1.4, ease: 'expo.out',
                    onComplete: () => { (card as HTMLElement).style.clipPath = 'none'; } });
                if (img)      tl.to(img,     { ...ir, scale: 1, duration: 1.8, ease: 'expo.out' }, 0);
                if (overlay)  tl.to(overlay, { ...ir, yPercent: 0, opacity: 1, duration: 1.1, ease: 'expo.out' }, 0.45);
                if (num)      tl.to(num,     { ...ir, opacity: 0.6, x: 0, duration: 0.9, ease: 'expo.out' }, 0.55);
                if (ctaInner) tl.to(ctaInner.children, {
                    ...ir, opacity: 1, y: 0, duration: 1.0, ease: 'expo.out', stagger: 0.1,
                }, 0.4);
            });

            /* Image Ken Burns parallax inside cards while scrolling section */
            gsap.utils.toArray<HTMLElement>('.clients-vertical-carousel .carousel-image').forEach(img => {
                gsap.to(img, {
                    yPercent: -8, ease: 'none',
                    scrollTrigger: {
                        trigger: '.clients-vertical-carousel',
                        start: 'top bottom', end: 'bottom top', scrub: 1.2,
                    },
                });
            });

            /* ═══════════════════════════════════════════════════
                            SERVICES SECTION
               ═══════════════════════════════════════════════════ */

            gsap.utils.toArray<HTMLElement>('.service-row').forEach((row, i) => {
                const num   = row.querySelector<HTMLElement>('.row-num');
                const h3    = row.querySelector<HTMLElement>('.row-content h3');
                const p     = row.querySelector<HTMLElement>('.row-content p');
                const arrow = row.querySelector<HTMLElement>('.arrow-circle');

                if (num)   gsap.set(num,   { opacity: 0, x: -16 });
                if (h3)    gsap.set(h3,    { opacity: 0, y: 28 });
                if (p)     gsap.set(p,     { opacity: 0, y: 18 });
                if (arrow) gsap.set(arrow, { opacity: 0, scale: 0.4, rotate: -45 });

                const tl = gsap.timeline({
                    scrollTrigger: { trigger: row, start: 'top 86%', once: true },
                    delay: i * 0.04,
                });

                if (num)   tl.to(num,   { ...ir, opacity: 1, x: 0, duration: 0.95, ease: 'expo.out' }, 0);
                if (h3)    tl.to(h3,    { ...ir, opacity: 1, y: 0, duration: 1.15, ease: 'expo.out' }, 0.08);
                if (p)     tl.to(p,     { ...ir, opacity: 1, y: 0, duration: 1.05, ease: 'expo.out' }, 0.18);
                if (arrow) tl.to(arrow, { ...ir, opacity: 1, scale: 1, rotate: 0, duration: 0.85, ease: 'back.out(2)' }, 0.28);
            });

            /* ═══════════════════════════════════════════════════
                           PROTOCOL SECTION
               ═══════════════════════════════════════════════════ */

            /* Sticky col children stagger */
            gsap.from('.protocol-sticky-col > *', {
                ...ir, y: 28, opacity: 0, duration: 1.1, ease: 'expo.out', stagger: 0.1,
                scrollTrigger: { trigger: '.protocol-section', start: 'top 78%', once: true },
            });

            /* Timeline track draws as user scrolls */
            const timelineTrack = document.querySelector('.timeline-track');
            if (timelineTrack) {
                gsap.set(timelineTrack, { transformOrigin: 'top center', scaleY: 0 });
                gsap.to(timelineTrack, {
                    scaleY: 1, ease: 'none',
                    scrollTrigger: {
                        trigger: '.protocol-section', start: 'top 60%', end: 'bottom 75%', scrub: 0.6,
                    },
                });
            }

            /* Steps: choreographed reveal — node bounce, watermark slide, h4 then p */
            gsap.utils.toArray<HTMLElement>('.protocol-step').forEach((step) => {
                const node = step.querySelector<HTMLElement>('.step-node');
                const wm   = step.querySelector<HTMLElement>('.watermark-num');
                const h4   = step.querySelector<HTMLElement>('h4');
                const p    = step.querySelector<HTMLElement>('p');

                if (node) gsap.set(node, { scale: 0 });
                if (wm)   gsap.set(wm,   { opacity: 0, x: -18 });
                if (h4)   gsap.set(h4,   { opacity: 0, y: 22 });
                if (p)    gsap.set(p,    { opacity: 0, y: 18 });

                const tl = gsap.timeline({
                    scrollTrigger: { trigger: step, start: 'top 86%', once: true },
                });

                if (node) tl.to(node, { ...ir, scale: 1, duration: 0.8, ease: 'back.out(2.6)' }, 0);
                if (wm)   tl.to(wm,   { ...ir, opacity: 1, x: 0, duration: 1.3, ease: 'expo.out' }, 0.08);
                if (h4)   tl.to(h4,   { ...ir, opacity: 1, y: 0, duration: 1.0, ease: 'expo.out' }, 0.18);
                if (p)    tl.to(p,    { ...ir, opacity: 1, y: 0, duration: 1.0, ease: 'expo.out' }, 0.28);
            });

            /* ═══════════════════════════════════════════════════
                                CTA SECTION
               ═══════════════════════════════════════════════════ */

            const ctaCard = document.getElementById('cta-card') as HTMLElement | null;
            if (ctaCard) {
                const ctaText = ctaCard.querySelectorAll<HTMLElement>('.cta-text-side > *');
                const ctaBtn  = ctaCard.querySelector<HTMLElement>('.cta-action-side');

                gsap.set(ctaText, { opacity: 0, y: 26 });
                if (ctaBtn) gsap.set(ctaBtn, { opacity: 0, y: 22 });

                const tl = gsap.timeline({
                    scrollTrigger: { trigger: ctaCard, start: 'top 82%', once: true },
                });

                tl.from(ctaCard, {
                    ...ir, y: 70, scale: 0.92, opacity: 0,
                    duration: 1.4, ease: 'expo.out',
                });
                tl.to(ctaText, {
                    ...ir, opacity: 1, y: 0, duration: 1.1, ease: 'expo.out', stagger: 0.12,
                }, '-=0.9');
                if (ctaBtn) tl.to(ctaBtn, {
                    ...ir, opacity: 1, y: 0, duration: 1.0, ease: 'expo.out',
                }, '-=0.7');

                ctaCard.addEventListener('mousemove', e => {
                    const r = ctaCard.getBoundingClientRect();
                    ctaCard.style.setProperty('--cta-mx', `${((e.clientX - r.left) / r.width) * 100}%`);
                    ctaCard.style.setProperty('--cta-my', `${((e.clientY - r.top) / r.height) * 100}%`);
                });
            }
        });

        /* ═════════════ MOBILE: lighter animations ═════════════ */
        mm.add('(max-width: 768px)', () => {
            /* MOBILE HERO — luxury minimalist (no blur) */
            const mHeroTitle = document.querySelector<HTMLElement>('.hero-title');
            const mEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const mHeroBottom = document.querySelector<HTMLElement>('.hero-bottom');
            const tlm = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (mEyebrow) tlm.from(mEyebrow, { opacity: 0, y: 10, letterSpacing: '6px', duration: 1.1 }, 0.1);
            if (mHeroTitle) tlm.from(mHeroTitle, { opacity: 0, y: 24, duration: 1.2 }, 0.3);
            if (mHeroBottom && mHeroBottom.children.length > 0) {
                tlm.from(gsap.utils.toArray<HTMLElement>(mHeroBottom.children), {
                    opacity: 0, y: 14, duration: 1.0, ease: 'power3.out',
                    stagger: 0.1,
                }, 0.85);
            }
            gsap.from('.tech-spotlight .tech-card', {
                ...ir, y: 30, opacity: 0, duration: 0.7, ease: 'power3.out', stagger: 0.05,
                scrollTrigger: { trigger: '.tech-spotlight', start: 'top 80%', once: true },
            });
            gsap.utils.toArray<HTMLElement>('.service-row').forEach((row) => {
                gsap.from(row, {
                    ...ir, y: 30, opacity: 0, duration: 0.7, ease: 'power3.out',
                    scrollTrigger: { trigger: row, start: 'top 88%', once: true },
                });
            });

            /* CAROUSEL CENTER DETECTION */
            const track = document.querySelector('.carousel-track-wrapper');
            const cards = document.querySelectorAll('.vertical-card');
            if (track && cards.length) {
                const observer = new IntersectionObserver(entries => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            cards.forEach(c => c.classList.remove('is-centered'));
                            entry.target.classList.add('is-centered');
                        }
                    });
                }, { root: track, threshold: 0.5 });
                cards.forEach(card => observer.observe(card));
                setTimeout(() => { cards[0]?.classList.add('is-centered'); }, 100);
            }
        });
    });
</script>