---
// src/components/PortalFooter.astro — Footer del portal de clientes.
// Coherente con el footer público (dark navy, watermark serif italic, eyebrow,
// numeración /0X serif, links con flecha-reveal) pero escalado a herramienta logueada.
// Logout: window.Clerk.signOut(cb) vía script (patrón documentado en CLAUDE.md),
// no <SignOutButton> — importar componentes Clerk aquí rompe el build.

const isEn = Astro.url.pathname.startsWith('/en');
const home = isEn ? '/en/' : '/';
---

<footer class="pf-root">
    <div class="pf-hairline"></div>
    <div class="pf-watermark" aria-hidden="true">Flouvia</div>

    <div class="pf-inner">

        <!-- META ROW: eyebrow + estado del sistema -->
        <div class="pf-meta">
            <p class="pf-eyebrow">FLOUVIA OS · {isEn ? 'CLIENT PORTAL' : 'PORTAL DE CLIENTES'}</p>
            <div class="pf-status">
                <span class="pf-led" aria-hidden="true"></span>
                <span class="pf-status-txt">{isEn ? 'SYSTEMS OPERATIONAL' : 'SISTEMAS OPERATIVOS'}</span>
            </div>
        </div>

        <!-- GRID: marca + columnas de navegación -->
        <div class="pf-grid">

            <div class="pf-brand-col">
                <img src="/imgs/logo-flouvia-1.svg" alt="Flouvia" class="pf-logo" />

                <h3 class="pf-statement">
                    {isEn ? 'Your operation, in one place.' : 'Tu operación, en un solo lugar.'}
                </h3>

                <a href="mailto:hola@flouvia.com" class="pf-email">
                    <span class="pf-email-txt">hola@flouvia.com</span>
                    <svg class="pf-email-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>

            <div class="pf-nav-cols">

                <div class="pf-col">
                    <div class="pf-col-head">
                        <span class="pf-col-num">/01</span>
                        <h4 class="pf-col-title">Portal</h4>
                    </div>
                    <nav class="pf-links">
                        <a href={isEn ? '/en/dashboard' : '/dashboard'} class="pf-link">
                            <span>Dashboard</span>
                            <span class="pf-arr">→</span>
                        </a>
                        <a href={isEn ? '/en/boveda' : '/boveda'} class="pf-link">
                            <span>{isEn ? 'Vault' : 'Bóveda'}</span>
                            <span class="pf-arr">→</span>
                        </a>
                        <a href={isEn ? '/en/facturacion' : '/facturacion'} class="pf-link">
                            <span>{isEn ? 'Billing' : 'Facturación'}</span>
                            <span class="pf-arr">→</span>
                        </a>
                        <a href={isEn ? '/en/calendario' : '/calendario'} class="pf-link">
                            <span>{isEn ? 'Calendar' : 'Calendario'}</span>
                            <span class="pf-arr">→</span>
                        </a>
                    </nav>
                </div>

                <div class="pf-col">
                    <div class="pf-col-head">
                        <span class="pf-col-num">/02</span>
                        <h4 class="pf-col-title">{isEn ? 'Tools' : 'Herramientas'}</h4>
                    </div>
                    <nav class="pf-links">
                        <a href={isEn ? '/en/roadmap' : '/roadmap'} class="pf-link">
                            <span>Roadmap</span>
                            <span class="pf-arr">→</span>
                        </a>
                        <a href={isEn ? '/en/entorno' : '/entorno'} class="pf-link">
                            <span>{isEn ? 'Environment' : 'Entorno'}</span>
                            <span class="pf-arr">→</span>
                        </a>
                        <a href={isEn ? '/en/changelog' : '/changelog'} class="pf-link">
                            <span>Changelog</span>
                            <span class="pf-arr">→</span>
                        </a>
                        <a href={isEn ? '/en/soporte' : '/soporte'} class="pf-link">
                            <span>{isEn ? 'Support' : 'Soporte'}</span>
                            <span class="pf-arr">→</span>
                        </a>
                    </nav>
                </div>

                <div class="pf-col">
                    <div class="pf-col-head">
                        <span class="pf-col-num">/03</span>
                        <h4 class="pf-col-title">{isEn ? 'Account' : 'Cuenta'}</h4>
                    </div>
                    <nav class="pf-links">
                        <a href={home} class="pf-link">
                            <span>{isEn ? 'Public Site' : 'Sitio Público'}</span>
                            <span class="pf-arr">→</span>
                        </a>
                        <button type="button" class="pf-link pf-logout" id="pf-signout">
                            <span>{isEn ? 'Sign out' : 'Cerrar sesión'}</span>
                            <span class="pf-arr">→</span>
                        </button>
                    </nav>
                </div>

            </div>

        </div>

        <div class="pf-divider"></div>

        <!-- BARRA INFERIOR: copyright + legal -->
        <div class="pf-bottom">
            <p class="pf-copy">&copy; 2026 <span class="pf-ed">Flouvia</span>. {isEn ? 'All rights reserved.' : 'Todos los derechos reservados.'}</p>
            <div class="pf-legal">
                <a href={isEn ? '/en/privacidad-portal' : '/privacidad-portal'} class="pf-legal-link">{isEn ? 'Privacy' : 'Privacidad'}</a>
                <span class="pf-legal-dot">·</span>
                <a href={isEn ? '/en/terms' : '/terminos'} class="pf-legal-link">{isEn ? 'Terms' : 'Términos'}</a>
            </div>
        </div>

    </div>
</footer>

<style>
    .pf-root {
        position: relative;
        background: radial-gradient(ellipse at 30% 20%, #112240 0%, #0a192f 60%, #050b14 100%);
        color: #ffffff;
        font-family: 'Inter', system-ui, sans-serif;
        overflow: hidden;
        isolation: isolate;
        --pf-muted: #8892b0;
        --pf-dim: #64748b;
        --pf-ease: cubic-bezier(0.16, 1, 0.3, 1);
        --pf-spring: cubic-bezier(0.175, 0.885, 0.32, 1.05);
        --pf-serif: 'Instrument Serif', serif;
    }

    .pf-root ::selection { background: #ffffff; color: #0a192f; }

    .pf-hairline {
        width: 100%; height: 1px;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.18) 20%, rgba(255,255,255,0.18) 80%, transparent);
    }

    /* Watermark editorial faint */
    .pf-watermark {
        position: absolute; bottom: -4vw; right: -2vw;
        font-family: var(--pf-serif); font-style: italic; font-weight: 400;
        font-size: 17vw; line-height: 0.85; letter-spacing: -0.04em;
        color: rgba(255,255,255,0.022);
        pointer-events: none; user-select: none; white-space: nowrap;
        z-index: 0;
    }

    .pf-inner {
        position: relative; z-index: 1;
        max-width: 1240px; margin: 0 auto; padding: 3rem 5% 2.25rem;
        animation: pf-fadein 0.9s var(--pf-ease) both;
        animation-delay: 0.1s;
    }

    /* ── META ROW ── */
    .pf-meta {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 3rem; gap: 1.5rem;
    }
    .pf-eyebrow {
        font-size: 0.65rem; font-weight: 800; letter-spacing: 3px;
        color: rgba(255,255,255,0.45); text-transform: uppercase; margin: 0;
    }
    .pf-status {
        display: flex; align-items: center; gap: 8px;
        background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
        padding: 5px 12px; border-radius: 100px; flex-shrink: 0;
    }
    .pf-status-txt {
        font-size: 0.6rem; font-weight: 700; letter-spacing: 1.2px;
        color: #94a3b8; text-transform: uppercase;
    }
    .pf-led {
        width: 6px; height: 6px; border-radius: 50%; background: #10b981;
        box-shadow: 0 0 0 0 rgba(16,185,129,0.4);
        animation: pf-pulse 2.5s infinite; flex-shrink: 0;
    }

    /* ── GRID ── */
    .pf-grid {
        display: grid; grid-template-columns: 5fr 7fr; gap: 4rem;
        margin-bottom: 3rem;
    }

    .pf-brand-col { display: flex; flex-direction: column; }
    .pf-logo { width: 118px; height: auto; margin-bottom: 1.75rem; opacity: 0.95; }

    .pf-statement {
        font-size: clamp(1.35rem, 1.8vw, 1.75rem);
        font-weight: 800; line-height: 1.18; letter-spacing: -0.5px;
        color: #ffffff; margin: 0 0 1.5rem 0; max-width: 90%;
    }
    .pf-ed {
        font-family: var(--pf-serif); font-style: italic; font-weight: 400;
        color: rgba(255,255,255,0.72); letter-spacing: -0.3px;
    }

    .pf-email {
        display: inline-flex; align-items: center; gap: 12px;
        text-decoration: none; color: #ffffff;
        padding-bottom: 11px; border-bottom: 1px solid rgba(255,255,255,0.12);
        transition: border-color 0.5s var(--pf-ease);
        width: max-content; max-width: 100%;
    }
    .pf-email-txt {
        font-size: 1.1rem; font-weight: 600; letter-spacing: -0.2px;
        transition: transform 0.5s var(--pf-spring);
    }
    .pf-email-arr {
        width: 16px; height: 16px; opacity: 0.55; color: var(--pf-muted);
        transition: all 0.5s var(--pf-spring);
    }
    .pf-email:hover { border-bottom-color: rgba(255,255,255,0.45); }
    .pf-email:hover .pf-email-txt { transform: translateX(4px); }
    .pf-email:hover .pf-email-arr { opacity: 1; transform: translateX(7px); color: #fff; }

    /* ── NAV COLS ── */
    .pf-nav-cols {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
        padding-top: 0.4rem;
    }
    .pf-col { display: flex; flex-direction: column; }
    .pf-col-head {
        display: flex; align-items: baseline; gap: 0.7rem; margin-bottom: 1.75rem;
    }
    .pf-col-num {
        font-family: var(--pf-serif); font-style: italic; font-weight: 400;
        font-size: 1.05rem; color: rgba(255,255,255,0.3); line-height: 1;
    }
    .pf-col-title {
        font-size: 0.7rem; font-weight: 700; letter-spacing: 1px;
        color: rgba(255,255,255,0.55); margin: 0; text-transform: uppercase;
    }

    .pf-links { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }

    .pf-link {
        display: inline-flex; align-items: center; gap: 10px;
        color: var(--pf-muted); text-decoration: none;
        font-size: 0.95rem; font-weight: 500;
        transition: color 0.4s var(--pf-ease);
        width: max-content;
        /* reset para <button> de SignOutButton */
        background: none; border: 0; padding: 0; margin: 0;
        font-family: inherit; cursor: pointer;
    }
    .pf-link span:first-child { transition: transform 0.5s var(--pf-spring); }
    .pf-arr {
        font-size: 0.85rem; opacity: 0; transform: translateX(-8px);
        transition: all 0.5s var(--pf-spring); color: #fff;
    }
    .pf-link:hover { color: #fff; }
    .pf-link:hover span:first-child { transform: translateX(4px); }
    .pf-link:hover .pf-arr { opacity: 1; transform: translateX(0); }
    .pf-link:active { transform: scale(0.97); transition: transform 0.1s; }

    /* ── DIVIDER ── */
    .pf-divider {
        height: 1px; margin: 0 0 1.75rem 0;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.1) 20%, rgba(255,255,255,0.1) 80%, transparent);
    }

    /* ── BARRA INFERIOR ── */
    .pf-bottom {
        display: flex; justify-content: space-between; align-items: center;
        gap: 1.5rem; font-size: 0.8rem; color: var(--pf-dim); font-weight: 500;
    }
    .pf-copy { margin: 0; letter-spacing: 0.2px; }
    .pf-copy .pf-ed { color: rgba(255,255,255,0.7); }

    .pf-legal { display: flex; align-items: center; gap: 1rem; }
    .pf-legal-dot { opacity: 0.4; }
    .pf-legal-link {
        color: var(--pf-dim); text-decoration: none; position: relative;
        transition: color 0.4s var(--pf-ease);
    }
    .pf-legal-link::after {
        content: ''; position: absolute; left: 0; right: 100%; bottom: -3px;
        height: 1px; background: rgba(255,255,255,0.4);
        transition: right 0.5s var(--pf-spring);
    }
    .pf-legal-link:hover { color: #fff; }
    .pf-legal-link:hover::after { right: 0; }

    /* ── ANIMACIONES ── */
    @keyframes pf-fadein {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes pf-pulse {
        0%   { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0.4); }
        70%  { transform: scale(1);    box-shadow: 0 0 0 6px rgba(16,185,129,0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
        .pf-grid { grid-template-columns: 1fr; gap: 2.75rem; }
        .pf-statement { max-width: 100%; }
        .pf-watermark { font-size: 30vw; bottom: -8vw; }
    }
    @media (max-width: 600px) {
        .pf-inner { padding: 2.25rem 5% 1.75rem; }
        .pf-meta { flex-direction: column; align-items: flex-start; gap: 1rem; margin-bottom: 2.25rem; }
        .pf-nav-cols { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .pf-link { width: 100%; justify-content: space-between; }
        .pf-arr { opacity: 0.35; transform: translateX(0); }
        .pf-email { width: 100%; justify-content: space-between; }
        .pf-bottom { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    }

    @media (prefers-reduced-motion: reduce) {
        .pf-inner { animation: none; }
        .pf-led { animation: none; }
    }
</style>

<script>
    // Cerrar sesión con Clerk. Se pasa callback como 1er arg para inhibir la
    // navegación default del SDK y redirigir nosotros al home (CLAUDE.md).
    const home = window.location.pathname.startsWith('/en') ? '/en/' : '/';
    document.getElementById('pf-signout')?.addEventListener('click', () => {
        const clerk = (window as any).Clerk;
        if (clerk?.signOut) {
            clerk.signOut(() => { window.location.href = home; });
        } else {
            window.location.href = home;
        }
    });
</script>
