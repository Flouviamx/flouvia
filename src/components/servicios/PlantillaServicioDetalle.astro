---
// src/components/servicios/PlantillaServicioDetalle.astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';
import WhatsApp from '../WhatsApp.astro';

import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
  serviceId: 1 | 2 | 3 | 4;
}

const { serviceId } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';

const n = String(serviceId) as '1' | '2' | '3' | '4';

const cat   = t(`serv.${n}.cat` as any);
const title = t(`serv.${n}.title` as any);
const desc  = t(`serv.${n}.desc` as any);
const btn   = t(`serv.${n}.btn` as any);

const caps = [
  { title: t(`serv.${n}.d1.t` as any), desc: t(`serv.${n}.d1.d` as any) },
  { title: t(`serv.${n}.d2.t` as any), desc: t(`serv.${n}.d2.d` as any) },
  { title: t(`serv.${n}.d3.t` as any), desc: t(`serv.${n}.d3.d` as any) },
  { title: t(`serv.${n}.d4.t` as any), desc: t(`serv.${n}.d4.d` as any) },
];

const steps = [
  t(`serv.${n}.p1` as any),
  t(`serv.${n}.p2` as any),
  t(`serv.${n}.p3` as any),
  t(`serv.${n}.p4` as any),
];

const stack = [
  t(`serv.${n}.t1` as any),
  t(`serv.${n}.t2` as any),
  t(`serv.${n}.t3` as any),
];

// Iconos por capability/servicio (4 iconos por servicio = 16 totales)
const capIcons: Record<string, string[]> = {
  '1': [
    `<path d="M3 3h18v18H3z"/><path d="M3 9h18M9 21V9"/>`,
    `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    `<path d="M9 11H5a2 2 0 0 0-2 2v7h18v-7a2 2 0 0 0-2-2h-4"/><path d="M9 11V7a3 3 0 0 1 6 0v4"/><circle cx="12" cy="16" r="1"/>`,
    `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
  ],
  '2': [
    `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
    `<path d="M3 12c0-1.5 2-3 4.5-3S12 10.5 12 12s-2 3-4.5 3S3 13.5 3 12z"/><path d="M12 12c0-1.5 2-3 4.5-3S21 10.5 21 12s-2 3-4.5 3S12 13.5 12 12z"/>`,
    `<polyline points="3 9 12 2 21 9 21 20 3 20 3 9"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    `<path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9m-9 9a9 9 0 0 1 9-9"/>`,
  ],
  '3': [
    `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
    `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/>`,
    `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
    `<path d="M16 3h5v5"/><path d="M8 21H3v-5"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/>`,
  ],
  '4': [
    `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
    `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
    `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    `<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>`,
  ],
};

const icons = capIcons[n] || capIcons['1'];

// Métricas por servicio
const metricsMap: Record<string, Array<{val: string, suf: string, label: string}>> = {
  '1': [
    { val: '34', suf: '%',  label: isEn ? 'CR uplift' : 'Aumento CR' },
    { val: '< 1', suf: 's', label: isEn ? 'Load time' : 'Tiempo de carga' },
    { val: '99.9', suf: '%', label: 'Uptime' },
    { val: '0',  suf: '',   label: isEn ? 'Tech debt' : 'Deuda técnica' },
  ],
  '2': [
    { val: '85', suf: '%',  label: isEn ? 'Automated ops' : 'Ops automatizadas' },
    { val: '24/7', suf: '', label: isEn ? 'Availability' : 'Disponibilidad' },
    { val: '5',  suf: '+',  label: isEn ? 'ERP integrations' : 'Integraciones ERP' },
    { val: '0',  suf: '',   label: isEn ? 'Manual errors' : 'Errores manuales' },
  ],
  '3': [
    { val: '10', suf: 'x',  label: isEn ? 'Faster ops' : 'Ops más rápidas' },
    { val: '100', suf: '%', label: isEn ? 'Real-time sync' : 'Sync en vivo' },
    { val: '0',  suf: '',   label: isEn ? 'Manual entries' : 'Entradas manuales' },
    { val: '15', suf: '+',  label: isEn ? 'Workflows' : 'Flujos' },
  ],
  '4': [
    { val: '34', suf: '%',  label: isEn ? 'CR average' : 'CR promedio' },
    { val: '2',  suf: 'x',  label: 'AOV' },
    { val: '100', suf: '%', label: isEn ? 'Data-driven' : 'Basado en datos' },
    { val: 'A/B', suf: '',  label: isEn ? 'Continuous' : 'Continuo' },
  ],
};
const metrics = metricsMap[n];

// "Why choose" — 3 razones por servicio
const whyMap: Record<string, Array<{title: string, desc: string}>> = {
  '1': [
    { title: isEn ? 'Native code, no templates' : 'Código nativo, sin plantillas',
      desc:  isEn ? 'We write modular code from scratch — no theme bloat, no app dependencies.' : 'Escribimos código modular desde cero — sin bloat de templates ni dependencias de apps.' },
    { title: isEn ? 'Headless architecture' : 'Arquitectura headless',
      desc:  isEn ? 'Decoupled front-end with React or Hydrogen for instant page loads.' : 'Front-end desacoplado con React o Hydrogen para cargas instantáneas.' },
    { title: isEn ? 'Documented Lifetime Value' : 'Lifetime Value documentado',
      desc:  isEn ? 'Every architectural decision tied to revenue impact and CR data.' : 'Cada decisión de arquitectura ligada al impacto en revenue y data de CR.' },
  ],
  '2': [
    { title: isEn ? 'Authenticated portals' : 'Portales autenticados',
      desc:  isEn ? 'Private B2B systems with role-based access and protected catalogs.' : 'Sistemas B2B privados con acceso por roles y catálogos protegidos.' },
    { title: isEn ? 'ERP-native integration' : 'Integración nativa ERP',
      desc:  isEn ? 'Bi-directional connection with SAP, NetSuite or Microsoft Dynamics.' : 'Conexión bidireccional con SAP, NetSuite o Microsoft Dynamics.' },
    { title: isEn ? 'Dynamic pricing engine' : 'Motor de precios dinámicos',
      desc:  isEn ? 'Volume rules, net terms, automated credit allocation per distributor.' : 'Reglas de volumen, net terms, asignación de crédito por distribuidor.' },
  ],
  '3': [
    { title: isEn ? 'Real-time orchestration' : 'Orquestación en tiempo real',
      desc:  isEn ? 'Webhooks and APIs that move data the moment events happen.' : 'Webhooks y APIs que mueven datos en el momento exacto del evento.' },
    { title: isEn ? 'Centralized command' : 'Comando centralizado',
      desc:  isEn ? 'Airtable as your operational source of truth, connected everywhere.' : 'Airtable como fuente única de verdad operativa, conectada a todo.' },
    { title: isEn ? 'Zero manual entry' : 'Cero captura manual',
      desc:  isEn ? 'Your team focuses on growth — the systems handle the data.' : 'Tu equipo se enfoca en crecer — los sistemas manejan los datos.' },
  ],
  '4': [
    { title: isEn ? 'Forensic UX audit' : 'Auditoría UX forense',
      desc:  isEn ? 'Heatmaps, session recordings, and friction maps based on real user data.' : 'Heatmaps, grabaciones y mapas de fricción con data real de usuarios.' },
    { title: isEn ? 'Continuous A/B testing' : 'A/B testing continuo',
      desc:  isEn ? 'Iterative experiments on critical conversion paths every sprint.' : 'Experimentos iterativos en rutas críticas de conversión cada sprint.' },
    { title: isEn ? 'Klaviyo-grade retention' : 'Retención nivel Klaviyo',
      desc:  isEn ? 'Engineered automation flows to maximize repeat purchase and LTV.' : 'Flujos de automatización para maximizar recompra y LTV.' },
  ],
};
const whys = whyMap[n];

const servicesLink = isEn ? '/en/servicios' : '/servicios';
const contactLink  = isEn ? '/en/contacto'  : '/contacto';

const pageTitle = `Flouvia | ${title.replace('.', '')}`;
---

<Layout title={pageTitle}>
  <Navbar />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

  <main class="sd-page">

    <!-- ══════════════ HERO ══════════════ -->
    <section class="sd-hero" id="sd-hero">
      <div class="sd-hero-grid-bg" aria-hidden="true"></div>
      <div class="container">

        <a href={servicesLink} class="sd-back" id="sd-back">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8"><polyline points="15 18 9 12 15 6"/></svg>
          {t('serv.page.back')}
        </a>

        <div class="sd-hero-content">
          <p class="sd-cat" id="sd-cat">
            <span class="sd-cat-line"></span>
            {cat}
          </p>

          <h1 class="sd-title" id="sd-title">
            {title.includes('.') ? (
              <>
                <span class="sd-t-plain">{title.split('.')[0]}</span>
                <span class="sd-t-serif">{title.split('.')[1] !== undefined ? '.' : ''}</span>
              </>
            ) : (
              <span class="sd-t-plain">{title}</span>
            )}
          </h1>

          <div class="sd-hero-bottom">
            <p class="sd-desc" id="sd-desc">{desc}</p>
            <a href={contactLink} class="sd-hero-cta" id="sd-hero-cta">
              <span>{btn}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="19" x2="19" y2="5"/><polyline points="9 5 19 5 19 15"/></svg>
            </a>
          </div>
        </div>

        <!-- Scroll cue -->
        <div class="sd-scroll-cue" id="sd-scroll-cue">
          <span>{isEn ? 'Scroll' : 'Desliza'}</span>
          <div class="sd-cue-line"></div>
        </div>
      </div>
    </section>

    <!-- ══════════════ METRICS BAR ══════════════ -->
    <section class="sd-metrics-section">
      <div class="container">
        <div class="sd-metrics-row" id="sd-metrics-row">
          {metrics.map(m => {
            const numericVal = parseFloat(m.val);
            const isNumeric  = !isNaN(numericVal);
            return (
              <div class="sd-metric">
                <span class="sd-metric-num" data-target={isNumeric ? numericVal : 0} data-display={!isNumeric ? m.val : ''}>
                  {isNumeric ? '0' : m.val}
                </span>
                <span class="sd-metric-suf">{m.suf}</span>
                <span class="sd-metric-label">{m.label}</span>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ══════════════ CAPACIDADES ══════════════ -->
    <section class="sd-caps-section">
      <div class="container">
        <div class="sd-section-head">
          <p class="sd-section-ey" id="sd-caps-ey">
            <span class="sd-ey-line"></span>
            {t('serv.page.capabilities')}
          </p>
          <h2 class="sd-section-title sd-caps-title" id="sd-caps-title">
            {isEn ? 'What we' : 'Lo que'} <em>{isEn ? 'engineer.' : 'ingenieramos.'}</em>
          </h2>
        </div>

        <div class="sd-caps-grid">
          {caps.map((cap, i) => (
            <div class="sd-cap-card" data-i={i}>
              <div class="sd-cap-spotlight"></div>
              <div class="sd-cap-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i]}></svg>
              </div>
              <div class="sd-cap-num">{String(i + 1).padStart(2, '0')}</div>
              <h3 class="sd-cap-title">{cap.title}</h3>
              <p class="sd-cap-desc">{cap.desc}</p>
              <div class="sd-cap-corner">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════ PROCESO (PINNED) ══════════════ -->
    <section class="sd-process-section" id="sd-process">
      <div class="container sd-process-grid">

        <div class="sd-process-left" id="sd-process-left">
          <p class="sd-section-ey">
            <span class="sd-ey-line"></span>
            {t('serv.page.process')}
          </p>
          <h2 class="sd-section-title">
            {isEn ? 'Execution' : 'Protocolo'} <em>{isEn ? 'protocol.' : 'de ejecución.'}</em>
          </h2>
          <p class="sd-process-intro">
            {isEn ? 'Four phases. No improvisation, no surprises — every milestone documented, every commit reviewed.'
                  : 'Cuatro fases. Sin improvisación, sin sorpresas — cada hito documentado, cada commit revisado.'}
          </p>
          <div class="sd-process-progress">
            <span class="sd-pp-label">{isEn ? 'PHASE' : 'FASE'}</span>
            <span class="sd-pp-current" id="sd-pp-current">01</span>
            <span class="sd-pp-of">/ 04</span>
          </div>
        </div>

        <div class="sd-steps">
          {steps.map((step, i) => (
            <div class="sd-step" data-step={i}>
              <div class="sd-step-marker">
                <div class="sd-step-num">
                  <span class="sd-step-n">{String(i + 1).padStart(2, '0')}</span>
                </div>
                {i < steps.length - 1 && <div class="sd-step-line"></div>}
              </div>
              <div class="sd-step-body">
                <h3 class="sd-step-title">
                  {isEn
                    ? ['Discovery', 'Architecture', 'Build', 'Launch'][i]
                    : ['Descubrimiento', 'Arquitectura', 'Construcción', 'Lanzamiento'][i]}
                </h3>
                <p class="sd-step-text">{step}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════ TECH STACK ══════════════ -->
    <section class="sd-stack-section">
      <div class="container">
        <div class="sd-section-head sd-stack-head">
          <p class="sd-section-ey" id="sd-stack-ey">
            <span class="sd-ey-line"></span>
            {t('serv.page.stack')}
          </p>
          <p class="sd-stack-sub">{isEn ? 'Production-grade technologies battle-tested at scale.' : 'Tecnologías production-grade probadas a escala.'}</p>
        </div>
        <div class="sd-stack-row" id="sd-stack-row">
          {stack.map(tech => (
            <div class="sd-tech-badge">
              <span class="sd-tech-pulse"></span>
              <span>{tech}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════ WHY ══════════════ -->
    <section class="sd-why-section" id="sd-why">
      <div class="container">
        <div class="sd-section-head">
          <p class="sd-section-ey">
            <span class="sd-ey-line"></span>
            {isEn ? 'WHY THIS, WHY US' : 'POR QUÉ ESTO, POR QUÉ NOSOTROS'}
          </p>
          <h2 class="sd-section-title">
            {isEn ? 'The Flouvia' : 'El estándar'} <em>{isEn ? 'standard.' : 'Flouvia.'}</em>
          </h2>
        </div>

        <div class="sd-why-grid">
          {whys.map((w, i) => (
            <div class="sd-why-item" data-i={i}>
              <div class="sd-why-num">0{i + 1}</div>
              <h3 class="sd-why-title">{w.title}</h3>
              <p class="sd-why-desc">{w.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════ CTA ══════════════ -->
    <section class="sd-cta-section">
      <div class="container">
        <div class="sd-cta-card" id="sd-cta-card">
          <div class="sd-cta-noise" aria-hidden="true"></div>
          <div class="sd-cta-glow" aria-hidden="true"></div>
          <div class="sd-cta-inner">
            <div class="sd-cta-text">
              <p class="sd-cta-eyebrow">
                <span class="sd-cta-dot"></span>
                {isEn ? 'THE NEXT STEP' : 'EL SIGUIENTE PASO'}
              </p>
              <h2 class="sd-cta-title">
                {t('serv.page.cta.title')}
                <em> {isEn ? 'Now.' : 'Ahora.'}</em>
              </h2>
              <p class="sd-cta-sub">{t('serv.page.cta.sub')}</p>
            </div>
            <a href={contactLink} class="sd-cta-btn" id="sd-cta-btn">
              <span class="sd-cta-btn-label">{t('serv.page.cta.btn')}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="19" x2="19" y2="5"/><polyline points="9 5 19 5 19 15"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <WhatsApp />
</Layout>

<style is:global>
  :root {
    --color-bg: #ffffff;
    --color-bg-soft: #fcfcfc;
    --color-blue-icy: #f4f6f9;
    --color-blue-deep: #0a192f;
    --color-glass-blue: rgba(10, 25, 47, 0.85);
    --color-text: #050505;
    --color-text-muted: #555555;
    --color-border: rgba(0, 0, 0, 0.08);
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-serif: 'Instrument Serif', serif;
    --ease-ios: cubic-bezier(0.25, 1, 0.5, 1);
    --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.05);
    --ease-smooth: cubic-bezier(0.16, 1, 0.3, 1);
  }
  body {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    margin: 0;
  }
</style>

<style>
.sd-page {
  width: 100%;
  font-family: var(--font-sans);
  background: var(--color-bg);
  color: var(--color-text);
}

.container { max-width: 1240px; margin: 0 auto; padding: 0 5%; }

/* ══════════════════════════════════════════════════════
   HERO
══════════════════════════════════════════════════════ */
.sd-hero {
  position: relative;
  padding: 11rem 0 6rem;
  background: var(--color-bg);
  overflow: hidden;
}
.sd-hero-grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, rgba(0,0,0,0.02) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(0,0,0,0.02) 1px, transparent 1px);
  background-size: 56px 56px;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 0%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 0%, transparent 70%);
  pointer-events: none;
}

.sd-back {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
  color: var(--color-text-muted); text-decoration: none;
  padding: 7px 14px; border-radius: 100px;
  background: rgba(0,0,0,0.025); border: 1px solid var(--color-border);
  margin-bottom: 3rem; opacity: 0;
  transition: all .3s var(--ease-smooth);
}
.sd-back:hover {
  color: var(--color-text); background: rgba(0,0,0,0.05);
  transform: translateX(-3px);
}

.sd-cat {
  display: inline-flex; align-items: center; gap: 12px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.16em;
  color: var(--color-blue-deep); text-transform: uppercase;
  margin: 0 0 1.6rem; opacity: 0;
}
.sd-cat-line {
  display: inline-block; width: 36px; height: 1px;
  background: var(--color-blue-deep); transform-origin: left;
}

.sd-title {
  font-size: clamp(3.4rem, 7.8vw, 7.6rem);
  font-weight: 600; letter-spacing: -0.05em; line-height: 1;
  margin: 0 0 3.5rem;
  display: inline-block;
  overflow: hidden;
}
.sd-t-plain { color: var(--color-text); }
.sd-t-serif {
  font-family: 'Instrument Serif', Georgia, serif;
  font-style: italic; font-weight: 400;
  font-size: 1.05em; color: var(--color-text-muted);
  margin-left: 0.05em;
}

.sd-hero-bottom {
  display: flex; justify-content: space-between; align-items: flex-end;
  gap: 4rem; border-top: 1px solid var(--color-border); padding-top: 2rem;
}
.sd-desc {
  font-size: 1.18rem; color: var(--color-text-muted);
  max-width: 580px; line-height: 1.55; margin: 0;
  font-weight: 400; opacity: 0;
}

.sd-hero-cta {
  flex-shrink: 0;
  display: inline-flex; align-items: center; gap: 9px;
  background: var(--color-text); color: #fff;
  font-size: 0.95rem; font-weight: 600;
  padding: 1rem 2rem; border-radius: 100px;
  text-decoration: none;
  box-shadow: 0 8px 22px rgba(10,14,26,0.18), inset 0 1px 0 rgba(255,255,255,0.08);
  transition: all .35s var(--ease-smooth);
  opacity: 0; position: relative; overflow: hidden;
}
.sd-hero-cta::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.08) 50%, transparent 70%);
  transform: translateX(-100%);
}
.sd-hero-cta:hover::before { transform: translateX(100%); transition: transform .6s var(--ease-smooth); }
.sd-hero-cta:hover {
  background: #1a2233;
  transform: translateY(-3px) scale(1.02);
