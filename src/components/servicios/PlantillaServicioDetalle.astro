</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import { SplitText } from 'gsap/SplitText';

gsap.registerPlugin(ScrollTrigger, SplitText);

document.addEventListener('DOMContentLoaded', () => {

  /* ─────────────── HERO ENTRANCE ─────────────── */
  const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

  tl.to('#sd-back', { opacity: 1, y: 0, duration: 0.55 }, 0.1);
  gsap.set('#sd-back', { y: 8 });

  // Category eyebrow + line
  tl.to('#sd-cat', { opacity: 1, duration: 0.55 }, 0.2);
  gsap.set('.sd-cat-line', { scaleX: 0 });
  tl.to('.sd-cat-line', { scaleX: 1, duration: 0.7, ease: 'power3.out' }, 0.3);

  // Title SplitText
  const titleEl = document.getElementById('sd-title');
  if (titleEl) {
    const split = SplitText.create(titleEl, { type: 'chars,words' });
    gsap.set(split.chars, { opacity: 0, y: 60, rotateX: -50, transformOrigin: 'center bottom' });
    tl.to(split.chars, {
      opacity: 1, y: 0, rotateX: 0,
      duration: 0.85, stagger: 0.018, ease: 'back.out(2)',
    }, 0.35);
  }

  tl.to('#sd-desc',     { opacity: 1, y: 0, duration: 0.6 }, 0.7);
  tl.to('#sd-hero-cta', { opacity: 1, y: 0, duration: 0.6 }, 0.78);
  gsap.set(['#sd-desc', '#sd-hero-cta'], { y: 12 });

  tl.to('#sd-scroll-cue', { opacity: 1, duration: 0.5 }, 1.1);

  // Hero parallax background
  gsap.to('.sd-hero-grid-bg', {
    yPercent: 30,
    ease: 'none',
    scrollTrigger: { trigger: '.sd-hero', start: 'top top', end: 'bottom top', scrub: true },
  });

  /* ─────────────── METRICS COUNTERS ─────────────── */
  const metricsRow = document.getElementById('sd-metrics-row');
  if (metricsRow) {
    ScrollTrigger.create({
      trigger: metricsRow, start: 'top 85%', once: true,
      onEnter: () => {
        const metrics = metricsRow.querySelectorAll<HTMLElement>('.sd-metric');
        gsap.fromTo(metrics,
          { opacity: 0, y: 18 },
          { opacity: 1, y: 0, duration: 0.7, stagger: 0.08, ease: 'expo.out' }
        );

        // Animate numbers
        metrics.forEach((m, i) => {
          const numEl = m.querySelector<HTMLElement>('.sd-metric-num');
          if (!numEl) return;
          const display = numEl.getAttribute('data-display') || '';
          if (display) return; // non-numeric, skip
          const target = parseFloat(numEl.getAttribute('data-target') || '0');
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target, duration: 1.6, ease: 'expo.out', delay: 0.2 + i * 0.05,
            onUpdate() {
              numEl.textContent = target % 1 === 0
                ? Math.round(obj.val).toString()
                : obj.val.toFixed(1);
            }
          });
        });
      }
    });
  }

  /* ─────────────── EYEBROW LINES ─────────────── */
  document.querySelectorAll<HTMLElement>('.sd-section-ey').forEach(ey => {
    const line = ey.querySelector<HTMLElement>('.sd-ey-line');
    if (!line) return;
    gsap.set(line, { scaleX: 0 });
    ScrollTrigger.create({
      trigger: ey, start: 'top 88%', once: true,
      onEnter: () => gsap.to(line, { scaleX: 1, duration: 0.7, ease: 'power3.out' })
    });
  });

  /* ─────────────── SECTION TITLES (SplitText reveal) ─────────────── */
  document.querySelectorAll<HTMLElement>('.sd-section-title').forEach(title => {
    const split = SplitText.create(title, { type: 'words' });
    gsap.set(split.words, { opacity: 0, y: 24, filter: 'blur(8px)' });
    ScrollTrigger.create({
      trigger: title, start: 'top 85%', once: true,
      onEnter: () => gsap.to(split.words, {
        opacity: 1, y: 0, filter: 'blur(0px)',
        duration: 0.8, stagger: 0.05, ease: 'expo.out'
      })
    });
  });

  /* ─────────────── CAPABILITY CARDS ─────────────── */
  const caps = document.querySelectorAll<HTMLElement>('.sd-cap-card');
  if (caps.length) {
    ScrollTrigger.create({
      trigger: '.sd-caps-grid', start: 'top 80%', once: true,
      onEnter: () => {
        gsap.fromTo(caps,
          { y: 36, opacity: 0, scale: 0.97 },
          { y: 0, opacity: 1, scale: 1, duration: 0.85, stagger: 0.1, ease: 'expo.out' }
        );
      }
    });

    // Spotlight tracking
    caps.forEach(card => {
      const spot = card.querySelector<HTMLElement>('.sd-cap-spotlight');
      if (!spot) return;
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const r = card.getBoundingClientRect();
        gsap.to(spot, { x: e.clientX - r.left, y: e.clientY - r.top, duration: 0.5, ease: 'power2.out' });
      });
    });
  }

  /* ─────────────── PROCESS STEPS (sequential reveal + active tracking) ─────────────── */
  const steps = document.querySelectorAll<HTMLElement>('.sd-step');
  const ppCurrent = document.getElementById('sd-pp-current');

  steps.forEach((step, i) => {
    // Entrance
    ScrollTrigger.create({
      trigger: step, start: 'top 85%', once: true,
      onEnter: () => gsap.to(step, { opacity: 1, x: 0, duration: 0.8, ease: 'expo.out' })
    });
    gsap.set(step, { x: -16 });

    // Active state tracking — current phase counter
    ScrollTrigger.create({
      trigger: step,
      start: 'top 60%',
      end: 'bottom 60%',
      onEnter:    () => { step.classList.add('is-active'); if (ppCurrent) ppCurrent.textContent = String(i + 1).padStart(2, '0'); },
      onEnterBack:() => { step.classList.add('is-active'); if (ppCurrent) ppCurrent.textContent = String(i + 1).padStart(2, '0'); },
      onLeave:    () => step.classList.remove('is-active'),
      onLeaveBack:() => step.classList.remove('is-active'),
    });
  });

  /* ─────────────── TECH STACK ─────────────── */
  const stack = document.querySelector('.sd-stack-row');
  if (stack) {
    ScrollTrigger.create({
      trigger: stack, start: 'top 85%', once: true,
      onEnter: () => {
        const badges = stack.querySelectorAll('.sd-tech-badge');
        gsap.fromTo(badges,
          { y: 18, opacity: 0, scale: 0.92 },
          { y: 0, opacity: 1, scale: 1, duration: 0.65, stagger: 0.08, ease: 'back.out(1.8)' }
        );
      }
    });
  }

  /* ─────────────── WHY GRID ─────────────── */
  const whyItems = document.querySelectorAll<HTMLElement>('.sd-why-item');
  if (whyItems.length) {
    ScrollTrigger.create({
      trigger: '.sd-why-grid', start: 'top 80%', once: true,
      onEnter: () => {
        gsap.fromTo(whyItems,
          { y: 28, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.75, stagger: 0.12, ease: 'expo.out' }
        );
      }
    });
  }

  /* ─────────────── CTA SCROLL REVEAL ─────────────── */
  const ctaCard = document.getElementById('sd-cta-card');
  if (ctaCard) {
    gsap.fromTo(ctaCard,
      { y: 50, opacity: 0, scale: 0.96 },
      {
        y: 0, opacity: 1, scale: 1, duration: 1.0, ease: 'expo.out',
        scrollTrigger: { trigger: ctaCard, start: 'top 85%', once: true }
      }
    );
  }

  /* ─────────────── REDUCED MOTION ─────────────── */
  gsap.matchMedia().add('(prefers-reduced-motion: reduce)', () => {
    gsap.globalTimeline.timeScale(2);
    document.querySelectorAll('.sd-cue-line, .sd-cta-dot, .sd-tech-pulse').forEach(el => {
      (el as HTMLElement).style.animation = 'none';
    });
  });
});
</script>
