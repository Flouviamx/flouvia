.sd-metric-num {
  font-size: clamp(2.4rem, 4vw, 3.4rem);
  font-weight: 700; letter-spacing: -0.04em;
  line-height: 1; color: #fff;
  font-variant-numeric: tabular-nums;
  display: inline-block;
