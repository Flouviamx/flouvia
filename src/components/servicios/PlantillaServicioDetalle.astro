.sd-cta-btn:hover::before { transform: translateX(100%); transition: transform .6s var(--ease-smooth); }
.sd-cta-btn:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: inset 0 0 0 1px rgba(0,0,0,0.06), 0 16px 32px rgba(255,255,255,0.15);
}
.sd-cta-btn-label { position: relative; z-index: 2; }
.sd-cta-btn svg { transition: transform .35s var(--ease-smooth); }
.sd-cta-btn:hover svg { transform: translate(2px, -2px); }

/* ══════════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .sd-process-grid { grid-template-columns: 1fr; gap: 3rem; }
  .sd-process-left { position: static; }
  .sd-cta-inner { flex-direction: column; align-items: flex-start; gap: 2.4rem; padding: 4rem; }
  .sd-why-grid { grid-template-columns: 1fr; gap: 2rem; }
  .sd-metrics-row { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  .sd-metric:nth-child(3) { padding-left: 0; border-left: none; }
}

@media (max-width: 768px) {
  .sd-hero { padding: 9rem 0 4rem; }
  .sd-back { margin-bottom: 2rem; }
  .sd-title { font-size: clamp(2.8rem, 12vw, 4.4rem); margin-bottom: 2.5rem; }
  .sd-hero-bottom { flex-direction: column; align-items: stretch; gap: 1.8rem; border-top: none; padding-top: 0; }
  .sd-desc { font-size: 1.04rem; }
  .sd-hero-cta { width: 100%; justify-content: center; }
  .sd-scroll-cue { display: none; }

  .sd-metrics-section { padding: 2.5rem 0; }
  .sd-metric-num { font-size: 2rem; }

  .sd-section-title { font-size: clamp(1.7rem, 7vw, 2.4rem); }
  .sd-section-head { margin-bottom: 2.5rem; }

  .sd-caps-section { padding: 4.5rem 0; }
  .sd-caps-grid { grid-template-columns: 1fr; }
  .sd-cap-card { padding: 2rem; }
  .sd-cap-num { top: 2rem; right: 2rem; }

  .sd-process-section { padding: 4.5rem 0; }
  .sd-step { gap: 1.4rem; padding: 1.6rem 0; }
  .sd-step-num { width: 38px; height: 38px; }

  .sd-stack-section { padding: 4rem 0; }
  .sd-tech-badge { padding: 9px 14px; font-size: 0.74rem; }

  .sd-why-section { padding: 5rem 0 4rem; }

  .sd-cta-section { padding: 0 0 5rem; }
