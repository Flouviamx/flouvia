<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  document.addEventListener('DOMContentLoaded', () => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth <= 768;
    const isDesktop = window.innerWidth > 1024;

    /* ───── REVEALS (intersection-driven CSS classes) ───── */
    document.querySelectorAll('.reveal-blur, .reveal-fade, .reveal-up, .blueprint-reveal').forEach(el => {
      ScrollTrigger.create({
        trigger: el, start: 'top 88%', once: true,
        onEnter: () => el.classList.add('active'),
      });
    });

    /* ───── HERO PARALLAX ───── */
    if (!reduced && !isMobile) {
      gsap.to('#hero-parallax', {
        yPercent: 22, opacity: 0.2,
        ease: 'none',
        scrollTrigger: { trigger: '.sd-hero', start: 'top top', end: 'bottom 30%', scrub: 0.8 },
      });
    }

    /* ───── HERO TITLE — split chars on entrance ───── */
    const titleEl = document.querySelector<HTMLElement>('.sd-hero .hero-title');
    if (titleEl && !reduced) {
      const split = SplitText.create(titleEl, { type: 'chars,words' });
      gsap.set(split.chars, { yPercent: 110, opacity: 0, rotateX: -45, transformOrigin: '50% 100%' });
      gsap.to(split.chars, {
        yPercent: 0, opacity: 1, rotateX: 0,
        duration: 1.05, ease: 'power4.out',
        stagger: 0.022, delay: 0.35,
      });
    }

    /* ───── METRICS COUNTERS ───── */
    const metricsRow = document.querySelector<HTMLElement>('.sd-metrics-grid');
    if (metricsRow) {
      ScrollTrigger.create({
        trigger: metricsRow, start: 'top 80%', once: true,
        onEnter: () => {
          metricsRow.querySelectorAll<HTMLElement>('.sd-metric-num').forEach((numEl, i) => {
            const display = numEl.getAttribute('data-display') || '';
            if (display) return;
            const target = parseFloat(numEl.getAttribute('data-target') || '0');
            const obj = { val: 0 };
            gsap.to(obj, {
              val: target, duration: 1.6, ease: 'expo.out', delay: 0.2 + i * 0.06,
              onUpdate() {
                numEl.textContent = target % 1 === 0
                  ? Math.round(obj.val).toString()
                  : obj.val.toFixed(1);
              }
            });
          });
        }
      });
    }

    /* ───── SECTION HEADINGS — split words on scroll ───── */
    if (!reduced) {
      document.querySelectorAll<HTMLElement>('.section-heading, .wf-title').forEach(h => {
        const split = SplitText.create(h, { type: 'words' });
        gsap.from(split.words, {
          y: 28, opacity: 0, rotateX: -25,
          duration: 0.85, ease: 'power3.out', stagger: 0.06,
          scrollTrigger: { trigger: h, start: 'top 85%' },
        });
      });
    }

    /* ───── BENTO MODULES — staggered entrance with subtle scale ───── */
    if (!reduced) {
      gsap.utils.toArray<HTMLElement>('.b-module').forEach((card, i) => {
        gsap.from(card, {
          y: 50, opacity: 0, scale: 0.96,
          duration: 0.95, ease: 'power3.out', delay: i * 0.08,
          scrollTrigger: { trigger: '.bento-modules-grid', start: 'top 80%' },
        });
      });
    }

    /* ───── DNA PILLS — pop-in stagger ───── */
    if (!reduced) {
      const dnaPills = document.querySelectorAll<HTMLElement>('.dna-pills span');
      if (dnaPills.length) {
        gsap.from(dnaPills, {
          y: 16, opacity: 0, scale: 0.85,
          duration: 0.6, ease: 'back.out(2)',
          stagger: 0.06,
          scrollTrigger: { trigger: '.dna-footer', start: 'top 90%' },
        });
      }
    }

    /* ───── PROTOCOL TIMELINE — track draw + step active state ───── */
    const track = document.querySelector<HTMLElement>('.timeline-track');
    if (track && !reduced) {
      gsap.set(track, { transformOrigin: 'top center', scaleY: 0 });
      gsap.to(track, {
        scaleY: 1, ease: 'none',
        scrollTrigger: {
          trigger: '.protocol-timeline',
          start: 'top 65%', end: 'bottom 70%', scrub: 0.6,
        },
      });
    }

    const steps = document.querySelectorAll<HTMLElement>('.protocol-step');
    const ppCurrent = document.getElementById('sd-pp-current');

    steps.forEach((step, i) => {
      if (!reduced) {
        gsap.from(step, {
          x: 40, opacity: 0,
          duration: 0.85, ease: 'power3.out', delay: i * 0.04,
          scrollTrigger: { trigger: step, start: 'top 88%' },
        });
        const node = step.querySelector('.step-node');
        if (node) {
          gsap.from(node, {
            scale: 0, rotate: 180,
            duration: 0.7, ease: 'back.out(2.4)', delay: i * 0.04 + 0.12,
            scrollTrigger: { trigger: step, start: 'top 88%' },
          });
        }
      }

      ScrollTrigger.create({
        trigger: step,
        start: 'top 60%', end: 'bottom 60%',
        onEnter:    () => { step.classList.add('is-active'); if (ppCurrent) ppCurrent.textContent = String(i + 1).padStart(2, '0'); },
        onEnterBack:() => { step.classList.add('is-active'); if (ppCurrent) ppCurrent.textContent = String(i + 1).padStart(2, '0'); },
        onLeave:    () => step.classList.remove('is-active'),
        onLeaveBack:() => step.classList.remove('is-active'),
      });
    });

    /* ───── HW CARDS — 3D TILT + GLOW (desktop only) ───── */
    if (isDesktop && !reduced) {
      document.querySelectorAll<HTMLElement>('.hw-card.tilt-card').forEach(card => {
        card.addEventListener('mousemove', e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
          const cx = rect.width / 2, cy = rect.height / 2;
          const rx = ((y - cy) / cy) * -5;
          const ry = ((x - cx) / cx) * 5;
          card.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.02, 1.02, 1.02)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = `perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)`;
        });
      });
    }

    /* ───── CTA — magnetic scale-in ───── */
    const ctaCard = document.querySelector<HTMLElement>('.cta-box-refined');
    if (ctaCard && !reduced) {
      gsap.from(ctaCard, {
        y: 60, scale: 0.94, opacity: 0,
        duration: 1.1, ease: 'expo.out',
        scrollTrigger: { trigger: ctaCard, start: 'top 82%' },
      });
    }

    /* ───── REDUCED MOTION FALLBACK ───── */
    if (reduced) {
      document.querySelectorAll<HTMLElement>('.reveal-blur, .reveal-fade, .reveal-up, .blueprint-reveal')
        .forEach(el => el.classList.add('active'));
    }
  });
</script>
