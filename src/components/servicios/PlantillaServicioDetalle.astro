---
// src/components/servicios/PlantillaServicioDetalle.astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';
import WhatsApp from '../WhatsApp.astro';

import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
  serviceId: 1 | 2 | 3 | 4;
}

const { serviceId } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';

const n = String(serviceId) as '1' | '2' | '3' | '4';

const cat   = t(`serv.${n}.cat` as any);
const title = t(`serv.${n}.title` as any);
const desc  = t(`serv.${n}.desc` as any);
const btn   = t(`serv.${n}.btn` as any);

const caps = [
  { title: t(`serv.${n}.d1.t` as any), desc: t(`serv.${n}.d1.d` as any) },
  { title: t(`serv.${n}.d2.t` as any), desc: t(`serv.${n}.d2.d` as any) },
  { title: t(`serv.${n}.d3.t` as any), desc: t(`serv.${n}.d3.d` as any) },
  { title: t(`serv.${n}.d4.t` as any), desc: t(`serv.${n}.d4.d` as any) },
];

const steps = [
  t(`serv.${n}.p1` as any),
  t(`serv.${n}.p2` as any),
  t(`serv.${n}.p3` as any),
  t(`serv.${n}.p4` as any),
];

const stack = [
  t(`serv.${n}.t1` as any),
  t(`serv.${n}.t2` as any),
  t(`serv.${n}.t3` as any),
];

// SVG paths per service (4 unique icons each)
const capIcons: Record<string, string[]> = {
  '1': [
    `<rect x="3" y="3" width="18" height="18" rx="4" stroke-opacity="0.3"/><path d="M9 3v18M15 3v18" stroke-opacity="1"/><path d="M3 9h18M3 15h18" stroke-opacity="0.3"/>`,
    `<path d="M12 2L2 7l10 5 10-5-10-5z" stroke-opacity="1"/><path d="M2 17l10 5 10-5" stroke-opacity="0.3"/><path d="M2 12l10 5 10-5" stroke-opacity="0.6"/>`,
    `<rect x="5" y="8" width="14" height="12" rx="2" stroke-opacity="1"/><path d="M8 8V6a4 4 0 0 1 8 0v2" stroke-opacity="0.3"/><circle cx="12" cy="14" r="1" stroke-opacity="1"/>`,
    `<polyline points="16 16 22 12 16 8" stroke-opacity="1"/><line x1="22" y1="12" x2="2" y2="12" stroke-opacity="0.3"/><path d="M8 4L2 12l6 8" stroke-opacity="0.3"/>`,
  ],
  '2': [
    `<rect x="3" y="11" width="18" height="11" rx="2" stroke-opacity="1"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke-opacity="0.3"/><circle cx="12" cy="16" r="1" stroke-opacity="1"/>`,
    `<line x1="4" y1="21" x2="4" y2="14" stroke-opacity="0.3"/><line x1="4" y1="10" x2="4" y2="3" stroke-opacity="1"/><line x1="12" y1="21" x2="12" y2="12" stroke-opacity="0.3"/><line x1="12" y1="8" x2="12" y2="3" stroke-opacity="1"/><line x1="20" y1="21" x2="20" y2="16" stroke-opacity="0.3"/><line x1="20" y1="12" x2="20" y2="3" stroke-opacity="1"/><circle cx="4" cy="12" r="2" stroke-opacity="1"/><circle cx="12" cy="10" r="2" stroke-opacity="1"/><circle cx="20" cy="14" r="2" stroke-opacity="1"/>`,
    `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" stroke-opacity="1"/>`,
    `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke-opacity="1"/><polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke-opacity="0.3"/><line x1="12" y1="22.08" x2="12" y2="12" stroke-opacity="0.3"/>`,
  ],
  '3': [
    `<ellipse cx="12" cy="5" rx="9" ry="3" stroke-opacity="1"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" stroke-opacity="0.3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" stroke-opacity="0.6"/>`,
    `<rect x="3" y="3" width="7" height="7" rx="1" stroke-opacity="1"/><rect x="14" y="3" width="7" height="7" rx="1" stroke-opacity="0.3"/><rect x="14" y="14" width="7" height="7" rx="1" stroke-opacity="1"/><rect x="3" y="14" width="7" height="7" rx="1" stroke-opacity="0.3"/>`,
    `<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" stroke-opacity="1"/><path d="M13.73 21a2 2 0 0 1-3.46 0" stroke-opacity="0.3"/>`,
    `<rect x="2" y="7" width="20" height="14" rx="2" ry="2" stroke-opacity="1"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" stroke-opacity="0.3"/>`,
  ],
  '4': [
    `<circle cx="11" cy="11" r="8" stroke-opacity="1"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke-opacity="0.3"/><path d="M11 8v6M8 11h6" stroke-opacity="0.3"/>`,
    `<path d="M16 3h5v5" stroke-opacity="1"/><path d="M8 3H3v5" stroke-opacity="0.3"/><path d="M12 22v-8.3a4 4 0 0 0-1.17-2.83L3 3" stroke-opacity="0.3"/><path d="M15 9l6-6" stroke-opacity="1"/>`,
    `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke-opacity="0.3"/><circle cx="12" cy="12" r="3" stroke-opacity="1"/>`,
    `<path d="M21 2v6h-6" stroke-opacity="1"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8" stroke-opacity="1"/><path d="M3 22v-6h6" stroke-opacity="0.3"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16" stroke-opacity="0.3"/>`,
  ],
};

const icons = capIcons[n];

// Métricas por servicio
const metricsMap: Record<string, Array<{val: string, suf: string, label: string}>> = {
  '1': [
    { val: '34', suf: '%',  label: isEn ? 'CR uplift' : 'Aumento CR' },
    { val: '< 1', suf: 's', label: isEn ? 'Load time' : 'Tiempo de carga' },
    { val: '99.9', suf: '%', label: 'Uptime' },
    { val: '0',  suf: '',   label: isEn ? 'Tech debt' : 'Deuda técnica' },
  ],
  '2': [
    { val: '85', suf: '%',  label: isEn ? 'Automated ops' : 'Ops automatizadas' },
    { val: '24/7', suf: '', label: isEn ? 'Availability' : 'Disponibilidad' },
    { val: '5',  suf: '+',  label: isEn ? 'ERP integrations' : 'Integraciones ERP' },
    { val: '0',  suf: '',   label: isEn ? 'Manual errors' : 'Errores manuales' },
  ],
  '3': [
    { val: '10', suf: 'x',  label: isEn ? 'Faster ops' : 'Ops más rápidas' },
    { val: '100', suf: '%', label: isEn ? 'Real-time sync' : 'Sync en vivo' },
    { val: '0',  suf: '',   label: isEn ? 'Manual entries' : 'Entradas manuales' },
    { val: '15', suf: '+',  label: isEn ? 'Workflows' : 'Flujos' },
  ],
  '4': [
    { val: '34', suf: '%',  label: isEn ? 'CR average' : 'CR promedio' },
    { val: '2',  suf: 'x',  label: 'AOV' },
    { val: '100', suf: '%', label: isEn ? 'Data-driven' : 'Basado en datos' },
    { val: 'A/B', suf: '',  label: isEn ? 'Continuous' : 'Continuo' },
  ],
};
const metrics = metricsMap[n];

// "Why choose" — 3 razones por servicio
const whyMap: Record<string, Array<{title: string, desc: string}>> = {
  '1': [
    { title: isEn ? 'Native code, no templates' : 'Código nativo, sin plantillas',
      desc:  isEn ? 'We write modular code from scratch — no theme bloat, no app dependencies.' : 'Escribimos código modular desde cero — sin bloat de templates ni dependencias de apps.' },
    { title: isEn ? 'Headless architecture' : 'Arquitectura headless',
      desc:  isEn ? 'Decoupled front-end with React or Hydrogen for instant page loads.' : 'Front-end desacoplado con React o Hydrogen para cargas instantáneas.' },
    { title: isEn ? 'Documented Lifetime Value' : 'Lifetime Value documentado',
      desc:  isEn ? 'Every architectural decision tied to revenue impact and CR data.' : 'Cada decisión de arquitectura ligada al impacto en revenue y data de CR.' },
  ],
  '2': [
    { title: isEn ? 'Authenticated portals' : 'Portales autenticados',
      desc:  isEn ? 'Private B2B systems with role-based access and protected catalogs.' : 'Sistemas B2B privados con acceso por roles y catálogos protegidos.' },
    { title: isEn ? 'ERP-native integration' : 'Integración nativa ERP',
      desc:  isEn ? 'Bi-directional connection with SAP, NetSuite or Microsoft Dynamics.' : 'Conexión bidireccional con SAP, NetSuite o Microsoft Dynamics.' },
    { title: isEn ? 'Dynamic pricing engine' : 'Motor de precios dinámicos',
      desc:  isEn ? 'Volume rules, net terms, automated credit allocation per distributor.' : 'Reglas de volumen, net terms, asignación de crédito por distribuidor.' },
  ],
  '3': [
    { title: isEn ? 'Real-time orchestration' : 'Orquestación en tiempo real',
      desc:  isEn ? 'Webhooks and APIs that move data the moment events happen.' : 'Webhooks y APIs que mueven datos en el momento exacto del evento.' },
    { title: isEn ? 'Centralized command' : 'Comando centralizado',
      desc:  isEn ? 'Airtable as your operational source of truth, connected everywhere.' : 'Airtable como fuente única de verdad operativa, conectada a todo.' },
    { title: isEn ? 'Zero manual entry' : 'Cero captura manual',
      desc:  isEn ? 'Your team focuses on growth — the systems handle the data.' : 'Tu equipo se enfoca en crecer — los sistemas manejan los datos.' },
  ],
  '4': [
    { title: isEn ? 'Forensic UX audit' : 'Auditoría UX forense',
      desc:  isEn ? 'Heatmaps, session recordings, and friction maps based on real user data.' : 'Heatmaps, grabaciones y mapas de fricción con data real de usuarios.' },
    { title: isEn ? 'Continuous A/B testing' : 'A/B testing continuo',
      desc:  isEn ? 'Iterative experiments on critical conversion paths every sprint.' : 'Experimentos iterativos en rutas críticas de conversión cada sprint.' },
    { title: isEn ? 'Klaviyo-grade retention' : 'Retención nivel Klaviyo',
      desc:  isEn ? 'Engineered automation flows to maximize repeat purchase and LTV.' : 'Flujos de automatización para maximizar recompra y LTV.' },
  ],
};
const whys = whyMap[n];

const stepTitles = isEn
  ? ['Discovery', 'Architecture', 'Build', 'Launch']
  : ['Descubrimiento', 'Arquitectura', 'Construcción', 'Lanzamiento'];

const titleParts = title.split('.');
const titleMain  = titleParts[0];
const titleHasDot = titleParts.length > 1;

const servicesLink = isEn ? '/en/servicios' : '/servicios';
const contactLink  = isEn ? '/en/contacto'  : '/contacto';

const pageTitle = `${title.replace('.', '')} | Flouvia`;
---

<Layout title={pageTitle} description={desc}>
  <Navbar />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

  <main class="flouvia-masterpiece sd-detail page-bg-unified">

    <!-- ══════════════ HERO ══════════════ -->
    <section class="hero-grand sd-hero">
      <div class="container hero-container">
        <div class="hero-content">

          <a href={servicesLink} class="sd-back-link reveal-blur" style="--delay: 0.05s;">
            <span class="sd-back-arrow">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
            </span>
            <span>{isEn ? 'Back to Services' : 'Volver a Servicios'}</span>
          </a>

          <div class="hero-text-zone" id="hero-parallax">
            <p class="eyebrow reveal-blur" style="--delay: 0.15s;">{cat}</p>
            <h1 class="hero-title reveal-blur" style="--delay: 0.25s;">
              <span class="title-bold">{titleMain}</span>{titleHasDot && (
                <span class="editorial title-serif">.</span>
              )}
            </h1>
          </div>

          <div class="hero-bottom reveal-blur" style="--delay: 0.4s;">
            <p class="hero-desc">{desc}</p>
            <div class="hero-actions-wrapper">
              <a href={contactLink} class="btn-luxe">
                <span>{btn}</span>
                <div class="btn-shimmer"></div>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════ METRICS BAR (DARK BLUEPRINT) ══════════════ -->
    <section class="dark-section sd-metrics">
      <div class="texture-noise-micro"></div>
      <div class="bp-line-x bp-line-top"></div>
      <div class="bp-line-x bp-line-bottom"></div>

      <div class="container relative-z">
        <div class="sd-metrics-grid blueprint-reveal">
          {metrics.map((m, i) => {
            const numericVal = parseFloat(m.val);
            const isNumeric  = !isNaN(numericVal);
            return (
              <div class="sd-metric-cell bp-fade-up" style={`--delay: ${0.1 + i * 0.08}s`}>
                <div class="sd-metric-value">
                  <span class="sd-metric-num"
                        data-target={isNumeric ? numericVal : 0}
                        data-display={!isNumeric ? m.val : ''}>
                    {isNumeric ? '0' : m.val}
                  </span>
                  {m.suf && <span class="sd-metric-suf">{m.suf}</span>}
                </div>
                <span class="sd-metric-label">{m.label}</span>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ══════════════ CAPABILITIES (BENTO MODULES) ══════════════ -->
    <section class="services-showcase sd-caps">
      <div class="container">

        <div class="section-header reveal-blur" style="--delay: 0s;">
          <p class="eyebrow">{t('serv.page.capabilities')}</p>
          <h2 class="section-heading">
            {isEn ? 'What we' : 'Lo que'} <span class="editorial">{isEn ? 'engineer.' : 'construimos.'}</span>
          </h2>
          <p class="section-sub">
            {isEn
              ? 'Four engineering modules. Each one removes a specific friction in your operation.'
              : 'Cuatro módulos de ingeniería. Cada uno elimina una fricción específica de tu operación.'}
          </p>
        </div>

        <div class="bento-modules-grid">
          {caps.map((cap, i) => (
            <div class="b-module squircle-math reveal-up" data-i={i} style={`--delay: ${0.1 + i * 0.08}s`}>
              <div class="b-mod-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={icons[i]}></svg>
              </div>
              <div class="b-mod-num">/0{i + 1}</div>
              <h3>{cap.title}</h3>
              <p>{cap.desc}</p>
            </div>
          ))}
        </div>

        <div class="dna-footer reveal-fade" style="--delay: 0.3s;">
          <span class="dna-label">{isEn ? 'STACK DNA:' : 'DNA DEL STACK:'}</span>
          <div class="dna-pills">
            {stack.map(tech => (
              <span>{tech}</span>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════ PROCESO (PROTOCOL TIMELINE) ══════════════ -->
    <section class="protocol-section sd-process">
      <div class="container protocol-grid">

        <div class="protocol-sticky-col reveal-blur">
          <p class="eyebrow">{t('serv.page.process')}</p>
          <h2 class="section-heading">
            {isEn ? 'Execution' : 'Protocolo'} <br>
            <span class="editorial">{isEn ? 'Protocol.' : 'de ejecución.'}</span>
          </h2>
          <p class="protocol-intro">
            {isEn
              ? 'Four phases. No improvisation, no surprises — every milestone documented, every commit reviewed.'
              : 'Cuatro fases. Sin improvisación, sin sorpresas — cada hito documentado, cada commit revisado.'}
          </p>

          <div class="sd-process-meter">
            <span class="sd-pp-label">{isEn ? 'PHASE' : 'FASE'}</span>
            <span class="sd-pp-current" id="sd-pp-current">01</span>
            <span class="sd-pp-of">/ 04</span>
          </div>
        </div>

        <div class="protocol-timeline">
          <div class="timeline-track"></div>

          {steps.map((step, i) => (
            <div class="protocol-step reveal-blur" data-step={i} style={`--delay: ${0.1 + i * 0.1}s`}>
              <div class="step-node"><div class="node-core"></div></div>
              <div class="step-content">
                <div class="watermark-num">0{i + 1}</div>
                <h4>{stepTitles[i]}</h4>
                <p>{step}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════ WHY (HARDWARE TILT GRID) ══════════════ -->
    <section class="why-flouvia-hardware sd-why">
      <div class="container">

        <div class="wf-header reveal-fade">
          <p class="eyebrow">{isEn ? 'WHY THIS, WHY US' : 'POR QUÉ ESTO, POR QUÉ NOSOTROS'}</p>
          <h2 class="wf-title">
            {isEn ? 'The Flouvia' : 'El estándar'} <span class="editorial">{isEn ? 'standard.' : 'Flouvia.'}</span>
          </h2>
        </div>

        <div class="wf-hardware-grid">
          {whys.map((w, i) => (
            <div class="hw-card squircle-math reveal-up tilt-card" style={`--delay: ${0.1 + i * 0.1}s`}>
              <div class="hw-glow-overlay"></div>
              <div class="hw-inner">
                <span class="hw-num">/0{i + 1}</span>
                <div class="hw-text-zone">
                  <h3>{w.title}</h3>
                  <p>{w.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════ CTA ══════════════ -->
    <section class="cta-final-clean sd-cta">
      <div class="container">
        <div class="cta-box-refined squircle-pro reveal-blur">
          <div class="texture-noise-micro"></div>
          <div class="cta-flex relative-z">
            <div class="cta-text">
              <p class="eyebrow" style="color: rgba(255,255,255,0.6); letter-spacing: 4px;">
                {isEn ? 'THE NEXT STEP' : 'EL SIGUIENTE PASO'}
              </p>
              <h2 class="cta-title">
                {isEn ? 'Scale your' : 'Escala tu'} <span class="editorial" style="color: #fff;">{isEn ? 'operation.' : 'operación.'}</span>
              </h2>
            </div>
            <a href={contactLink} class="btn-luxe-main">
              <span>{t('serv.page.cta.btn')}</span>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <WhatsApp />
</Layout>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    width: 100%; position: relative;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    -webkit-tap-highlight-color: transparent;
  }
  ::selection { background: #0a192f; color: #ffffff; }

  :root {
    --color-bg: #ffffff;
    --color-bg-soft: #fcfcfc;
    --color-blue-icy: #f4f6f9;
    --color-blue-deep: #0a192f;
    --color-glass-blue: rgba(10, 25, 47, 0.85);
    --color-text: #050505;
    --color-text-muted: #555555;
    --color-border: rgba(0, 0, 0, 0.08);
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-serif: 'Instrument Serif', serif;
    --ease-ios: cubic-bezier(0.25, 1, 0.5, 1);
    --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.05);
    --ease-smooth: cubic-bezier(0.16, 1, 0.3, 1);
  }

  body { background-color: var(--color-bg); color: var(--color-text); font-family: var(--font-sans); margin: 0; }

  .flouvia-masterpiece { width: 100%; position: relative; overflow-x: clip; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 5%; position: relative; }
  .editorial { font-family: var(--font-serif); font-style: italic; font-weight: 400; color: #222; }
  .eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; color: #888; text-transform: uppercase; margin-bottom: 1rem; }

  .reveal-blur {
    opacity: 0; transform: translateY(30px) scale(0.98); filter: blur(8px);
    animation: sd-reveal 1s var(--ease-spring) forwards;
    animation-play-state: paused; animation-delay: var(--delay, 0s);
  }
  .reveal-blur.active { animation-play-state: running; }
  @keyframes sd-reveal { to { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); } }

  .reveal-fade {
    opacity: 0; transform: translateY(30px) scale(0.98);
    animation: sd-revealFade 1s var(--ease-spring) forwards;
    animation-play-state: paused; animation-delay: var(--delay, 0s);
  }
  .reveal-fade.active { animation-play-state: running; }
  @keyframes sd-revealFade { to { opacity: 1; transform: translateY(0) scale(1); } }

  .reveal-up {
    opacity: 0; transform: translateY(60px);
    animation: sd-revealUp 1s var(--ease-smooth) forwards;
    animation-play-state: paused; animation-delay: var(--delay, 0s);
  }
  .reveal-up.active { animation-play-state: running; }
  @keyframes sd-revealUp { to { opacity: 1; transform: translateY(0); } }

  .btn-luxe {
    position: relative; display: inline-flex; align-items: center; gap: 12px;
    background: var(--color-text); color: #fff;
    padding: 16px 38px; border-radius: 100px;
    text-decoration: none; font-size: 0.9rem; font-weight: 600;
    transition: all 0.5s var(--ease-spring); overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.04), 0 10px 20px rgba(0,0,0,0.08);
  }
  .btn-luxe span { position: relative; z-index: 2; }
  .btn-shimmer {
    position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    transform: skewX(-20deg); transition: 0s; z-index: 1;
  }
  .btn-luxe:hover { transform: translateY(-4px); box-shadow: 0 6px 12px rgba(0,0,0,0.08), 0 15px 30px rgba(0,0,0,0.15); }
  .btn-luxe:hover .btn-shimmer { left: 200%; transition: left 0.8s var(--ease-smooth); }
  .btn-luxe:active { transform: scale(0.97); transition: 0.1s; }

  .squircle-math { border-radius: 20px; overflow: hidden; transform: translateZ(0); }
  .squircle-pro  { border-radius: 36px; overflow: hidden; transform: translateZ(0); }

  .texture-noise-micro {
    position: absolute; inset: 0;
