---
// src/components/PlantillaServicios.astro
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import WhatsApp from './WhatsApp.astro';

import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';
---

<Layout title={`Flouvia | ${t('serv.hero.badge')}`}>
    <Navbar />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

    <main class="flouvia-masterpiece page-bg-unified">
        
        <section class="hero-grand">
            <div class="container hero-container">
                <div class="hero-content">
                    <div class="hero-text-zone" id="hero-parallax">
                        <p class="eyebrow reveal-blur" style="--delay: 0.1s;">
                            {t('serv.hero.badge')}
                        </p>
                        <h1 class="hero-title reveal-blur" style="--delay: 0.2s;">
                            <span class="title-bold">{t('serv.hero.title1')}</span><br>
                            <span class="editorial title-serif">{t('serv.hero.title2')}</span>
                        </h1>
                    </div>
                    
                    <div class="hero-bottom reveal-blur" style="--delay: 0.4s;">
                        <p class="hero-desc">{t('serv.hero.desc')}</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="philosophy-blueprint dark-section">
            <div class="texture-noise-micro"></div>
            
            <div class="bp-line-x bp-line-top"></div>
            <div class="bp-line-x bp-line-bottom"></div>

            <div class="container relative-z">
                <div class="blueprint-grid blueprint-reveal">
                    
                    <div class="bp-col bp-header-col">
                        <div class="bp-content">
                            <span class="p-badge">{t('serv.why.badge')}</span>
                            <h2 class="p-title">{t('serv.why.title')} <br><span class="editorial text-dim">{t('serv.why.title_ed')}</span></h2>
                            
                            <a href="/contacto" class="sleek-btn-light bp-fade-up" style="--delay: 0.5s;">
                                <span>{t('serv.why.btn')}</span>
                                <div class="m-circle-light">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        </div>
                        <div class="bp-line-y"></div>
                    </div>
                    
                    <div class="bp-col">
                        <div class="bp-content bp-fade-up" style="--delay: 0.6s;">
                            <span class="bp-num">01</span>
                            <span class="p-val-title">{t('serv.why.1.title')}</span>
                            <p>{t('serv.why.1.desc')}</p>
                        </div>
                        <div class="bp-line-y"></div>
                    </div>
                    
                    <div class="bp-col">
                        <div class="bp-content bp-fade-up" style="--delay: 0.7s;">
                            <span class="bp-num">02</span>
                            <span class="p-val-title">{t('serv.why.2.title')}</span>
                            <p>{t('serv.why.2.desc')}</p>
                        </div>
                        <div class="bp-line-y"></div>
                    </div>
                    
                    <div class="bp-col bp-last">
                        <div class="bp-content bp-fade-up" style="--delay: 0.8s;">
                            <span class="bp-num">03</span>
                            <span class="p-val-title">{t('serv.why.3.title')}</span>
                            <p>{t('serv.why.3.desc')}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="services-showcase">
            <div class="container">
                
                <div class="master-service-row" id="s1">
                    <div class="ms-left">
                        <div class="ms-sticky-content">
                            <span class="ms-index">{t('serv.1.cat')}</span>
                            <div class="ms-progress-track">
                                <div class="ms-progress-bar"></div>
                            </div>
                            <a href={isEn ? '/en/servicios/ecommerce' : '/servicios/ecommerce'} class="magnetic-btn-minimal">
                                <span class="btn-text">{t('serv.1.btn')}</span>
                                <div class="m-circle">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        </div>
                    </div>
                    <div class="ms-right">
                        <div class="ms-content-wrap reveal-up">
                            <h2 class="ms-massive-title">{t('serv.1.title')}</h2>
                            <p class="ms-main-desc">{t('serv.1.desc')}</p>
                            
                            <div class="bento-modules-grid">
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <rect x="3" y="3" width="18" height="18" rx="4" stroke-opacity="0.3"></rect>
                                            <path d="M9 3v18M15 3v18" stroke-opacity="1"></path>
                                            <path d="M3 9h18M3 15h18" stroke-opacity="0.3"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.1.d1.t')}</h3>
                                    <p>{t('serv.1.d1.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M12 2L2 7l10 5 10-5-10-5z" stroke-opacity="1"></path>
                                            <path d="M2 17l10 5 10-5" stroke-opacity="0.3"></path>
                                            <path d="M2 12l10 5 10-5" stroke-opacity="0.6"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.1.d2.t')}</h3>
                                    <p>{t('serv.1.d2.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <rect x="5" y="8" width="14" height="12" rx="2" stroke-opacity="1"></rect>
                                            <path d="M8 8V6a4 4 0 0 1 8 0v2" stroke-opacity="0.3"></path>
                                            <circle cx="12" cy="14" r="1" stroke-opacity="1"></circle>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.1.d3.t')}</h3>
                                    <p>{t('serv.1.d3.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <polyline points="16 16 22 12 16 8" stroke-opacity="1"></polyline>
                                            <line x1="22" y1="12" x2="2" y2="12" stroke-opacity="0.3"></line>
                                            <path d="M8 4L2 12l6 8" stroke-opacity="0.3"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.1.d4.t')}</h3>
                                    <p>{t('serv.1.d4.d')}</p>
                                </div>
                            </div>

                            <div class="dna-footer">
                                <span class="dna-label">STACK DNA:</span>
                                <div class="dna-pills">
                                    <span>{t('serv.1.t1')}</span>
                                    <span>{t('serv.1.t2')}</span>
                                    <span>{t('serv.1.t3')}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="master-service-row" id="s2">
                    <div class="ms-left">
                        <div class="ms-sticky-content">
                            <span class="ms-index">{t('serv.2.cat')}</span>
                            <div class="ms-progress-track">
                                <div class="ms-progress-bar"></div>
                            </div>
                            <a href={isEn ? '/en/servicios/b2b' : '/servicios/b2b'} class="magnetic-btn-minimal">
                                <span class="btn-text">{t('serv.2.btn')}</span>
                                <div class="m-circle">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        </div>
                    </div>
                    <div class="ms-right">
                        <div class="ms-content-wrap reveal-up">
                            <h2 class="ms-massive-title">{t('serv.2.title')}</h2>
                            <p class="ms-main-desc">{t('serv.2.desc')}</p>
                            
                            <div class="bento-modules-grid">
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <rect x="3" y="11" width="18" height="11" rx="2" stroke-opacity="1"></rect>
                                            <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke-opacity="0.3"></path>
                                            <circle cx="12" cy="16" r="1" stroke-opacity="1"></circle>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.2.d1.t')}</h3>
                                    <p>{t('serv.2.d1.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <line x1="4" y1="21" x2="4" y2="14" stroke-opacity="0.3"></line>
                                            <line x1="4" y1="10" x2="4" y2="3" stroke-opacity="1"></line>
                                            <line x1="12" y1="21" x2="12" y2="12" stroke-opacity="0.3"></line>
                                            <line x1="12" y1="8" x2="12" y2="3" stroke-opacity="1"></line>
                                            <line x1="20" y1="21" x2="20" y2="16" stroke-opacity="0.3"></line>
                                            <line x1="20" y1="12" x2="20" y2="3" stroke-opacity="1"></line>
                                            <circle cx="4" cy="12" r="2" stroke-opacity="1"></circle>
                                            <circle cx="12" cy="10" r="2" stroke-opacity="1"></circle>
                                            <circle cx="20" cy="14" r="2" stroke-opacity="1"></circle>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.2.d2.t')}</h3>
                                    <p>{t('serv.2.d2.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" stroke-opacity="1"></polygon>
                                            <path d="M13 2L3 14h9v8l9-12h-9z" stroke-opacity="0.3"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.2.d3.t')}</h3>
                                    <p>{t('serv.2.d3.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke-opacity="1"></path>
                                            <polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke-opacity="0.3"></polyline>
                                            <line x1="12" y1="22.08" x2="12" y2="12" stroke-opacity="0.3"></line>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.2.d4.t')}</h3>
                                    <p>{t('serv.2.d4.d')}</p>
                                </div>
                            </div>

                            <div class="dna-footer">
                                <span class="dna-label">STACK DNA:</span>
                                <div class="dna-pills">
                                    <span>{t('serv.2.t1')}</span>
                                    <span>{t('serv.2.t2')}</span>
                                    <span>{t('serv.2.t3')}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="master-service-row" id="s3">
                    <div class="ms-left">
                        <div class="ms-sticky-content">
                            <span class="ms-index">{t('serv.3.cat')}</span>
                            <div class="ms-progress-track">
                                <div class="ms-progress-bar"></div>
                            </div>
                            <a href={isEn ? '/en/servicios/automatizacion' : '/servicios/automatizacion'} class="magnetic-btn-minimal">
                                <span class="btn-text">{t('serv.3.btn')}</span>
                                <div class="m-circle">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        </div>
                    </div>
                    <div class="ms-right">
                        <div class="ms-content-wrap reveal-up">
                            <h2 class="ms-massive-title">{t('serv.3.title')}</h2>
                            <p class="ms-main-desc">{t('serv.3.desc')}</p>
                            
                            <div class="bento-modules-grid">
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <ellipse cx="12" cy="5" rx="9" ry="3" stroke-opacity="1"></ellipse>
                                            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" stroke-opacity="0.3"></path>
                                            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" stroke-opacity="0.6"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.3.d1.t')}</h3>
                                    <p>{t('serv.3.d1.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <rect x="3" y="3" width="7" height="7" rx="1" stroke-opacity="1"></rect>
                                            <rect x="14" y="3" width="7" height="7" rx="1" stroke-opacity="0.3"></rect>
                                            <rect x="14" y="14" width="7" height="7" rx="1" stroke-opacity="1"></rect>
                                            <rect x="3" y="14" width="7" height="7" rx="1" stroke-opacity="0.3"></rect>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.3.d2.t')}</h3>
                                    <p>{t('serv.3.d2.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" stroke-opacity="1"></path>
                                            <path d="M13.73 21a2 2 0 0 1-3.46 0" stroke-opacity="0.3"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.3.d3.t')}</h3>
                                    <p>{t('serv.3.d3.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <rect x="2" y="7" width="20" height="14" rx="2" ry="2" stroke-opacity="1"></rect>
                                            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" stroke-opacity="0.3"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.3.d4.t')}</h3>
                                    <p>{t('serv.3.d4.d')}</p>
                                </div>
                            </div>

                            <div class="dna-footer">
                                <span class="dna-label">STACK DNA:</span>
                                <div class="dna-pills">
                                    <span>{t('serv.3.t1')}</span>
                                    <span>{t('serv.3.t2')}</span>
                                    <span>{t('serv.3.t3')}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="master-service-row" id="s4" style="border-bottom: none; padding-bottom: 2rem;">
                    <div class="ms-left">
                        <div class="ms-sticky-content">
                            <span class="ms-index">{t('serv.4.cat')}</span>
                            <div class="ms-progress-track">
                                <div class="ms-progress-bar"></div>
                            </div>
                            <a href={isEn ? '/en/servicios/growth' : '/servicios/growth'} class="magnetic-btn-minimal">
                                <span class="btn-text">{t('serv.4.btn')}</span>
                                <div class="m-circle">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        </div>
                    </div>
                    <div class="ms-right">
                        <div class="ms-content-wrap reveal-up">
                            <h2 class="ms-massive-title">{t('serv.4.title')}</h2>
                            <p class="ms-main-desc">{t('serv.4.desc')}</p>
                            
                            <div class="bento-modules-grid">
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <circle cx="11" cy="11" r="8" stroke-opacity="1"></circle>
                                            <line x1="21" y1="21" x2="16.65" y2="16.65" stroke-opacity="0.3"></line>
                                            <path d="M11 8v6M8 11h6" stroke-opacity="0.3"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.4.d1.t')}</h3>
                                    <p>{t('serv.4.d1.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M16 3h5v5" stroke-opacity="1"></path>
                                            <path d="M8 3H3v5" stroke-opacity="0.3"></path>
                                            <path d="M12 22v-8.3a4 4 0 0 0-1.17-2.83L3 3" stroke-opacity="0.3"></path>
                                            <path d="M15 9l6-6" stroke-opacity="1"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.4.d2.t')}</h3>
                                    <p>{t('serv.4.d2.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke-opacity="0.3"></path>
                                            <circle cx="12" cy="12" r="3" stroke-opacity="1"></circle>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.4.d3.t')}</h3>
                                    <p>{t('serv.4.d3.d')}</p>
                                </div>
                                <div class="b-module squircle-math">
                                    <div class="b-mod-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M21 2v6h-6" stroke-opacity="1"></path>
                                            <path d="M3 12a9 9 0 0 1 15-6.7L21 8" stroke-opacity="1"></path>
                                            <path d="M3 22v-6h6" stroke-opacity="0.3"></path>
                                            <path d="M21 12a9 9 0 0 1-15 6.7L3 16" stroke-opacity="0.3"></path>
                                        </svg>
                                    </div>
                                    <h3>{t('serv.4.d4.t')}</h3>
                                    <p>{t('serv.4.d4.d')}</p>
                                </div>
                            </div>

                            <div class="dna-footer">
                                <span class="dna-label">STACK DNA:</span>
                                <div class="dna-pills">
                                    <span>{t('serv.4.t1')}</span>
                                    <span>{t('serv.4.t2')}</span>
                                    <span>{t('serv.4.t3')}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section class="why-flouvia-hardware">
            <div class="container">
                <div class="wf-header reveal-fade">
                    <p class="eyebrow">{t('serv.choose.badge')}</p>
                    <h2 class="wf-title">
                        {t('serv.choose.title')} <span class="editorial">{t('serv.choose.title_ed')}</span>
                    </h2>
                </div>

                <div class="wf-hardware-grid">
                    
                    <div class="hw-card squircle-math reveal-up tilt-card" style="--delay: 0.1s;">
                        <div class="hw-glow-overlay"></div>
                        <div class="hw-inner">
                            <span class="hw-num">/01</span>
                            <div class="hw-text-zone">
                                <h3>{t('serv.choose.1.title')}</h3>
                                <p>{t('serv.choose.1.desc')}</p>
                            </div>
                        </div>
                    </div>

                    <div class="hw-card squircle-math reveal-up tilt-card" style="--delay: 0.2s;">
                        <div class="hw-glow-overlay"></div>
                        <div class="hw-inner">
                            <span class="hw-num">/02</span>
                            <div class="hw-text-zone">
                                <h3>{t('serv.choose.2.title')}</h3>
                                <p>{t('serv.choose.2.desc')}</p>
                            </div>
                        </div>
                    </div>

                    <div class="hw-card squircle-math reveal-up tilt-card" style="--delay: 0.3s;">
                        <div class="hw-glow-overlay"></div>
                        <div class="hw-inner">
                            <span class="hw-num">/03</span>
                            <div class="hw-text-zone">
                                <h3>{t('serv.choose.3.title')}</h3>
                                <p>{t('serv.choose.3.desc')}</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <section class="cta-final-clean">
            <div class="container">
                <div class="cta-box-refined squircle-pro reveal-blur">
                    <div class="texture-noise-micro"></div>
                    <div class="cta-flex relative-z">
                        <div class="cta-text">
                            <p class="eyebrow" style="color: rgba(255,255,255,0.6); letter-spacing: 4px;">
                                {isEn ? 'THE NEXT STEP' : 'EL SIGUIENTE PASO'}
                            </p>
                            <h2 class="cta-title">
                                {isEn ? 'Scale your' : 'Escale su'} <span class="editorial" style="color: #fff;">{isEn ? 'operation.' : 'operación.'}</span>
                            </h2>
