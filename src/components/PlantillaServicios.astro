    import { SplitText } from 'gsap/SplitText';
    gsap.registerPlugin(ScrollTrigger, SplitText);

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Kill ALL CSS reveal animations + reset to visible state ──
    // GSAP will explicitly hide via gsap.set() and animate in via gsap.to()
    document.querySelectorAll<HTMLElement>(
        '.reveal-blur, .reveal-fade, .reveal-up, .bp-fade-up, .blueprint-reveal'
    ).forEach(el => {
        el.style.animation = 'none';
        el.style.opacity = '1';
        el.style.filter = 'none';
        el.style.transform = 'none';
    });
    // Disable CSS transitions on blueprint lines (GSAP will animate width/height)
    document.querySelectorAll<HTMLElement>('.bp-line-x, .bp-line-y').forEach(el => {
        el.style.transition = 'none';
    });

    // ── Robust ScrollTrigger refresh (waits for fonts + window.load) ──
    const robustRefresh = () => {
        const winLoad = new Promise<void>((resolve) => {
            if (document.readyState === 'complete') resolve();
            else window.addEventListener('load', () => resolve(), { once: true });
        });
        const fontsReady = (document as any).fonts?.ready ?? Promise.resolve();
        Promise.all([winLoad, fontsReady]).then(() => {
            setTimeout(() => ScrollTrigger.refresh(), 120);
        });
    };
    robustRefresh();

    if (!reduced) {
        const mm = gsap.matchMedia();

        // Helper to safely create SplitText (returns null if element missing)
        const splitWords = (el: HTMLElement | null) => {
            if (!el) return null;
            const split = SplitText.create(el, { type: 'lines,words', linesClass: 'lx-line-mask' });
            gsap.set(split.words, { yPercent: 110 });
            return split;
        };

        // ── DESKTOP ────────────────────────────────────────────────────
        mm.add('(min-width: 769px)', () => {

            // HERO ───────────────────────────────────────────────
            const heroTitle   = document.querySelector<HTMLElement>('.hero-title');
            const heroEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const heroBottom  = document.querySelector<HTMLElement>('.hero-bottom');

            // Hide immediately so nothing flashes
            if (heroEyebrow) gsap.set(heroEyebrow, { opacity: 0, y: 14 });
            if (heroBottom)  gsap.set(heroBottom.children, { opacity: 0, y: 16 });
            const heroSplit = heroTitle ? SplitText.create(heroTitle, {
                type: 'lines,words', linesClass: 'lx-line-mask',
            }) : null;
            if (heroSplit) gsap.set(heroSplit.words, { yPercent: 105 });

            const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (heroEyebrow) tl.to(heroEyebrow, { opacity: 1, y: 0, duration: 1.4 }, 0.1);
            if (heroSplit)   tl.to(heroSplit.words, {
                yPercent: 0, duration: 1.5, stagger: { amount: 0.5, from: 'start' },
            }, 0.35);
            if (heroBottom && heroBottom.children.length > 0) {
                tl.to(heroBottom.children, {
                    opacity: 1, y: 0, duration: 1.1, ease: 'power3.out', stagger: 0.12,
                }, 1.0);
            }

            // Hero parallax
            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 28, opacity: 0.15, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 0.8 },
                });
            }

            // PHILOSOPHY BLUEPRINT ───────────────────────────────
            const bpSection = document.querySelector<HTMLElement>('.philosophy-blueprint');
            if (bpSection) {
                const bpLineTop    = bpSection.querySelector<HTMLElement>('.bp-line-top');
                const bpLineBottom = bpSection.querySelector<HTMLElement>('.bp-line-bottom');
                const bpLineYs     = bpSection.querySelectorAll<HTMLElement>('.bp-line-y');
                const bpBadge      = bpSection.querySelector<HTMLElement>('.p-badge');
                const bpTitle      = bpSection.querySelector<HTMLElement>('.p-title');
                const bpBtn        = bpSection.querySelector<HTMLElement>('.sleek-btn-light');
                const bpCols       = bpSection.querySelectorAll<HTMLElement>('.bp-col:not(.bp-header-col) .bp-content');

                // Hide all immediately
                if (bpLineTop)    gsap.set(bpLineTop,    { width: 0 });
                if (bpLineBottom) gsap.set(bpLineBottom, { width: 0 });
                gsap.set(bpLineYs, { height: 0 });
                if (bpBadge) gsap.set(bpBadge, { opacity: 0, y: 16 });
                if (bpBtn)   gsap.set(bpBtn,   { opacity: 0, y: 12 });
                gsap.set(bpCols, { opacity: 0, y: 20 });
                const bpSplit = splitWords(bpTitle);

                const bpTl = gsap.timeline({
                    scrollTrigger: { trigger: bpSection, start: 'top 85%', once: true },
                });
                if (bpLineTop)    bpTl.to(bpLineTop,    { width: '100%', duration: 1.5, ease: 'expo.out' }, 0);
                if (bpLineBottom) bpTl.to(bpLineBottom, { width: '100%', duration: 1.5, ease: 'expo.out' }, 0.3);
                bpLineYs.forEach((line, i) => {
                    bpTl.to(line, { height: '100%', duration: 1.2, ease: 'expo.out' }, 0.4 + i * 0.1);
                });
                if (bpBadge) bpTl.to(bpBadge, { opacity: 1, y: 0, duration: 0.9, ease: 'expo.out' }, 0.25);
                if (bpSplit) bpTl.to(bpSplit.words, {
                    yPercent: 0, duration: 1.3, ease: 'expo.out', stagger: { amount: 0.4 },
                }, 0.4);
                if (bpBtn) bpTl.to(bpBtn, { opacity: 1, y: 0, duration: 0.9, ease: 'expo.out' }, 0.75);
                bpCols.forEach((col, i) => {
                    bpTl.to(col, { opacity: 1, y: 0, duration: 1.0, ease: 'expo.out' }, 0.5 + i * 0.12);
                });
            }

            // SERVICES ROWS ──────────────────────────────────────
            document.querySelectorAll<HTMLElement>('.master-service-row').forEach((row) => {
                const stickyContent = row.querySelector<HTMLElement>('.ms-sticky-content');
                const title   = row.querySelector<HTMLElement>('.ms-massive-title');
                const desc    = row.querySelector<HTMLElement>('.ms-main-desc');
                const modules = row.querySelectorAll<HTMLElement>('.b-module');
                const dna     = row.querySelector<HTMLElement>('.dna-footer');

                if (stickyContent) gsap.set(stickyContent, { opacity: 0, x: -24 });
                if (desc) gsap.set(desc, { opacity: 0, y: 18 });
                gsap.set(modules, { opacity: 0, y: 28 });
                if (dna) gsap.set(dna, { opacity: 0 });
                const titleSplit = splitWords(title);

                const rowTl = gsap.timeline({
                    scrollTrigger: { trigger: row, start: 'top 85%', once: true },
                });
                if (stickyContent) rowTl.to(stickyContent, { opacity: 1, x: 0, duration: 1.0, ease: 'expo.out' }, 0);
                if (titleSplit)    rowTl.to(titleSplit.words, {
                    yPercent: 0, duration: 1.4, ease: 'expo.out', stagger: { amount: 0.35 },
                }, 0.1);
                if (desc) rowTl.to(desc, { opacity: 1, y: 0, duration: 1.1, ease: 'expo.out' }, 0.5);
                modules.forEach((mod, j) => {
                    rowTl.to(mod, { opacity: 1, y: 0, duration: 1.0, ease: 'expo.out' }, 0.7 + j * 0.07);
                });
                if (dna) rowTl.to(dna, { opacity: 1, duration: 0.8, ease: 'expo.out' }, 1.1);
            });

            // WHY FLOUVIA HARDWARE ───────────────────────────────
            const wfSection = document.querySelector<HTMLElement>('.why-flouvia-hardware');
            if (wfSection) {
                const eyebrow = wfSection.querySelector<HTMLElement>('.eyebrow');
                const wfTitle = wfSection.querySelector<HTMLElement>('.wf-title');
                const cards   = wfSection.querySelectorAll<HTMLElement>('.hw-card');

                if (eyebrow) gsap.set(eyebrow, { opacity: 0, y: 14 });
                gsap.set(cards, { opacity: 0, y: 30 });
                const wfSplit = splitWords(wfTitle);

                const wfTl = gsap.timeline({
                    scrollTrigger: { trigger: wfSection, start: 'top 85%', once: true },
                });
                if (eyebrow) wfTl.to(eyebrow, { opacity: 1, y: 0, duration: 1.2, ease: 'expo.out' }, 0);
                if (wfSplit) wfTl.to(wfSplit.words, {
                    yPercent: 0, duration: 1.4, ease: 'expo.out', stagger: { amount: 0.4 },
                }, 0.2);
                cards.forEach((card, i) => {
                    wfTl.to(card, { opacity: 1, y: 0, duration: 1.1, ease: 'expo.out' }, 0.55 + i * 0.1);
                });
            }

            // CTA FINAL ──────────────────────────────────────────
            const ctaSection = document.querySelector<HTMLElement>('.cta-final-clean');
            if (ctaSection) {
                const ctaBox     = ctaSection.querySelector<HTMLElement>('.cta-box-refined');
                const ctaEyebrow = ctaSection.querySelector<HTMLElement>('.eyebrow');
                const ctaTitle   = ctaSection.querySelector<HTMLElement>('.cta-title');
                const ctaBtn     = ctaSection.querySelector<HTMLElement>('.btn-luxe-main');

                if (ctaBox)     gsap.set(ctaBox,     { opacity: 0, y: 30, scale: 0.97 });
                if (ctaEyebrow) gsap.set(ctaEyebrow, { opacity: 0, y: 12 });
                if (ctaBtn)     gsap.set(ctaBtn,     { opacity: 0, y: 16 });
                const ctaSplit = splitWords(ctaTitle);

                const ctaTl = gsap.timeline({
                    scrollTrigger: { trigger: ctaSection, start: 'top 85%', once: true },
                });
                if (ctaBox)     ctaTl.to(ctaBox,     { opacity: 1, y: 0, scale: 1, duration: 1.3, ease: 'expo.out' }, 0);
                if (ctaEyebrow) ctaTl.to(ctaEyebrow, { opacity: 1, y: 0, duration: 1.0, ease: 'expo.out' }, 0.35);
                if (ctaSplit)   ctaTl.to(ctaSplit.words, {
                    yPercent: 0, duration: 1.3, ease: 'expo.out', stagger: { amount: 0.3 },
                }, 0.45);
                if (ctaBtn)     ctaTl.to(ctaBtn,     { opacity: 1, y: 0, duration: 1.0, ease: 'expo.out' }, 0.85);
            }
        });

        // ── MOBILE ─────────────────────────────────────────────────────
        mm.add('(max-width: 768px)', () => {
            const mHeroTitle  = document.querySelector<HTMLElement>('.hero-title');
            const mEyebrow    = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const mHeroBottom = document.querySelector<HTMLElement>('.hero-bottom');

            if (mEyebrow)    gsap.set(mEyebrow,    { opacity: 0, y: 10 });
            if (mHeroTitle)  gsap.set(mHeroTitle,  { opacity: 0, y: 24 });
            if (mHeroBottom) gsap.set(mHeroBottom.children, { opacity: 0, y: 14 });

            const tlm = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (mEyebrow)   tlm.to(mEyebrow,   { opacity: 1, y: 0, duration: 1.1 }, 0.1);
            if (mHeroTitle) tlm.to(mHeroTitle, { opacity: 1, y: 0, duration: 1.2 }, 0.3);
            if (mHeroBottom && mHeroBottom.children.length > 0) {
                tlm.to(mHeroBottom.children, {
                    opacity: 1, y: 0, duration: 1.0, ease: 'power3.out', stagger: 0.1,
                }, 0.85);
            }
        });
    }

    // ── SCROLL PROGRESS BARS ────────────────────────────────────────
    window.addEventListener('scroll', () => {
        document.querySelectorAll('.master-service-row').forEach(section => {
            const bar = section.querySelector('.ms-progress-bar') as HTMLElement;
            if (!bar) return;
            const rect = section.getBoundingClientRect();
            if (rect.top <= 140 && rect.bottom >= 0) {
                const total = (section as HTMLElement).offsetHeight;
                const pct = Math.min(Math.max((Math.abs(rect.top - 140) / (total - 140)) * 100, 0), 100);
                bar.style.height = `${pct}%`;
            } else if (rect.top > 140) {
                bar.style.height = '0%';
            } else {
                bar.style.height = '100%';
            }
        });
    }, { passive: true });

    // ── 3D TILT (APPLE GLOW) ────────────────────────────────────────
    if (window.innerWidth > 768) {
        document.querySelectorAll('.tilt-card').forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = (e as MouseEvent).clientX - rect.left;
                const y = (e as MouseEvent).clientY - rect.top;
                (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
                (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
                const cx = rect.width / 2, cy = rect.height / 2;
                const rx = ((y - cy) / cy) * -5, ry = ((x - cx) / cx) * 5;
                (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.02, 1.02, 1.02)`;
            });
            card.addEventListener('mouseleave', () => {
                (card as HTMLElement).style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
            });
        });
    }

    // ── MAGNETIC BUTTONS ────────────────────────────────────────────
    if (window.innerWidth > 1024) {
        document.querySelectorAll('.magnetic-btn-minimal, .sleek-btn-light').forEach(btn => {
            btn.addEventListener('mousemove', e => {
                const rect = btn.getBoundingClientRect();
                const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
                const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
                (btn as HTMLElement).style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
            });
            btn.addEventListener('mouseleave', () => {
                (btn as HTMLElement).style.transform = 'translate(0, 0)';
            });
        });
    }
</script>