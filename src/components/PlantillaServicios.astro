</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';
    gsap.registerPlugin(ScrollTrigger, SplitText);

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // GSAP controls hero — fully clear CSS fallback (.reveal-blur leaves filter+transform behind)
    document.querySelectorAll<HTMLElement>('.hero-title, .hero-text-zone .eyebrow, .hero-bottom').forEach(el => {
        el.style.animation = 'none';
        el.style.opacity = '1';
        el.style.filter = 'none';
        el.style.transform = 'none';
    });

    // Fallback reveals for non-hero elements
    const revealObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal-blur, .reveal-fade, .reveal-up, .blueprint-reveal').forEach(el => {
        if (!el.closest('.hero-grand')) revealObserver.observe(el);
    });

    if (!reduced) {
        const mm = gsap.matchMedia();

        mm.add('(min-width: 769px)', () => {
            /* HERO — luxury minimalist reveal (pure curtain, no blur, no scale) */
            const heroTitle = document.querySelector<HTMLElement>('.hero-title');
            const heroEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const heroBottom = document.querySelector<HTMLElement>('.hero-bottom');

            const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (heroEyebrow) {
                tl.from(heroEyebrow, { opacity: 0, y: 14, letterSpacing: '7px', duration: 1.4 }, 0.1);
            }
            if (heroTitle) {
                const split = SplitText.create(heroTitle, { type: 'lines,words', linesClass: 'lx-line-mask' });
                gsap.set(split.words, { yPercent: 105 });
                tl.to(split.words, {
                    yPercent: 0, duration: 1.5,
                    stagger: { amount: 0.5, from: 'start' },
                }, 0.35);
            }
            if (heroBottom && heroBottom.children.length > 0) {
                tl.from(gsap.utils.toArray<HTMLElement>(heroBottom.children), {
                    opacity: 0, y: 16, duration: 1.1, ease: 'power3.out',
                    stagger: 0.12,
                }, 1.0);
            }

            /* HERO PARALLAX */
            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 28, opacity: 0.15, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 0.8 },
                });
            }
        });

        mm.add('(max-width: 768px)', () => {
            const mHeroTitle = document.querySelector<HTMLElement>('.hero-title');
            const mEyebrow = document.querySelector<HTMLElement>('.hero-text-zone .eyebrow');
            const mHeroBottom = document.querySelector<HTMLElement>('.hero-bottom');
            const tlm = gsap.timeline({ defaults: { ease: 'expo.out' } });
            if (mEyebrow) tlm.from(mEyebrow, { opacity: 0, y: 10, letterSpacing: '6px', duration: 1.1 }, 0.1);
            if (mHeroTitle) tlm.from(mHeroTitle, { opacity: 0, y: 24, duration: 1.2 }, 0.3);
            if (mHeroBottom && mHeroBottom.children.length > 0) {
                tlm.from(gsap.utils.toArray<HTMLElement>(mHeroBottom.children), {
                    opacity: 0, y: 14, duration: 1.0, ease: 'power3.out',
                    stagger: 0.1,
                }, 0.85);
            }
        });
    }

    // 2. BARRAS DE PROGRESO DE SCROLL
    window.addEventListener('scroll', () => {
        const sections = document.querySelectorAll('.master-service-row');

        sections.forEach(section => {
            const bar = section.querySelector('.ms-progress-bar') as HTMLElement;
            if (!bar) return;

            const rect = section.getBoundingClientRect();

            if (rect.top <= 140 && rect.bottom >= 0) {
                const totalHeight = (section as HTMLElement).offsetHeight;
                const progress = Math.abs(rect.top - 140) / (totalHeight - 140);
                const percent = Math.min(Math.max(progress * 100, 0), 100);
                bar.style.height = `${percent}%`;
            } else if (rect.top > 140) {
                bar.style.height = '0%';
            } else if (rect.bottom < 140) {
                bar.style.height = '100%';
            }
        });
    });

    // 3. EFECTO HARDWARE 3D TILT (APPLE GLOW + ROTACIÓN)
    if (window.innerWidth > 768) {
        document.querySelectorAll('.tilt-card').forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = (e as MouseEvent).clientX - rect.left;
                const y = (e as MouseEvent).clientY - rect.top;
                
                (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
                (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);

                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                const rotateX = ((y - centerY) / centerY) * -5; 
                const rotateY = ((x - centerX) / centerX) * 5;
                
                (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
            });

            card.addEventListener('mouseleave', () => {
                (card as HTMLElement).style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
            });
        });
    }

    // 4. BOTONES MAGNÉTICOS
    if (window.innerWidth > 1024) {
        document.querySelectorAll('.magnetic-btn-minimal, .sleek-btn-light').forEach(btn => {
            btn.addEventListener('mousemove', (e) => {
                const rect = btn.getBoundingClientRect();
                const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
                const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
                (btn as HTMLElement).style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
            });
            
            btn.addEventListener('mouseleave', () => {
                (btn as HTMLElement).style.transform = `translate(0, 0)`;
            });
        });
    }
</script>