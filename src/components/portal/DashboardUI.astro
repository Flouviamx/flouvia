---
// src/components/portal/DashboardUI.astro
import { useTranslations } from '../../i18n/utils';
import { supabase } from '../../lib/supabase';

interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const user = await Astro.locals.currentUser();

// fullName primero (Google OAuth lo rellena siempre), luego partes, luego fallback
const fullName =
  user?.fullName?.trim() ||
  `${user?.firstName || ""} ${user?.lastName || ""}`.trim() ||
  (lang === 'en' ? "Executive" : "Ejecutivo");

const email = user?.emailAddresses[0]?.emailAddress || "flouvia.mx@gmail.com";

const dateOptions: Intl.DateTimeFormatOptions = { weekday: 'long', day: 'numeric', month: 'long' };
const today = new Date().toLocaleDateString(lang === 'en' ? 'en-US' : 'es-MX', dateOptions);

const formatDate = (iso: string | null) => {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString(lang === 'en' ? 'en-US' : 'es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
};

const [{ data: proyecto }, { data: finanza }, { data: roadmapRows }, { data: archivos }] = await Promise.all([
  supabase.from('proyectos').select('*').eq('email_cliente', email).single(),
  supabase.from('finanzas_config').select('*').eq('email_cliente', email).single(),
  supabase.from('roadmap').select('*').eq('email_cliente', email).order('orden_index'),
  supabase.from('boveda_archivos').select('*').eq('email_cliente', email).limit(2),
]);

const fallbackPortalUrl = lang === 'en' ? "/en/portal/facturacion" : "/portal/facturacion";

const data = {
  project: {
    name:     proyecto?.nombre_proyecto ?? (lang === 'en' ? "Global B2B Platform"  : "Plataforma B2B Global"),
    stage:    proyecto?.etapa           ?? (lang === 'en' ? "Frontend Engineering"  : "Ingeniería Backend"),
    progress: proyecto?.progreso        ?? 0,
    uptime:   proyecto?.uptime          ?? "99.98%",
    liveUrl:  proyecto?.live_url        ?? "#",
    deadline: proyecto?.deadline        ?? "—",
  },
  capital: {
    status:    finanza?.auto_pay
                 ? (lang === 'en' ? "Active Subscription" : "Suscripción Activa")
                 : (lang === 'en' ? "Payment Pending"     : "Pago Pendiente"),
    isAutoPay: finanza?.auto_pay        ?? false,
    amount:    finanza?.monto_proximo   ?? 0,
    currency:  finanza?.moneda          ?? "USD",
    nextDate:  formatDate(finanza?.fecha_proxima ?? null),
    portalUrl: finanza?.stripe_portal_url || fallbackPortalUrl,
  },
  services: [
    { label: lang === 'en' ? "Book Consultancy"      : "Agendar Consultoría",  icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, link: lang === 'en' ? "/en/calendario" : "/calendario", info: lang === 'en' ? "2h SLA" : "SLA de 2h" },
    { label: lang === 'en' ? "Document Vault"        : "Bóveda de Documentos", icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`, link: lang === 'en' ? "/en/boveda" : "/boveda",     info: lang === 'en' ? "Contracts" : "Contratos/Entregables" },
    { label: lang === 'en' ? "VIP Technical Support" : "Soporte Técnico VIP",  icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`, link: lang === 'en' ? "/en/soporte" : "/soporte",    info: lang === 'en' ? "Assigned Engineer" : "Ingeniero Asignado" },
  ],
  roadmap: (roadmapRows ?? []).map((r: any) => ({
    title:  r.titulo,
    status: r.status,
    date:   r.fecha_info ?? "",
  })),
  documents: (archivos ?? []).map((a: any) => ({
    name: a.nombre,
    type: a.tipo,
    size: a.size ?? "",
    url:  a.url_descarga,
  })),
};

---

<div class="db-root">
    <div class="db-wrap">

        <!-- ═══════════════ HEADER ═══════════════ -->
        <header class="db-header">
            <div class="db-meta-row" id="db-meta-row">
                <span class="db-mono">{today}</span>
                <span class="db-meta-sep">·</span>
                <span class="db-mono db-mono-ok">
                    <span class="db-meta-dot"></span>
                    {t('portal.uptime')} {data.project.uptime}
                </span>
            </div>

            <h1 class="db-title" id="db-title">
                <span class="db-greeting">{t('portal.greeting')}</span>
                <span class="db-name">{fullName}.</span>
            </h1>

            <p class="db-sub" id="db-sub">
                {t('portal.subtitle')} <strong>{data.project.deadline}</strong>
            </p>
        </header>

        <!-- ═══════════════ GRID ═══════════════ -->
        <div class="db-grid">

            <!-- PROYECTO -->
            <div class="db-card db-c-project" id="card-project">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.project')}</span>
                        <a href={lang === 'en' ? '/en/entorno' : '/entorno'} class="db-ghost-btn">
                            {t('portal.btn.env')}
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
                        </a>
                    </div>

                    <div class="db-proj-body">
                        <div class="db-proj-left">
                            <h2 class="db-proj-name">{data.project.name}</h2>
                            <div class="db-proj-meta">
                                <span class="db-tag">{t('portal.stage')} <strong>{data.project.stage}</strong></span>
                                <span class="db-tag">{lang === 'en' ? 'Deadline' : 'Entrega'}: <strong>{data.project.deadline}</strong></span>
                            </div>
                        </div>

                        <div class="db-ring-shell">
                            <svg class="db-ring-svg" width="140" height="140" viewBox="0 0 160 160">
                                <circle class="db-rt" cx="80" cy="80" r="68"/>
                                <circle class="db-rf" cx="80" cy="80" r="68"
                                    data-progress={data.project.progress}
                                    style="stroke-dasharray:427;stroke-dashoffset:427;"
                                />
                            </svg>
                            <div class="db-ring-mid">
                                <span class="db-pct"><span class="db-cnt" data-target={data.project.progress}>0</span><span class="db-pct-sym">%</span></span>
                                <span class="db-pct-lbl">{lang === 'en' ? 'complete' : 'avance'}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FINANZAS -->
            <div class="db-card db-c-fin" id="card-fin">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.finance')}</span>
                        <span class={`db-pill ${data.capital.isAutoPay ? 'db-pill-ok' : 'db-pill-warn'}`}>
                            {data.capital.status}
                        </span>
                    </div>
                    <div class="db-fin-body">
                        <p class="db-fin-label">{t('portal.next_charge')} · {data.capital.nextDate}</p>
                        <div class="db-fin-amount">
                            <span class="db-fin-sym">$</span>
                            <span class="db-fin-num" data-target={data.capital.amount}>0</span>
                            <span class="db-fin-cur">{data.capital.currency}</span>
                        </div>
                    </div>
                    <a href={data.capital.portalUrl} class="db-pay-btn" id="db-pay-btn">
                        <span>{t('portal.btn.pay')}</span>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                </div>
            </div>

            <!-- SERVICIOS -->
            <div class="db-card db-c-svc" id="card-svc">
                <div class="db-c-in">
                    <span class="db-ey db-ey-mb">{t('portal.services')}</span>
                    <div class="db-svc-list">
                        {data.services.map((svc: any) => (
                            <a href={svc.link} class="db-svc-row">
                                <span class="db-svc-ico" set:html={svc.icon}></span>
                                <span class="db-svc-info">
                                    <span class="db-svc-lbl">{svc.label}</span>
                                    <span class="db-svc-sub">{svc.info}</span>
                                </span>
                                <span class="db-svc-arr">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                                </span>
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <!-- ROADMAP -->
            <div class="db-card db-c-rm" id="card-rm">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.roadmap')}</span>
                        <a href={lang === 'en' ? "/en/roadmap" : "/roadmap"} class="db-link-blue">{t('portal.btn.all')} →</a>
                    </div>
                    <div class="db-rm-list">
                        {data.roadmap.map((item: any, i: number) => (
                            <div class={`db-rm-row db-rm-${item.status}`}>
                                <div class="db-rm-track">
                                    <div class="db-rm-dot"></div>
                                    {i < data.roadmap.length - 1 && <div class="db-rm-line"></div>}
                                </div>
                                <div class="db-rm-body">
                                    <span class="db-rm-title">{item.title}</span>
                                    <span class="db-rm-date">{item.date}</span>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- BÓVEDA -->
            <div class="db-card db-c-vault" id="card-vault">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.vault')}</span>
                        <a href={lang === 'en' ? "/en/boveda" : "/boveda"} class="db-link-blue">{t('portal.btn.all')} →</a>
                    </div>
                    <div class="db-vault-list">
                        {data.documents.map((doc: any) => (
                            <a href={doc.url} class="db-vault-row" download>
                                <span class={`db-fchip db-fchip-${doc.type.toLowerCase()}`}>{doc.type}</span>
                                <span class="db-fmeta">
                                    <span class="db-fname">{doc.name}</span>
                                    <span class="db-fsize">{doc.size}</span>
                                </span>
                                <span class="db-fdl">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                                </span>
                            </a>
                        ))}
                        {data.documents.length === 0 && (
                            <p class="db-vault-empty">{lang === 'en' ? 'No documents yet.' : 'Sin documentos aún.'}</p>
                        )}
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
/* ══════════════════════════════════════════════════════════
   TOKENS
══════════════════════════════════════════════════════════ */
.db-root {
    --blue:   #0055cc;
    --green:  #10b981;
    --text:   #0a0e1a;
    --muted:  #6e7d96;
    --dim:    #c4cdd9;
    --border: rgba(0,0,0,0.07);
    --bg-soft: #fafafa;
    --ease:   cubic-bezier(0.16, 1, 0.3, 1);
    --shadow:
        0 0 0 1px rgba(0,0,0,0.035),
        0 1px 2px rgba(0,0,0,0.03),
        0 4px 12px rgba(0,0,0,0.035);
    --shadow-up:
        0 0 0 1px rgba(0,0,0,0.06),
        0 2px 6px rgba(0,0,0,0.05),
        0 16px 32px rgba(0,0,0,0.07);

    background: #ffffff;
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
    min-height: 100vh;
    padding: 0 0 8rem;
}

.db-wrap { max-width: 1240px; margin: 0 auto; padding: 3rem 5% 0; }

/* ══════════════════════════════════════════════════════════
   HEADER — minimalista, editorial
══════════════════════════════════════════════════════════ */
.db-header { margin-bottom: 3.2rem; }

.db-meta-row {
    display: flex; align-items: center; gap: 0.7rem;
    margin: 0 0 2rem; opacity: 0;
}
.db-mono {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 0.66rem; letter-spacing: 0.1em; color: var(--muted);
    text-transform: uppercase; font-weight: 500;
    display: inline-flex; align-items: center; gap: 0.4rem;
}
.db-meta-sep { color: var(--dim); font-size: 0.7rem; }
.db-mono-ok { color: var(--green); }
.db-meta-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--green);
    animation: led-pulse 2.5s ease-in-out infinite; flex-shrink: 0;
}

.db-title {
    font-size: clamp(2.4rem, 4.8vw, 4.4rem);
    font-weight: 600; letter-spacing: -0.045em;
    line-height: 1.04; margin: 0 0 1rem;
    color: var(--text); overflow: hidden;
    display: flex; flex-direction: column; gap: 0.1em;
}
.db-greeting {
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    font-weight: 500; letter-spacing: 0.06em;
    color: var(--muted); text-transform: uppercase;
    margin-bottom: 0.4em;
}
.db-name {
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.045em;
    line-height: 1;
}

.db-sub {
    font-size: 1rem; color: var(--muted); margin: 0;
    font-weight: 400; opacity: 0; letter-spacing: -0.005em;
    max-width: 520px;
}
.db-sub strong { color: var(--text); font-weight: 600; }

/* ══════════════════════════════════════════════════════════
   BENTO GRID
══════════════════════════════════════════════════════════ */
.db-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1rem;
}

/* ══════════════════════════════════════════════════════════
   CARD BASE
══════════════════════════════════════════════════════════ */
.db-card {
    position: relative; background: #ffffff;
    border: 1px solid var(--border); border-radius: 22px;
    overflow: hidden; opacity: 0;
    box-shadow: var(--shadow);
    transition: box-shadow .45s var(--ease), border-color .45s var(--ease), transform .45s var(--ease);
    will-change: transform, box-shadow;
}
.db-card:hover {
    box-shadow: var(--shadow-up); border-color: rgba(0,0,0,0.1);
    transform: translateY(-3px);
}

.db-c-in { padding: 1.8rem 2rem 1.9rem; height: 100%; display: flex; flex-direction: column; }
.db-c-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.4rem; gap: 0.8rem; }
.db-ey {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.13em;
    text-transform: uppercase; color: var(--muted);
}
.db-ey-mb { display: block; margin-bottom: 1.4rem; }

/* Column spans — bento balanceado */
.db-c-project { grid-column: span 8; }
.db-c-fin     { grid-column: span 4; }
.db-c-svc     { grid-column: span 4; }
.db-c-rm      { grid-column: span 4; }
.db-c-vault   { grid-column: span 4; }

/* Pills neutros */
.db-pill {
    font-size: 0.66rem; font-weight: 700; padding: 5px 12px; border-radius: 100px;
    letter-spacing: 0.01em; flex-shrink: 0;
}
.db-pill-ok   { background: rgba(16,185,129,0.09); color: #0d9966; border: 1px solid rgba(16,185,129,0.2); }
.db-pill-warn { background: rgba(220,120,0,0.08); color: #b86000; border: 1px solid rgba(220,120,0,0.18); }

/* ══════════════════════════════════════════════════════════
   PROYECTO
══════════════════════════════════════════════════════════ */
.db-proj-body {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: auto; flex-grow: 1; padding-top: 1rem; gap: 1.5rem;
}
.db-proj-left { min-width: 0; flex: 1; }
.db-proj-name {
    font-size: clamp(1.6rem, 2.4vw, 2.2rem);
    font-weight: 600; letter-spacing: -0.035em;
    margin: 0 0 1rem; line-height: 1.1; color: var(--text);
}
.db-proj-meta { display: flex; flex-wrap: wrap; gap: 0.45rem; }
.db-tag {
    font-size: 0.7rem; font-weight: 500; padding: 5px 11px; border-radius: 8px;
    color: var(--muted); background: var(--bg-soft);
    border: 1px solid rgba(0,0,0,0.05); letter-spacing: -0.005em;
}
.db-tag strong { color: var(--text); font-weight: 600; }

/* Ring */
.db-ring-shell {
    position: relative; width: 140px; height: 140px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.db-ring-svg { transform: rotate(-90deg); overflow: visible; }
.db-rt { fill: none; stroke: rgba(0,0,0,0.05); stroke-width: 7; }
.db-rf { fill: none; stroke: var(--text); stroke-width: 7; stroke-linecap: round; }
.db-ring-mid {
    position: absolute; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 1px;
}
.db-pct { font-family: 'JetBrains Mono', monospace; font-size: 1.95rem; font-weight: 700; line-height: 1; color: var(--text); letter-spacing: -0.03em; }
.db-pct-sym { font-size: 1rem; color: var(--muted); }
.db-pct-lbl { font-size: 0.56rem; letter-spacing: 0.13em; text-transform: uppercase; color: var(--muted); margin-top: 4px; }
.db-cnt { display: inline-block; }

/* ══════════════════════════════════════════════════════════
   FINANZAS — limpio, light
══════════════════════════════════════════════════════════ */
.db-fin-body { margin: auto 0; flex-grow: 1; padding: 1.2rem 0 1.4rem; }
.db-fin-label { font-size: 0.74rem; color: var(--muted); margin: 0 0 0.6rem; font-weight: 500; }
.db-fin-amount { display: flex; align-items: baseline; gap: 0.2rem; letter-spacing: -0.04em; line-height: 1; }
.db-fin-sym { font-size: 1.4rem; color: var(--muted); font-weight: 500; }
.db-fin-num { font-size: clamp(2.6rem, 4vw, 3.4rem); font-weight: 600; color: var(--text); font-variant-numeric: tabular-nums; }
.db-fin-cur { font-size: 0.85rem; color: var(--muted); font-weight: 500; align-self: flex-end; padding-bottom: 0.45rem; margin-left: 0.25rem; letter-spacing: 0.02em; }

.db-pay-btn {
    display: flex; align-items: center; justify-content: center; gap: 7px;
    background: var(--text); color: #ffffff;
    padding: 0.95rem 1.4rem; border-radius: 12px;
    font-size: 0.88rem; font-weight: 600; text-decoration: none;
    will-change: transform; transition: background .2s, box-shadow .2s;
    box-shadow: 0 4px 14px rgba(10,14,26,0.18);
    margin-top: auto;
}
.db-pay-btn:hover { background: #1a2233; box-shadow: 0 8px 24px rgba(10,14,26,0.28); transform: translateY(-2px) scale(1.015); }
.db-pay-btn:active { transform: translateY(0) scale(0.98); }

/* ══════════════════════════════════════════════════════════
   GHOST + LINK BUTTONS
══════════════════════════════════════════════════════════ */
.db-ghost-btn {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.72rem; font-weight: 600; color: var(--muted);
    text-decoration: none; background: transparent;
    border: 1px solid rgba(0,0,0,0.1); padding: 6px 13px; border-radius: 100px;
    transition: color .2s, border-color .2s, background .2s;
    flex-shrink: 0;
}
.db-ghost-btn:hover { color: var(--text); border-color: rgba(0,0,0,0.2); background: var(--bg-soft); }
.db-link-blue { font-size: 0.74rem; font-weight: 600; color: var(--text); text-decoration: none; opacity: .55; transition: opacity .2s; flex-shrink: 0; }
.db-link-blue:hover { opacity: 1; }

/* ══════════════════════════════════════════════════════════
   SERVICIOS
══════════════════════════════════════════════════════════ */
.db-svc-list { display: flex; flex-direction: column; gap: 0.25rem; }
.db-svc-row {
    display: flex; align-items: center; gap: 0.95rem;
    padding: 0.85rem 0.9rem; border-radius: 12px;
    text-decoration: none; color: var(--text);
    border: 1px solid transparent;
    transition: background .25s var(--ease), border-color .25s, transform .2s var(--ease);
}
.db-svc-row:hover { background: var(--bg-soft); border-color: rgba(0,0,0,0.06); transform: translateX(3px); }
.db-svc-ico  { color: var(--muted); display: flex; flex-shrink: 0; transition: color .2s; }
.db-svc-row:hover .db-svc-ico { color: var(--text); }
.db-svc-info { flex-grow: 1; display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.db-svc-lbl  { font-size: 0.86rem; font-weight: 600; }
.db-svc-sub  { font-size: 0.68rem; color: var(--muted); }
.db-svc-arr  { color: var(--dim); display: flex; transition: transform .25s var(--ease), color .2s; }
.db-svc-row:hover .db-svc-arr { transform: translateX(3px); color: var(--text); }

/* ══════════════════════════════════════════════════════════
   ROADMAP
══════════════════════════════════════════════════════════ */
.db-rm-list { display: flex; flex-direction: column; }
.db-rm-row  { display: flex; gap: 0.9rem; padding-bottom: 0.95rem; }
.db-rm-row:last-child { padding-bottom: 0; }
.db-rm-track { display: flex; flex-direction: column; align-items: center; width: 12px; flex-shrink: 0; padding-top: 4px; }
.db-rm-dot  { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; border: 1.5px solid var(--dim); background: #fff; transition: all .3s; }
.db-rm-line { flex-grow: 1; width: 1px; background: rgba(0,0,0,0.07); margin-top: 5px; min-height: 14px; }
.db-rm-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.db-rm-title { font-size: 0.85rem; font-weight: 500; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.db-rm-date  { font-size: 0.62rem; color: var(--dim); font-family: 'JetBrains Mono', monospace; letter-spacing: 0.04em; }
.db-rm-done .db-rm-dot { background: var(--text); border-color: var(--text); }
.db-rm-done .db-rm-title { color: var(--dim); text-decoration: line-through; text-decoration-color: var(--dim); }
.db-rm-active .db-rm-dot {
    background: var(--text); border-color: var(--text);
    box-shadow: 0 0 0 4px rgba(10,14,26,0.08);
    animation: node-pulse 2.4s ease-in-out infinite;
}
.db-rm-active .db-rm-title { color: var(--text); font-weight: 600; }

/* ══════════════════════════════════════════════════════════
   BÓVEDA
══════════════════════════════════════════════════════════ */
.db-vault-list { display: flex; flex-direction: column; gap: 0.25rem; }
.db-vault-row {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 0.7rem 0.7rem; border-radius: 11px;
    text-decoration: none; color: var(--text);
    border: 1px solid transparent;
    transition: background .2s, border-color .2s;
}
.db-vault-row:hover { background: var(--bg-soft); border-color: rgba(0,0,0,0.06); }
.db-fchip { font-size: 0.55rem; font-weight: 800; letter-spacing: 0.05em; padding: 4px 8px; border-radius: 6px; background: rgba(0,0,0,0.05); color: var(--muted); flex-shrink: 0; }
.db-fchip-pdf { background: rgba(220,38,38,0.08); color: #b91c1c; }
.db-fchip-fig { background: rgba(0,85,204,0.08); color: var(--blue); }
.db-fmeta { flex-grow: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
.db-fname { font-size: 0.78rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.db-fsize { font-size: 0.62rem; color: var(--muted); }
.db-fdl { color: var(--dim); opacity: 0; transition: opacity .2s, color .2s; display: flex; flex-shrink: 0; }
.db-vault-row:hover .db-fdl { opacity: 1; color: var(--text); }
.db-vault-empty { font-size: 0.82rem; color: var(--dim); margin: 1rem 0 0; text-align: center; }

/* ══════════════════════════════════════════════════════════
   KEYFRAMES
══════════════════════════════════════════════════════════ */
@keyframes led-pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(16,185,129,.5); transform: scale(1); }
    60%      { box-shadow: 0 0 0 4px rgba(16,185,129,0); transform: scale(1.15); }
}
@keyframes node-pulse {
    0%,100% { box-shadow: 0 0 0 4px rgba(10,14,26,.08); }
    50%      { box-shadow: 0 0 0 6px rgba(10,14,26,.03); }
}

/* ══════════════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
    .db-c-project { grid-column: span 12; }
    .db-c-fin     { grid-column: span 6; }
    .db-c-svc     { grid-column: span 6; }
    .db-c-rm      { grid-column: span 6; }
    .db-c-vault   { grid-column: span 6; }
}
@media (max-width: 720px) {
    .db-root { padding-bottom: 5rem; }
    .db-wrap { padding-top: 2.4rem; }
    .db-grid { display: flex; flex-direction: column; gap: 0.85rem; }
    .db-header { margin-bottom: 2.2rem; }
    .db-title { font-size: clamp(2.2rem, 9vw, 3.2rem); }
    .db-proj-body { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .db-ring-shell { margin: 0 auto; width: 120px; height: 120px; }
    .db-ring-svg { width: 120px; height: 120px; }
    .db-c-in { padding: 1.5rem 1.5rem 1.6rem; }
    .db-fin-num { font-size: 2.4rem; }
    .db-meta-row { flex-wrap: wrap; gap: 0.5rem; }
    .db-c-top { flex-wrap: wrap; }
}
</style>

<script>
import { gsap } from "gsap";
import { SplitText } from "gsap/SplitText";

gsap.registerPlugin(SplitText);

document.addEventListener("DOMContentLoaded", () => {

    const tl = gsap.timeline({ defaults: { ease: "expo.out" } });

    /* 1 ── Meta row (date + uptime) */
    tl.to("#db-meta-row", { opacity: 1, y: 0, duration: 0.7 }, 0);

    /* 2 ── Greeting label */
    const greetingEl = document.querySelector(".db-greeting") as HTMLElement | null;
    if (greetingEl) {
        gsap.set(greetingEl, { opacity: 0, y: 14 });
        tl.to(greetingEl, { opacity: 1, y: 0, duration: 0.6 }, 0.15);
    }

    /* 3 ── Name con SplitText elegante */
    const nameEl = document.querySelector(".db-name") as HTMLElement | null;
    if (nameEl) {
        const split = SplitText.create(nameEl, { type: "chars,words" });
        gsap.set(split.chars, { opacity: 0, y: 28, rotateX: -45, transformOrigin: "center bottom" });
        tl.to(split.chars, {
            opacity: 1, y: 0, rotateX: 0,
            duration: 0.75, stagger: 0.018,
            ease: "back.out(1.7)"
        }, 0.3);
    }

    /* 4 ── Subtítulo */
    tl.to("#db-sub", { opacity: 1, y: 0, duration: 0.7 }, 0.7);

    /* 5 ── Cards stagger */
    const cards = ["#card-project","#card-fin","#card-svc","#card-rm","#card-vault"];
    gsap.set(cards, { y: 32, opacity: 0, scale: 0.985 });
    tl.to(cards, {
        y: 0, opacity: 1, scale: 1,
        duration: 1.0, stagger: 0.06, ease: "expo.out"
    }, 0.5);

    /* 6 ── Progress ring */
    const ring = document.querySelector(".db-rf") as SVGCircleElement | null;
    if (ring) {
        const target = parseInt(ring.getAttribute("data-progress") || "0");
        tl.to(ring, { strokeDashoffset: 427 - (427 * target) / 100, duration: 2.0, ease: "expo.out" }, 0.85);
    }

    /* 7 ── Counter % */
    const cntEl = document.querySelector(".db-cnt") as HTMLElement | null;
    if (cntEl) {
        const target = parseInt(cntEl.getAttribute("data-target") || "0");
        const obj = { val: 0 };
        tl.to(obj, { val: target, duration: 2.0, ease: "expo.out",
            onUpdate() { cntEl.textContent = String(Math.round(obj.val)); }
        }, 0.85);
    }

    /* 8 ── Money counter */
    const moneyEl = document.querySelector(".db-fin-num") as HTMLElement | null;
    if (moneyEl) {
        const target = parseInt(moneyEl.getAttribute("data-target") || "0");
        const obj = { val: 0 };
        tl.to(obj, { val: target, duration: 1.7, ease: "power3.out",
            onUpdate() { moneyEl.textContent = Math.round(obj.val).toLocaleString('en-US'); }
        }, 0.9);
    }

    /* 9 ── Roadmap dots + lines */
    gsap.set(".db-rm-dot",  { scale: 0 });
    gsap.set(".db-rm-line", { scaleY: 0, transformOrigin: "top" });
    tl.to(".db-rm-dot",  { scale: 1, duration: 0.5, stagger: 0.08, ease: "back.out(2.2)" }, 1.0);
    tl.to(".db-rm-line", { scaleY: 1, duration: 0.4, stagger: 0.08, ease: "power2.out" }, 1.15);

    /* 10 ── Service rows */
    gsap.set(".db-svc-row", { x: -12, opacity: 0 });
    tl.to(".db-svc-row", { x: 0, opacity: 1, duration: 0.65, stagger: 0.06, ease: "expo.out" }, 0.8);

    /* 11 ── Vault rows */
    gsap.set(".db-vault-row", { opacity: 0, y: 8 });
    tl.to(".db-vault-row", { opacity: 1, y: 0, duration: 0.5, stagger: 0.06, ease: "power2.out" }, 0.95);

});

</script>
