<script>
import { gsap } from "gsap";
import { SplitText } from "gsap/SplitText";

gsap.registerPlugin(SplitText);

document.addEventListener("DOMContentLoaded", () => {

    const tl = gsap.timeline({ defaults: { ease: "expo.out" } });

    /* 1 ── Meta row (date + uptime) */
    tl.to("#db-meta-row", { opacity: 1, y: 0, duration: 0.7 }, 0);

    /* 2 ── Greeting label */
    const greetingEl = document.querySelector(".db-greeting") as HTMLElement | null;
    if (greetingEl) {
        gsap.set(greetingEl, { opacity: 0, y: 14 });
        tl.to(greetingEl, { opacity: 1, y: 0, duration: 0.6 }, 0.15);
    }

    /* 3 ── Name con SplitText elegante */
    const nameEl = document.querySelector(".db-name") as HTMLElement | null;
    if (nameEl) {
        const split = SplitText.create(nameEl, { type: "chars,words" });
        gsap.set(split.chars, { opacity: 0, y: 28, rotateX: -45, transformOrigin: "center bottom" });
        tl.to(split.chars, {
            opacity: 1, y: 0, rotateX: 0,
            duration: 0.75, stagger: 0.018,
            ease: "back.out(1.7)"
        }, 0.3);
    }

    /* 4 ── Subtítulo */
    tl.to("#db-sub", { opacity: 1, y: 0, duration: 0.7 }, 0.7);

    /* 4b ── Announcements (dismiss via localStorage) */
    document.querySelectorAll<HTMLElement>(".db-ann-card").forEach((card, i) => {
        const annId = card.dataset.annId;
        if (annId && localStorage.getItem(`flouvia_ann_${annId}`)) {
            card.remove();
            return;
        }
        gsap.to(card, { opacity: 1, y: 0, duration: 0.5, delay: 0.05 * i, ease: "expo.out" });
    });
    const annWrap = document.getElementById("db-ann-wrap");
    if (annWrap && annWrap.children.length === 0) annWrap.remove();

    document.querySelectorAll<HTMLButtonElement>("[data-ann-close]").forEach(btn => {
        btn.addEventListener("click", () => {
            const annId = btn.dataset.annClose;
            const card = annId ? document.getElementById(`ann-${annId}`) : null;
            if (!card) return;
            if (annId) localStorage.setItem(`flouvia_ann_${annId}`, "1");
            gsap.to(card, {
                opacity: 0, height: 0, paddingTop: 0, paddingBottom: 0,
                marginBottom: 0, duration: 0.35, ease: "power2.in",
                onComplete: () => {
                    card.remove();
                    if (annWrap && annWrap.children.length === 0) annWrap.remove();
                },
            });
        });
    });

    /* 5 ── Notification strip */
    const notifStrip = document.getElementById("db-notif-panel");
    if (notifStrip) {
        gsap.set(notifStrip, { y: -8, opacity: 0 });
        tl.to(notifStrip, { y: 0, opacity: 1, duration: 0.55 }, 0.1);
        document.getElementById("db-notif-close")?.addEventListener("click", () => {
            gsap.to(notifStrip, { opacity: 0, height: 0, marginBottom: 0, padding: 0, duration: 0.35, ease: "power2.in",
                onComplete: () => notifStrip.remove() });
        });
    }

    /* 6 ── Cards stagger */
    const cards = ["#card-project","#card-fin","#card-svc","#card-rm","#card-vault","#card-activity"].filter(id => document.querySelector(id));
    gsap.set(cards, { y: 32, opacity: 0, scale: 0.985 });
    tl.to(cards, {
        y: 0, opacity: 1, scale: 1,
        duration: 1.0, stagger: 0.06, ease: "expo.out"
    }, 0.5);

    /* 6 ── Progress ring */
    const ring = document.querySelector(".db-rf") as SVGCircleElement | null;
    if (ring) {
        const target = parseInt(ring.getAttribute("data-progress") || "0");
        tl.to(ring, { strokeDashoffset: 427 - (427 * target) / 100, duration: 2.0, ease: "expo.out" }, 0.85);
    }

    /* 7 ── Counter % */
    const cntEl = document.querySelector(".db-cnt") as HTMLElement | null;
    if (cntEl) {
        const target = parseInt(cntEl.getAttribute("data-target") || "0");
        const obj = { val: 0 };
        tl.to(obj, { val: target, duration: 2.0, ease: "expo.out",
            onUpdate() { cntEl.textContent = String(Math.round(obj.val)); }
        }, 0.85);
    }

    /* 8 ── Money counter */
    const moneyEl = document.querySelector(".db-fin-num") as HTMLElement | null;
    if (moneyEl) {
        const target = parseInt(moneyEl.getAttribute("data-target") || "0");
        const obj = { val: 0 };
        tl.to(obj, { val: target, duration: 1.7, ease: "power3.out",
            onUpdate() { moneyEl.textContent = Math.round(obj.val).toLocaleString('en-US'); }
        }, 0.9);
    }

    /* 9 ── Roadmap dots + lines */
    gsap.set(".db-rm-dot",  { scale: 0 });
    gsap.set(".db-rm-line", { scaleY: 0, transformOrigin: "top" });
    tl.to(".db-rm-dot",  { scale: 1, duration: 0.5, stagger: 0.08, ease: "back.out(2.2)" }, 1.0);
    tl.to(".db-rm-line", { scaleY: 1, duration: 0.4, stagger: 0.08, ease: "power2.out" }, 1.15);

    /* 10 ── Service rows */
    gsap.set(".db-svc-row", { x: -12, opacity: 0 });
    tl.to(".db-svc-row", { x: 0, opacity: 1, duration: 0.65, stagger: 0.06, ease: "expo.out" }, 0.8);

    /* 11 ── Vault rows */
    gsap.set(".db-vault-row", { opacity: 0, y: 8 });
    tl.to(".db-vault-row", { opacity: 1, y: 0, duration: 0.5, stagger: 0.06, ease: "power2.out" }, 0.95);

    /* 12 ── Health score bar + counter */
    const healthBar = document.getElementById("db-health-bar");
    const healthNum = document.getElementById("db-health-num");
    if (healthBar && healthNum) {
        const score = parseInt(healthBar.style.getPropertyValue("--score") || "0");
        tl.to(healthBar, { width: score + "%", duration: 1.6, ease: "expo.out" }, 1.1);
        const obj = { val: 0 };
        tl.to(obj, { val: score, duration: 1.6, ease: "expo.out",
            onUpdate() { healthNum.textContent = String(Math.round(obj.val)); }
        }, 1.1);
    }

    /* 13 ── Activity rows */
    const actRows = document.querySelectorAll(".db-act-row");
    if (actRows.length) {
        gsap.set(actRows, { opacity: 0, y: 10 });
        tl.to(actRows, { opacity: 1, y: 0, duration: 0.5, stagger: 0.045, ease: "expo.out" }, 1.0);
    }

});

</script>
