---
// src/components/portal/DashboardUI.astro
import { useTranslations } from '../../i18n/utils';
import { supabase } from '../../lib/supabase';

interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const user = await Astro.locals.currentUser();

// fullName primero (Google OAuth lo rellena siempre), luego partes, luego fallback
const fullName =
  user?.fullName?.trim() ||
  `${user?.firstName || ""} ${user?.lastName || ""}`.trim() ||
  (lang === 'en' ? "Executive" : "Ejecutivo");

const email = user?.emailAddresses[0]?.emailAddress || "flouvia.mx@gmail.com";

// Auto-create perfil on first login
if (user?.id && email !== "flouvia.mx@gmail.com") {
  try {
    const { data: existing } = await supabase
      .from('perfiles')
      .select('id')
      .eq('email_cliente', email)
      .single();
    if (!existing) {
      await supabase.from('perfiles').insert({
        email_cliente: email,
        clerk_id:      user.id,
        nombre_empresa: 'Nuevo Cliente',
        nombre:        user.fullName?.trim() || user.firstName || 'Cliente',
      } as any);
    }
  } catch {
    // non-critical — fail silently
  }
}

const dateOptions: Intl.DateTimeFormatOptions = { weekday: 'long', day: 'numeric', month: 'long' };
const today = new Date().toLocaleDateString(lang === 'en' ? 'en-US' : 'es-MX', dateOptions);

const formatDate = (iso: string | null) => {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString(lang === 'en' ? 'en-US' : 'es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
};

const [
  { data: proyecto },
  { data: finanza },
  { data: roadmapRows },
  { data: archivos },
  { data: ticketRows },
  { data: notifRows },
  { data: announcementRows },
] = await Promise.all([
  supabase.from('proyectos').select('*').eq('email_cliente', email).single(),
  supabase.from('finanzas_config').select('*').eq('email_cliente', email).single(),
  supabase.from('roadmap').select('*').eq('email_cliente', email).order('orden_index'),
  supabase.from('boveda_archivos').select('nombre,tipo,created_at').eq('email_cliente', email).order('created_at', { ascending: false }).limit(3),
  supabase.from('tickets').select('ticket_ref,title,status,created_at').eq('email_cliente', email).order('created_at', { ascending: false }).limit(5),
  supabase.from('notificaciones').select('id,titulo,mensaje,tipo,leida,created_at').eq('email_cliente', email).order('created_at', { ascending: false }).limit(6),
  supabase.from('announcements').select('id,titulo,mensaje,tipo').eq('activo', true).order('created_at', { ascending: false }).limit(3),
]);

// Fetch Vercel deploys if project has an ID
const vercelProjectId = proyecto?.vercel_project_id;
const vercelToken = import.meta.env.VERCEL_TOKEN;
let recentDeploys: any[] = [];
if (vercelProjectId && vercelToken) {
  try {
    const vRes = await fetch(
      `https://api.vercel.com/v6/deployments?projectId=${vercelProjectId}&limit=5`,
      { headers: { Authorization: `Bearer ${vercelToken}` }, signal: AbortSignal.timeout(4000) }
    );
    if (vRes.ok) {
      const vJson = await vRes.json();
      recentDeploys = (vJson.deployments ?? []).map((d: any) => ({
        sha:    (d.meta?.githubCommitSha ?? d.uid ?? '').slice(0, 7),
        msg:    d.meta?.githubCommitMessage?.split('\n')[0] ?? d.name ?? 'Deploy',
        status: d.state,
        when:   d.created,
      }));
    }
  } catch { /* timeout ok */ }
}

// ── Health score (0–100) ──────────────────────────────────
const uptimePct = parseFloat((proyecto?.uptime ?? '99.9').replace('%','')) || 99.9;
const progress  = proyecto?.progreso ?? 0;
const openTickets = (ticketRows ?? []).filter((t: any) => t.status === 'open').length;
const lastDeployOk = recentDeploys.length > 0 && recentDeploys[0].status === 'READY';

let healthScore = 0;
healthScore += uptimePct >= 99.9 ? 30 : uptimePct >= 99.0 ? 20 : 10;
healthScore += progress >= 75 ? 25 : progress >= 50 ? 18 : progress >= 25 ? 10 : 5;
healthScore += recentDeploys.length === 0 ? 15 : lastDeployOk ? 25 : 10;
healthScore += openTickets === 0 ? 20 : openTickets <= 2 ? 12 : 5;

const healthLabel = healthScore >= 85
  ? (lang === 'en' ? 'Excellent' : 'Excelente')
  : healthScore >= 65
    ? (lang === 'en' ? 'Good' : 'Bueno')
    : (lang === 'en' ? 'Needs attention' : 'Requiere atención');
const healthColor = healthScore >= 85 ? '#10b981' : healthScore >= 65 ? '#f59e0b' : '#ef4444';

// ── Activity feed ─────────────────────────────────────────
function timeAgo(ms: number, l: string): string {
  const diff = Date.now() - ms;
  const m = Math.floor(diff / 60000);
  if (m < 60) return l === 'en' ? `${m}m ago` : `hace ${m} min`;
  const h = Math.floor(m / 60);
  if (h < 24) return l === 'en' ? `${h}h ago` : `hace ${h} h`;
  const d = Math.floor(h / 24);
  return l === 'en' ? `${d}d ago` : `hace ${d} d`;
}

type ActivityItem = { type: 'deploy' | 'ticket' | 'upload'; title: string; sub: string; when: number; dot: string; };

const activityItems: ActivityItem[] = [
  ...recentDeploys.slice(0, 3).map((d: any) => ({
    type: 'deploy' as const,
    title: d.msg,
    sub: d.sha ? `${d.sha} · ${d.status === 'READY' ? (lang === 'en' ? 'Deployed' : 'Desplegado') : d.status}` : d.status,
    when: d.when,
    dot: d.status === 'READY' ? '#10b981' : d.status === 'ERROR' ? '#ef4444' : '#f59e0b',
  })),
  ...(ticketRows ?? []).slice(0, 3).map((t: any) => ({
    type: 'ticket' as const,
    title: t.title,
    sub: `${t.ticket_ref} · ${t.status === 'open' ? (lang === 'en' ? 'Open' : 'Abierto') : t.status === 'resolved' ? (lang === 'en' ? 'Resolved' : 'Resuelto') : (lang === 'en' ? 'Pending' : 'Pendiente')}`,
    when: new Date(t.created_at).getTime(),
    dot: t.status === 'resolved' ? '#10b981' : t.status === 'open' ? '#0055cc' : '#f59e0b',
  })),
  ...(archivos ?? []).slice(0, 2).map((a: any) => ({
    type: 'upload' as const,
    title: a.nombre,
    sub: `${a.tipo?.toUpperCase() ?? 'FILE'} · ${lang === 'en' ? 'Vault' : 'Bóveda'}`,
    when: new Date(a.created_at).getTime(),
    dot: '#8b5cf6',
  })),
].sort((a, b) => b.when - a.when).slice(0, 7);

// ── Notifications ─────────────────────────────────────────
const notifications = (notifRows ?? []);
const unreadNotifs  = notifications.filter((n: any) => !n.leida);
const latestNotif   = notifications[0] ?? null;

const fallbackPortalUrl = lang === 'en' ? "/en/portal/facturacion" : "/portal/facturacion";

const data = {
  project: {
    name:     proyecto?.nombre_proyecto ?? (lang === 'en' ? "Global B2B Platform"  : "Plataforma B2B Global"),
    stage:    proyecto?.etapa           ?? (lang === 'en' ? "Frontend Engineering"  : "Ingeniería Backend"),
    progress: proyecto?.progreso        ?? 0,
    uptime:   proyecto?.uptime          ?? "99.98%",
    liveUrl:  proyecto?.live_url        ?? "#",
    deadline: proyecto?.deadline        ?? "—",
  },
  capital: {
    status:    finanza?.auto_pay
                 ? (lang === 'en' ? "Active Subscription" : "Suscripción Activa")
                 : (lang === 'en' ? "Payment Pending"     : "Pago Pendiente"),
    isAutoPay: finanza?.auto_pay        ?? false,
    amount:    finanza?.monto_proximo   ?? 0,
    currency:  finanza?.moneda          ?? "USD",
    nextDate:  formatDate(finanza?.fecha_proxima ?? null),
    portalUrl: finanza?.stripe_portal_url || fallbackPortalUrl,
  },
  services: [
    { label: lang === 'en' ? "Book Consultancy"      : "Agendar Consultoría",  icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, link: lang === 'en' ? "/en/calendario" : "/calendario", info: lang === 'en' ? "2h SLA" : "SLA de 2h" },
    { label: lang === 'en' ? "Document Vault"        : "Bóveda de Documentos", icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`, link: lang === 'en' ? "/en/boveda" : "/boveda",     info: lang === 'en' ? "Contracts" : "Contratos/Entregables" },
    { label: lang === 'en' ? "VIP Technical Support" : "Soporte Técnico VIP",  icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`, link: lang === 'en' ? "/en/soporte" : "/soporte",    info: lang === 'en' ? "Assigned Engineer" : "Ingeniero Asignado" },
  ],
  roadmap: (roadmapRows ?? []).map((r: any) => ({
    title:  r.titulo,
    status: r.status,
    date:   r.fecha_info ?? "",
  })),
  documents: (archivos ?? []).map((a: any) => ({
    name: a.nombre,
    type: a.tipo,
    size: a.size ?? "",
    url:  a.url_descarga,
  })),
};

---

<div class="db-root">
    <div class="db-wrap">

        <!-- ═══════════════ HEADER ═══════════════ -->
        <header class="db-header">
            <div class="db-meta-row" id="db-meta-row">
                <span class="db-mono">{today}</span>
                <span class="db-meta-sep">·</span>
                <span class="db-mono db-mono-ok">
                    <span class="db-meta-dot"></span>
                    {t('portal.uptime')} {data.project.uptime}
                </span>
                {unreadNotifs.length > 0 && (
                  <a href="#db-notif-panel" class="db-notif-chip" id="db-notif-chip">
                    <span class="db-notif-dot"></span>
                    <span>{unreadNotifs.length} {lang === 'en' ? 'new' : 'nuevas'}</span>
                  </a>
                )}
            </div>

            {latestNotif && (
              <div class="db-notif-strip" id="db-notif-panel">
                <div class="db-notif-icon">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <div class="db-notif-body">
                  <span class="db-notif-title">{latestNotif.titulo}</span>
                  {latestNotif.mensaje && <span class="db-notif-msg">{latestNotif.mensaje}</span>}
                </div>
                <span class="db-notif-when">{timeAgo(new Date(latestNotif.created_at).getTime(), lang)}</span>
                <button class="db-notif-close" aria-label="Dismiss" id="db-notif-close">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
            )}

            <h1 class="db-title" id="db-title">
                <span class="db-greeting">{t('portal.greeting')}</span>
                <span class="db-name">{fullName}.</span>
            </h1>

            <p class="db-sub" id="db-sub">
                {t('portal.subtitle')} <strong>{data.project.deadline}</strong>
            </p>
        </header>

        <!-- ═══════════════ ANNOUNCEMENTS ═══════════════ -->
        {announcementRows && announcementRows.length > 0 && (
          <div class="db-ann-wrap" id="db-ann-wrap">
            {announcementRows.map((ann: any) => (
              <div class="db-ann-card" id={`ann-${ann.id}`} data-ann-id={ann.id} data-ann-tipo={ann.tipo ?? 'info'}>
                <div class="db-ann-icon" aria-hidden="true">
                  {(ann.tipo === 'warning') ? (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  ) : (ann.tipo === 'success') ? (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  ) : (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  )}
                </div>
                <div class="db-ann-body">
                  <span class="db-ann-title">{ann.titulo}</span>
                  {ann.mensaje && <span class="db-ann-msg">{ann.mensaje}</span>}
                </div>
                <button class="db-ann-close" data-ann-close={ann.id} aria-label="Cerrar">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
            ))}
          </div>
        )}

        <!-- ═══════════════ GRID ═══════════════ -->
        <div class="db-grid">

            <!-- PROYECTO -->
            <div class="db-card db-c-project" id="card-project">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.project')}</span>
                        <a href={lang === 'en' ? '/en/entorno' : '/entorno'} class="db-ghost-btn">
                            {t('portal.btn.env')}
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
                        </a>
                    </div>

                    <div class="db-proj-body">
                        <div class="db-proj-left">
                            <h2 class="db-proj-name">{data.project.name}</h2>
                            <div class="db-proj-meta">
                                <span class="db-tag">{t('portal.stage')} <strong>{data.project.stage}</strong></span>
                                <span class="db-tag">{lang === 'en' ? 'Deadline' : 'Entrega'}: <strong>{data.project.deadline}</strong></span>
                            </div>
                            <div class="db-health-row">
                              <div class="db-health-bar-wrap">
                                <div class="db-health-bar" id="db-health-bar" style={`--score:${healthScore}`}></div>
                              </div>
                              <span class="db-health-label" style={`color:${healthColor}`}>
                                <span class="db-health-num" id="db-health-num">0</span>
                                <span class="db-health-slash">/100 ·</span>
                                <span class="db-health-txt">{healthLabel}</span>
                              </span>
                            </div>
                        </div>

                        <div class="db-ring-shell">
                            <svg class="db-ring-svg" width="140" height="140" viewBox="0 0 160 160">
                                <circle class="db-rt" cx="80" cy="80" r="68"/>
                                <circle class="db-rf" cx="80" cy="80" r="68"
                                    data-progress={data.project.progress}
                                    style="stroke-dasharray:427;stroke-dashoffset:427;"
                                />
                            </svg>
                            <div class="db-ring-mid">
                                <span class="db-pct"><span class="db-cnt" data-target={data.project.progress}>0</span><span class="db-pct-sym">%</span></span>
                                <span class="db-pct-lbl">{lang === 'en' ? 'complete' : 'avance'}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FINANZAS -->
            <div class="db-card db-c-fin" id="card-fin">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.finance')}</span>
                        <span class={`db-pill ${data.capital.isAutoPay ? 'db-pill-ok' : 'db-pill-warn'}`}>
                            {data.capital.status}
                        </span>
                    </div>
                    <div class="db-fin-body">
                        <p class="db-fin-label">{t('portal.next_charge')} · {data.capital.nextDate}</p>
                        <div class="db-fin-amount">
                            <span class="db-fin-sym">$</span>
                            <span class="db-fin-num" data-target={data.capital.amount}>0</span>
                            <span class="db-fin-cur">{data.capital.currency}</span>
                        </div>
                    </div>
                    <a href={data.capital.portalUrl} class="db-pay-btn" id="db-pay-btn">
                        <span>{t('portal.btn.pay')}</span>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                </div>
            </div>

            <!-- SERVICIOS -->
            <div class="db-card db-c-svc" id="card-svc">
                <div class="db-c-in">
                    <span class="db-ey db-ey-mb">{t('portal.services')}</span>
                    <div class="db-svc-list">
                        {data.services.map((svc: any) => (
                            <a href={svc.link} class="db-svc-row">
                                <span class="db-svc-ico" set:html={svc.icon}></span>
                                <span class="db-svc-info">
                                    <span class="db-svc-lbl">{svc.label}</span>
                                    <span class="db-svc-sub">{svc.info}</span>
                                </span>
                                <span class="db-svc-arr">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                                </span>
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <!-- ROADMAP -->
            <div class="db-card db-c-rm" id="card-rm">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.roadmap')}</span>
                        <a href={lang === 'en' ? "/en/roadmap" : "/roadmap"} class="db-link-blue">{t('portal.btn.all')} →</a>
                    </div>
                    <div class="db-rm-list">
                        {data.roadmap.map((item: any, i: number) => (
                            <div class={`db-rm-row db-rm-${item.status}`}>
                                <div class="db-rm-track">
                                    <div class="db-rm-dot"></div>
                                    {i < data.roadmap.length - 1 && <div class="db-rm-line"></div>}
                                </div>
                                <div class="db-rm-body">
                                    <span class="db-rm-title">{item.title}</span>
                                    <span class="db-rm-date">{item.date}</span>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- BÓVEDA -->
            <div class="db-card db-c-vault" id="card-vault">
                <div class="db-c-in">
                    <div class="db-c-top">
                        <span class="db-ey">{t('portal.vault')}</span>
                        <a href={lang === 'en' ? "/en/boveda" : "/boveda"} class="db-link-blue">{t('portal.btn.all')} →</a>
                    </div>
                    <div class="db-vault-list">
                        {data.documents.map((doc: any) => (
                            <a href={doc.url} class="db-vault-row" download>
                                <span class={`db-fchip db-fchip-${doc.type.toLowerCase()}`}>{doc.type}</span>
                                <span class="db-fmeta">
                                    <span class="db-fname">{doc.name}</span>
                                    <span class="db-fsize">{doc.size}</span>
                                </span>
                                <span class="db-fdl">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                                </span>
                            </a>
                        ))}
                        {data.documents.length === 0 && (
                            <p class="db-vault-empty">{lang === 'en' ? 'No documents yet.' : 'Sin documentos aún.'}</p>
                        )}
                    </div>
                </div>
            </div>

            <!-- ACTIVIDAD RECIENTE -->
            {activityItems.length > 0 && (
              <div class="db-card db-c-activity" id="card-activity">
                <div class="db-c-in">
                  <div class="db-c-top">
                    <span class="db-ey">{lang === 'en' ? 'RECENT ACTIVITY' : 'ACTIVIDAD RECIENTE'}</span>
                    <span class="db-act-count">{activityItems.length} {lang === 'en' ? 'events' : 'eventos'}</span>
                  </div>
                  <div class="db-act-list">
                    {activityItems.map((item) => (
                      <div class="db-act-row">
                        <div class="db-act-icon-wrap">
                          <div class="db-act-dot" style={`background:${item.dot}`}></div>
                          {item.type === 'deploy' && (
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg>
                          )}
                          {item.type === 'ticket' && (
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                          )}
                          {item.type === 'upload' && (
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                          )}
                        </div>
                        <div class="db-act-body">
                          <span class="db-act-title">{item.title}</span>
                          <span class="db-act-sub">{item.sub}</span>
                        </div>
                        <span class="db-act-when">{timeAgo(item.when, lang)}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            )}

        </div>
    </div>
</div>

<style>
