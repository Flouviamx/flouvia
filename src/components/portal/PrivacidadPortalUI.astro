---
import { useTranslations } from '../../i18n/utils';
import PortalHeader from './PortalHeader.astro';

interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const updated = '1 de mayo de 2026';
const updatedEn = 'May 1, 2026';

const sections = lang === 'en' ? [
  {
    id: 'what',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="2"/></svg>`,
    title: 'Data we handle',
    items: [
      { label: 'Identity', desc: 'Name and email managed by Clerk (flouvia.com). We store only your email as a reference key in our database.' },
      { label: 'Project data', desc: 'Technical and commercial information about your active projects: URLs, progress, stack, SLA configuration, billing amounts.' },
      { label: 'Vault files', desc: 'Documents you upload are stored in a private Supabase Storage bucket with AES-256 encryption. Access is limited to your session only.' },
      { label: 'Support tickets', desc: 'Category, subject, description, and priority of each request you submit, along with resolution status.' },
      { label: 'Invoices', desc: 'Billing history: invoice IDs, amounts, dates, and download links. Payment details (card) are managed exclusively by Stripe.' },
    ],
  },
  {
    id: 'how',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    title: 'How we protect it',
    items: [
      { label: 'Authentication', desc: 'Access requires a valid Clerk session. Invitation-only: only emails explicitly authorized by Flouvia can create an account.' },
      { label: 'Encrypted transport', desc: 'All communication uses TLS 1.3. Vault signed URLs expire in 1 hour and are non-transferable.' },
      { label: 'Row-level security', desc: 'Supabase RLS ensures each query only reads rows belonging to your email. No cross-client data access is possible at the database layer.' },
      { label: 'No client-side secrets', desc: 'API keys and service role keys never reach the browser. All sensitive operations run server-side only.' },
    ],
  },
  {
    id: 'retention',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Retention & deletion',
    items: [
      { label: 'Active relationship', desc: 'Data is retained for the duration of the active service relationship plus 12 months for legal compliance.' },
      { label: 'On cancellation', desc: 'Upon service termination, you may request complete deletion of your data within 30 business days.' },
      { label: 'Vault files', desc: 'Files are deleted immediately upon your request via the Vault interface or by emailing hola@flouvia.com.' },
      { label: 'Backups', desc: 'Encrypted Supabase backups are retained for up to 30 days and are purged automatically on a rolling basis.' },
    ],
  },
  {
    id: 'rights',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Your rights',
    items: [
      { label: 'Access', desc: 'Request a complete export of your data stored across all Flouvia systems.' },
      { label: 'Rectification', desc: 'Correct or update any inaccurate information held about you.' },
      { label: 'Deletion', desc: 'Request erasure of your personal data. Response within 5 business days.' },
      { label: 'Portability', desc: 'Receive your data in a structured, machine-readable format (JSON/CSV).' },
    ],
  },
  {
    id: 'contact',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    title: 'Contact',
    items: [
      { label: 'Data requests', desc: 'hola@flouvia.com — all privacy and data-related requests are handled here.' },
      { label: 'Legal entity', desc: 'Flouvia Boutique, S. de R.L. de C.V. — incorporated in Mexico.' },
      { label: 'Response SLA', desc: 'We respond to all data requests within 5 business days.' },
    ],
  },
] : [
  {
    id: 'what',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="2"/></svg>`,
    title: 'Datos que manejamos',
    items: [
      { label: 'Identidad', desc: 'Nombre y correo electrónico administrados por Clerk (flouvia.com). Solo almacenamos tu email como llave de referencia en nuestra base de datos.' },
      { label: 'Datos del proyecto', desc: 'Información técnica y comercial de tus proyectos activos: URLs, progreso, stack tecnológico, configuración de SLA, montos de facturación.' },
      { label: 'Archivos de la Bóveda', desc: 'Los documentos que subes se almacenan en un bucket privado de Supabase Storage con cifrado AES-256. El acceso está limitado únicamente a tu sesión.' },
      { label: 'Tickets de soporte', desc: 'Categoría, asunto, descripción y prioridad de cada solicitud que envías, junto con el estado de resolución.' },
      { label: 'Facturas', desc: 'Historial de facturación: IDs de facturas, montos, fechas y enlaces de descarga. Los datos de pago (tarjeta) son gestionados exclusivamente por Stripe.' },
    ],
  },
  {
    id: 'how',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    title: 'Cómo los protegemos',
    items: [
      { label: 'Autenticación', desc: 'El acceso requiere una sesión válida de Clerk. Solo por invitación: únicamente los correos autorizados por Flouvia pueden crear una cuenta.' },
      { label: 'Transporte cifrado', desc: 'Toda la comunicación usa TLS 1.3. Las URLs firmadas de la Bóveda expiran en 1 hora y no son transferibles.' },
      { label: 'Seguridad a nivel de fila', desc: 'El RLS de Supabase garantiza que cada consulta solo lea filas pertenecientes a tu email. No hay acceso entre datos de diferentes clientes.' },
      { label: 'Sin secretos en el cliente', desc: 'Las API keys y service role keys nunca llegan al navegador. Todas las operaciones sensibles corren exclusivamente del lado del servidor.' },
    ],
  },
  {
    id: 'retention',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Retención y eliminación',
    items: [
      { label: 'Relación activa', desc: 'Los datos se conservan durante la vigencia de la relación de servicio activa más 12 meses por cumplimiento legal.' },
      { label: 'Al cancelar', desc: 'Al terminar el servicio, puedes solicitar la eliminación completa de tus datos en un plazo de 30 días hábiles.' },
      { label: 'Archivos de la Bóveda', desc: 'Los archivos se eliminan de inmediato a petición tuya desde la interfaz de la Bóveda o enviando un correo a hola@flouvia.com.' },
      { label: 'Respaldos', desc: 'Los backups cifrados de Supabase se conservan hasta 30 días y se purgan automáticamente de forma continua.' },
    ],
  },
  {
    id: 'rights',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Tus derechos',
    items: [
      { label: 'Acceso', desc: 'Solicita una exportación completa de todos tus datos almacenados en los sistemas de Flouvia.' },
      { label: 'Rectificación', desc: 'Corrige o actualiza cualquier información inexacta que tengamos sobre ti.' },
      { label: 'Eliminación', desc: 'Solicita el borrado de tus datos personales. Respuesta en máximo 5 días hábiles.' },
      { label: 'Portabilidad', desc: 'Recibe tus datos en formato estructurado y legible por máquina (JSON/CSV).' },
    ],
  },
  {
    id: 'contact',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    title: 'Contacto',
    items: [
      { label: 'Solicitudes de datos', desc: 'hola@flouvia.com — todas las solicitudes relacionadas con privacidad y datos son atendidas aquí.' },
      { label: 'Entidad legal', desc: 'Flouvia Boutique, S. de R.L. de C.V. — constituida en México.' },
      { label: 'SLA de respuesta', desc: 'Respondemos todas las solicitudes de datos en un máximo de 5 días hábiles.' },
    ],
  },
];
---

<div class="priv-page">
  <div class="priv-wrap">

    <PortalHeader
      title={lang === 'en' ? 'Privacy' : 'Privacidad'}
      titleEd={lang === 'en' ? 'Policy.' : 'de Datos.'}
      subtitle={lang === 'en'
        ? 'How we handle, protect, and store the information you entrust us with.'
        : 'Cómo manejamos, protegemos y almacenamos la información que nos confías.'}
      backHref={lang === 'en' ? '/en/dashboard' : '/dashboard'}
      {lang}
    />

    <!-- Last updated chip -->
    <div class="priv-meta" id="priv-meta">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span>{lang === 'en' ? `Last updated: ${updatedEn}` : `Última actualización: ${updated}`}</span>
      <span class="priv-sep">·</span>
      <span>Flouvia Boutique, S. de R.L. de C.V.</span>
    </div>

    <!-- Sections grid -->
    <div class="priv-grid">
      {sections.map((sec, i) => (
        <div class="priv-card" id={`priv-card-${i}`}>
          <div class="priv-card-head">
            <div class="priv-icon" set:html={sec.icon} />
            <h2 class="priv-card-title">{sec.title}</h2>
          </div>
          <ul class="priv-list">
            {sec.items.map((item) => (
              <li class="priv-item">
                <span class="priv-item-label">{item.label}</span>
                <span class="priv-item-desc">{item.desc}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Footer note -->
    <p class="priv-footer-note" id="priv-foot">
      {lang === 'en'
        ? 'This policy applies exclusively to the Flouvia Client Portal. For the public privacy notice, see '
        : 'Esta política aplica exclusivamente al Portal de Clientes de Flouvia. Para el aviso de privacidad público, consulta '}
      <a href={lang === 'en' ? '/en/privacy' : '/privacidad'} class="priv-link">
        {lang === 'en' ? 'flouvia.com/en/privacy' : 'flouvia.com/privacidad'}
      </a>.
    </p>

  </div>
</div>

<style>
.priv-page {
  background: #fff;
  min-height: 100vh;
  padding: 2.6rem 0 6rem;
  font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
  color: #0a0e1a;
}
.priv-wrap { max-width: 1040px; margin: 0 auto; padding: 0 5%; }

/* ── META CHIP ── */
.priv-meta {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem; letter-spacing: 0.08em;
  color: rgba(0,0,0,0.38); margin-bottom: 2.4rem;
  opacity: 0;
}
.priv-sep { color: rgba(0,0,0,0.18); }

/* ── GRID ── */
.priv-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 2.4rem;
}

/* ── CARD ── */
.priv-card {
  background: #fff;
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: 20px;
  padding: 1.8rem 2rem;
  opacity: 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03), 0 8px 24px rgba(0,0,0,0.04);
  transition: box-shadow .4s cubic-bezier(0.16,1,0.3,1), border-color .4s, transform .4s cubic-bezier(0.16,1,0.3,1);
}
.priv-card:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.06), 0 16px 40px rgba(0,0,0,0.07);
  border-color: rgba(0,0,0,0.11);
  transform: translateY(-2px);
}

.priv-card-head {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 1.4rem;
  padding-bottom: 1.1rem;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}
.priv-icon {
  width: 34px; height: 34px; border-radius: 10px;
  background: rgba(0,0,0,0.035);
  display: flex; align-items: center; justify-content: center;
  color: rgba(0,0,0,0.55); flex-shrink: 0;
}
.priv-card-title {
  font-size: 0.92rem; font-weight: 700;
  letter-spacing: -0.01em; margin: 0;
  color: #0a0e1a;
}

/* ── LIST ── */
.priv-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
.priv-item { display: flex; flex-direction: column; gap: 3px; }
.priv-item-label {
  font-size: 0.78rem; font-weight: 700;
  color: #0a0e1a; letter-spacing: 0.005em;
}
.priv-item-desc {
  font-size: 0.84rem; color: rgba(0,0,0,0.5);
  line-height: 1.55; font-weight: 400;
}

/* ── FOOTER NOTE ── */
.priv-footer-note {
  font-size: 0.84rem; color: rgba(0,0,0,0.4);
  line-height: 1.6; opacity: 0;
}
.priv-link {
  color: rgba(0,0,0,0.55);
  text-decoration: underline;
  text-decoration-color: rgba(0,0,0,0.2);
  transition: color .2s, text-decoration-color .2s;
}
.priv-link:hover { color: #0a0e1a; text-decoration-color: rgba(0,0,0,0.5); }

/* ── RESPONSIVE ── */
@media (max-width: 720px) {
  .priv-grid { grid-template-columns: 1fr; }
  .priv-card { padding: 1.4rem 1.5rem; border-radius: 16px; }
}
@media (max-width: 480px) {
  .priv-page { padding: 2rem 0 5rem; }
  .priv-meta { flex-wrap: wrap; }
}
</style>

<script>
import { gsap } from 'gsap';

document.addEventListener('DOMContentLoaded', () => {
  const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

  gsap.set('#priv-meta', { y: 8, opacity: 0 });
  tl.to('#priv-meta', { y: 0, opacity: 1, duration: 0.6 }, 0.25);

  const cards = document.querySelectorAll('.priv-card');
  if (cards.length) {
    gsap.set(cards, { y: 28, opacity: 0, scale: 0.985 });
    tl.to(cards, { y: 0, opacity: 1, scale: 1, duration: 0.9, stagger: 0.06 }, 0.4);
  }

  gsap.set('#priv-foot', { y: 8, opacity: 0 });
  tl.to('#priv-foot', { y: 0, opacity: 1, duration: 0.6 }, 0.85);
});
</script>
