---
// src/components/portal/BovedaUploadUI.astro
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="up-root">
  <div class="up-wrap">

    <!-- TOPBAR -->
    <div class="up-topbar" id="up-topbar">
      <a href={lang === 'en' ? '/en/boveda' : '/boveda'} class="up-back">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8"><polyline points="15 18 9 12 15 6"/></svg>
        {t('upload.back')}
      </a>
      <div class="up-badge">
        <span class="up-led"></span>
        <span>{t('portal.secure')}</span>
      </div>
    </div>

    <!-- HEADER -->
    <div class="up-header">
      <span class="up-eyebrow" id="up-eyebrow">{t('upload.eyebrow')}</span>
      <h1 class="up-title" id="up-title">
        <span>{t('upload.title')}</span>
        <em>{t('upload.title_ed')}</em>
      </h1>
      <p class="up-sub" id="up-sub">{t('upload.subtitle')}</p>
    </div>

    <div class="up-rule" id="up-rule"></div>

    <!-- FORM CARD -->
    <div class="up-card" id="up-card">
      <div class="up-spotlight" aria-hidden="true"></div>

      <form class="up-form" id="up-form" enctype="multipart/form-data">

        <!-- DROP ZONE -->
        <div class="up-zone" id="up-zone">
          <input type="file" id="up-file-input" class="up-file-input"
            accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.fig,.zip" />
          <div class="up-zone-inner" id="up-zone-inner">
            <div class="up-zone-icon" id="up-zone-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
            </div>
            <p class="up-zone-main">{t('upload.zone')}</p>
            <p class="up-zone-or">{t('upload.zone_or')}</p>
            <p class="up-zone-hint">{t('upload.zone_hint')}</p>
            <p class="up-file-name" id="up-file-name" style="display:none;"></p>
          </div>
        </div>

        <!-- FIELDS -->
        <div class="up-fields">

          <div class="up-field">
            <label for="up-name" class="up-label">{t('upload.label.name')}</label>
            <input type="text" id="up-name" name="name" class="up-input"
              placeholder={lang === 'en' ? "e.g. contract_q1_2025.pdf" : "ej. contrato_q1_2025.pdf"} />
          </div>

          <div class="up-field">
            <label for="up-category" class="up-label">{t('upload.label.category')}</label>
            <div class="up-select-wrap">
              <select id="up-category" name="category" class="up-select">
                <option value="contratos">{t('upload.cat.contracts')}</option>
                <option value="diseno">{t('upload.cat.design')}</option>
                <option value="general" selected>{t('upload.cat.general')}</option>
              </select>
              <svg class="up-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>

        </div>

        <!-- SUBMIT -->
        <button type="submit" class="up-submit-btn" id="up-submit-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          <span id="up-btn-label">{t('upload.btn')}</span>
        </button>

        <!-- FEEDBACK -->
        <div id="up-success" class="up-feedback up-success" style="display:none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          {t('upload.success')}
        </div>
        <div id="up-error" class="up-feedback up-error" style="display:none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          {t('upload.error')}
        </div>

      </form>
    </div>

  </div>
</div>

<style>
/* ══ TOKENS ══ */
.up-root {
  --blue:   #0055cc;
  --green:  #10b981;
  --text:   #0a0e1a;
  --muted:  #6e7d96;
  --dim:    #c4cdd9;
  --border: rgba(0,0,0,0.07);
  --ease:   cubic-bezier(0.16, 1, 0.3, 1);
  --shadow: 0 0 0 1px rgba(0,0,0,0.04), 0 2px 4px rgba(0,0,0,0.04), 0 8px 20px rgba(0,0,0,0.05);
  --shadow-up: 0 0 0 1px rgba(0,0,0,0.07), 0 4px 12px rgba(0,0,0,0.08), 0 16px 32px rgba(0,0,0,0.08);

  background: #ffffff;
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
  min-height: 100vh;
  padding: 2.8rem 0 6rem;
}
.up-wrap { max-width: 820px; margin: 0 auto; padding: 0 5%; }

/* ══ TOPBAR ══ */
.up-topbar {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 2.4rem; opacity: 0;
}
.up-back {
  display: flex; align-items: center; gap: 6px;
  font-size: 0.82rem; font-weight: 600; color: var(--muted);
  text-decoration: none; transition: color .2s;
}
.up-back:hover { color: var(--text); }
.up-badge {
  display: flex; align-items: center; gap: 8px;
  background: #0a192f; padding: 6px 16px; border-radius: 100px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem; letter-spacing: 0.1em;
  color: rgba(255,255,255,0.75); font-weight: 600;
  box-shadow: 0 4px 14px rgba(10,25,47,0.2);
}
.up-led {
  width: 6px; height: 6px; border-radius: 50%; background: var(--green);
  animation: led-pulse 2.5s ease-in-out infinite;
}

/* ══ HEADER ══ */
.up-header { margin-bottom: 0.4rem; }
.up-eyebrow {
  display: block; font-size: 0.62rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--muted); margin-bottom: 0.9rem;
}
.up-title {
  font-size: clamp(2.4rem, 5vw, 3.8rem);
  font-weight: 600; letter-spacing: -0.045em;
  line-height: 1.04; margin: 0 0 0.9rem;
  display: flex; gap: 0.3em; flex-wrap: wrap;
  overflow: hidden;
}
.up-title span { opacity: 0; }
.up-title em { font-style: normal; color: var(--muted); opacity: 0; }
.up-sub {
  font-size: 0.98rem; color: var(--muted); margin: 0;
  font-weight: 400; opacity: 0; max-width: 480px;
}
.up-rule {
  height: 1px; margin: 1.6rem 0 2rem;
  background: linear-gradient(90deg, transparent, var(--border) 20%, var(--border) 80%, transparent);
  transform: scaleX(0); transform-origin: left;
}

/* ══ CARD ══ */
.up-card {
  position: relative; background: #ffffff;
  border: 1px solid var(--border); border-radius: 22px;
  padding: 2.2rem 2.4rem; overflow: hidden; opacity: 0;
  box-shadow: var(--shadow);
  transition: box-shadow .45s var(--ease);
}
.up-card:hover { box-shadow: var(--shadow-up); }
.up-spotlight {
  position: absolute; width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, rgba(0,85,204,0.055) 0%, transparent 70%);
  pointer-events: none; transform: translate(-50%,-50%);
  top: 0; left: 0; opacity: 0; transition: opacity .4s; z-index: 0;
}
.up-card:hover .up-spotlight { opacity: 1; }
.up-form { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 1.8rem; }

/* ══ DROP ZONE ══ */
.up-zone {
  position: relative; border: 1.5px dashed var(--dim);
  border-radius: 16px; cursor: pointer;
  transition: border-color .25s var(--ease), background .25s;
  background: rgba(0,0,0,0.015);
}
.up-zone:hover, .up-zone.drag-over {
  border-color: var(--text); background: rgba(0,0,0,0.03);
}
.up-zone.drag-over .up-zone-icon { transform: scale(1.1) translateY(-4px); }
.up-file-input {
  position: absolute; inset: 0; width: 100%; height: 100%;
  opacity: 0; cursor: pointer; z-index: 2;
}
.up-zone-inner {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; padding: 3rem 2rem; gap: 0.3rem; pointer-events: none;
}
.up-zone-icon {
  color: var(--dim); margin-bottom: 0.6rem;
  transition: transform .3s var(--ease), color .2s;
}
.up-zone:hover .up-zone-icon { color: var(--text); }
.up-zone-main { font-size: 1rem; font-weight: 600; color: var(--text); margin: 0; }
.up-zone-or   { font-size: 0.82rem; color: var(--muted); margin: 0; font-weight: 400; }
.up-zone-hint { font-size: 0.72rem; color: var(--dim); margin: 0.3rem 0 0; font-family: 'JetBrains Mono', monospace; }
.up-file-name {
  font-size: 0.82rem; font-weight: 600; color: var(--blue);
  margin-top: 0.6rem;
}

/* ══ FIELDS ══ */
.up-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.up-field { display: flex; flex-direction: column; gap: 0.5rem; }
.up-label {
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted);
}
.up-input {
  font-family: inherit; font-size: 0.92rem; font-weight: 500;
  color: var(--text); background: rgba(0,0,0,0.02);
  border: 1px solid var(--border); border-radius: 12px;
  padding: 0.7rem 1rem; outline: none;
  transition: border-color .2s, background .2s, box-shadow .2s;
}
.up-input::placeholder { color: var(--dim); }
.up-input:focus {
  border-color: rgba(0,0,0,0.18);
  background: #fff;
  box-shadow: 0 0 0 3px rgba(0,0,0,0.04);
}
.up-select-wrap { position: relative; }
.up-select {
  appearance: none; -webkit-appearance: none;
  font-family: inherit; font-size: 0.92rem; font-weight: 500;
  color: var(--text); background: rgba(0,0,0,0.02);
  border: 1px solid var(--border); border-radius: 12px;
  padding: 0.7rem 2.4rem 0.7rem 1rem;
  width: 100%; outline: none; cursor: pointer;
  transition: border-color .2s, background .2s, box-shadow .2s;
}
.up-select:focus {
  border-color: rgba(0,0,0,0.18); background: #fff;
  box-shadow: 0 0 0 3px rgba(0,0,0,0.04);
}
.up-select-arrow {
  position: absolute; right: 0.9rem; top: 50%; transform: translateY(-50%);
  color: var(--muted); pointer-events: none;
}

/* ══ SUBMIT ══ */
.up-submit-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: var(--text); color: #fff;
  font-family: inherit; font-size: 0.92rem; font-weight: 600;
  padding: 0.95rem 2rem; border-radius: 100px; border: none; cursor: pointer;
  box-shadow: 0 4px 14px rgba(10,14,26,0.18);
  transition: background .25s var(--ease), transform .2s var(--ease), box-shadow .25s;
  align-self: flex-start;
}
.up-submit-btn:hover {
  background: #1a2233;
  box-shadow: 0 8px 22px rgba(10,14,26,0.25);
  transform: translateY(-2px) scale(1.015);
}
.up-submit-btn:active { transform: translateY(0) scale(0.98); }
.up-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

/* ══ FEEDBACK ══ */
.up-feedback {
  display: flex; align-items: center; gap: 8px;
  font-size: 0.88rem; font-weight: 600;
  padding: 0.85rem 1.2rem; border-radius: 12px;
}
.up-success { background: rgba(16,185,129,0.09); color: #059669; border: 1px solid rgba(16,185,129,0.2); }
.up-error   { background: rgba(220,38,38,0.07); color: #b91c1c; border: 1px solid rgba(220,38,38,0.15); }

/* ══ KEYFRAMES ══ */
@keyframes led-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(16,185,129,.5); transform: scale(1); }
  60%      { box-shadow: 0 0 0 5px rgba(16,185,129,0); transform: scale(1.2); }
}

/* ══ RESPONSIVE ══ */
@media (max-width: 640px) {
  .up-root { padding: 2rem 0 5rem; }
  .up-card { padding: 1.5rem 1.5rem; border-radius: 18px; }
  .up-fields { grid-template-columns: 1fr; }
  .up-title { font-size: clamp(2rem, 9vw, 3rem); }
  .up-submit-btn { width: 100%; }
}
</style>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";
  gsap.registerPlugin(SplitText);

  document.addEventListener("DOMContentLoaded", () => {
    const tl = gsap.timeline({ defaults: { ease: "expo.out" } });

    tl.to("#up-topbar", { opacity: 1, duration: 0.7 }, 0);

    gsap.set("#up-eyebrow", { y: 10 });
    tl.to("#up-eyebrow", { opacity: 1, y: 0, duration: 0.6 }, 0.1);

    const titleSpan = document.querySelector(".up-title span") as HTMLElement | null;
    const titleEm   = document.querySelector(".up-title em")   as HTMLElement | null;
    if (titleSpan) {
      const split = SplitText.create(titleSpan, { type: "chars" });
      gsap.set(split.chars, { opacity: 0, y: 22, rotateX: -38, transformOrigin: "center bottom" });
      tl.to(split.chars, { opacity: 1, y: 0, rotateX: 0, duration: 0.65, stagger: 0.025, ease: "back.out(1.8)" }, 0.25);
    }
    if (titleEm) tl.to(titleEm, { opacity: 1, duration: 0.6 }, 0.55);
    tl.to("#up-sub",  { opacity: 1, duration: 0.6 }, 0.65);
    tl.to("#up-rule", { scaleX: 1, duration: 1.0, ease: "power3.out" }, 0.5);

    gsap.set("#up-card", { y: 28, opacity: 0, scale: 0.985 });
    tl.to("#up-card", { y: 0, opacity: 1, scale: 1, duration: 1.0, ease: "expo.out" }, 0.5);

    // Spotlight
    const card = document.getElementById("up-card");
    const spot = card?.querySelector<HTMLElement>(".up-spotlight");
    if (card && spot) {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const r = card.getBoundingClientRect();
        gsap.to(spot, { x: e.clientX - r.left, y: e.clientY - r.top, duration: 0.5, ease: "power2.out" });
      });
    }

    // File input + drag & drop
    const zone = document.getElementById("up-zone") as HTMLElement | null;
    const fileInput = document.getElementById("up-file-input") as HTMLInputElement | null;
    const fileName  = document.getElementById("up-file-name") as HTMLElement | null;
    const nameInput = document.getElementById("up-name")      as HTMLInputElement | null;

    function setFile(file: File) {
      if (fileName) {
        fileName.textContent = file.name;
        fileName.style.display = "block";
      }
      if (nameInput && !nameInput.value) nameInput.value = file.name;
      gsap.from(fileName!, { opacity: 0, y: 6, duration: 0.4, ease: "expo.out" });
    }

    fileInput?.addEventListener("change", () => {
      if (fileInput.files?.[0]) setFile(fileInput.files[0]);
    });

    zone?.addEventListener("dragover", (e) => { e.preventDefault(); zone.classList.add("drag-over"); });
    zone?.addEventListener("dragleave", () => zone.classList.remove("drag-over"));
    zone?.addEventListener("drop", (e: DragEvent) => {
      e.preventDefault();
      zone.classList.remove("drag-over");
      const file = e.dataTransfer?.files[0];
      if (file && fileInput) {
        const dt = new DataTransfer();
        dt.items.add(file);
        fileInput.files = dt.files;
        setFile(file);
      }
    });

    // Form submit — uploads to Supabase Storage via API endpoint
    const form = document.getElementById("up-form") as HTMLFormElement | null;
    const submitBtn   = document.getElementById("up-submit-btn") as HTMLButtonElement | null;
    const btnLabel    = document.getElementById("up-btn-label")  as HTMLElement | null;
    const successEl   = document.getElementById("up-success")    as HTMLElement | null;
    const errorEl     = document.getElementById("up-error")      as HTMLElement | null;

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!fileInput?.files?.[0]) return;

      const file     = fileInput.files[0];
      const name     = (document.getElementById("up-name") as HTMLInputElement)?.value || file.name;
      const category = (document.getElementById("up-category") as HTMLSelectElement)?.value || "general";

      if (submitBtn) submitBtn.disabled = true;
      if (btnLabel) btnLabel.textContent = "Uploading…";
      if (successEl) successEl.style.display = "none";
      if (errorEl)   errorEl.style.display   = "none";

      try {
        const fd = new FormData();
        fd.append("file", file);
        fd.append("name", name);
        fd.append("category", category);

        const res = await fetch("/api/boveda/upload", { method: "POST", body: fd });
        if (!res.ok) throw new Error("upload failed");

        if (successEl) {
          successEl.style.display = "flex";
          gsap.from(successEl, { opacity: 0, y: 8, duration: 0.5, ease: "expo.out" });
        }
        form.reset();
        if (fileName) { fileName.textContent = ""; fileName.style.display = "none"; }

      } catch {
        if (errorEl) {
          errorEl.style.display = "flex";
          gsap.from(errorEl, { opacity: 0, y: 8, duration: 0.5, ease: "expo.out" });
        }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (btnLabel) btnLabel.textContent = document.documentElement.lang === "en" ? "Upload to Vault" : "Subir a Bóveda";
      }
    });
  });
</script>
