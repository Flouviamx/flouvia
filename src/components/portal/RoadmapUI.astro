---
// src/components/portal/RoadmapUI.astro
import { useTranslations } from '../../i18n/utils';
import { supabase } from '../../lib/supabase';

interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const user = await Astro.locals.currentUser();
const email = user?.emailAddresses[0]?.emailAddress || "flouvia.mx@gmail.com";

const { data: rows } = await supabase
  .from('roadmap')
  .select('*')
  .eq('email_cliente', email)
  .order('orden_index');

const items = (rows ?? []).map((r: any) => ({
  id:          r.id,
  title:       r.titulo,
  status:      r.status as 'done' | 'active' | 'pending',
  date:        r.fecha_info ?? "",
  description: r.descripcion ?? "",
}));

const statusLabel = (s: string) => {
  if (s === 'done')   return t('road.status.done');
  if (s === 'active') return t('road.status.active');
  return t('road.status.pending');
};

const doneCount = items.filter(i => i.status === 'done').length;
---

<div class="pure-white-wrapper">
    <div class="noise-overlay"></div>

    <div class="container-master">

        <header class="dashboard-header gsap-reveal">
            <div class="header-status">
                <a href={lang === 'en' ? "/en/portal/dashboard" : "/portal/dashboard"} class="back-link haptic-soft">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    {lang === 'en' ? 'Back to Console' : 'Volver a Console'}
                </a>
                <div class="secure-badge">
                    <span class="dot-secure pulse"></span> {t('portal.secure')}
                </div>
            </div>

            <div class="header-flex mt-4">
                <div class="title-group">
                    <h1 class="greeting-title">{t('road.title')}</h1>
                    <p class="greeting-subtitle">{t('road.subtitle')}</p>
                </div>
                {items.length > 0 && (
                    <div class="sprint-count-badge">
                        <span class="count-num">{doneCount}</span>
                        <span class="count-slash">/</span>
                        <span class="count-total">{items.length}</span>
                        <span class="count-label">{lang === 'en' ? 'completed' : 'completados'}</span>
                    </div>
                )}
            </div>
        </header>

        <div class="timeline-wrapper gsap-reveal">
            {items.length === 0 ? (
                <div class="empty-state">
                    <div class="empty-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    </div>
                    <p>{t('road.empty')}</p>
                </div>
            ) : (
                <div class="timeline-list">
                    {items.map((item, index) => (
                        <div class={`timeline-item ${item.status}`}>
                            <div class="tl-left">
                                <div class={`node-dot ${item.status}`}></div>
                                {index < items.length - 1 && <div class="connector-line"></div>}
                            </div>
                            <div class="tl-card">
                                <div class="tl-card-header">
                                    <span class="sprint-eyebrow">{t('road.sprint')} {String(index + 1).padStart(2, '0')}</span>
                                    <span class={`status-chip ${item.status}`}>{statusLabel(item.status)}</span>
                                </div>
                                <h3 class={`sprint-title ${item.status === 'done' ? 'is-done' : ''}`}>{item.title}</h3>
                                {item.description && <p class="sprint-desc">{item.description}</p>}
                                {item.date && (
                                    <div class="sprint-meta">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                        <span class="sprint-date">{item.date}</span>
                                    </div>
                                )}
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </div>

    </div>
</div>

<style>
    :root {
        --color-bg-white:      #ffffff;
        --color-card-white:    #ffffff;
        --color-text-main:     #111111;
        --color-text-muted:    #86868b;
        --color-border-subtle: rgba(0,0,0,0.06);
        --shadow-premium: 0 24px 48px -12px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.02);
    }

    .pure-white-wrapper {
        position: relative; width: 100%; min-height: 100vh;
        background-color: var(--color-bg-white);
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
        color: var(--color-text-main); padding: 6rem 0 8rem; overflow-x: hidden;
    }

    .noise-overlay {
        position: absolute; inset: 0; pointer-events: none; z-index: 1;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.025; mix-blend-mode: multiply;
    }

    .container-master {
        width: 100%; max-width: 760px; margin: 0 auto; padding: 0 5%;
        position: relative; z-index: 2;
    }

    /* ── HEADER ── */
    .dashboard-header { margin-bottom: 4rem; opacity: 0; }
    .header-status {
        display: flex; justify-content: space-between; align-items: center;
        border-bottom: 1px solid var(--color-border-subtle); padding-bottom: 1rem;
    }

    .back-link {
        display: flex; align-items: center; gap: 6px; font-size: 0.85rem;
        font-weight: 600; color: var(--color-text-muted); text-decoration: none;
        transition: color 0.2s;
    }
    .back-link:hover { color: var(--color-text-main); }

    .secure-badge {
        display: flex; align-items: center; gap: 6px; font-size: 0.7rem;
        font-weight: 700; color: var(--color-text-muted); letter-spacing: 1px;
    }
    .dot-secure { width: 6px; height: 6px; background: #34c759; border-radius: 50%; }
    .pulse { animation: led-pulse 2.8s ease-in-out infinite; }

    .header-flex {
        display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem;
    }
    .mt-4 { margin-top: 1.5rem; }

    .greeting-title {
        font-size: clamp(2.5rem, 5vw, 3.5rem); margin: 0 0 0.5rem 0;
        line-height: 1.05; letter-spacing: -0.04em; font-weight: 600;
        color: var(--color-text-main);
    }
    .greeting-subtitle { font-size: 1.1rem; color: var(--color-text-muted); margin: 0; font-weight: 400; }

    /* Sprint counter badge */
    .sprint-count-badge {
        display: flex; align-items: baseline; gap: 3px; flex-shrink: 0;
        background: rgba(0,0,0,0.025); border: 1px solid var(--color-border-subtle);
        border-radius: 18px; padding: 0.85rem 1.5rem;
    }
    .count-num {
        font-size: 2.4rem; font-weight: 700; letter-spacing: -0.04em;
        color: var(--color-text-main); font-family: 'JetBrains Mono', monospace; line-height: 1;
    }
    .count-slash { font-size: 1.5rem; color: rgba(0,0,0,0.15); margin: 0 3px; }
    .count-total { font-size: 1.5rem; font-weight: 500; color: var(--color-text-muted); }
    .count-label {
        font-size: 0.7rem; font-weight: 700; color: var(--color-text-muted);
        margin-left: 10px; text-transform: uppercase; letter-spacing: 0.5px;
    }

    /* ── TIMELINE ── */
    .timeline-wrapper { opacity: 0; }
    .timeline-list { display: flex; flex-direction: column; }

    .timeline-item {
        display: flex; align-items: flex-start; gap: 1.8rem;
    }

    /* Left column: node + vertical line */
    .tl-left {
        display: flex; flex-direction: column; align-items: center;
        flex-shrink: 0; width: 18px; padding-top: 0.5rem;
    }

    .node-dot {
        width: 18px; height: 18px; border-radius: 50%; flex-shrink: 0;
        border: 2.5px solid rgba(0,0,0,0.1);
        background: #fff; position: relative; z-index: 2;
    }
    .node-dot.done {
        background: var(--color-text-main);
        border-color: var(--color-text-main);
        box-shadow: 0 0 0 4px rgba(17,17,17,0.06);
    }
    .node-dot.done::after {
        content: '';
        position: absolute; inset: 4px;
        border-radius: 50%;
        background: rgba(255,255,255,0.35);
    }
    .node-dot.active {
        background: #34c759;
        border-color: #2db34e;
        animation: node-glow 2.5s ease-in-out infinite;
    }
    .node-dot.pending {
        background: #fff;
        border-color: rgba(0,0,0,0.1);
    }

    .connector-line {
        width: 2px; flex-grow: 1; min-height: 2.5rem; margin-top: 5px;
        background: linear-gradient(to bottom, rgba(0,0,0,0.07) 0%, rgba(0,0,0,0.025) 100%);
        border-radius: 1px;
        transform-origin: top center;
    }

    /* Card */
    .tl-card {
        flex-grow: 1; padding: 1.8rem 2rem;
        background: var(--color-card-white);
        border-radius: 22px;
        border: 1px solid var(--color-border-subtle);
        box-shadow: var(--shadow-premium);
        margin-bottom: 1.4rem;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .tl-card:hover {
        transform: translateX(5px);
        box-shadow: 0 20px 40px -8px rgba(0,0,0,0.07), 0 4px 12px rgba(0,0,0,0.03);
    }

    .timeline-item.active .tl-card {
        border-color: rgba(52, 199, 89, 0.2);
        box-shadow: var(--shadow-premium), 0 0 0 1px rgba(52, 199, 89, 0.08), 0 0 24px rgba(52, 199, 89, 0.04);
    }
    .timeline-item.done .tl-card {
        opacity: 0.72;
    }

    .tl-card-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 0.9rem;
    }

    .sprint-eyebrow {
        font-size: 0.62rem; font-weight: 800; letter-spacing: 0.14em;
        color: var(--color-text-muted); text-transform: uppercase;
        font-family: 'JetBrains Mono', monospace;
    }

    .status-chip {
        font-size: 0.67rem; font-weight: 800; padding: 3px 10px;
        border-radius: 100px; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .status-chip.done {
        background: rgba(0,0,0,0.04); color: var(--color-text-muted);
        border: 1px solid rgba(0,0,0,0.05);
    }
    .status-chip.active {
        background: linear-gradient(135deg, rgba(52,199,89,0.18), rgba(52,199,89,0.07));
        color: #1a7a35; border: 1px solid rgba(52,199,89,0.22);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);
    }
    .status-chip.pending {
        background: rgba(0,0,0,0.02); color: rgba(0,0,0,0.28);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .sprint-title {
        font-size: 1.25rem; font-weight: 600; color: var(--color-text-main);
        margin: 0 0 0.5rem 0; letter-spacing: -0.025em; line-height: 1.3;
    }
    .sprint-title.is-done {
        color: var(--color-text-muted);
        text-decoration: line-through;
        text-decoration-color: rgba(0,0,0,0.18);
        text-decoration-thickness: 1.5px;
    }

    .sprint-desc {
        font-size: 0.9rem; color: var(--color-text-muted); margin: 0 0 0.9rem 0;
        line-height: 1.65; font-weight: 400;
    }

    .sprint-meta { display: flex; align-items: center; gap: 6px; color: var(--color-text-muted); }
    .sprint-date {
        font-size: 0.78rem; font-family: 'JetBrains Mono', monospace;
        color: var(--color-text-muted); font-weight: 500;
    }

    /* Empty state */
    .empty-state {
        padding: 6rem 2rem; text-align: center;
        color: var(--color-text-muted); font-size: 1.05rem; font-weight: 500;
        display: flex; flex-direction: column; align-items: center; gap: 1rem;
    }
    .empty-icon {
        width: 56px; height: 56px; border-radius: 16px;
        background: rgba(0,0,0,0.03); border: 1px solid var(--color-border-subtle);
        display: flex; align-items: center; justify-content: center;
        color: var(--color-text-muted);
    }

    /* Haptics */
    .haptic-soft:active { transform: scale(0.985); }

    /* Animations */
    @keyframes led-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(52,199,89,0.55); transform: scale(1); }
        55%       { box-shadow: 0 0 0 5px rgba(52,199,89,0.0);  transform: scale(1.18); }
    }
    @keyframes node-glow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(52,199,89,0.65); }
        50%       { box-shadow: 0 0 0 10px rgba(52,199,89,0.0); }
    }

    /* Responsive */
    @media (max-width: 640px) {
        .header-flex { flex-direction: column; align-items: flex-start; gap: 1.2rem; }
        .sprint-count-badge { width: 100%; justify-content: center; }
        .tl-card { padding: 1.4rem 1.5rem; border-radius: 18px; }
        .timeline-item { gap: 1.2rem; }
        .tl-card:hover { transform: none; }
    }
</style>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        gsap.set(".gsap-reveal", { y: 24, opacity: 0, scale: 0.99 });

        const tl = gsap.timeline();
        tl.to(".dashboard-header", { y: 0, opacity: 1, duration: 1.2, ease: "expo.out" });
        tl.to(".timeline-wrapper", { y: 0, opacity: 1, scale: 1, duration: 1.1, ease: "expo.out" }, "-=0.8");

        // Cards slide in from left with stagger
        const cards = document.querySelectorAll('.tl-card');
        if (cards.length > 0) {
            gsap.set(cards, { x: -24, opacity: 0 });
            tl.to(cards, {
                x: 0, opacity: 1,
                duration: 0.75, stagger: 0.1, ease: "expo.out",
            }, "-=0.7");
        }

        // Connector lines draw downward
        const lines = document.querySelectorAll('.connector-line');
        if (lines.length > 0) {
            gsap.set(lines, { scaleY: 0, transformOrigin: "top center" });
            tl.to(lines, {
                scaleY: 1,
                duration: 0.55, stagger: 0.1, ease: "expo.out",
            }, "-=0.85");
        }

        // Node dots pop in
        const nodes = document.querySelectorAll('.node-dot');
        if (nodes.length > 0) {
            gsap.set(nodes, { scale: 0, opacity: 0 });
            tl.to(nodes, {
                scale: 1, opacity: 1,
                duration: 0.4, stagger: 0.1, ease: "back.out(2)",
            }, "-=0.85");
        }
    });
</script>
