}

.env-vitals-pill-warn { background: rgba(245,158,11,0.08); border-color: rgba(245,158,11,0.2); color: #d97706; }
.env-vitals-dot-warn  { background: var(--amber); }
.vital-warn { border-color: rgba(245,158,11,0.2); }
.vital-warn:hover { border-color: rgba(245,158,11,0.35); }
