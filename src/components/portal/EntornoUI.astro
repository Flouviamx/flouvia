---
// src/components/portal/EntornoUI.astro
import { useTranslations } from '../../i18n/utils';
import { supabase } from '../../lib/supabase';

interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const user = await Astro.locals.currentUser();
const email = user?.emailAddresses[0]?.emailAddress || "flouvia.mx@gmail.com";

const { data: proyecto } = await supabase
  .from('proyectos')
  .select('*')
  .eq('email_cliente', email)
  .single();

const data = {
  name:     proyecto?.nombre_proyecto ?? (lang === 'en' ? "Global B2B Platform" : "Plataforma B2B Global"),
  stage:    proyecto?.etapa           ?? (lang === 'en' ? "Frontend Engineering" : "Ingeniería Frontend"),
  progress: proyecto?.progreso        ?? 0,
  uptime:   proyecto?.uptime          ?? "99.98%",
  liveUrl:  proyecto?.live_url        ?? "",
  deadline: proyecto?.deadline        ?? "—",
  stack:    proyecto?.stack           ?? "Next.js · Vercel · Supabase",
  region:   proyecto?.region          ?? "US East",
  latency:  proyecto?.latencia        ?? "62 ms",
};

const hasUrl = data.liveUrl && data.liveUrl !== "#" && data.liveUrl !== "";
const displayHost = hasUrl ? (() => { try { return new URL(data.liveUrl).host; } catch { return data.liveUrl; } })() : "";

// Mock Core Web Vitals (production-grade values, would come from real RUM later)
const vitals = [
  { key: 'lcp',  label: t('entorno.perf.lcp'),  value: 1.2, unit: 's',  full: t('entorno.perf.lcp_full'),  threshold: 2.5, target: 1.2 },
  { key: 'fid',  label: t('entorno.perf.fid'),  value: 84,  unit: 'ms', full: t('entorno.perf.fid_full'),  threshold: 200, target: 84  },
  { key: 'cls',  label: t('entorno.perf.cls'),  value: 0.03, unit: '',  full: t('entorno.perf.cls_full'),  threshold: 0.1, target: 0.03 },
  { key: 'ttfb', label: t('entorno.perf.ttfb'), value: 180, unit: 'ms', full: t('entorno.perf.ttfb_full'), threshold: 600, target: 180 },
];

// Mock deploys (would come from Vercel API later)
const deploys = [
  { sha: '4b28187', msg: lang === 'en' ? 'fix: navbar scroll transition' : 'fix: transición scroll del navbar', branch: 'main', env: 'production', when: '12 min', status: 'ready' },
  { sha: '9f1613e', msg: lang === 'en' ? 'feat: GSAP entrance, active dots' : 'feat: entrada GSAP, dots activos',  branch: 'main', env: 'production', when: '47 min', status: 'ready' },
  { sha: '6025bad', msg: lang === 'en' ? 'feat: Clerk → Supabase webhook' : 'feat: webhook Clerk → Supabase',     branch: 'main', env: 'production', when: '2 h',   status: 'ready' },
  { sha: '616bd2d', msg: lang === 'en' ? 'feat: Entorno & Upload pages' : 'feat: páginas Entorno & Upload',       branch: 'main', env: 'production', when: '5 h',   status: 'ready' },
];

// Mock regions
const regions = [
  { name: 'US East',   code: 'iad1', latency: 62,  status: 'healthy' },
  { name: 'US West',   code: 'sfo1', latency: 88,  status: 'healthy' },
  { name: 'EU West',   code: 'lhr1', latency: 142, status: 'healthy' },
  { name: 'Asia Pac',  code: 'hnd1', latency: 198, status: 'healthy' },
  { name: 'South Am',  code: 'gru1', latency: 124, status: 'healthy' },
];

// Mock activity log
const activity = [
  { time: '14:32:08', type: 'deploy', text: lang === 'en' ? 'Deployment ready · build cached'      : 'Despliegue listo · build cacheado',    color: 'green' },
  { time: '14:31:42', type: 'build',  text: lang === 'en' ? 'Build completed in 24.6s'             : 'Build completado en 24.6s',            color: 'blue'  },
  { time: '14:31:18', type: 'commit', text: lang === 'en' ? 'Pushed to main · 4b28187'             : 'Push a main · 4b28187',                color: 'muted' },
  { time: '13:45:00', type: 'health', text: lang === 'en' ? 'Health check: all systems operational': 'Health check: sistemas operativos',     color: 'green' },
  { time: '12:18:11', type: 'cache',  text: lang === 'en' ? 'Edge cache invalidated · 4 regions'   : 'Cache de edge invalidado · 4 regiones', color: 'blue'  },
  { time: '11:02:55', type: 'deploy', text: lang === 'en' ? 'Production rollout 100%'              : 'Rollout a producción 100%',            color: 'green' },
];
---

<div class="env-root">
  <div class="env-wrap">

    <!-- TOPBAR -->
    <div class="env-topbar" id="env-topbar">
      <a href={lang === 'en' ? '/en/dashboard' : '/dashboard'} class="env-back">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8"><polyline points="15 18 9 12 15 6"/></svg>
        {t('entorno.back')}
      </a>
      <div class="env-badge-row">
        <button class="env-refresh-btn" id="env-refresh">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          {t('entorno.refresh')}
        </button>
        <div class="env-badge">
          <span class="env-led"></span>
          <span>{t('portal.secure')}</span>
        </div>
      </div>
    </div>

    <!-- HEADER -->
    <div class="env-header">
      <span class="env-eyebrow" id="env-eyebrow">
        <span class="env-dot-line"></span>
        {t('entorno.eyebrow')}
      </span>
      <h1 class="env-title" id="env-title">
        <span class="env-title-1">{t('entorno.title')}</span>
        <em class="env-title-2">{t('entorno.title_ed')}</em>
      </h1>
      <p class="env-sub" id="env-sub">{t('entorno.subtitle')}</p>
    </div>

    <div class="env-rule" id="env-rule"></div>

    <!-- ROW 1: Live Preview + Status -->
    <div class="env-grid">

      <!-- LIVE PREVIEW BROWSER -->
      <div class="env-card env-preview-card" id="card-preview">
        <div class="env-spotlight" aria-hidden="true"></div>

        <!-- Browser chrome -->
        <div class="env-browser">
          <div class="env-browser-bar">
            <div class="env-browser-dots">
              <span class="env-dot env-dot-r"></span>
              <span class="env-dot env-dot-y"></span>
              <span class="env-dot env-dot-g"></span>
            </div>
            <div class="env-browser-url">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="env-url-host">{hasUrl ? displayHost : t('entorno.preview.unavailable')}</span>
            </div>
            <div class="env-browser-actions">
              {hasUrl && (
                <a href={data.liveUrl} target="_blank" rel="noopener noreferrer" class="env-browser-open" title={t('entorno.open_btn')}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              )}
            </div>
          </div>

          <!-- Iframe / fallback -->
          <div class="env-browser-frame">
            {hasUrl ? (
              <>
                <div class="env-iframe-loader" id="env-iframe-loader">
                  <div class="env-loader-bar"></div>
                </div>
                <iframe id="env-iframe" src={data.liveUrl} loading="lazy" referrerpolicy="no-referrer"
                  title="Live preview" sandbox="allow-scripts allow-same-origin"></iframe>
                <div class="env-iframe-overlay" id="env-iframe-overlay">
                  <div class="env-iframe-overlay-text">
                    <p>{t('entorno.preview.fallback')}</p>
                    <a href={data.liveUrl} target="_blank" rel="noopener noreferrer" class="env-overlay-link">{t('entorno.open_btn')} ↗</a>
                  </div>
                </div>
              </>
            ) : (
              <div class="env-iframe-empty">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <p>{t('entorno.no_url')}</p>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- STATUS PANEL -->
      <div class="env-card env-status-card" id="card-status">
        <div class="env-spotlight" aria-hidden="true"></div>

        <span class="env-ey">{t('entorno.status.label')}</span>
        <h2 class="env-project-name">{data.name}</h2>

        <div class="env-status-rows">
          <div class="env-stat-row">
            <span class="env-stat-label">{t('entorno.status.online')}</span>
            <span class="env-stat-val env-stat-green">
              <span class="env-pulse-dot"></span>
              {lang === 'en' ? 'Operational' : 'Operativo'}
            </span>
          </div>
          <div class="env-stat-row">
            <span class="env-stat-label">{t('entorno.status.uptime')}</span>
            <span class="env-stat-val">{data.uptime}</span>
          </div>
          <div class="env-stat-row">
            <span class="env-stat-label">{t('entorno.status.latency')}</span>
            <span class="env-stat-val">{data.latency}</span>
          </div>
          <div class="env-stat-row">
            <span class="env-stat-label">{t('entorno.status.region')}</span>
            <span class="env-stat-val">{data.region}</span>
          </div>
        </div>

        <!-- Mini progress -->
        <div class="env-mini-progress">
          <div class="env-mini-progress-head">
            <span class="env-mini-label">{lang === 'en' ? 'PROJECT COMPLETION' : 'AVANCE DEL PROYECTO'}</span>
            <span class="env-mini-pct" id="env-pct">0%</span>
          </div>
          <div class="env-mini-bar">
            <div class="env-mini-fill" id="env-fill" data-target={data.progress} style="width:0%"></div>
          </div>
        </div>
      </div>

    </div>

    <!-- ROW 2: Core Web Vitals -->
    <div class="env-vitals-row" id="vitals-row">
      <div class="env-vitals-header">
        <span class="env-ey">{t('entorno.perf.label')}</span>
        <span class="env-vitals-pill">
          <span class="env-vitals-dot"></span>
          {lang === 'en' ? 'All metrics passing' : 'Todas las métricas pasan'}
        </span>
      </div>
      <div class="env-vitals-grid">
        {vitals.map((v) => (
          <div class="env-vital-card vital-card" data-target={v.target}>
            <div class="env-vital-top">
              <span class="env-vital-label">{v.label}</span>
              <span class="env-vital-status">●</span>
            </div>
            <div class="env-vital-num-row">
              <span class="env-vital-num" data-target={v.target} data-decimals={v.unit === '' ? 2 : (v.value < 10 ? 1 : 0)}>0</span>
              <span class="env-vital-unit">{v.unit}</span>
            </div>
            <p class="env-vital-full">{v.full}</p>
            <div class="env-vital-spark" data-vital={v.key}>
              <svg viewBox="0 0 100 30" preserveAspectRatio="none">
                <path class="env-spark-path" d={
                  v.key === 'lcp'  ? 'M0,18 L14,15 L28,20 L42,12 L56,16 L70,9 L84,11 L100,7' :
                  v.key === 'fid'  ? 'M0,16 L14,14 L28,18 L42,11 L56,15 L70,8 L84,10 L100,6' :
                  v.key === 'cls'  ? 'M0,20 L14,17 L28,22 L42,14 L56,18 L70,11 L84,13 L100,8' :
                                     'M0,15 L14,18 L28,12 L42,15 L56,10 L70,13 L84,8 L100,5'
                } fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ROW 3: Deploys + Regions -->
    <div class="env-grid">

      <!-- DEPLOY HISTORY -->
      <div class="env-card env-deploy-card" id="card-deploys">
        <div class="env-spotlight" aria-hidden="true"></div>
        <div class="env-card-head">
          <span class="env-ey">{t('entorno.deploy.label')}</span>
          <span class="env-count-pill">{deploys.length}</span>
        </div>
        <div class="env-deploys">
          {deploys.map((d, i) => (
            <div class="env-deploy-row" data-i={i}>
              <div class="env-deploy-status">
                <div class="env-deploy-dot"></div>
                {i < deploys.length - 1 && <div class="env-deploy-line"></div>}
              </div>
              <div class="env-deploy-body">
                <div class="env-deploy-top">
                  <span class="env-deploy-msg">{d.msg}</span>
                  <span class="env-deploy-when">{d.when}</span>
                </div>
                <div class="env-deploy-meta">
                  <span class="env-deploy-sha"><span class="env-sha-prefix">git:</span>{d.sha}</span>
                  <span class="env-deploy-branch">{d.branch}</span>
                  <span class="env-deploy-env env-deploy-env-prod">{t('entorno.deploy.production')}</span>
                  <span class="env-deploy-status-pill">
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                    {t('entorno.deploy.success')}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- REGION STATUS -->
      <div class="env-card env-region-card" id="card-regions">
        <div class="env-spotlight" aria-hidden="true"></div>
        <div class="env-card-head">
          <span class="env-ey">{t('entorno.region.label')}</span>
          <span class="env-count-pill">{regions.length}</span>
        </div>
        <div class="env-regions">
          {regions.map((r) => (
            <div class="env-region-row">
              <div class="env-region-left">
                <span class="env-region-pulse"></span>
                <div class="env-region-info">
                  <span class="env-region-name">{r.name}</span>
                  <span class="env-region-code">{r.code}</span>
                </div>
              </div>
              <div class="env-region-right">
                <div class="env-region-bar">
                  <div class="env-region-fill" style={`width:${Math.min(100, (r.latency / 250) * 100)}%`}></div>
                </div>
                <span class="env-region-ms">{r.latency}<small>ms</small></span>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- ROW 4: Activity Log -->
    <div class="env-card env-activity-card" id="card-activity">
      <div class="env-spotlight" aria-hidden="true"></div>
      <div class="env-card-head">
        <span class="env-ey">
          <span class="env-terminal-prompt">$</span>
          {t('entorno.activity.label')}
        </span>
        <span class="env-blink-cursor">_</span>
      </div>
      <div class="env-activity-log">
        {activity.map((a, i) => (
          <div class="env-log-row" data-i={i}>
            <span class="env-log-time">{a.time}</span>
            <span class={`env-log-tag env-log-tag-${a.color}`}>[{a.type}]</span>
            <span class="env-log-text">{a.text}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</div>

<style>
.env-root {
  --blue:   #0055cc;
  --green:  #10b981;
  --amber:  #f59e0b;
  --red:    #dc2626;
  --text:   #0a0e1a;
  --muted:  #6e7d96;
  --dim:    #c4cdd9;
  --border: rgba(0,0,0,0.07);
  --ease:   cubic-bezier(0.16, 1, 0.3, 1);
  --shadow: 0 0 0 1px rgba(0,0,0,0.04), 0 2px 4px rgba(0,0,0,0.04), 0 8px 20px rgba(0,0,0,0.05);
  --shadow-up: 0 0 0 1px rgba(0,0,0,0.07), 0 4px 12px rgba(0,0,0,0.08), 0 16px 32px rgba(0,0,0,0.08);

  background: #ffffff;
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
  min-height: 100vh;
  padding: 2.6rem 0 6rem;
}
.env-wrap { max-width: 1240px; margin: 0 auto; padding: 0 5%; }

/* ── TOPBAR ── */
.env-topbar {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 2.4rem; opacity: 0;
}
.env-back {
  display: flex; align-items: center; gap: 6px;
  font-size: 0.82rem; font-weight: 600; color: var(--muted);
  text-decoration: none; transition: color .2s, transform .3s var(--ease);
}
.env-back:hover { color: var(--text); transform: translateX(-3px); }

.env-badge-row { display: flex; align-items: center; gap: 10px; }

.env-refresh-btn {
  display: flex; align-items: center; gap: 6px;
  background: rgba(0,0,0,0.04); border: 1px solid var(--border);
  border-radius: 100px; padding: 5px 12px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem; font-weight: 700; letter-spacing: 0.08em;
  color: var(--muted); cursor: pointer;
  transition: all .25s var(--ease);
}
.env-refresh-btn:hover { background: rgba(0,0,0,0.07); color: var(--text); }
.env-refresh-btn.spinning svg { animation: env-spin 0.7s linear; }
@keyframes env-spin { to { transform: rotate(360deg); } }

.env-badge {
  display: flex; align-items: center; gap: 8px;
  background: #0a192f; padding: 6px 16px; border-radius: 100px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem; letter-spacing: 0.1em;
  color: rgba(255,255,255,0.78); font-weight: 600;
  box-shadow: 0 4px 14px rgba(10,25,47,0.2);
}
.env-led {
  width: 6px; height: 6px; border-radius: 50%; background: var(--green);
  animation: env-pulse 2.5s ease-in-out infinite;
}

/* ── HEADER ── */
.env-header { margin-bottom: 0.6rem; }
.env-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem; font-weight: 700;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--muted); margin-bottom: 1.1rem; opacity: 0;
}
.env-dot-line {
  display: inline-block; width: 24px; height: 1px;
  background: var(--muted); transform-origin: left;
}
.env-title {
  font-size: clamp(2.6rem, 5.4vw, 4.4rem);
  font-weight: 600; letter-spacing: -0.045em;
  line-height: 1.04; margin: 0 0 0.95rem;
  display: flex; flex-direction: column; gap: 0.05em;
  overflow: hidden;
}
.env-title-1 { display: block; opacity: 0; }
.env-title-2 { font-style: italic; font-family: 'Instrument Serif', Georgia, serif; font-weight: 400; color: var(--muted); opacity: 0; letter-spacing: -0.02em; font-size: 1.05em; }
.env-sub {
  font-size: 1rem; color: var(--muted); margin: 0;
  font-weight: 400; opacity: 0; max-width: 520px; line-height: 1.5;
}
.env-rule {
  height: 1px; margin: 1.6rem 0 1.8rem;
  background: linear-gradient(90deg, transparent, var(--border) 20%, var(--border) 80%, transparent);
  transform: scaleX(0); transform-origin: left;
}

/* ── GRID ── */
.env-grid {
  display: grid; grid-template-columns: repeat(12, 1fr);
  gap: 1rem; margin-bottom: 1rem;
}
.env-preview-card { grid-column: span 8; }
.env-status-card  { grid-column: span 4; display: flex; flex-direction: column; }
.env-deploy-card  { grid-column: span 7; }
.env-region-card  { grid-column: span 5; }

/* ── CARD BASE ── */
.env-card {
  position: relative; background: #ffffff;
  border: 1px solid var(--border); border-radius: 22px;
  padding: 1.8rem 2rem; overflow: hidden; opacity: 0;
  box-shadow: var(--shadow);
  transition: box-shadow .45s var(--ease), transform .45s var(--ease), border-color .4s;
}
.env-card:hover { box-shadow: var(--shadow-up); transform: translateY(-3px); border-color: rgba(0,85,204,0.1); }

.env-spotlight {
  position: absolute; width: 380px; height: 380px; border-radius: 50%;
  background: radial-gradient(circle, rgba(0,85,204,0.06) 0%, transparent 70%);
  pointer-events: none; transform: translate(-50%,-50%);
  top: 0; left: 0; opacity: 0; transition: opacity .4s; z-index: 0;
}
.env-card:hover .env-spotlight { opacity: 1; }
.env-card > *:not(.env-spotlight) { position: relative; z-index: 1; }

.env-ey {
  display: flex; align-items: center; gap: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem; font-weight: 700;
  letter-spacing: 0.13em; text-transform: uppercase;
  color: var(--muted); margin-bottom: 1rem;
}
.env-card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 1rem;
}
.env-card-head .env-ey { margin-bottom: 0; }
.env-count-pill {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem; font-weight: 700; letter-spacing: 0.05em;
  background: rgba(0,0,0,0.04); border: 1px solid var(--border);
  padding: 2px 8px; border-radius: 100px;
  color: var(--muted);
}

/* ── BROWSER (PREVIEW CARD) ── */
.env-preview-card { padding: 0; }
.env-preview-card > .env-spotlight { z-index: 0; }
.env-browser {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; height: 100%;
  border-radius: 22px; overflow: hidden;
}
.env-browser-bar {
  display: grid; grid-template-columns: auto 1fr auto;
  align-items: center; gap: 14px;
  padding: 12px 18px; background: rgba(0,0,0,0.025);
  border-bottom: 1px solid var(--border);
}
.env-browser-dots { display: flex; gap: 6px; }
.env-dot {
  width: 11px; height: 11px; border-radius: 50%;
  border: 1px solid rgba(0,0,0,0.06);
}
.env-dot-r { background: #ff5f57; }
.env-dot-y { background: #febc2e; }
.env-dot-g { background: #28c840; }

.env-browser-url {
  display: flex; align-items: center; gap: 8px;
  background: #fff; border: 1px solid var(--border);
  border-radius: 100px; padding: 6px 14px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.74rem; color: var(--muted);
  max-width: 400px; margin: 0 auto;
}
.env-url-host { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.env-browser-actions { display: flex; gap: 6px; }
.env-browser-open {
  display: flex; align-items: center; justify-content: center;
  width: 28px; height: 28px; border-radius: 50%;
  background: rgba(0,0,0,0.04); border: 1px solid var(--border);
  color: var(--muted); transition: all .25s var(--ease);
}
.env-browser-open:hover {
  background: var(--text); color: #fff; border-color: var(--text);
  transform: rotate(-8deg) scale(1.08);
}

.env-browser-frame {
  position: relative; flex: 1; min-height: 380px;
  background: #f8f9fc;
}
.env-browser-frame iframe {
  width: 100%; height: 100%; min-height: 380px;
  border: none; display: block;
  opacity: 0; transition: opacity 0.5s var(--ease);
}
.env-browser-frame iframe.loaded { opacity: 1; }

.env-iframe-loader {
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: rgba(0,85,204,0.08); overflow: hidden;
  z-index: 2;
}
.env-loader-bar {
  position: absolute; left: 0; top: 0; bottom: 0; width: 30%;
  background: var(--blue);
  animation: env-loader 1.4s ease-in-out infinite;
}
.env-iframe-loader.done { display: none; }
@keyframes env-loader {
  0%   { left: -30%; }
  100% { left: 100%; }
}

.env-iframe-overlay {
  position: absolute; inset: 0;
  display: none; align-items: flex-end; justify-content: flex-end;
  padding: 18px;
  pointer-events: none;
}
.env-iframe-overlay.visible { display: flex; }
.env-iframe-overlay-text {
  background: rgba(10,14,26,0.92); color: #fff;
  padding: 10px 16px; border-radius: 12px;
  font-size: 0.78rem; max-width: 280px;
  display: flex; flex-direction: column; gap: 6px;
  pointer-events: auto;
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}
.env-overlay-link {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem; color: #93c5fd; text-decoration: none;
}

.env-iframe-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 1rem; padding: 4rem 2rem; height: 100%; min-height: 380px;
  color: var(--dim); text-align: center;
}
.env-iframe-empty p { font-size: 0.92rem; color: var(--muted); margin: 0; font-weight: 500; }

/* ── STATUS CARD ── */
.env-project-name {
  font-size: 1.5rem; font-weight: 600; letter-spacing: -0.035em;
  margin: 0 0 1.4rem; color: var(--text); line-height: 1.15;
}
.env-status-rows { display: flex; flex-direction: column; flex: 1; }
.env-stat-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.85rem 0; border-bottom: 1px solid rgba(0,0,0,0.05);
}
.env-stat-row:last-child { border-bottom: none; }
.env-stat-label { font-size: 0.82rem; font-weight: 500; color: var(--muted); }
.env-stat-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem; font-weight: 600; color: var(--text);
  display: flex; align-items: center; gap: 7px;
}
.env-stat-green { color: #059669; }
.env-pulse-dot {
  width: 7px; height: 7px; border-radius: 50%; background: var(--green);
  animation: env-pulse 2.5s ease-in-out infinite;
}

.env-mini-progress {
  margin-top: 1.4rem; padding-top: 1.4rem;
  border-top: 1px solid rgba(0,0,0,0.06);
}
.env-mini-progress-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 0.7rem;
}
.env-mini-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem; font-weight: 700; letter-spacing: 0.12em;
  color: var(--muted);
}
.env-mini-pct {
  font-family: 'JetBrains Mono', monospace;
