  margin: 0 0 0.7rem; line-height: 1.3;
}
.env-vital-spark {
  height: 28px; color: var(--green);
  opacity: 0.7;
}
.env-vital-spark svg { width: 100%; height: 100%; display: block; }

/* ── DEPLOYS ── */
.env-deploys { display: flex; flex-direction: column; gap: 0; }
.env-deploy-row {
  display: flex; gap: 14px; padding: 0.85rem 0;
  position: relative;
  opacity: 0;
}
