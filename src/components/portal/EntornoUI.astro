.env-deploy-status {
  position: relative; flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center;
  padding-top: 4px;
}
.env-deploy-dot {
  width: 9px; height: 9px; border-radius: 50%;
  background: var(--green); flex-shrink: 0;
  box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
  z-index: 1;
}
.env-deploy-line {
  width: 1px; flex: 1;
  background: rgba(0,0,0,0.08);
  margin-top: 4px;
  min-height: 30px;
}
.env-deploy-body { flex: 1; min-width: 0; }
.env-deploy-top {
  display: flex; justify-content: space-between; align-items: baseline;
  gap: 12px; margin-bottom: 5px;
}
.env-deploy-msg {
  font-size: 0.92rem; font-weight: 600; color: var(--text);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  flex: 1; min-width: 0;
}
.env-deploy-when {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem; color: var(--muted); flex-shrink: 0;
}
.env-deploy-meta {
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  font-family: 'JetBrains Mono', monospace; font-size: 0.66rem;
}
.env-deploy-sha {
  color: var(--muted); font-weight: 500;
  background: rgba(0,0,0,0.03); padding: 2px 6px; border-radius: 4px;
}
.env-sha-prefix { opacity: 0.5; margin-right: 3px; }
.env-deploy-branch {
  color: var(--muted); font-weight: 600;
  display: flex; align-items: center;
}
.env-deploy-branch::before { content: '⎇'; margin-right: 3px; opacity: 0.5; }
.env-deploy-env {
  font-weight: 700; padding: 2px 6px; border-radius: 4px;
  font-size: 0.6rem; letter-spacing: 0.04em;
}
.env-deploy-env-prod {
  background: rgba(0,85,204,0.08); color: var(--blue);
}
.env-deploy-status-pill {
  display: inline-flex; align-items: center; gap: 4px;
  background: rgba(16,185,129,0.08); color: #059669;
  padding: 2px 7px; border-radius: 4px; font-weight: 700;
  font-size: 0.6rem;
}

/* ── REGIONS ── */
.env-regions { display: flex; flex-direction: column; gap: 0; }
.env-region-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.85rem 0; border-bottom: 1px solid rgba(0,0,0,0.05);
  gap: 12px;
}
.env-region-row:last-child { border-bottom: none; }
.env-region-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
.env-region-pulse {
  width: 8px; height: 8px; border-radius: 50%; background: var(--green);
  flex-shrink: 0;
  animation: env-pulse 2.5s ease-in-out infinite;
}
.env-region-info { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.env-region-name { font-size: 0.86rem; font-weight: 600; color: var(--text); }
.env-region-code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem; color: var(--muted); letter-spacing: 0.05em;
}
.env-region-right {
  display: flex; align-items: center; gap: 10px; flex-shrink: 0;
}
.env-region-bar {
  width: 70px; height: 4px;
  background: rgba(0,0,0,0.05); border-radius: 100px; overflow: hidden;
}
.env-region-fill {
  height: 100%; background: var(--green); border-radius: 100px;
  transform-origin: left; transform: scaleX(0);
}
.env-region-row.in .env-region-fill {
  transform: scaleX(1); transition: transform 1.2s var(--ease);
}
.env-region-ms {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem; font-weight: 700; color: var(--text);
  min-width: 48px; text-align: right;
}
.env-region-ms small { font-size: 0.6rem; color: var(--muted); margin-left: 1px; font-weight: 500; }

/* ── ACTIVITY LOG ── */
.env-activity-card {
  background: #0a0e1a; border-color: rgba(255,255,255,0.06);
  color: #cbd5e1;
}
.env-activity-card:hover {
  border-color: rgba(0,85,204,0.3);
  box-shadow: 0 0 0 1px rgba(0,85,204,0.15), 0 16px 36px rgba(0,0,0,0.3);
}
.env-activity-card .env-spotlight {
  background: radial-gradient(circle, rgba(0,85,204,0.18) 0%, transparent 70%);
}
.env-activity-card .env-ey { color: rgba(255,255,255,0.5); }
.env-terminal-prompt { color: var(--green); font-weight: 800; }

.env-blink-cursor {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem; font-weight: 700; color: var(--green);
  animation: env-blink 1.1s steps(1) infinite;
}
@keyframes env-blink {
  0%,50% { opacity: 1; }
  51%,100% { opacity: 0; }
}

.env-activity-log {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.74rem; line-height: 1.6;
  display: flex; flex-direction: column; gap: 0.4rem;
}
.env-log-row {
  display: flex; gap: 10px; align-items: baseline;
  opacity: 0;
}
.env-log-row.in { opacity: 1; }
.env-log-time {
  color: rgba(255,255,255,0.4); flex-shrink: 0;
  font-weight: 500;
}
.env-log-tag {
  font-weight: 700; flex-shrink: 0;
  text-transform: uppercase;
}
.env-log-tag-green { color: #34d399; }
.env-log-tag-blue  { color: #60a5fa; }
.env-log-tag-muted { color: rgba(255,255,255,0.5); }
.env-log-text {
  color: rgba(255,255,255,0.78); flex: 1;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* ── KEYFRAMES ── */
@keyframes env-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(16,185,129,.5); transform: scale(1); }
  60%      { box-shadow: 0 0 0 5px rgba(16,185,129,0); transform: scale(1.2); }
}

/* ── RESPONSIVE ── */
@media (max-width: 1100px) {
  .env-preview-card { grid-column: span 12; }
  .env-status-card  { grid-column: span 12; }
  .env-deploy-card  { grid-column: span 12; }
  .env-region-card  { grid-column: span 12; }
  .env-vitals-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .env-root { padding: 2rem 0 5rem; }
  .env-card { padding: 1.4rem 1.4rem; border-radius: 18px; }
  .env-vitals-row { padding: 1.2rem 1.4rem; }
  .env-vital-card { padding: 1rem; }
  .env-vital-num { font-size: 1.5rem; }
  .env-title { font-size: clamp(2rem, 9vw, 2.8rem); }
  .env-browser-bar { gap: 8px; padding: 10px 14px; }
  .env-browser-url { padding: 5px 10px; font-size: 0.66rem; }
  .env-deploy-meta { font-size: 0.6rem; }
  .env-deploy-msg { font-size: 0.84rem; }
  .env-activity-log { font-size: 0.66rem; }
  .env-region-bar { width: 50px; }
}
</style>

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import { SplitText } from "gsap/SplitText";

gsap.registerPlugin(ScrollTrigger, SplitText);

document.addEventListener("DOMContentLoaded", () => {
  /* ── ENTRANCE TIMELINE ── */
  const tl = gsap.timeline({ defaults: { ease: "expo.out" } });

  tl.to("#env-topbar", { opacity: 1, duration: 0.6 }, 0);

  // Eyebrow with line draw
  gsap.set("#env-eyebrow", { y: 8 });
  tl.to("#env-eyebrow", { opacity: 1, y: 0, duration: 0.55 }, 0.1);
  gsap.set(".env-dot-line", { scaleX: 0 });
  tl.to(".env-dot-line", { scaleX: 1, duration: 0.6, ease: "power3.out" }, 0.2);

  // Title SplitText
  const titleEl = document.querySelector(".env-title-1") as HTMLElement | null;
  if (titleEl) {
    const split = SplitText.create(titleEl, { type: "chars" });
    gsap.set(split.chars, { opacity: 0, y: 28, rotateX: -45, transformOrigin: "center bottom" });
    tl.to(split.chars, {
      opacity: 1, y: 0, rotateX: 0,
      duration: 0.7, stagger: 0.022, ease: "back.out(1.8)"
    }, 0.25);
  }
  tl.to(".env-title-2", { opacity: 1, duration: 0.6 }, 0.6);
  tl.to("#env-sub",     { opacity: 1, duration: 0.6 }, 0.7);
  tl.to("#env-rule",    { scaleX: 1, duration: 1.0, ease: "power3.out" }, 0.55);

  /* ── ROW 1 CARDS ── */
  gsap.set(["#card-preview", "#card-status"], { y: 28, opacity: 0, scale: 0.985 });
  tl.to(["#card-preview", "#card-status"], {
    y: 0, opacity: 1, scale: 1, duration: 1.0, stagger: 0.08, ease: "expo.out"
  }, 0.55);

  // Mini progress
  const fillEl = document.getElementById("env-fill") as HTMLElement | null;
  const pctEl  = document.getElementById("env-pct")  as HTMLElement | null;
  if (fillEl && pctEl) {
    const target = parseInt(fillEl.getAttribute("data-target") || "0") || 0;
    const obj = { val: 0 };
    tl.to(obj, {
      val: target, duration: 1.8, ease: "expo.out",
      onUpdate() {
        const v = Math.round(obj.val);
        fillEl.style.width = v + "%";
        pctEl.textContent = v + "%";
      }
    }, 0.95);
  }

  /* ── VITALS ROW (ScrollTrigger) ── */
  const vitalsRow = document.getElementById("vitals-row") as HTMLElement | null;
  if (vitalsRow) {
    ScrollTrigger.create({
      trigger: vitalsRow,
      start: "top 85%",
      once: true,
      onEnter: () => {
        gsap.to(vitalsRow, { opacity: 1, duration: 0.6, ease: "expo.out" });
        const cards = vitalsRow.querySelectorAll<HTMLElement>(".env-vital-card");
        gsap.fromTo(cards,
          { y: 22, opacity: 0, scale: 0.96 },
          { y: 0, opacity: 1, scale: 1, duration: 0.85, stagger: 0.08, ease: "expo.out" }
        );

        // Animate numbers
        cards.forEach((card) => {
          const numEl = card.querySelector<HTMLElement>(".env-vital-num");
          if (!numEl) return;
          const target   = parseFloat(numEl.getAttribute("data-target") || "0");
          const decimals = parseInt(numEl.getAttribute("data-decimals") || "0");
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target, duration: 1.6, ease: "expo.out", delay: 0.3,
            onUpdate() {
              numEl.textContent = decimals > 0 ? obj.val.toFixed(decimals) : Math.round(obj.val).toString();
            }
          });
        });

        // Animate sparkline paths
        vitalsRow.querySelectorAll<SVGPathElement>(".env-spark-path").forEach((p, i) => {
          const len = p.getTotalLength();
          gsap.set(p, { strokeDasharray: len, strokeDashoffset: len });
          gsap.to(p, { strokeDashoffset: 0, duration: 1.6, ease: "expo.out", delay: 0.4 + i * 0.08 });
        });
      }
    });
  }

  /* ── DEPLOYS + REGIONS (ScrollTrigger) ── */
  ["card-deploys", "card-regions", "card-activity"].forEach((id, idx) => {
    const card = document.getElementById(id);
    if (!card) return;
    ScrollTrigger.create({
      trigger: card,
      start: "top 85%",
      once: true,
      onEnter: () => {
        gsap.fromTo(card, { y: 24, opacity: 0, scale: 0.985 }, { y: 0, opacity: 1, scale: 1, duration: 0.9, ease: "expo.out", delay: idx * 0.05 });

        // Stagger inner rows
        const rows = card.querySelectorAll<HTMLElement>(".env-deploy-row, .env-region-row, .env-log-row");
        rows.forEach((r, i) => {
          gsap.delayedCall(0.25 + i * 0.06 + idx * 0.05, () => r.classList.add("in"));
        });
      }
    });
  });

  /* ── SPOTLIGHT ── */
  document.querySelectorAll<HTMLElement>(".env-card").forEach(card => {
    const spot = card.querySelector<HTMLElement>(".env-spotlight");
    if (!spot) return;
    card.addEventListener("mousemove", (e: MouseEvent) => {
      const r = card.getBoundingClientRect();
      gsap.to(spot, { x: e.clientX - r.left, y: e.clientY - r.top, duration: 0.5, ease: "power2.out" });
    });
  });

  /* ── IFRAME LOADER ── */
  const iframe = document.getElementById("env-iframe") as HTMLIFrameElement | null;
  const loader = document.getElementById("env-iframe-loader");
  const overlay = document.getElementById("env-iframe-overlay");
  if (iframe) {
    let loaded = false;
    iframe.addEventListener("load", () => {
      loaded = true;
      iframe.classList.add("loaded");
      loader?.classList.add("done");
    });
    // If iframe doesn't load in 4s (X-Frame-Options), show overlay hint
    setTimeout(() => {
      if (!loaded) {
        loader?.classList.add("done");
        overlay?.classList.add("visible");
      }
    }, 4000);
  }

  /* ── REFRESH BUTTON ── */
  const refreshBtn = document.getElementById("env-refresh");
  refreshBtn?.addEventListener("click", () => {
    refreshBtn.classList.add("spinning");
    if (iframe && iframe.src) {
      const src = iframe.src;
      iframe.src = "about:blank";
      setTimeout(() => { iframe.src = src; }, 80);
    }
    setTimeout(() => refreshBtn.classList.remove("spinning"), 700);
  });
});
</script>
