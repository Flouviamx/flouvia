  pointer-events: none;
}
.env-iframe-overlay.visible { display: flex; }
.env-iframe-overlay-text {
  background: rgba(10,14,26,0.92); color: #fff;
  padding: 10px 16px; border-radius: 12px;
  font-size: 0.78rem; max-width: 280px;
