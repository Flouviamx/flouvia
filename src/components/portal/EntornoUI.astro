}
.env-log-tag-green { color: #34d399; }
.env-log-tag-blue  { color: #60a5fa; }
.env-log-tag-amber { color: #fbbf24; }
.env-log-tag-red   { color: #f87171; }
.env-log-tag-muted { color: rgba(255,255,255,0.5); }
.env-log-text {
  color: rgba(255,255,255,0.78); flex: 1;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* ── KEYFRAMES ── */
@keyframes env-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(16,185,129,.5); transform: scale(1); }
  60%      { box-shadow: 0 0 0 5px rgba(16,185,129,0); transform: scale(1.2); }
}

/* ── RESPONSIVE ── */
@media (max-width: 1100px) {
  .env-preview-card { grid-column: span 12; }
  .env-status-card  { grid-column: span 12; }
  .env-deploy-card  { grid-column: span 12; }
  .env-region-card  { grid-column: span 12; }
  .env-vitals-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .env-root { padding: 2rem 0 5rem; }
  .env-card { padding: 1.4rem 1.4rem; border-radius: 18px; }
  .env-vitals-row { padding: 1.2rem 1.4rem; }
  .env-vital-card { padding: 1rem; }
  .env-vital-num { font-size: 1.5rem; }

  .env-browser-bar { gap: 8px; padding: 10px 14px; }
  .env-browser-url { padding: 5px 10px; font-size: 0.66rem; }
  .env-deploy-meta { font-size: 0.6rem; }
  .env-deploy-msg { font-size: 0.84rem; }
  .env-activity-log { font-size: 0.66rem; }
  .env-region-bar { width: 50px; }
}
</style>

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import { SplitText } from "gsap/SplitText";

gsap.registerPlugin(ScrollTrigger, SplitText);

document.addEventListener("DOMContentLoaded", () => {
  /* ── ENTRANCE TIMELINE ── */
  const tl = gsap.timeline({ defaults: { ease: "expo.out" } });

  /* ── ROW 1 CARDS ── */
  gsap.set(["#card-preview", "#card-status"], { y: 28, opacity: 0, scale: 0.985 });
  tl.to(["#card-preview", "#card-status"], {
    y: 0, opacity: 1, scale: 1, duration: 1.0, stagger: 0.08, ease: "expo.out"
  }, 0.55);

  // Mini progress
  const fillEl = document.getElementById("env-fill") as HTMLElement | null;
  const pctEl  = document.getElementById("env-pct")  as HTMLElement | null;
  if (fillEl && pctEl) {
    const target = parseInt(fillEl.getAttribute("data-target") || "0") || 0;
    const obj = { val: 0 };
    tl.to(obj, {
      val: target, duration: 1.8, ease: "expo.out",
      onUpdate() {
        const v = Math.round(obj.val);
        fillEl.style.width = v + "%";
        pctEl.textContent = v + "%";
      }
    }, 0.95);
  }

  /* ── VITALS ROW (ScrollTrigger) ── */
  const vitalsRow = document.getElementById("vitals-row") as HTMLElement | null;
  if (vitalsRow) {
    ScrollTrigger.create({
      trigger: vitalsRow,
      start: "top 85%",
      once: true,
      onEnter: () => {
        gsap.to(vitalsRow, { opacity: 1, duration: 0.6, ease: "expo.out" });
        const cards = vitalsRow.querySelectorAll<HTMLElement>(".env-vital-card");
        gsap.fromTo(cards,
          { y: 22, opacity: 0, scale: 0.96 },
          { y: 0, opacity: 1, scale: 1, duration: 0.85, stagger: 0.08, ease: "expo.out" }
        );

        // Animate numbers
        cards.forEach((card) => {
          const numEl = card.querySelector<HTMLElement>(".env-vital-num");
          if (!numEl) return;
          const target   = parseFloat(numEl.getAttribute("data-target") || "0");
          const decimals = parseInt(numEl.getAttribute("data-decimals") || "0");
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target, duration: 1.6, ease: "expo.out", delay: 0.3,
            onUpdate() {
              numEl.textContent = decimals > 0 ? obj.val.toFixed(decimals) : Math.round(obj.val).toString();
            }
          });
        });

        // Animate sparkline paths
        vitalsRow.querySelectorAll<SVGPathElement>(".env-spark-path").forEach((p, i) => {
          const len = p.getTotalLength();
          gsap.set(p, { strokeDasharray: len, strokeDashoffset: len });
          gsap.to(p, { strokeDashoffset: 0, duration: 1.6, ease: "expo.out", delay: 0.4 + i * 0.08 });
        });
      }
    });
  }

  /* ── DEPLOYS + REGIONS (ScrollTrigger) ── */
  ["card-deploys", "card-regions", "card-activity"].forEach((id, idx) => {
    const card = document.getElementById(id);
    if (!card) return;
    ScrollTrigger.create({
      trigger: card,
      start: "top 85%",
      once: true,
      onEnter: () => {
        gsap.fromTo(card, { y: 24, opacity: 0, scale: 0.985 }, { y: 0, opacity: 1, scale: 1, duration: 0.9, ease: "expo.out", delay: idx * 0.05 });

        // Stagger inner rows
        const rows = card.querySelectorAll<HTMLElement>(".env-deploy-row, .env-region-row, .env-log-row");
        rows.forEach((r, i) => {
          gsap.delayedCall(0.25 + i * 0.06 + idx * 0.05, () => r.classList.add("in"));
        });
      }
    });
  });

  /* ── SPOTLIGHT ── */
  document.querySelectorAll<HTMLElement>(".env-card").forEach(card => {
    const spot = card.querySelector<HTMLElement>(".env-spotlight");
    if (!spot) return;
    card.addEventListener("mousemove", (e: MouseEvent) => {
      const r = card.getBoundingClientRect();
      gsap.to(spot, { x: e.clientX - r.left, y: e.clientY - r.top, duration: 0.5, ease: "power2.out" });
    });
  });

  /* ── IFRAME LOADER ── */
  const iframe = document.getElementById("env-iframe") as HTMLIFrameElement | null;
  const loader = document.getElementById("env-iframe-loader");
  const overlay = document.getElementById("env-iframe-overlay");
  if (iframe) {
    let loaded = false;
    iframe.addEventListener("load", () => {
      loaded = true;
      iframe.classList.add("loaded");
      loader?.classList.add("done");
    });
    // If iframe doesn't load in 4s (X-Frame-Options), show overlay hint
    setTimeout(() => {
      if (!loaded) {
        loader?.classList.add("done");
        overlay?.classList.add("visible");
      }
    }, 4000);
  }

  /* ── REFRESH BUTTON ── */
  const refreshBtn = document.getElementById("env-refresh");
  refreshBtn?.addEventListener("click", () => {
    refreshBtn.classList.add("spinning");
    if (iframe && iframe.src) {
      const src = iframe.src;
      iframe.src = "about:blank";
      setTimeout(() => { iframe.src = src; }, 80);
    }
    setTimeout(() => refreshBtn.classList.remove("spinning"), 700);
  });
});
</script>
