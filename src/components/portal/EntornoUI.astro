  pointer-events: auto;
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}
.env-overlay-link {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem; color: #93c5fd; text-decoration: none;
}

.env-iframe-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 1rem; padding: 4rem 2rem; height: 100%; min-height: 380px;
