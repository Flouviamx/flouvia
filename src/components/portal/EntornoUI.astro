.deploy-dot-green { background: var(--green); box-shadow: 0 0 0 3px rgba(16,185,129,0.15); }
.deploy-dot-red   { background: var(--red);   box-shadow: 0 0 0 3px rgba(220,38,38,0.15); }
.deploy-dot-amber { background: var(--amber); box-shadow: 0 0 0 3px rgba(245,158,11,0.15); animation: env-pulse 1s ease-in-out infinite; }
