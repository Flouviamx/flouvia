}
.env-region-ms small { font-size: 0.6rem; color: var(--muted); margin-left: 1px; font-weight: 500; }

/* ── ACTIVITY LOG ── */
.env-activity-card {
  background: #0a0e1a; border-color: rgba(255,255,255,0.06);
  color: #cbd5e1;
}
.env-activity-card:hover {
  border-color: rgba(0,85,204,0.3);
  box-shadow: 0 0 0 1px rgba(0,85,204,0.15), 0 16px 36px rgba(0,0,0,0.3);
}
.env-activity-card .env-spotlight {
  background: radial-gradient(circle, rgba(0,85,204,0.18) 0%, transparent 70%);
}
.env-activity-card .env-ey { color: rgba(255,255,255,0.5); }
.env-terminal-prompt { color: var(--green); font-weight: 800; }

.env-blink-cursor {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem; font-weight: 700; color: var(--green);
  animation: env-blink 1.1s steps(1) infinite;
}
@keyframes env-blink {
  0%,50% { opacity: 1; }
  51%,100% { opacity: 0; }
}

.env-activity-log {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.74rem; line-height: 1.6;
  display: flex; flex-direction: column; gap: 0.4rem;
}
.env-log-row {
  display: flex; gap: 10px; align-items: baseline;
  opacity: 0;
}
.env-log-row.in { opacity: 1; }
.env-log-time {
  color: rgba(255,255,255,0.4); flex-shrink: 0;
  font-weight: 500;
}
