---
// Footer Flouvia — Editorial Luxury (Apple / Bottega aesthetic)
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
---

<footer class="footer-premium">
    <div class="top-hairline"></div>

    <div class="footer-watermark" aria-hidden="true">Flouvia</div>

    <div class="container footer-inner">

        <div class="footer-meta-row">
            <p class="footer-eyebrow">{isEn ? 'STUDIO · MEXICO CITY' : 'ESTUDIO · CIUDAD DE MÉXICO'}</p>
            <p class="footer-edition"><span class="edition-num">2026</span><span class="edition-divider">·</span><span class="edition-label">{isEn ? 'Edition' : 'Edición'}</span></p>
        </div>

        <div class="footer-grid">

            <div class="brand-column">
                <img src="/imgs/logo-flouvia-1.svg" alt="Flouvia" class="footer-logo-svg" />

                <h3 class="footer-statement">
                    {isEn ? 'E-commerce & B2B engineering.' : 'Ingeniería e-commerce y B2B.'}
                </h3>

                <p class="description">
                    {isEn
                        ? 'Boutique firm based in Mexico City. We build Shopify Plus stores, private B2B portals and automations for brands with established operations. By application — fewer than 8 active clients a year.'
                        : 'Firma boutique con sede en CDMX. Construimos tiendas Shopify Plus, portales B2B privados y automatizaciones para marcas con operación establecida. Proyectos por aplicación — menos de 8 clientes activos al año.'}
                </p>

                <div class="footer-status-badge">
                    <span class="dot-online"></span>
                    <span class="status-text">{isEn ? 'ACCEPTING PROJECTS Q3' : 'ACEPTANDO PROYECTOS Q3'}</span>
                </div>
            </div>

            <div class="navigation-columns">

                <div class="nav-col">
                    <div class="col-head">
                        <span class="col-num">/01</span>
                        <h4 class="col-title">{isEn ? 'Work' : 'Trabajo'}</h4>
                    </div>
                    <nav class="nav-links">
                        <a href={isEn ? '/en/servicios' : '/servicios'} class="link-item">
                            <span>{isEn ? 'Services' : 'Servicios'}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href={isEn ? '/en/casos' : '/casos'} class="link-item">
                            <span>{isEn ? 'Cases' : 'Casos'}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href={isEn ? '/en/blog' : '/blog'} class="link-item">
                            <span>Blog</span>
                            <span class="link-arrow">→</span>
                        </a>
                    </nav>
                </div>

                <div class="nav-col">
                    <div class="col-head">
                        <span class="col-num">/02</span>
                        <h4 class="col-title">{isEn ? 'The Firm' : 'La Firma'}</h4>
                    </div>
                    <nav class="nav-links">
                        <a href={isEn ? '/en/nosotros' : '/nosotros'} class="link-item">
                            <span>{isEn ? 'About' : 'Nosotros'}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href={isEn ? '/en/login' : '/login'} class="link-item">
                            <span>{isEn ? 'Client Portal' : 'Portal de Clientes'}</span>
                            <span class="link-arrow">→</span>
                        </a>
                    </nav>
                </div>

                <div class="nav-col contact-col">
                    <div class="col-head">
                        <span class="col-num">/03</span>
                        <h4 class="col-title">{isEn ? 'Contact' : 'Contacto'}</h4>
                    </div>

                    <p class="contact-location">{isEn ? 'Mexico City — Global operation' : 'CDMX — Operación global'}</p>

                    <a href="mailto:hola@flouvia.com" class="minimal-email-link">
                        <span class="email-text">hola@flouvia.com</span>
                        <svg class="email-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                    <p class="contact-note">{isEn ? 'Reply within 24h.' : 'Respuesta en menos de 24 h.'}</p>
                </div>

            </div>

        </div>

        <div class="footer-divider"></div>

        <div class="footer-bottom">
            <div class="legal-left">
                <p class="copyright">&copy; <span class="copy-year">2026</span> <span class="editorial">Flouvia</span>. {isEn ? 'All rights reserved.' : 'Todos los derechos reservados.'}</p>
            </div>

            <div class="footer-socials">
                <a href="https://www.instagram.com/flouvia.mx/" class="social-icon-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                    <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                    </svg>
                </a>
                <a href="https://www.facebook.com/flouvia" class="social-icon-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                    <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                    </svg>
                </a>
                <a href="https://www.linkedin.com/company/flouvia/" class="social-icon-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                    <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                        <rect x="2" y="9" width="4" height="12"></rect>
                        <circle cx="4" cy="4" r="2"></circle>
                    </svg>
                </a>
            </div>

            <div class="legal-right">
                <a href={isEn ? '/en/privacy' : '/privacidad'} class="legal-link">{isEn ? 'Privacy' : 'Privacidad'}</a>
                <span class="legal-dot">·</span>
                <a href={isEn ? '/en/terms' : '/terminos'} class="legal-link">{isEn ? 'Terms' : 'Términos'}</a>
            </div>
        </div>

    </div>
</footer>

<style>
    /* ==========================================================
       VARIABLES
       ========================================================== */
    :root {
        --bg-footer: #0a192f;
        --text-main: #ffffff;
        --text-muted: #8892b0;
        --text-dim: #64748b;
        --hairline: rgba(255, 255, 255, 0.08);

        --ease-apple: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.05);
        --font-sans: 'Inter', system-ui, sans-serif;
        --font-serif: 'Instrument Serif', serif;
    }

    .footer-premium ::selection { background: #ffffff; color: #0a192f; }

    .footer-premium {
        background: radial-gradient(ellipse at 30% 20%, #112240 0%, #0a192f 60%, #050b14 100%);
        color: var(--text-main);
        padding: 0 0 2.5rem 0;
        position: relative;
        font-family: var(--font-sans);
        overflow: hidden;
        isolation: isolate;
    }

    .container { width: 100%; max-width: 1240px; padding: 0 5%; margin: 0 auto; position: relative; }
    .footer-inner { z-index: 2; }

    /* ── Editorial watermark — gigantesco "Flouvia" en serif italic ── */
    .footer-watermark {
        position: absolute; bottom: -6vw; right: -3vw;
        font-family: var(--font-serif); font-style: italic; font-weight: 400;
        font-size: 26vw; line-height: 0.85; letter-spacing: -0.04em;
        color: rgba(255,255,255,0.025);
        pointer-events: none; user-select: none; white-space: nowrap;
        z-index: 1;
    }

    /* ── Top hairline ── */
    .top-hairline {
        width: 100%; height: 1px;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.18) 20%, rgba(255,255,255,0.18) 80%, transparent);
        margin-bottom: 3rem;
        transform-origin: left center;
    }

    /* ── Meta row encima del grid (eyebrow + edition) ── */
    .footer-meta-row {
        display: flex; justify-content: space-between; align-items: baseline;
        margin-bottom: 5rem; padding-top: 1rem;
    }
    .footer-eyebrow {
        font-size: 0.65rem; font-weight: 800; letter-spacing: 3px;
        color: rgba(255,255,255,0.45); text-transform: uppercase; margin: 0;
    }
    .footer-edition {
        display: inline-flex; align-items: baseline; gap: 0.55rem;
        font-family: var(--font-serif); font-style: italic; font-weight: 400;
        color: rgba(255,255,255,0.65); margin: 0; line-height: 1;
    }
    .edition-num { font-size: 1.5rem; }
    .edition-divider { color: rgba(255,255,255,0.3); font-size: 1rem; }
    .edition-label { font-size: 1.05rem; color: rgba(255,255,255,0.45); }

    /* ==========================================================
       1. GRID EDITORIAL
       ========================================================== */
    .footer-grid {
        display: grid;
        grid-template-columns: 5fr 7fr;
        gap: 6rem;
        margin-bottom: 6rem;
    }

    .brand-column { display: flex; flex-direction: column; }

    .footer-logo-svg { width: 130px; height: auto; margin-bottom: 2.5rem; opacity: 0.95; }

    /* Statement editorial — la frase grande con accent serif */
    .footer-statement {
        font-size: clamp(1.7rem, 2.2vw, 2.3rem);
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.8px;
        color: var(--text-main);
        margin: 0 0 1.5rem 0;
        max-width: 95%;
    }
    .description {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.65;
        font-weight: 400;
        letter-spacing: -0.1px;
        margin: 0 0 2.25rem 0;
        max-width: 90%;
    }

    /* ── Status badge — "Aceptando proyectos Q3" ── */
    .footer-status-badge {
        display: inline-flex; align-items: center; gap: 9px;
        background: rgba(255,255,255,0.03); padding: 7px 14px; border-radius: 100px;
        border: 1px solid rgba(255,255,255,0.06);
        width: max-content;
    }
    .footer-status-badge .status-text {
        letter-spacing: 1.2px; font-weight: 700;
        color: #94a3b8; font-size: 0.65rem; text-transform: uppercase;
    }

    /* ── Bloque derecho: nav columns ── */
    .navigation-columns {
        display: grid; grid-template-columns: 1fr 1fr 1.7fr; gap: 2.5rem;
        padding-top: 0.5rem;
    }

    .nav-col { display: flex; flex-direction: column; }

    .col-head {
        display: flex; align-items: baseline; gap: 0.7rem;
        margin-bottom: 2.25rem;
    }
    .col-num {
        font-family: var(--font-serif); font-style: italic; font-weight: 400;
        font-size: 1.05rem; color: rgba(255,255,255,0.3); line-height: 1;
    }
    .col-title {
        font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;
        color: rgba(255,255,255,0.55); margin: 0;
    }

    .nav-links { display: flex; flex-direction: column; gap: 1.1rem; }

    .link-item {
        display: inline-flex; align-items: center; gap: 10px;
        color: var(--text-muted); text-decoration: none;
        font-size: 0.98rem; font-weight: 500;
        transition: color 0.4s var(--ease-apple), transform 0.5s var(--ease-spring);
        width: max-content; position: relative;
    }
    .link-item span:first-child {
        transition: transform 0.5s var(--ease-spring);
    }
    .link-arrow {
        font-size: 0.85rem; opacity: 0;
        transform: translateX(-8px);
        transition: all 0.5s var(--ease-spring);
        color: #fff;
    }
    .link-item:hover { color: #fff; }
    .link-item:hover span:first-child { transform: translateX(4px); }
    .link-item:hover .link-arrow { opacity: 1; transform: translateX(0); }

    /* ── Columna Contacto — correo protagonista (A2) ── */
    .contact-location {
        color: var(--text-dim);
        font-size: 0.85rem; font-weight: 500; letter-spacing: 0.2px;
        margin: 0 0 1.5rem 0;
    }

    .minimal-email-link {
        display: inline-flex; align-items: center; gap: 14px;
        text-decoration: none; color: var(--text-main);
        padding-bottom: 14px;
        border-bottom: 1px solid rgba(255,255,255,0.14);
        transition: border-color 0.5s var(--ease-apple);
        width: max-content; max-width: 100%;
    }
    .email-text {
        font-size: clamp(1.4rem, 1.9vw, 1.8rem); font-weight: 600; letter-spacing: -0.5px;
        transition: transform 0.5s var(--ease-spring);
    }
    .email-arrow {
        width: 20px; height: 20px; opacity: 0.6; color: var(--text-muted);
        transition: all 0.5s var(--ease-spring);
    }
    .minimal-email-link:hover { border-bottom-color: rgba(255,255,255,0.45); }
    .minimal-email-link:hover .email-text { transform: translateX(4px); }
    .minimal-email-link:hover .email-arrow { opacity: 1; transform: translateX(8px); color: #fff; }
    .minimal-email-link:active { transform: scale(0.98); transition: 0.1s; }

    .contact-note {
        color: var(--text-dim);
        font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1px;
        margin: 0.9rem 0 0 0;
    }

    /* ── Divider entre grid y bottom ── */
    .footer-divider {
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.1) 20%, rgba(255,255,255,0.1) 80%, transparent);
        margin: 0 0 2rem 0;
        transform-origin: center;
    }

    /* ==========================================================
       2. BARRA INFERIOR
       ========================================================== */
    .footer-bottom {
        display: flex; justify-content: space-between; align-items: center;
        font-size: 0.8rem; color: var(--text-dim); font-weight: 500;
        gap: 1.5rem;
    }

    .legal-left { display: flex; align-items: center; gap: 1.25rem; }
    .copyright { margin: 0; letter-spacing: 0.2px; }
    .copyright .editorial {
        font-family: var(--font-serif); font-style: italic; font-weight: 400;
        color: rgba(255,255,255,0.7);
    }

    /* ── Redes (íconos compactos en la barra inferior) ── */
    .footer-socials { display: flex; align-items: center; gap: 0.5rem; }
    .social-icon-link {
        width: 32px; height: 32px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: rgba(255,255,255,0.03);
        color: var(--text-muted);
        transition: background 0.45s var(--ease-apple), color 0.4s var(--ease-apple), transform 0.5s var(--ease-spring);
    }
    .social-icon { width: 15px; height: 15px; opacity: 0.7; transition: opacity 0.4s var(--ease-apple); }
    .social-icon-link:hover { background: rgba(255,255,255,0.1); color: #fff; transform: translateY(-2px); }
    .social-icon-link:hover .social-icon { opacity: 1; }

    .dot-online {
        width: 6px; height: 6px; background-color: #10b981; border-radius: 50%;
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
        animation: pulse-server 2.5s infinite;
    }
    @keyframes pulse-server {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }

    .legal-right { display: flex; gap: 1rem; align-items: center; }
    .legal-dot { opacity: 0.4; }
    .legal-link {
        color: var(--text-dim); text-decoration: none;
        transition: color 0.4s var(--ease-apple);
        position: relative;
    }
    .legal-link::after {
        content: ''; position: absolute; left: 0; right: 100%;
        bottom: -3px; height: 1px; background: rgba(255,255,255,0.4);
        transition: right 0.5s var(--ease-spring);
    }
    .legal-link:hover { color: #fff; }
    .legal-link:hover::after { right: 0; }

    /* ==========================================================
       MÓVIL
       ========================================================== */
    @media (max-width: 1024px) {
        .footer-grid { grid-template-columns: 1fr; gap: 4rem; margin-bottom: 4.5rem; }
        .navigation-columns { gap: 2rem; }
        .description { max-width: 100%; }
        .footer-statement { max-width: 100%; }
        .footer-watermark { font-size: 38vw; bottom: -10vw; }
    }

    @media (max-width: 768px) {
        .footer-premium { padding-bottom: 2rem; }
        .top-hairline { margin-bottom: 2.5rem; }
        .footer-meta-row { margin-bottom: 3.5rem; padding-top: 0.5rem; }
        .footer-edition { gap: 0.4rem; }
        .edition-num { font-size: 1.2rem; }
        .edition-label { font-size: 0.9rem; }

        .footer-logo-svg { width: 110px; margin-bottom: 2rem; }
        .footer-statement { font-size: 1.55rem; line-height: 1.2; margin-bottom: 1.25rem; }
        .description { font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; }

        .navigation-columns {
            grid-template-columns: 1fr 1fr;
            row-gap: 3rem; column-gap: 1.5rem;
        }
        .navigation-columns .contact-col { grid-column: span 2; }
        .col-head { margin-bottom: 1.75rem; }
        .link-item { padding: 4px 0; width: 100%; justify-content: space-between; }
        .link-arrow { opacity: 0.35; transform: translateX(0); }
        .minimal-email-link { width: 100%; justify-content: space-between; }

        .footer-divider { margin: 1rem 0 2rem 0; }
        .footer-bottom { flex-direction: column; align-items: flex-start; gap: 1.75rem; }
        .footer-socials { order: 3; }
        .legal-right { gap: 0.85rem; flex-wrap: wrap; }

        .footer-watermark { font-size: 56vw; bottom: -12vw; right: -8vw; }
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Patrón anti-parpadeo (igual que Inicio.astro): se OCULTA de entrada con
    // gsap.set y se revela UNA vez en onEnter con gsap.to. Nunca usar
    // gsap.from + immediateRender:false (dejaba el footer visible hasta el primer
    // scroll y entonces lo re-animaba). El footer siempre está bajo el fold, así
    // que el set inicial no se ve. Con reduced-motion no se anima (queda visible).
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const initFooterAnimations = () => {
        const footer = document.querySelector<HTMLElement>('.footer-premium');
        if (!footer || reducedMotion) return;

        const fadeSel = [
            '.footer-eyebrow', '.footer-edition', '.footer-logo-svg', '.footer-statement',
            '.description', '.footer-status-badge', '.nav-col', '.footer-bottom > *',
        ].map(s => '.footer-premium ' + s).join(', ');

        // Estado inicial oculto
        gsap.set('.footer-premium .top-hairline',  { scaleX: 0, transformOrigin: 'left center' });
        gsap.set('.footer-premium .footer-divider', { scaleX: 0, transformOrigin: 'center' });
        gsap.set(fadeSel, { opacity: 0, y: 16 });

        ScrollTrigger.create({
            trigger: footer,
            start: 'top 88%',
            once: true,
            onEnter: () => {
                const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
                tl
                    .to('.footer-premium .top-hairline',   { scaleX: 1, duration: 1.0 }, 0)
                    .to('.footer-premium .footer-eyebrow', { opacity: 1, y: 0, duration: 0.9, clearProps: 'transform,opacity' }, 0.1)
                    .to('.footer-premium .footer-edition', { opacity: 1, y: 0, duration: 0.9, clearProps: 'transform,opacity' }, 0.16)
                    .to('.footer-premium .footer-logo-svg', { opacity: 1, y: 0, duration: 1.0, clearProps: 'transform,opacity' }, 0.24)
                    .to('.footer-premium .footer-statement', { opacity: 1, y: 0, duration: 1.0, clearProps: 'transform,opacity' }, 0.32)
                    .to('.footer-premium .description',     { opacity: 1, y: 0, duration: 0.9, clearProps: 'transform,opacity' }, 0.42)
                    .to('.footer-premium .footer-status-badge', { opacity: 1, y: 0, duration: 0.9, clearProps: 'transform,opacity' }, 0.5)
                    .to('.footer-premium .nav-col',         { opacity: 1, y: 0, duration: 0.9, stagger: 0.09, clearProps: 'transform,opacity' }, 0.4)
                    .to('.footer-premium .footer-divider',  { scaleX: 1, duration: 1.0 }, 0.75)
                    .to('.footer-premium .footer-bottom > *', { opacity: 1, y: 0, duration: 0.85, stagger: 0.07, clearProps: 'transform,opacity' }, 0.85);
            },
        });

        // Refresh después de que carguen fuentes/imágenes
        window.addEventListener('load', () => setTimeout(() => ScrollTrigger.refresh(), 100), { once: true });
    };

    document.addEventListener('DOMContentLoaded', initFooterAnimations);
</script>
