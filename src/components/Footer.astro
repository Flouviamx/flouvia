---
// Footer Flouvia Elite: Minimalismo Suizo & Quiet Luxury (Apple Pro Style)
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';
---

<footer class="footer-premium">
    <div class="top-hairline"></div>

    <div class="container">
        
        <div class="footer-grid">
            
            <div class="brand-column reveal-stagger">
                <img src="/imgs/logo-flouvia-1.svg" alt="Flouvia" class="footer-logo-svg" />
                
                <div class="statement-box">
                    <p class="description">
                        {isEn ? 'Digital engineering studio.' : 'Estudio de ingeniería digital.'}<br>
                        {isEn ? 'We design high-conversion transactional ecosystems for leading brands in B2B and E-commerce.' : 'Diseñamos ecosistemas transaccionales de alta conversión para marcas líderes en B2B y E-commerce.'}
                    </p>
                </div>

                <div class="contact-action">
                    <a href="mailto:flouvia.mx@gmail.com" class="minimal-email-link">
                        <span class="email-text">flouvia.mx@gmail.com</span>
                        <svg class="email-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>
            </div>

            <div class="navigation-columns">
                
                <div class="nav-col reveal-stagger" style="--delay: 0.1s;">
                    <h4 class="col-title">{isEn ? 'PORTFOLIO' : 'PORTAFOLIO'}</h4>
                    <nav class="nav-links">
                        <a href={isEn ? '/en/' : '/'} class="link-item">
                            <span>{isEn ? 'HOME' : 'INICIO'}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href={isEn ? '/en/servicios' : '/servicios'} class="link-item">
                            <span>{t('nav.services')}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href={isEn ? '/en/casos' : '/casos'} class="link-item">
                            <span>{t('nav.cases')}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href={isEn ? '/en/blog' : '/blog'} class="link-item">
                            <span>BLOG</span>
                            <span class="link-arrow">→</span>
                        </a>
                    </nav>
                </div>

                <div class="nav-col reveal-stagger" style="--delay: 0.2s;">
                    <h4 class="col-title">{isEn ? 'STUDIO' : 'ESTUDIO'}</h4>
                    <nav class="nav-links">
                        <a href={isEn ? '/en/nosotros' : '/nosotros'} class="link-item">
                            <span>{t('nav.about')}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href={isEn ? '/en/login' : '/login'} class="link-item">
                            <span>{isEn ? 'Client Portal' : 'Portal de Clientes'}</span>
                            <span class="link-arrow">→</span>
                        </a>
                        <a href="#contacto" class="link-item">
                            <span>{isEn ? 'Private Contact' : 'Contacto Privado'}</span>
                            <span class="link-arrow">→</span>
                        </a>
                    </nav>
                </div>

                <div class="nav-col reveal-stagger" style="--delay: 0.3s;">
                    <h4 class="col-title">{isEn ? 'SOCIALS' : 'REDES'}</h4>
                    <div class="social-links">
                        <a href="#" class="social-item" aria-label="Instagram">
                            <span class="social-text">Instagram</span>
                            <div class="s-icon-wrap">
                                <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                                </svg>
                            </div>
                        </a>
                        
                        <a href="#" class="social-item" aria-label="LinkedIn">
                            <span class="social-text">LinkedIn</span>
                            <div class="s-icon-wrap">
                                <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                                    <rect x="2" y="9" width="4" height="12"></rect>
                                    <circle cx="4" cy="4" r="2"></circle>
                                </svg>
                            </div>
                        </a>

                        <a href="#" class="social-item" aria-label="X (Twitter)">
                            <span class="social-text">X (Twitter)</span>
                            <div class="s-icon-wrap">
                                <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
                                    <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
                                </svg>
                            </div>
                        </a>
                    </div>
                </div>

            </div>

        </div>

        <div class="footer-bottom reveal-stagger" style="--delay: 0.5s;">
            <div class="legal-left">
                <p class="copyright">&copy; 2026 Flouvia Boutique.</p>
                <span class="dot-separator">•</span>
                <div class="status-indicator">
                    <span class="dot-online"></span>
                    <span class="status-text">SYSTEMS OPERATIONAL</span>
                </div>
            </div>
            
            <div class="legal-right">
                <a href={isEn ? '/en/privacy' : '/privacidad'} class="legal-link">{isEn ? 'Privacy Policy' : 'Aviso de Privacidad'}</a>
                <a href={isEn ? '/en/terms' : '/terminos'} class="legal-link">{isEn ? 'Terms of Service' : 'Términos de Servicio'}</a>
                <a href="#" class="legal-link">Op. Global — CDMX</a>
            </div>
        </div>

    </div>
</footer>

<style>
    /* ==========================================================
       VARIABLES & RESET MAESTRO (Precisión Matemática)
       ========================================================== */
    :root {
        --bg-footer: #0a192f; 
        --text-main: #ffffff;
        --text-muted: #8892b0;
        --text-dim: #64748b;
        --hairline: rgba(255, 255, 255, 0.08); 
        
        --ease-apple: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.05);
        --font-sans: 'Inter', system-ui, sans-serif;
    }

    .footer-premium ::selection { background: #ffffff; color: #0a192f; }

    .footer-premium {
        background-color: var(--bg-footer);
        color: var(--text-main);
        padding: 0 0 3rem 0; 
        position: relative;
        font-family: var(--font-sans);
        overflow: hidden;
    }

    .container { width: 100%; max-width: 1240px; padding: 0 5%; margin: 0 auto; position: relative;}

    /* Modificación GSAP: Transform origin para que la línea crezca de izquierda a derecha */
    .top-hairline { 
        width: 100%; 
        height: 1px; 
        background-color: var(--hairline); 
        margin-bottom: 6rem;
        transform-origin: left center;
    }

    /* ==========================================================
       1. GRID ASIMÉTRICO (12 Columnas Editoriales)
       ========================================================== */
    .footer-grid {
        display: grid;
        grid-template-columns: 5fr 7fr; 
        gap: 6rem;
        margin-bottom: 8rem;
    }

    .brand-column {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .footer-logo-svg { width: 130px; height: auto; margin-bottom: 3rem; opacity: 0.9;}

    .statement-box { margin-bottom: 4rem; }
    
    .description { 
        color: var(--text-muted); 
        font-size: 1.25rem; 
        line-height: 1.5; 
        font-weight: 400;
        letter-spacing: -0.3px;
        margin: 0; 
        max-width: 90%;
    }

    /* EL BOTÓN DE CORREO SUTIL (Micro-interacción mantenida en CSS por performance) */
    .minimal-email-link {
        display: inline-flex; align-items: center; gap: 12px;
        text-decoration: none; color: var(--text-main);
        padding-bottom: 8px;
        border-bottom: 1px solid var(--hairline);
        transition: border-color 0.4s var(--ease-apple);
    }

    .email-text {
        font-size: 1.05rem; font-weight: 500; letter-spacing: 0.5px;
        transition: transform 0.4s var(--ease-spring), color 0.4s var(--ease-apple);
    }

    .email-arrow {
        width: 16px; height: 16px; opacity: 0.5; color: var(--text-muted);
        transition: all 0.4s var(--ease-spring);
    }

    .minimal-email-link:hover { border-bottom-color: rgba(255,255,255,0.4); }
    .minimal-email-link:hover .email-text { transform: translateX(4px); }
    .minimal-email-link:hover .email-arrow { opacity: 1; transform: translateX(8px); color: #fff; }
    .minimal-email-link:active { transform: scale(0.98); transition: 0.1s; }

    /* BLOQUE DERECHO (Navegación) */
    .navigation-columns {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
    }

    .nav-col { display: flex; flex-direction: column; }

    .col-title {
        font-size: 0.65rem; font-weight: 700; letter-spacing: 1.5px;
        color: var(--text-dim); margin-bottom: 2rem;
    }

    .nav-links { display: flex; flex-direction: column; gap: 1.2rem; }
    
    .link-item {
        display: inline-flex; align-items: center; gap: 8px;
        color: var(--text-muted); text-decoration: none; font-size: 0.95rem; font-weight: 500;
        transition: color 0.3s var(--ease-apple); width: max-content;
    }
    
    .link-arrow {
        font-size: 0.8rem; opacity: 0; transform: translateX(-10px);
        transition: all 0.4s var(--ease-spring); color: #fff;
    }

    .link-item:hover { color: #fff; }
    .link-item:hover .link-arrow { opacity: 1; transform: translateX(0); }

    /* REDES SOCIALES */
    .social-links { display: flex; flex-direction: column; gap: 1.2rem; }
    
    .social-item {
        display: flex; align-items: center; gap: 12px;
        color: var(--text-muted); text-decoration: none; font-size: 0.95rem; font-weight: 500;
        transition: color 0.3s var(--ease-apple);
        width: max-content; 
    }

    .s-icon-wrap {
        width: 28px; height: 28px; border-radius: 50%; border: 1px solid transparent;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.4s var(--ease-spring);
    }

    .social-icon { width: 14px; height: 14px; opacity: 0.6; transition: all 0.4s var(--ease-apple); }

    .social-item:hover { color: #fff; }
    .social-item:hover .s-icon-wrap { border-color: rgba(255,255,255,0.2); transform: translateX(4px);}
    .social-item:hover .social-icon { opacity: 1; }

    /* ==========================================================
       2. BARRA INFERIOR (Status Legal Integrado)
       ========================================================== */
    .footer-bottom {
        display: flex; justify-content: space-between; align-items: center;
        border-top: 1px solid var(--hairline); padding-top: 2rem;
        font-size: 0.8rem; color: var(--text-dim); font-weight: 500;
    }

    .legal-left { display: flex; align-items: center; gap: 1rem; }
    .copyright { margin: 0; }
    .dot-separator { opacity: 0.5; font-size: 0.6rem;}

    .status-indicator { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.03); padding: 4px 10px; border-radius: 100px; border: 1px solid rgba(255,255,255,0.05);}
    .status-text { letter-spacing: 1px; font-weight: 600; color: #94a3b8; font-size: 0.7rem;}

    .dot-online { 
        width: 6px; height: 6px; background-color: #10b981; border-radius: 50%; 
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); 
        animation: pulse-server 2.5s infinite;
    }
    @keyframes pulse-server { 
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); } 
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); } 
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); } 
    }

    .legal-right { display: flex; gap: 2rem; }
    .legal-link { color: var(--text-dim); text-decoration: none; transition: color 0.3s; }
    .legal-link:hover { color: var(--text-muted); }

    /* MÓVIL RESPONSIVE */
    @media (max-width: 1024px) {
        .footer-grid { grid-template-columns: 1fr; gap: 5rem; margin-bottom: 6rem;}
        .navigation-columns { gap: 2rem; }
        .description { max-width: 100%; }
        .brand-column { gap: 2rem; }
        .statement-box { margin-bottom: 2rem; }
    }

    @media (max-width: 768px) {
        .top-hairline { margin-bottom: 4rem; }
        .footer-logo-svg { width: 110px; margin-bottom: 2rem;}
        .description { font-size: 1.1rem; line-height: 1.6; }
        .minimal-email-link { width: 100%; justify-content: space-between; }
        .navigation-columns { 
            grid-template-columns: 1fr 1fr; 
            row-gap: 3rem; column-gap: 1rem; 
        }
        .navigation-columns .nav-col:nth-child(3) { grid-column: span 2; }
        .link-item { padding: 4px 0; width: 100%; justify-content: space-between;}
        .link-arrow { opacity: 0.3; transform: translateX(0); }
        .social-item { width: 100%; justify-content: space-between; padding: 4px 0;}
        .s-icon-wrap { border-color: rgba(255,255,255,0.1); }
        .social-icon { opacity: 0.8; }
        .footer-bottom { flex-direction: column; align-items: flex-start; gap: 2.5rem; }
        .legal-left { flex-direction: column; align-items: flex-start; gap: 1rem; }
        .dot-separator { display: none; }
        .status-indicator { align-self: stretch; justify-content: center; padding: 8px;} 
        .legal-right { flex-direction: column; gap: 1.5rem; width: 100%; }
        .legal-link { padding: 8px 0; display: block; border-bottom: 1px solid var(--hairline);}
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    // Registro del plugin en el ecosistema Astro/Client
    gsap.registerPlugin(ScrollTrigger);

    const initFooterAnimations = () => {
        // Pre-establecer estados iniciales para evitar parpadeos antes del scroll
        gsap.set('.top-hairline', { scaleX: 0 });
        gsap.set(['.footer-logo-svg', '.statement-box', '.contact-action', '.nav-col', '.footer-bottom'], { y: 30, opacity: 0 });

        // Crear una línea de tiempo maestra
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: '.footer-premium',
                start: 'top 85%', // Dispara la animación cuando el footer asoma el 15% en pantalla
                toggleActions: 'play none none reverse', // Vuelve a reproducirse si haces scroll up/down
            }
        });

        tl
            // 1. La línea superior se despliega (Precisión geométrica)
            .to('.top-hairline', { 
                scaleX: 1, 
                duration: 1.2, 
                ease: 'expo.out' 
            })
            
            // 2. Aparece la columna izquierda (Logo, texto, correo) en cascada
            .to(['.footer-logo-svg', '.statement-box', '.contact-action'], { 
                y: 0, 
                opacity: 1, 
                duration: 0.8, 
                stagger: 0.15, 
                ease: 'power3.out' 
            }, '-=0.8') // El '-=0.8' empalma la animación con la de la línea
            
            // 3. Las columnas de navegación entran una por una
            .to('.nav-col', { 
                y: 0, 
                opacity: 1, 
                duration: 0.8, 
                stagger: 0.1, 
                ease: 'power3.out' 
            }, '-=0.6')
            
            // 4. El status operativo y el copyright se revelan sutilmente al final
            .to('.footer-bottom', { 
                y: 0, 
                opacity: 1, 
                duration: 1, 
                ease: 'power2.out' 
            }, '-=0.4');
    };

    // Asegurar ejecución en la arquitectura Astro
    document.addEventListener('DOMContentLoaded', initFooterAnimations);
    // Soporte para transiciones de vista de Astro (ViewTransitions) si las tienes activas
    document.addEventListener('astro:page-load', initFooterAnimations);
</script>