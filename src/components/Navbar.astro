---
// Navbar Flouvia Elite: Mobile Consistency & Aesthetic Mastery
---

<header class="navbar-wrapper" id="navbar">
    <div class="top-bar">
        <div class="container-fluid top-bar-inner">
            <span class="top-text">INGENIERÍA B2B & E-COMMERCE DE ALTO RENDIMIENTO</span>
            <span class="top-text dot-sep desktop-only">•</span>
            <span class="top-text desktop-only">PRIVATE GROWTH BOUTIQUE</span>
        </div>
    </div>

    <nav class="main-nav">
        <div class="nav-container">
            
            <div class="nav-left desktop-nav">
                <div class="glass-pill">
                    <a href="/" class="pill-logo">FLOUVIA</a>
                    <a href="/" class="nav-link">TRABAJO</a>
                    <a href="/servicios" class="nav-link">SERVICIOS</a>
                    <a href="/nosotros" class="nav-link">NOSOTROS</a>
                    <a href="/casos" class="nav-link">CASOS</a>
                </div>
            </div>

            <div class="nav-center desktop-nav">
                <a href="/" class="main-logo" id="main-logo">FLOUVIA</a>
            </div>

            <div class="nav-right desktop-nav">
                <div class="mini-pill"><span class="lang-text">ES</span></div>
                <a href="/login" class="mini-pill user-link" aria-label="Login">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </a>
                <a href="#contacto" class="btn-contact">
                    CONTACTO 
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="7" y1="17" x2="17" y2="7"></line>
                        <polyline points="7 7 17 7 17 17"></polyline>
                    </svg>
                </a>
            </div>

            <div class="mobile-pill-nav">
                <div class="mobile-pill-inner">
                    <button class="hamburger-btn" id="menu-toggle" aria-label="Abrir Menú">
                        <div class="burger-lines">
                            <span class="l1"></span>
                            <span class="l2"></span>
                            <span class="l3"></span>
                        </div>
                    </button>

                    <a href="/" class="mobile-logo">FLOUVIA</a>

                    <a href="#contacto" class="btn-contact-mobile">
                        CONTACTO
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="7" y1="17" x2="17" y2="7"></line>
                            <polyline points="7 7 17 7 17 17"></polyline>
                        </svg>
                    </a>
                </div>
            </div>

        </div>
    </nav>

    <div class="mobile-menu-overlay" id="mobile-menu">
        <div class="mobile-menu-content">
            <nav class="mobile-links">
                <a href="/" class="m-link">TRABAJO</a>
                <a href="/servicios" class="m-link">SERVICIOS</a>
                <a href="/nosotros" class="m-link">NOSOTROS</a>
                <a href="/casos" class="m-link">CASOS</a>
            </nav>
            
            <div class="mobile-menu-footer">
                <div class="m-legal">
                    <span>CDMX — OP. GLOBAL</span>
                    <a href="mailto:flouvia.mx@gmail.com">flouvia.mx@gmail.com</a>
                </div>
            </div>
        </div>
    </div>

</header>

<style>
    :root {
        --color-azul-pro: #0a192f;
        --color-azul-dark: rgba(6, 17, 33, 0.98); 
        --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
        --ease-elastic: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    /* 1. TOP BAR */
    .top-bar { background: var(--color-azul-pro); color: #fff; padding: 9px 0; text-align: center; text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .container-fluid { display: flex; justify-content: center; padding: 0 40px; max-width: 100%; align-items: center; }
    .top-bar-inner { display: flex; gap: 10px; align-items: center; justify-content: space-between;}
    .top-text { font-size: 9px; font-weight: 700; letter-spacing: 2px; }
    .dot-sep { opacity: 0.5; }

    /* 2. WRAPPER */
    .navbar-wrapper { position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; background: transparent; transition: background 0.3s ease;}
    .main-nav { padding: 25px 0; transition: padding 0.5s var(--ease-out-expo); }
    .navbar-wrapper.scrolled .main-nav { padding: 15px 0; }
    .nav-container { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 0 40px; position: relative;}

    /* ESCRITORIO */
    .desktop-nav { display: flex; align-items: center; }
    .glass-pill { display: inline-flex; align-items: center; background: rgba(0, 0, 0, 0.04); padding: 4px 6px; border-radius: 100px; border: 1px solid rgba(0, 0, 0, 0.05); transition: all 0.5s var(--ease-out-expo); }
    .navbar-wrapper.scrolled .glass-pill { background: rgba(10, 25, 47, 0.85); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); border: 1px solid rgba(255, 255, 255, 0.1); padding: 4px 12px; }
    
    .nav-link { color: #000; text-decoration: none; font-size: 9.5px; font-weight: 700; padding: 8px 14px; letter-spacing: 1px; opacity: 0.6; position: relative; z-index: 1; transition: all 0.3s ease; }
    .navbar-wrapper.scrolled .nav-link { color: #fff; }
    .nav-link::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.06); border-radius: 100px; z-index: -1; opacity: 0; transform: scale(0.8); transition: all 0.3s var(--ease-out-expo); }
    .navbar-wrapper.scrolled .nav-link::before { background: rgba(255, 255, 255, 0.15); }
    .nav-link:hover { opacity: 1; }
    .nav-link:hover::before { opacity: 1; transform: scale(1); }

    .pill-logo { color: #fff; text-decoration: none; font-weight: 800; font-size: 13px; letter-spacing: 1px; width: 0; overflow: hidden; opacity: 0; transition: all 0.5s var(--ease-out-expo); white-space: nowrap;}
    .navbar-wrapper.scrolled .pill-logo { width: 75px; opacity: 1; margin-right: 10px; padding-left: 8px; }

    .main-logo { color: #000; text-decoration: none; font-size: 24px; font-weight: 800; letter-spacing: 4px; transition: all 0.5s var(--ease-out-expo); }
    .navbar-wrapper.scrolled .main-logo { opacity: 0; transform: translateY(-10px); }

    .nav-right { justify-content: flex-end; gap: 10px; }
    .mini-pill { display: flex; align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.03); border: 1px solid rgba(0, 0, 0, 0.08); color: #000; border-radius: 100px; padding: 8px 14px; transition: all 0.3s ease; }
    .navbar-wrapper.scrolled .mini-pill { background: rgba(10, 25, 47, 0.85); border-color: rgba(255, 255, 255, 0.1); color: #fff; }
    
    .user-link:hover { background: rgba(0, 0, 0, 0.08); transform: translateY(-1px); }
    .navbar-wrapper.scrolled .user-link:hover { background: #fff; color: var(--color-azul-pro); border-color: #fff; box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2); }
    .lang-text { font-size: 10px; font-weight: 800; letter-spacing: 1px; }

    .btn-contact { background: var(--color-azul-pro); color: #fff; padding: 10px 22px; border-radius: 100px; text-decoration: none; font-size: 10px; font-weight: 700; letter-spacing: 0.5px; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease; border: 1px solid rgba(255,255,255,0.1); margin-left: 5px; }
    .btn-contact:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(10, 25, 47, 0.2); }

    /* ESCONDER EN ESCRITORIO */
    .mobile-pill-nav { display: none; }
    .mobile-menu-overlay { display: none; } 

    /* =========================================
       MÓVIL (Alta Costura)
       ========================================= */
    @media (max-width: 1024px) {
        .desktop-nav, .desktop-only { display: none; }
        
        /* TOP BAR MÓVIL */
        .top-bar { padding: 6px 0; }
        .top-bar-inner { justify-content: center; gap: 6px; }
        .top-text { font-size: 6.5px; letter-spacing: 1px; white-space: nowrap;}
        
        .nav-container { display: flex; justify-content: center; padding: 0 20px; }
        .main-nav { padding: 15px 0; }

        /* PÍLDORA FLOTANTE */
        .mobile-pill-nav { display: flex; width: 100%; justify-content: center; position: relative; z-index: 2000; }
        .mobile-pill-inner {
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.08); border-radius: 100px;
            padding: 5px 6px 5px 12px; width: 90%; max-width: 400px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06); transition: all 0.4s var(--ease-out-expo);
        }
        .navbar-wrapper.scrolled .mobile-pill-inner { background: var(--color-azul-pro); border-color: rgba(255,255,255,0.1); box-shadow: 0 10px 30px rgba(10, 25, 47, 0.2);}

        /* Hamburguesa con Físicas Precisas */
        .hamburger-btn { background: transparent; border: none; padding: 8px 10px 8px 0; cursor: pointer; display: flex; align-items: center; }
        .burger-lines { width: 18px; height: 12px; position: relative; }
        .burger-lines span { 
            display: block; width: 100%; height: 2px; 
            background: var(--color-azul-pro); border-radius: 2px; 
            position: absolute; left: 0; transition: all 0.4s var(--ease-elastic); 
        }
        .burger-lines .l1 { top: 0; }
        .burger-lines .l2 { top: 5px; } /* Exacto en el centro */
        .burger-lines .l3 { top: 10px; }
        
        .navbar-wrapper.scrolled .burger-lines span { background: #fff; }

        /* LA "X" PERFECTA */
        .navbar-wrapper.menu-open .mobile-pill-inner { background: rgba(255, 255, 255, 0.1); border-color: rgba(255, 255, 255, 0.2); box-shadow: none; }
        .navbar-wrapper.menu-open .burger-lines span { background: #fff; }
        .navbar-wrapper.menu-open .burger-lines .l1 { transform: translateY(5px) rotate(45deg); }
        .navbar-wrapper.menu-open .burger-lines .l2 { opacity: 0; transform: scale(0); }
        .navbar-wrapper.menu-open .burger-lines .l3 { transform: translateY(-5px) rotate(-45deg); }

        /* Logo Móvil */
        .mobile-logo { font-size: 13px; font-weight: 800; letter-spacing: 2.5px; color: var(--color-azul-pro); text-decoration: none; position: absolute; left: 50%; transform: translateX(-50%); transition: color 0.4s ease;}
        .navbar-wrapper.scrolled .mobile-logo { color: #fff; }
        .navbar-wrapper.menu-open .mobile-logo { color: #fff; }

        /* Botón Contacto Móvil */
        .btn-contact-mobile {
            background: var(--color-azul-pro); color: #fff;
            padding: 8px 14px; border-radius: 100px;
            text-decoration: none; font-size: 8.5px; font-weight: 700; letter-spacing: 0.5px;
            display: flex; align-items: center; gap: 6px; transition: 0.4s ease;
        }
        .navbar-wrapper.scrolled .btn-contact-mobile { background: #fff; color: var(--color-azul-pro); }
        .navbar-wrapper.menu-open .btn-contact-mobile { background: #fff; color: var(--color-azul-pro); }

        /* OVERLAY MÓVIL (Minimalismo Puro) */
        .mobile-menu-overlay {
            display: flex; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background-color: var(--color-azul-dark); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            z-index: 1500; flex-direction: column; justify-content: center;
            opacity: 0; visibility: hidden; clip-path: circle(0% at 50% 10%); transition: all 0.7s var(--ease-out-expo);
        }
        .navbar-wrapper.menu-open .mobile-menu-overlay { opacity: 1; visibility: visible; clip-path: circle(150% at 50% 10%); }
        
        .mobile-menu-content { padding: 0 10%; display: flex; flex-direction: column; justify-content: center; height: 100%; gap: 6rem;}
        
        /* Links Exactos */
        .mobile-links { display: flex; flex-direction: column; gap: 2.5rem; text-align: center;}
        .m-link { 
            font-size: 2rem; font-weight: 800; color: #fff; text-decoration: none; letter-spacing: 2px;
            opacity: 0; transform: translateY(20px); transition: 0.5s var(--ease-out-expo);
        }
        .navbar-wrapper.menu-open .m-link { opacity: 1; transform: translateY(0); }
        .navbar-wrapper.menu-open .m-link:nth-child(1) { transition-delay: 0.1s; }
        .navbar-wrapper.menu-open .m-link:nth-child(2) { transition-delay: 0.2s; }
        .navbar-wrapper.menu-open .m-link:nth-child(3) { transition-delay: 0.3s; }
        .navbar-wrapper.menu-open .m-link:nth-child(4) { transition-delay: 0.4s; }

        .mobile-menu-footer { 
            border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; 
            opacity: 0; transform: translateY(20px); transition: all 0.6s var(--ease-out-expo) 0.5s; 
        }
        .navbar-wrapper.menu-open .mobile-menu-footer { opacity: 1; transform: translateY(0); }
        .m-legal { display: flex; justify-content: space-between; font-size: 8px; color: #8892b0; letter-spacing: 1px; font-weight: 700; text-transform: uppercase; }
        .m-legal a { color: #fff; text-decoration: none; }
    }
</style>

<script>
    const navbar = document.getElementById("navbar");
    const menuToggle = document.getElementById("menu-toggle");

    window.addEventListener("scroll", () => {
        if (window.pageYOffset > 50) navbar.classList.add("scrolled");
        else navbar.classList.remove("scrolled");
    });

    menuToggle.addEventListener("click", () => {
        navbar.classList.toggle("menu-open");
        document.body.style.overflow = navbar.classList.contains("menu-open") ? "hidden" : "";
    });

    document.querySelectorAll('.m-link, .btn-contact-mobile').forEach(l => {
        l.addEventListener('click', () => {
            navbar.classList.remove("menu-open");
            document.body.style.overflow = "";
        });
    });
</script>