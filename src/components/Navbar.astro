<!-- Gate global: el navbar parte oculto antes del primer paint (cuando hay JS sin
     reduced-motion) para que GSAP lo revele sin flash. -->
<style is:global>
    .js-anim #navbar { opacity: 0; }
</style>

<script>
import { gsap } from "gsap";

document.addEventListener("DOMContentLoaded", () => {
    const navbar = document.getElementById("navbar");
    const toggle = document.getElementById("menu-toggle");

    /* ═══════════════════════════════════════════════════
       RESTORE SCROLL tras cambio de idioma — volver a donde estabas (no reiniciar arriba).
       El body viene oculto (html.lang-restoring, puesto en el <head> antes del paint);
       posicionamos el scroll y lo revelamos con un crossfade en el MISMO punto.
       ═══════════════════════════════════════════════════ */
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let langScroll: number | null = null;
    try {
        const s = sessionStorage.getItem("flouviaLangScroll");
        if (s !== null) { langScroll = parseInt(s, 10) || 0; sessionStorage.removeItem("flouviaLangScroll"); }
    } catch (err) {}
    if (langScroll !== null) {
        const y = langScroll;
        window.scrollTo(0, y);                                          // restaura ya
        requestAnimationFrame(() => window.scrollTo(0, y));             // tras el primer frame (layout)
        window.addEventListener("load", () => window.scrollTo(0, y), { once: true }); // con fuentes/imágenes
        if (prefersReduced) {
            document.documentElement.classList.remove("lang-restoring");
        } else {
            gsap.set(document.body, { opacity: 0 });
            document.documentElement.classList.remove("lang-restoring");
            gsap.to(document.body, { opacity: 1, duration: 0.25, ease: "power1.out" });
        }
    }

    /* ═══════════════════════════════════════════════════
       ENTRANCE — reveal escalonado sutil de las piezas internas.
       El CSS (.js-anim #navbar) oculta el navbar completo antes del primer paint.
       Ocultamos las piezas (mientras el contenedor sigue en opacity:0 por el gate),
       luego revelamos el contenedor y las dejamos entrar con un stagger suave.
       Sin blur/scale/drama — solo fade + leve bajada. Al terminar, clearProps en
       las piezas para que .scrolled / :hover gobiernen; el navbar conserva su
       opacity:1 inline (gana sobre el gate).
       ═══════════════════════════════════════════════════ */
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    // recolocador del indicador deslizante — lo asigna el bloque NAV INDICATOR;
    // lo llaman la entrada (onComplete) y el scroll (cambio claro→oscuro).
    let indicatorRelayout: ((animate?: boolean) => void) | null = null;
    // hace que el indicador SIGA al link mientras el layout se mueve (transición del logo).
    let indicatorFollow: ((ms?: number) => void) | null = null;

    if (navbar && !reducedMotion) {
        const topBar    = document.getElementById("top-bar");
        const pill      = document.getElementById("glass-pill");
        const mainLogo  = document.getElementById("main-logo");
        const navRight  = document.getElementById("nav-right");
        const rightKids = navRight ? Array.from(navRight.children) : [];
        const mobile    = document.getElementById("mobile-pill");
        const pieces    = [topBar, pill, mainLogo, ...rightKids, mobile].filter(Boolean);

        gsap.set(pieces, { opacity: 0, y: -10 });   // ocultas (navbar aún tapado por el gate)
        gsap.set(navbar, { opacity: 1 });           // revela contenedor; piezas siguen ocultas

        const tl = gsap.timeline({
            defaults: { ease: "power3.out", duration: 0.95 },
            delay: 0.05,
            onComplete: () => {
                gsap.set(pieces, { clearProps: "transform,opacity" });
                if (indicatorRelayout) indicatorRelayout(false); // recolocar tras settle
            },
        });
        tl.to(topBar,                 { opacity: 1, y: 0, duration: 0.6 }, 0)
          .to([pill, mobile],         { opacity: 1, y: 0, duration: 1.0 }, 0.1)
          .to(mainLogo,               { opacity: 1, y: 0, duration: 0.9 }, "<0.07")
          .to(rightKids,              { opacity: 1, y: 0, stagger: 0.08, duration: 0.75 }, "<0.05");
    }

    /* ═══════════════════════════════════════════════════
       ACTIVE LINK — filled pill background
       ═══════════════════════════════════════════════════ */
    const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll<HTMLAnchorElement>(".nav-link[data-path]").forEach(link => {
        const lp = (link.getAttribute("data-path") || "").replace(/\/$/, '');
        // exact match para "/" y "/en/" — startsWith para sub-rutas
        const isHome = lp === '/' || lp === '/en';
        const matches = isHome
            ? (currentPath === lp || currentPath === '')
            : currentPath.startsWith(lp);
        if (lp && matches) link.classList.add("nav-active");
    });

    /* ═══════════════════════════════════════════════════
       NAV INDICATOR — cápsula de vidrio que se desliza al link en hover
       (estilo segmented control iOS). Por defecto descansa en el link activo;
       al pasar el mouse se desliza (x/y/width/height vía GSAP) y al salir regresa.
       Nunca crece de golpe: morph suave. Se recalcula en fuentes/resize/scroll.
       ═══════════════════════════════════════════════════ */
    const glassPill = document.getElementById("glass-pill");
    const indicator = document.getElementById("nav-indicator");
    if (glassPill && indicator) {
        const navLinks = Array.from(glassPill.querySelectorAll<HTMLElement>(".nav-link"));
        const current  = glassPill.querySelector<HTMLElement>(".nav-link.nav-active"); // link activo (fijo por página)
        let visible = false;
        let target: HTMLElement | null = current;   // dónde DEBE estar el indicador (activo o hovered)

        const rectOf = (el: HTMLElement) => {
            const pr = glassPill.getBoundingClientRect();
            const r  = el.getBoundingClientRect();
            return { x: r.left - pr.left, y: r.top - pr.top, width: r.width, height: r.height };
        };
        // pega el indicador al link SIN animar (para seguir un layout en movimiento)
        const snap = (el: HTMLElement | null) => {
            if (!el) return;
            gsap.set(indicator, { ...rectOf(el), opacity: 1 });
            visible = true;
        };
        // mueve el indicador (animado) o lo oculta si no hay destino
        const slide = (el: HTMLElement | null, animate = true) => {
            target = el;
            if (!el) { gsap.to(indicator, { opacity: 0, duration: animate ? 0.3 : 0, overwrite: true }); visible = false; return; }
            if (!visible) {
                gsap.set(indicator, rectOf(el));                          // aparece ya colocado (no crece desde la esquina)
                gsap.to(indicator, { opacity: 1, duration: animate ? 0.3 : 0, overwrite: true });
            } else {
                gsap.to(indicator, { ...rectOf(el), opacity: 1, duration: animate ? 0.5 : 0, ease: "power3.out", overwrite: true });
            }
            visible = true;
        };

        slide(current, false);
        navLinks.forEach(l => l.addEventListener("mouseenter", () => slide(l)));
        glassPill.addEventListener("mouseleave", () => slide(current));

        // recolocar (sin animar) cuando cambian las medidas reales
        indicatorRelayout = (animate = false) => slide(target, animate);
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => indicatorRelayout && indicatorRelayout(false));
        window.addEventListener("load", () => indicatorRelayout && indicatorRelayout(false), { once: true });
        window.addEventListener("resize", () => indicatorRelayout && indicatorRelayout(false), { passive: true });

        // SEGUIMIENTO: mientras el logo crece/encoge (transición CSS 0.7s) los links se
        // mueven; el indicador se pega al target cuadro por cuadro → sin desfase ni salto.
        let followRAF = 0, followUntil = 0;
        const followTick = (now: number) => {
            snap(target);
            if (now < followUntil) { followRAF = requestAnimationFrame(followTick); }
            else { followRAF = 0; }
        };
        indicatorFollow = (ms = 780) => {
            followUntil = performance.now() + ms;
            if (!followRAF) followRAF = requestAnimationFrame(followTick);
        };
    }

    /* ═══════════════════════════════════════════════════
       LANG SWITCH — crossfade + prefetch (sin sensación de recarga)
       Precargamos el destino al primer indicio de intención (hover/touch) para que
       la navegación sea casi instantánea, y hacemos un fade-out corto del contenido
       al hacer click. El destino entra con su propio gate .js-anim → se lee como
       crossfade en vez de flash blanco. Con reduced-motion → navegación normal.
       ═══════════════════════════════════════════════════ */
    const langLinks = document.querySelectorAll<HTMLAnchorElement>(".lang-option, .lang-option-m");
    const prefetched = new Set<string>();
    const prefetch = (href: string) => {
        if (!href || prefetched.has(href)) return;
        prefetched.add(href);
        const link = document.createElement("link");
        link.rel = "prefetch";
        link.href = href;
        document.head.appendChild(link);
    };
    langLinks.forEach(a => {
        const href = a.getAttribute("href") || "";
        a.addEventListener("mouseenter", () => prefetch(href), { once: true });
        a.addEventListener("touchstart", () => prefetch(href), { once: true, passive: true });

        a.addEventListener("click", (e) => {
            if (a.classList.contains("active")) { e.preventDefault(); return; } // idioma actual → no recargar
            const dest = a.href;
            if (!dest || dest === window.location.href) return;
            // guarda la posición de scroll para restaurarla en la página destino (no reiniciar arriba)
            try { sessionStorage.setItem("flouviaLangScroll", String(Math.round(window.scrollY))); } catch (err) {}
            if (reducedMotion) return; // sin anim → navegación normal (pero ya guardamos scroll)
            e.preventDefault();
            prefetch(href);
            gsap.to(document.body, {
                opacity: 0, duration: 0.16, ease: "power1.out",
                onComplete: () => { window.location.href = dest; },
            });
        });
    });
    // bfcache (botón atrás): la página se restaura con el opacity:0 inline pegado →
    // lo limpiamos al volver para no dejar la pantalla en blanco.
    window.addEventListener("pageshow", (e) => {
        if ((e as PageTransitionEvent).persisted) gsap.set(document.body, { clearProps: "opacity" });
    });

    /* ═══════════════════════════════════════════════════
       SCROLL — toggle scrolled class
       ═══════════════════════════════════════════════════ */
    if (navbar) {
        let wasScrolled = navbar.classList.contains("scrolled");
        window.addEventListener("scroll", () => {
            const isScrolled = window.scrollY > 50;
            navbar.classList.toggle("scrolled", isScrolled);
            if (isScrolled !== wasScrolled) {
                wasScrolled = isScrolled;
                // el pill-logo aparece/desaparece (transición 0.7s) y empuja los links →
                // el indicador SIGUE al link durante toda la transición (sin desfase).
                if (indicatorFollow) indicatorFollow();
            }
        }, { passive: true });
    }

    /* ═══════════════════════════════════════════════════
       MOBILE MENU
       ═══════════════════════════════════════════════════ */
    if (navbar && toggle) {
        toggle.addEventListener("click", () => {
            navbar.classList.toggle("menu-open");
            const main = document.querySelector("main");
            if (navbar.classList.contains("menu-open")) {
                document.body.style.overflow = "hidden";
                if (main) gsap.to(main, { scale: 0.96, y: 10, filter: "blur(4px)", borderRadius: "20px", duration: 0.6, ease: "expo.out" });
            } else {
                document.body.style.overflow = "";
                if (main) gsap.to(main, { scale: 1, y: 0, filter: "blur(0px)", borderRadius: "0px", duration: 0.5, ease: "expo.out" });
            }
        });

        document.querySelectorAll(".m-link, .utility-pill, .btn-contact-mobile").forEach(el => {
            el.addEventListener("click", () => {
                navbar.classList.remove("menu-open");
                document.body.style.overflow = "";
                const main = document.querySelector("main");
                if (main) gsap.to(main, { scale: 1, y: 0, filter: "blur(0px)", borderRadius: "0px", duration: 0.45, ease: "expo.out" });
            });
        });
    }
});
</script>
