---
// Navbar Flouvia Elite: Cápsulas de Alta Precisión
---

<header class="navbar-wrapper" id="navbar">
    <div class="top-bar">
        <div class="container-fluid">
            <span>INGENIERÍA B2B & E-COMMERCE DE ALTO RENDIMIENTO</span>
            <span class="desktop-only">PRIVATE GROWTH BOUTIQUE</span>
        </div>
    </div>

    <nav class="main-nav">
        <div class="nav-container">
            
            <div class="nav-left">
                <div class="glass-pill">
                    <a href="/" class="pill-logo">FLOUVIA</a>
                    <a href="/" class="nav-link">TRABAJO</a>
                    <a href="/servicios" class="nav-link">SERVICIOS</a>
                    <a href="/nosotros" class="nav-link">NOSOTROS</a>
                    <a href="/casos" class="nav-link">CASOS</a>
                </div>
            </div>

            <div class="nav-center">
                <a href="/" class="main-logo" id="main-logo">FLOUVIA</a>
            </div>

            <div class="nav-right">
                <div class="mini-pill">
                    <span class="lang-text">ES</span>
                </div>

                <a href="/login" class="mini-pill user-link" aria-label="Login">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </a>
                
                <a href="#contacto" class="btn-contact">
                    CONTACTO 
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="7" y1="17" x2="17" y2="7"></line>
                        <polyline points="7 7 17 7 17 17"></polyline>
                    </svg>
                </a>
            </div>

        </div>
    </nav>
</header>

<style>
    :root {
        --color-azul-pro: #0a192f;
    }

    /* 1. TOP BAR */
    .top-bar {
        background: var(--color-azul-pro);
        color: #fff;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 2px;
        padding: 9px 0;
        text-align: center;
        text-transform: uppercase;
    }
    .container-fluid {
        display: flex;
        justify-content: space-between;
        padding: 0 40px;
        max-width: 100%;
        align-items: center;
    }

    /* 2. WRAPPER (FULL TRANSPARENTE) */
    .navbar-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        background: transparent;
    }

    .main-nav {
        padding: 25px 0;
        background: transparent !important;
        transition: padding 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .navbar-wrapper.scrolled .main-nav {
        padding: 15px 0;
    }

    .nav-container {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 0 40px;
    }

    /* IZQUIERDA: PÍLDORA */
    .glass-pill {
        display: inline-flex;
        align-items: center;
        background: rgba(0, 0, 0, 0.04);
        padding: 4px 6px;
        border-radius: 100px;
        border: 1px solid rgba(0, 0, 0, 0.05);
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .navbar-wrapper.scrolled .glass-pill {
        background: rgba(10, 25, 47, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 4px 12px;
    }

    /* MAGNETIC HOVER */
    .nav-link {
        color: #000;
        text-decoration: none;
        font-size: 9.5px;
        font-weight: 700;
        padding: 8px 14px;
        letter-spacing: 1px;
        opacity: 0.6;
        position: relative;
        z-index: 1;
        transition: all 0.3s ease;
    }
    .navbar-wrapper.scrolled .nav-link { color: #fff; }

    .nav-link::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.06);
        border-radius: 100px;
        z-index: -1;
        opacity: 0;
        transform: scale(0.8);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .navbar-wrapper.scrolled .nav-link::before { background: rgba(255, 255, 255, 0.15); }
    
    .nav-link:hover { opacity: 1; }
    .nav-link:hover::before { opacity: 1; transform: scale(1); }

    .pill-logo {
        color: #fff;
        text-decoration: none;
        font-weight: 800;
        font-size: 13px;
        letter-spacing: 1px;
        width: 0;
        overflow: hidden;
        opacity: 0;
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .navbar-wrapper.scrolled .pill-logo { width: 75px; opacity: 1; margin-right: 10px; padding-left: 8px; }

    /* LOGO CENTRAL */
    .main-logo {
        color: #000;
        text-decoration: none;
        font-size: 24px;
        font-weight: 800;
        letter-spacing: 4px;
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .navbar-wrapper.scrolled .main-logo { opacity: 0; transform: translateY(-10px); }

    /* DERECHA: CÁPSULAS SEPARADAS Y DEFINIDAS */
    .nav-right {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
    }

    /* Estilo base de las mini-píldoras (Estado Hasta Arriba) */
    .mini-pill {
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.03);
        border: 1px solid rgba(0, 0, 0, 0.08); /* Borde más definido arriba */
        color: #000; /* Negro nítido */
        border-radius: 100px;
        padding: 8px 14px;
        transition: all 0.3s ease;
    }

    /* Estado Al Bajar (Azul Transparentoso) */
    .navbar-wrapper.scrolled .mini-pill {
        background: rgba(10, 25, 47, 0.85);
        border-color: rgba(255, 255, 255, 0.1);
        color: #fff;
    }

    /* Interacción Píldora de Login (Estado Hasta Arriba) */
    .user-link { text-decoration: none; cursor: pointer; }
    .user-link:hover { 
        background: rgba(0, 0, 0, 0.08); 
        transform: translateY(-1px); 
    }
    
    /* Interacción Píldora de Login (Estado Al Bajar -> SE VUELVE BLANCA) */
    .navbar-wrapper.scrolled .user-link:hover { 
        background: #fff; /* Fondo blanco sólido */
        color: var(--color-azul-pro); /* Icono azul oscuro para contrastar */
        border-color: #fff;
        box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);
    }

    .lang-text { font-size: 10px; font-weight: 800; letter-spacing: 1px; }

    /* Botón Contacto */
    .btn-contact {
        background: var(--color-azul-pro);
        color: #fff;
        padding: 10px 22px;
        border-radius: 100px;
        text-decoration: none;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        border: 1px solid rgba(255,255,255,0.1);
        margin-left: 5px; /* Pequeña separación extra del resto */
    }
    .btn-contact:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(10, 25, 47, 0.2); }

    @media (max-width: 1024px) {
        .nav-left, .desktop-only { display: none; }
        .nav-container { grid-template-columns: 1fr 1fr; }
    }
</style>

<script>
    const navbar = document.getElementById("navbar");
    window.addEventListener("scroll", () => {
        let scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        if (scrollTop > 60) {
            navbar.classList.add("scrolled");
        } else {
            navbar.classList.remove("scrolled");
        }
    });
</script>