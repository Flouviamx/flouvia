---
// Navbar Flouvia Elite: Píldora Asimétrica + Menú Editorial
---

<header class="navbar-wrapper" id="navbar">
    <div class="top-bar">
        <div class="container-fluid top-bar-inner">
            <span class="top-text">INGENIERÍA B2B & E-COMMERCE DE ALTO RENDIMIENTO</span>
            <span class="top-text dot-sep desktop-only">•</span>
            <span class="top-text desktop-only">PRIVATE GROWTH BOUTIQUE</span>
        </div>
    </div>

    <nav class="main-nav">
        <div class="nav-container">
            
            <div class="nav-left desktop-nav">
                <div class="glass-pill">
                    <a href="/" class="pill-logo">FLOUVIA</a>
                    <a href="/" class="nav-link">TRABAJO</a>
                    <a href="/servicios" class="nav-link">SERVICIOS</a>
                    <a href="/nosotros" class="nav-link">NOSOTROS</a>
                    <a href="/casos" class="nav-link">CASOS</a>
                </div>
            </div>

            <div class="nav-center desktop-nav">
                <a href="/" class="main-logo" id="main-logo">FLOUVIA</a>
            </div>

            <div class="nav-right desktop-nav">
                <div class="mini-pill"><span class="lang-text">ES</span></div>
                <a href="/login" class="mini-pill user-link" aria-label="Login">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </a>
                <a href="#contacto" class="btn-contact">CONTACTO ↗</a>
            </div>

            <div class="mobile-pill-nav">
                <div class="mobile-pill-inner">
                    
                    <div class="pill-left-group">
                        <button class="hamburger-btn" id="menu-toggle" aria-label="Menú">
                            <div class="burger-lines">
                                <span class="l1"></span>
                                <span class="l2"></span>
                                <span class="l3"></span>
                            </div>
                        </button>
                        <a href="/" class="mobile-logo">FLOUVIA</a>
                    </div>

                    <a href="#contacto" class="btn-contact-mobile">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="7" y1="17" x2="17" y2="7"></line>
                            <polyline points="7 7 17 7 17 17"></polyline>
                        </svg>
                    </a>
                    
                </div>
            </div>

        </div>
    </nav>

    <div class="mobile-menu-overlay" id="mobile-menu">
        <div class="mobile-menu-content">
            
            <div class="menu-top-row">
                <a href="/login" class="utility-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    INICIAR SESIÓN
                </a>
                <div class="utility-pill lang-selector">ES</div>
            </div>

            <nav class="mobile-links">
                <a href="/" class="m-link">TRABAJO</a>
                <a href="/servicios" class="m-link">SERVICIOS</a>
                <a href="/nosotros" class="m-link">NOSOTROS</a>
                <a href="/casos" class="m-link">CASOS</a>
            </nav>
            
            <div class="mobile-menu-footer">
                <p class="m-eyebrow">ESTUDIO DE INGENIERÍA DIGITAL</p>
                <div class="m-legal">
                    <span>CDMX — OP. GLOBAL</span>
                    <a href="mailto:flouvia.mx@gmail.com">flouvia.mx@gmail.com</a>
                </div>
            </div>
        </div>
    </div>
</header>

<style>
    :root {
        --color-azul-pro: #0a192f;
        --color-azul-dark: #061121;
        --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
        --ease-elastic: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    /* 1. TOP BAR */
    .top-bar { background: var(--color-azul-pro); color: #fff; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .container-fluid { display: flex; justify-content: center; padding: 0 40px; }
    .top-text { font-size: 8px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; }

    /* 2. WRAPPER & DESKTOP */
    .navbar-wrapper { position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; background: transparent; }
    .main-nav { padding: 25px 0; transition: all 0.5s var(--ease-out-expo); }
    .navbar-wrapper.scrolled .main-nav { padding: 15px 0; }
    .nav-container { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 0 40px; }
    
    .desktop-nav { display: flex; align-items: center; }
    .glass-pill { display: inline-flex; align-items: center; background: rgba(0, 0, 0, 0.04); padding: 4px 6px; border-radius: 100px; border: 1px solid rgba(0, 0, 0, 0.05); }
    .navbar-wrapper.scrolled .glass-pill { background: rgba(10, 25, 47, 0.9); backdrop-filter: blur(10px); color: #fff; }
    .nav-link { color: #000; text-decoration: none; font-size: 9px; font-weight: 700; padding: 8px 12px; letter-spacing: 1px; opacity: 0.6; transition: 0.3s; }
    .navbar-wrapper.scrolled .nav-link { color: #fff; }
    .main-logo { color: #000; text-decoration: none; font-size: 22px; font-weight: 800; letter-spacing: 4px; transition: 0.4s; }
    .navbar-wrapper.scrolled .main-logo { opacity: 0; transform: translateY(-10px); }
    .btn-contact { background: var(--color-azul-pro); color: #fff; padding: 8px 18px; border-radius: 100px; text-decoration: none; font-size: 10px; font-weight: 700; }

    .mobile-pill-nav { display: none; }
    .mobile-menu-overlay { display: none; }

    /* =========================================
       MÓVIL
       ========================================= */
    @media (max-width: 1024px) {
        .desktop-nav, .desktop-only { display: none; }
        .top-text { font-size: 7px; letter-spacing: 1.5px; }

        .mobile-pill-nav { display: flex; width: 100%; justify-content: center; z-index: 2000; }
        .mobile-pill-inner {
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.08); border-radius: 100px;
            padding: 6px 8px 6px 12px; width: 92%; max-width: 380px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06); transition: all 0.5s var(--ease-out-expo);
        }
        .navbar-wrapper.scrolled .mobile-pill-inner { background: var(--color-azul-pro); border-color: rgba(255,255,255,0.1); }

        /* Grupo Izquierdo (Hamburger + Logo) */
        .pill-left-group { display: flex; align-items: center; gap: 14px; }

        .hamburger-btn { background: transparent; border: none; padding: 6px 0; cursor: pointer; display: flex; align-items: center; position: relative; z-index: 2;}
        .burger-lines { width: 18px; height: 12px; position: relative; }
        .burger-lines span { display: block; width: 100%; height: 2px; background: var(--color-azul-pro); border-radius: 2px; position: absolute; left: 0; transition: all 0.4s var(--ease-elastic); }
        .burger-lines .l1 { top: 0; } .burger-lines .l2 { top: 5px; } .burger-lines .l3 { top: 10px; }
        .navbar-wrapper.scrolled .burger-lines span { background: #fff; }

        /* La "X" */
        .navbar-wrapper.menu-open .burger-lines .l1 { transform: translateY(5px) rotate(45deg); background: #fff !important; }
        .navbar-wrapper.menu-open .burger-lines .l2 { opacity: 0; transform: scale(0); }
        .navbar-wrapper.menu-open .burger-lines .l3 { transform: translateY(-5px) rotate(-45deg); background: #fff !important; }

        /* Logo pegado a la izquierda */
        .mobile-logo { 
            font-size: 13px; font-weight: 800; letter-spacing: 2px; color: var(--color-azul-pro); 
            text-decoration: none; transition: color 0.4s ease;
        }
        .navbar-wrapper.scrolled .mobile-logo { color: #fff; }
        .navbar-wrapper.menu-open .mobile-logo { color: #fff !important; }

        /* Botón Contacto Derecho */
        .btn-contact-mobile {
            background: var(--color-azul-pro); color: #fff;
            width: 36px; height: 36px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none; transition: 0.4s ease;
        }
        .navbar-wrapper.scrolled .btn-contact-mobile { background: #fff; color: var(--color-azul-pro); }
        .navbar-wrapper.menu-open .btn-contact-mobile { background: rgba(255,255,255,0.1); color: #fff; }

        /* =========================================
           MENÚ DESPLEGABLE
           ========================================= */
        .mobile-menu-overlay {
            display: flex; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background-color: var(--color-azul-dark); z-index: 1500;
            opacity: 0; visibility: hidden; clip-path: circle(0% at 15% 10%); transition: all 0.7s var(--ease-out-expo);
        }
        .navbar-wrapper.menu-open .mobile-menu-overlay { opacity: 1; visibility: visible; clip-path: circle(150% at 15% 10%); }

        .mobile-menu-content { 
            padding: 12vh 8% 6vh 8%; display: flex; flex-direction: column; 
            justify-content: space-between; height: 100%; width: 100%;
        }

        .menu-top-row { display: flex; gap: 10px; opacity: 0; transform: translateY(20px); transition: all 0.6s var(--ease-out-expo) 0.2s; }
        .navbar-wrapper.menu-open .menu-top-row { opacity: 1; transform: translateY(0); }
        .utility-pill {
            background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
            color: #fff; padding: 10px 18px; border-radius: 100px; font-size: 10px; 
            font-weight: 700; letter-spacing: 1px; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .lang-selector { width: 45px; justify-content: center; }

        .mobile-links { display: flex; flex-direction: column; gap: 1.5rem; }
        .m-link { 
            font-size: 2.8rem; font-weight: 400; font-family: 'Instrument Serif', serif; font-style: italic;
            color: #fff; text-decoration: none; letter-spacing: -0.5px;
            opacity: 0; transform: translateY(30px); transition: all 0.6s var(--ease-out-expo);
        }
        .navbar-wrapper.menu-open .m-link { opacity: 1; transform: translateY(0); }
        .m-link:nth-child(1) { transition-delay: 0.3s; }
        .m-link:nth-child(2) { transition-delay: 0.4s; }
        .m-link:nth-child(3) { transition-delay: 0.5s; }
        .m-link:nth-child(4) { transition-delay: 0.6s; }

        .mobile-menu-footer { 
            border-top: 1px solid rgba(255,255,255,0.08); padding-top: 2rem; 
            opacity: 0; transform: translateY(20px); transition: all 0.6s var(--ease-out-expo) 0.7s; 
        }
        .navbar-wrapper.menu-open .mobile-menu-footer { opacity: 1; transform: translateY(0); }
        .m-eyebrow { font-size: 8px; font-weight: 800; letter-spacing: 2px; color: #64748b; margin-bottom: 1.5rem; }
        .m-legal { display: flex; justify-content: space-between; font-size: 9px; color: #8892b0; letter-spacing: 1px; font-weight: 700; }
        .m-legal a { color: #fff; text-decoration: none; }
    }
</style>

<script>
    const navbar = document.getElementById("navbar");
    const menuToggle = document.getElementById("menu-toggle");

    window.addEventListener("scroll", () => {
        if (window.pageYOffset > 50) navbar.classList.add("scrolled");
        else navbar.classList.remove("scrolled");
    });

    menuToggle.addEventListener("click", () => {
        navbar.classList.toggle("menu-open");
        document.body.style.overflow = navbar.classList.contains("menu-open") ? "hidden" : "";
    });

    document.querySelectorAll('.m-link, .utility-pill, .btn-contact-mobile').forEach(l => {
        l.addEventListener('click', () => {
            navbar.classList.remove("menu-open");
            document.body.style.overflow = "";
        });
    });
</script>