        .cmp-header { margin-bottom: 2.5rem; }
        .faq-section { padding: 4rem 0; }
        .faq-q { font-size: 1rem; padding: 1.3rem 0; gap: 1rem; }
        .faq-a p { padding-right: 0; }

        .cta-final-clean { padding: 2rem 0 6rem 0; }
        .cta-box-refined { padding: 3rem 1.6rem; border-radius: 28px; }
        .cta-title { font-size: 1.7rem; }
        .btn-luxe-main { width: 100%; justify-content: center; }
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // Recalcular posiciones tras fuentes + carga para que los triggers ya pasados disparen.
    const robustRefresh = () => {
        const winLoad = new Promise<void>((resolve) => {
            if (document.readyState === 'complete') resolve();
            else window.addEventListener('load', () => resolve(), { once: true });
        });
        const fontsReady = (document as any).fonts?.ready ?? Promise.resolve();
        Promise.all([winLoad, fontsReady]).then(() => {
            setTimeout(() => ScrollTrigger.refresh(), 120);
        });
    };
    robustRefresh();

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) return;

        const EASE = 'power2.out';
        const DUR = 0.9;
        const Y = 14;

        /* HERO — entrada en carga (gate .js-anim ya lo tiene en opacity:0) */
        const heroAnim = gsap.utils.toArray<HTMLElement>('.hero-anim');
        if (heroAnim.length) {
            gsap.set(heroAnim, { opacity: 0, y: 12 });
            gsap.timeline({ defaults: { ease: 'power2.out' } })
                .to('.hero-status',             { opacity: 1, y: 0, duration: 0.9 }, 0)
                .to('.hero-text-zone .eyebrow', { opacity: 1, y: 0, duration: 0.9 }, 0.1)
                .to('.hero-title',              { opacity: 1, y: 0, duration: 1.1 }, 0.2)
                .to('.hero-bottom',             { opacity: 1, y: 0, duration: 1.0 }, 0.42);
        }

        /* Reveal robusto (sin parpadeo): oculta con set, revela una vez en onEnter. */
        const reveal = (
            targets: string | HTMLElement | NodeListOf<Element> | HTMLElement[],
            opts: { trigger?: string | HTMLElement; start?: string; y?: number; dur?: number; stagger?: number; delay?: number } = {}
        ) => {
            const els = gsap.utils.toArray<HTMLElement>(targets as any);
            if (!els.length) return;
            const y = opts.y ?? Y;
            gsap.set(els, { opacity: 0, y });
            ScrollTrigger.create({
                trigger: opts.trigger ?? els[0],
                start: opts.start ?? 'top 85%',
                once: true,
                onEnter: () => gsap.to(els, {
                    opacity: 1, y: 0, duration: opts.dur ?? DUR, ease: EASE,
                    stagger: opts.stagger ?? 0.08, delay: opts.delay ?? 0,
                    clearProps: 'transform,opacity',
                }),
            });
        };
        const revealEach = (selector: string, opts: { start?: string; y?: number; dur?: number } = {}) => {
            gsap.utils.toArray<HTMLElement>(selector).forEach(el => {
                reveal(el, { trigger: el, start: opts.start, y: opts.y, dur: opts.dur, stagger: 0 });
            });
        };

        const mm = gsap.matchMedia();

        /* Parallax leve del hero (solo desktop) */
        mm.add('(min-width: 769px)', () => {
            const heroParallax = document.getElementById('hero-parallax');
            if (heroParallax) {
                gsap.to(heroParallax, {
                    yPercent: 5, opacity: 0.85, ease: 'none',
                    scrollTrigger: { trigger: '.hero-grand', start: 'top top', end: 'bottom 30%', scrub: 1 },
                });
            }
        });

        /* Encabezados + eyebrows */
        revealEach('section:not(.hero-grand) .eyebrow', { y: 10, dur: 0.9, start: 'top 90%' });
        revealEach('.section-heading', { y: 16, dur: 1.0, start: 'top 88%' });

        /* PHILOSOPHY (dark) — líneas + columnas */
        const bp = document.querySelector<HTMLElement>('.philosophy-blueprint');
        if (bp) {
            const lineTop = bp.querySelector<HTMLElement>('.bp-line-top');
            const lineBottom = bp.querySelector<HTMLElement>('.bp-line-bottom');
            const lineYs = bp.querySelectorAll<HTMLElement>('.bp-line-y');
            const badge = bp.querySelector<HTMLElement>('.p-badge');
            const title = bp.querySelector<HTMLElement>('.p-title');
            const btn = bp.querySelector<HTMLElement>('.sleek-btn-light');
            const cols = bp.querySelectorAll<HTMLElement>('.bp-col:not(.bp-header-col) .bp-content');

            if (lineTop) gsap.set(lineTop, { width: 0 });
            if (lineBottom) gsap.set(lineBottom, { width: 0 });
            gsap.set(lineYs, { height: 0 });
            const fade = [badge, title, btn].filter(Boolean) as HTMLElement[];
            gsap.set(fade, { opacity: 0, y: 16 });
            gsap.set(cols, { opacity: 0, y: 20 });

            const tl = gsap.timeline({ scrollTrigger: { trigger: bp, start: 'top 82%', once: true } });
            if (lineTop) tl.to(lineTop, { width: '100%', duration: 1.2, ease: 'power3.inOut' }, 0);
            if (lineBottom) tl.to(lineBottom, { width: '100%', duration: 1.2, ease: 'power3.inOut' }, 0.15);
            lineYs.forEach((l, i) => tl.to(l, { height: '100%', duration: 1.0, ease: 'power3.inOut' }, 0.3 + i * 0.08));
            tl.to(fade, { opacity: 1, y: 0, duration: DUR, ease: EASE, stagger: 0.1 }, 0.25);
            tl.to(cols, { opacity: 1, y: 0, duration: DUR, ease: EASE, stagger: 0.1 }, 0.4);
        }

        /* SERVICIOS — índice editorial (capítulo por servicio) */
        document.querySelectorAll<HTMLElement>('.svc-chapter').forEach((row) => {
            const head = row.querySelectorAll<HTMLElement>('.svc-head, .svc-title, .svc-desc, .svc-proof');
            const caps = row.querySelectorAll<HTMLElement>('.svc-cap');
            const stack = row.querySelector<HTMLElement>('.svc-stack');

            gsap.set(head, { opacity: 0, y: 16 });
            gsap.set(caps, { opacity: 0, y: 16 });
            if (stack) gsap.set(stack, { opacity: 0, y: 10 });

            const tl = gsap.timeline({ scrollTrigger: { trigger: row, start: 'top 82%', once: true } });
            tl.to(head, { opacity: 1, y: 0, duration: DUR, ease: EASE, stagger: 0.07, clearProps: 'transform,opacity' }, 0);
            tl.to(caps, { opacity: 1, y: 0, duration: DUR, ease: EASE, stagger: 0.06, clearProps: 'transform,opacity' }, 0.2);
            if (stack) tl.to(stack, { opacity: 1, y: 0, duration: DUR, ease: EASE, clearProps: 'transform,opacity' }, 0.45);
        });

        /* WHY FLOUVIA cards */
        reveal('.wf-hardware-grid .hw-card', { trigger: '.wf-hardware-grid', y: 28, dur: 1.0, stagger: 0.1, start: 'top 82%' });

        /* COMPARISON table */
        reveal('.cmp-scroll', { trigger: '.comparison-section', y: 24, dur: 1.0, start: 'top 80%' });

        /* FAQ items — reveal en scroll */
        reveal('.faq-item', { trigger: '.faq-list', y: 16, dur: 0.85, stagger: 0.06, start: 'top 84%' });

        /* FAQ — acordeón con despliegue de altura suave (una sola abierta) */
        const faqItems = gsap.utils.toArray<HTMLElement>('.faq-item');
        const closeFaq = (item: HTMLElement) => {
            const panel = item.querySelector<HTMLElement>('.faq-a');
            if (!panel) return;
            gsap.set(panel, { height: panel.offsetHeight });
            gsap.to(panel, {
                height: 0, opacity: 0, duration: 0.4, ease: 'power2.inOut',
                onComplete: () => { item.removeAttribute('open'); gsap.set(panel, { clearProps: 'height,opacity' }); },
            });
        };
        const openFaq = (item: HTMLElement) => {
            const panel = item.querySelector<HTMLElement>('.faq-a');
            if (!panel) return;
            item.setAttribute('open', '');
            gsap.set(panel, { height: 'auto', opacity: 1 });
            const h = panel.offsetHeight;
            gsap.fromTo(panel,
                { height: 0, opacity: 0 },
                { height: h, opacity: 1, duration: 0.55, ease: 'power2.out',
                  onComplete: () => gsap.set(panel, { height: 'auto' }) });
        };
        faqItems.forEach((item) => {
            const summary = item.querySelector<HTMLElement>('.faq-q');
            if (!summary) return;
            summary.addEventListener('click', (e) => {
                e.preventDefault();
                if (item.hasAttribute('open')) {
                    closeFaq(item);
                } else {
                    faqItems.forEach((o) => { if (o !== item && o.hasAttribute('open')) closeFaq(o); });
                    openFaq(item);
                }
            });
        });

        /* CTA final */
        const cta = document.querySelector<HTMLElement>('.cta-box-refined');
        if (cta) {
            reveal(cta, { trigger: cta, y: 24, dur: 1.0, start: 'top 84%' });
            reveal(cta.querySelectorAll('.cta-text > *, .btn-luxe-main'), { trigger: cta, y: 16, dur: 0.9, stagger: 0.08, delay: 0.15, start: 'top 84%' });
        }
    });

    /* HW CARD — mouse glow (microinteracción sobria, sin tilt 3D) */
    if (window.matchMedia('(hover: hover)').matches) {
        document.querySelectorAll<HTMLElement>('.hw-card').forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                card.style.setProperty('--mouse-x', `${(e as MouseEvent).clientX - rect.left}px`);
                card.style.setProperty('--mouse-y', `${(e as MouseEvent).clientY - rect.top}px`);
            });
        });
    }
</script>
