---
// src/components/PlantillaServicios.astro
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';

const SITE = 'https://flouvia.com';
const servPath = isEn ? '/en/servicios' : '/servicios';

// ── Schema Service (uno por servicio) — citable por AI Overviews ──
const services = isEn ? [
    { anchor: 'ecommerce',  name: 'E-commerce Engineering — Shopify Plus', serviceType: 'E-commerce Engineering',
      description: 'Transactional store builds on Shopify Plus. Headless architecture with Next.js and Hydrogen, native themes, checkout engineering, and migrations from Magento or VTEX without SEO loss.' },
    { anchor: 'b2b',        name: 'B2B Digital Architecture', serviceType: 'B2B E-commerce',
      description: 'Private B2B portals on Shopify Plus with role-based access, dynamic pricing, SKU quick-order, and native two-way ERP integration.' },
    { anchor: 'automation', name: 'Business Automation', serviceType: 'Business Process Automation',
      description: 'E-commerce operations automation: native ERP integration (SAP, NetSuite, Dynamics), workflow orchestration with Make, and data centralization in Airtable.' },
    { anchor: 'cro',        name: 'Conversion Rate Optimization (CRO)', serviceType: 'Conversion Rate Optimization',
      description: 'Data-driven conversion optimization: forensic UX audit, A/B testing, heatmaps, and Klaviyo retention flows. Average increases of +34% in conversion rate.' },
] : [
    { anchor: 'ecommerce',  name: 'E-commerce Engineering — Shopify Plus', serviceType: 'E-commerce Engineering',
      description: 'Construcción de tiendas transaccionales en Shopify Plus. Arquitectura headless con Next.js y Hydrogen, themes nativos, checkout engineering y migraciones desde Magento o VTEX sin pérdida de SEO.' },
    { anchor: 'b2b',        name: 'B2B Digital Architecture', serviceType: 'B2B E-commerce',
      description: 'Portales B2B privados sobre Shopify Plus con acceso por rol, precios dinámicos, quick-order por SKU e integración ERP nativa bidireccional.' },
    { anchor: 'automation', name: 'Business Automation', serviceType: 'Business Process Automation',
      description: 'Automatización de operaciones e-commerce: integración ERP nativa (SAP, NetSuite, Dynamics), orquestación de flujos con Make y centralización de datos en Airtable.' },
    { anchor: 'cro',        name: 'Conversion Rate Optimization (CRO)', serviceType: 'Conversion Rate Optimization',
      description: 'Optimización de conversión basada en datos: auditoría UX forense, A/B testing, heatmaps y flujos de retención en Klaviyo. Incrementos promedio de +34% en tasa de conversión.' },
];

const serviceSchemas = services.map((s) => ({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: s.name,
    description: s.description,
    provider: { '@id': `${SITE}/#organization` },
    areaServed: [
        { '@type': 'Country', name: isEn ? 'Mexico' : 'México' },
        { '@type': 'Country', name: 'United States' },
    ],
    serviceType: s.serviceType,
    url: `${SITE}${servPath}#${s.anchor}`,
}));

// ── FAQ — fuente única para render + FAQPage schema ──
const faqs = isEn ? [
    { q: 'How much does an e-commerce project with Flouvia cost?',
      a: 'Flouvia projects are high-value and vary by complexity. We don’t work with budgets under $30,000 MXN. The process starts with a free 30-min diagnosis where we assess fit before making any commercial proposal.' },
    { q: 'When do I need Shopify Plus instead of standard Shopify?',
      a: 'Shopify Plus is necessary when your operation exceeds $500k USD a year, you need a custom checkout, native ERP integrations, B2B portals with differentiated pricing, or advanced flow automation. For smaller operations, standard Shopify can be enough.' },
    { q: 'How long does it take to build a B2B portal on Shopify Plus?',
      a: 'A B2B portal with role-based access, dynamic pricing, and a protected catalog takes 8 to 14 weeks. With native ERP integration (SAP, NetSuite, Dynamics), it’s 12 to 16 weeks. Timing depends on the complexity of the business rules and available APIs.' },
    { q: 'Do you work with companies outside Mexico?',
      a: 'Yes. Flouvia operates with clients in Mexico and the United States. The operation is 100% remote and digital. We handle projects in both markets with teams in CDMX as the development hub.' },
    { q: 'What is CRO and how does it improve my e-commerce?',
      a: 'CRO (Conversion Rate Optimization) is the process of analyzing your users’ real behavior — heatmaps, session recordings, A/B tests — to identify where you lose sales and build data-backed improvements. In our projects we’ve achieved average increases of +34% in conversion rate.' },
    { q: 'Do you provide maintenance after delivering the project?',
      a: 'Yes. We offer technical maintenance and post-launch support plans that include latency monitoring, security updates, and CRO iterations. The systems we build are made to evolve, not to stay static.' },
    { q: 'How do you integrate Shopify Plus with an ERP like SAP or NetSuite?',
      a: 'We build bespoke two-way API connectors — we don’t use generic ones. The integration syncs inventory, orders, pricing, and customers in real time between Shopify Plus and the ERP. Integration takes 6 to 10 weeks depending on flow complexity.' },
] : [
    { q: '¿Cuánto cuesta un proyecto de e-commerce con Flouvia?',
      a: 'Los proyectos de Flouvia son de alto valor y varían según complejidad. No trabajamos con presupuestos menores a $30,000 MXN. El proceso empieza con un diagnóstico gratuito de 30 min donde evaluamos si hay fit antes de hacer cualquier propuesta económica.' },
    { q: '¿Cuándo necesito Shopify Plus en lugar de Shopify estándar?',
      a: 'Shopify Plus es necesario cuando tu operación supera los $500k USD anuales, necesitas checkout personalizado, integraciones ERP nativas, portales B2B con precios diferenciados, o automatizaciones avanzadas de flujo. Para operaciones menores, Shopify estándar puede ser suficiente.' },
    { q: '¿Cuánto tiempo tarda construir un portal B2B en Shopify Plus?',
      a: 'Un portal B2B con acceso por rol, precios dinámicos y catálogo protegido tarda entre 8 y 14 semanas. Con integración ERP nativa (SAP, NetSuite, Dynamics), el plazo es de 12 a 16 semanas. El tiempo depende de la complejidad de las reglas de negocio y las APIs disponibles.' },
    { q: '¿Trabajan con empresas fuera de México?',
      a: 'Sí. Flouvia opera con clientes en México y Estados Unidos. La operación es 100% remota y digital. Manejamos proyectos en ambos mercados con equipos en CDMX como hub de desarrollo.' },
    { q: '¿Qué es CRO y cómo mejora mi e-commerce?',
      a: 'CRO (Conversion Rate Optimization) es el proceso de analizar el comportamiento real de tus usuarios — heatmaps, grabaciones de sesión, A/B tests — para identificar dónde pierdes ventas y construir mejoras con datos. En nuestros proyectos hemos logrado incrementos promedio de +34% en tasa de conversión.' },
    { q: '¿Hacen mantenimiento después de entregar el proyecto?',
      a: 'Sí. Ofrecemos esquemas de mantenimiento técnico y soporte post-lanzamiento que incluyen monitoreo de latencia, actualizaciones de seguridad e iteraciones de CRO. Los sistemas que construimos están hechos para evolucionar, no para quedarse estáticos.' },
    { q: '¿Cómo integran Shopify Plus con un ERP como SAP o NetSuite?',
      a: 'Desarrollamos conectores API bidireccionales a medida — no usamos conectores genéricos. La integración sincroniza inventario, pedidos, precios y clientes en tiempo real entre Shopify Plus y el ERP. El proceso de integración toma entre 6 y 10 semanas dependiendo de la complejidad de los flujos.' },
];

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// ── Comparison table rows ──
const cmpHead = isEn
    ? ['Criterion', 'Flouvia', 'Traditional agency', 'Freelancer / Generic']
    : ['Criterio', 'Flouvia', 'Agencia tradicional', 'Freelancer / Genérica'];
// tones: 'pos' (✓) · 'mid' (~) · 'neg' (✗) · 'none' (descriptivo, sin ícono)
const cmpRows = isEn ? [
    { c: 'Code',                cells: [['pos', 'Native, no apps'], ['mid', 'Mix of apps & code'], ['neg', 'Templates + apps']] },
    { c: 'Specialization',      cells: [['pos', 'E-commerce & B2B only'], ['mid', 'E-commerce + others'], ['neg', 'All kinds of projects']] },
    { c: 'ERP integrations',    cells: [['pos', 'Native two-way API'], ['mid', 'Depends on project'], ['neg', 'Rare or superficial']] },
    { c: 'Client volume',       cells: [['pos', 'Max. 8 projects / year'], ['mid', '10–30 at once'], ['neg', 'No defined limit']] },
    { c: 'Measurable result',   cells: [['pos', '+34% CR · −67% time'], ['mid', 'Project delivery'], ['neg', 'Site delivery']] },
    { c: 'Who it’s for',        cells: [['none', 'Established operation'], ['none', 'Mid-size projects'], ['none', 'Any client']] },
] : [
    { c: 'Código',              cells: [['pos', 'Nativo, sin apps'], ['mid', 'Mix de apps y código'], ['neg', 'Plantillas + apps']] },
    { c: 'Especialización',     cells: [['pos', 'Solo e-commerce y B2B'], ['mid', 'E-commerce + otros'], ['neg', 'Todo tipo de proyectos']] },
    { c: 'Integraciones ERP',   cells: [['pos', 'API nativa bidireccional'], ['mid', 'Depende del proyecto'], ['neg', 'Raro o superficial']] },
    { c: 'Volumen de clientes', cells: [['pos', 'Máx. 8 proyectos / año'], ['mid', '10–30 simultáneos'], ['neg', 'Sin límite definido']] },
    { c: 'Resultado medible',   cells: [['pos', '+34% CR · −67% tiempo'], ['mid', 'Entrega del proyecto'], ['neg', 'Entrega del sitio']] },
    { c: 'Para quién',          cells: [['none', 'Operación con tracción'], ['none', 'Proyectos medianos'], ['none', 'Cualquier cliente']] },
];

// ── Caso / métrica discreta por servicio (número en serif italic, sin caja) ──
const proofs = isEn ? [
    { metric: '+42%', text: 'conversion · Setnpet, after a headless rebuild on Shopify Plus.' },
    { metric: '6h → 0', text: 'manual work · El Zarco, with a B2B portal on Shopify Plus.' },
    { metric: '−67%', text: 'process time · El Zarco, after automating its order flow.' },
    { metric: '+42%', text: 'conversion · Setnpet, after a CRO audit and flow rebuild.' },
] : [
    { metric: '+42%', text: 'conversión · Setnpet, tras reconstrucción headless en Shopify Plus.' },
    { metric: '6 h → 0', text: 'intervención manual · El Zarco, con portal B2B en Shopify Plus.' },
    { metric: '−67%', text: 'tiempo de proceso · El Zarco, tras automatizar su flujo de pedidos.' },
    { metric: '+42%', text: 'conversión · Setnpet, tras auditoría CRO y reconstrucción de flujo.' },
];

// ── Índice editorial de servicios (un capítulo por servicio) ──
const serviceRows = [
    { n: '1', anchor: 'ecommerce',  href: isEn ? '/en/servicios/ecommerce' : '/servicios/ecommerce' },
    { n: '2', anchor: 'b2b',        href: isEn ? '/en/servicios/b2b' : '/servicios/b2b' },
    { n: '3', anchor: 'automation', href: isEn ? '/en/servicios/automatizacion' : '/servicios/automatizacion' },
    { n: '4', anchor: 'cro',        href: isEn ? '/en/servicios/growth' : '/servicios/growth' },
].map((s, i) => ({
    ...s,
    proof: proofs[i],
    cat: t(`serv.${s.n}.cat` as any),
    title: t(`serv.${s.n}.title` as any),
    desc: t(`serv.${s.n}.desc` as any),
    btn: t(`serv.${s.n}.btn` as any),
    caps: [1, 2, 3, 4].map((d) => ({ t: t(`serv.${s.n}.d${d}.t` as any), d: t(`serv.${s.n}.d${d}.d` as any) })),
    stack: [t(`serv.${s.n}.t1` as any), t(`serv.${s.n}.t2` as any), t(`serv.${s.n}.t3` as any)],
}));
---

<Layout
    title={isEn ? 'E-commerce, B2B & Automation Engineering in CDMX | Flouvia — Shopify Plus' : 'Servicios de E-commerce, B2B y Automatización en CDMX | Flouvia — Shopify Plus'}
    description={isEn ? 'E-commerce engineering, B2B architecture, automation and CRO on Shopify Plus. Bespoke systems for operations that already sell and need to scale without breaking.' : 'Ingeniería e-commerce, arquitectura B2B, automatización y CRO en Shopify Plus. Sistemas a medida para operaciones que ya venden y necesitan escalar sin romperse.'}
>
    <Navbar />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    {serviceSchemas.map((s) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
    ))}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

    <main class="flouvia-masterpiece page-bg-unified">

        <!-- ════════ HERO (estándar inicio) ════════ -->
        <section class="hero-grand">
            <div class="serv-watermark" aria-hidden="true">Servicios</div>
            <div class="container hero-container">
                <div class="hero-content">
                    <div class="hero-text-zone" id="hero-parallax">
                        <div class="hero-status hero-anim">
                            <span class="hero-status-dot" aria-hidden="true"></span>
                            <span>{isEn ? 'ACCEPTING Q3 PROJECTS' : 'ACEPTANDO PROYECTOS Q3'}</span>
                        </div>
                        <p class="eyebrow hero-anim">{t('serv.hero.badge')}</p>
                        <h1 class="hero-title hero-anim">
                            <span class="title-bold">{t('serv.hero.title1')}</span>
                            <span class="title-soft">{t('serv.hero.title2')}</span>
                        </h1>
                    </div>

                    <div class="hero-bottom hero-anim">
                        <p class="hero-desc">{t('serv.hero.desc')}</p>
                        <div class="hero-action">
                            <a href="/contacto" class="btn-luxe">
                                <span>{isEn ? 'See if I qualify' : 'Ver si califico'}</span>
                                <span class="btn-arrow" aria-hidden="true">→</span>
                                <div class="btn-shimmer"></div>
                            </a>
                            <a href="#servicios-showcase" class="btn-ghost">
                                <span>{isEn ? 'Explore services' : 'Explorar servicios'}</span>
                                <span class="btn-arrow-down" aria-hidden="true">↓</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════ PHILOSOPHY (dark band) ════════ -->
        <section class="philosophy-blueprint dark-section">
            <div class="bp-watermark" aria-hidden="true">{isEn ? 'Why' : 'Por qué'}</div>
            <div class="texture-noise-micro"></div>

            <div class="bp-line-x bp-line-top"></div>
            <div class="bp-line-x bp-line-bottom"></div>

            <div class="container relative-z">
                <div class="blueprint-grid">

                    <div class="bp-col bp-header-col">
                        <div class="bp-content">
                            <span class="p-badge">{t('serv.why.badge')}</span>
                            <h2 class="p-title">{t('serv.why.title')} <br><span class="editorial text-dim">{t('serv.why.title_ed')}</span></h2>

                            <a href="/contacto" class="sleek-btn-light">
                                <span>{t('serv.why.btn')}</span>
                                <div class="m-circle-light">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        </div>
                        <div class="bp-line-y"></div>
                    </div>

                    <div class="bp-col">
                        <div class="bp-content">
                            <span class="bp-num">01</span>
                            <span class="p-val-title">{t('serv.why.1.title')}</span>
                            <p>{t('serv.why.1.desc')}</p>
                        </div>
                        <div class="bp-line-y"></div>
                    </div>

                    <div class="bp-col">
                        <div class="bp-content">
                            <span class="bp-num">02</span>
                            <span class="p-val-title">{t('serv.why.2.title')}</span>
                            <p>{t('serv.why.2.desc')}</p>
                        </div>
                        <div class="bp-line-y"></div>
                    </div>

                    <div class="bp-col bp-last">
                        <div class="bp-content">
                            <span class="bp-num">03</span>
                            <span class="p-val-title">{t('serv.why.3.title')}</span>
                            <p>{t('serv.why.3.desc')}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════ SERVICIOS — índice editorial ════════ -->
        <section class="services-index" id="servicios-showcase">
            <div class="container">
                {serviceRows.map((s) => (
                    <article class="svc-chapter" id={s.anchor}>
                        <div class="svc-head">
                            <span class="svc-eyebrow">
                                <span class="svc-num editorial">/0{s.n}</span>
                                <span class="svc-cat">{s.cat.replace(/^\d+\s*—\s*/, '')}</span>
                            </span>
                            <a href={s.href} class="svc-cta">
                                <span>{s.btn}</span>
                                <span class="svc-cta-arrow" aria-hidden="true">→</span>
                            </a>
                        </div>

                        <h2 class="svc-title">{s.title}</h2>
                        <p class="svc-desc">{s.desc}</p>
                        <p class="svc-proof"><span class="svc-proof-metric editorial">{s.proof.metric}</span> {s.proof.text}</p>

                        <div class="svc-caps">
                            {s.caps.map((c, ci) => (
                                <div class="svc-cap">
                                    <span class="svc-cap-idx editorial">·0{ci + 1}</span>
                                    <div class="svc-cap-text">
                                        <h3>{c.t}</h3>
                                        <p>{c.d}</p>
                                    </div>
                                </div>
                            ))}
                        </div>

                        <div class="svc-stack">
                            <span class="svc-stack-label">STACK</span>
                            <div class="svc-stack-pills">{s.stack.map((p) => (<span>{p}</span>))}</div>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <!-- ════════ WHY FLOUVIA (cards) ════════ -->
        <section class="why-flouvia-hardware">
            <div class="container">
                <div class="wf-header">
                    <p class="eyebrow">{t('serv.choose.badge')}</p>
                    <h2 class="wf-title section-heading">
                        {t('serv.choose.title')} {t('serv.choose.title_ed')}
                    </h2>
                </div>

                <div class="wf-hardware-grid">
                    <div class="hw-card">
                        <div class="hw-glow-overlay"></div>
                        <div class="hw-inner">
                            <span class="hw-num">/01</span>
                            <div class="hw-text-zone"><h3>{t('serv.choose.1.title')}</h3><p>{t('serv.choose.1.desc')}</p></div>
                        </div>
                    </div>
                    <div class="hw-card">
                        <div class="hw-glow-overlay"></div>
                        <div class="hw-inner">
                            <span class="hw-num">/02</span>
                            <div class="hw-text-zone"><h3>{t('serv.choose.2.title')}</h3><p>{t('serv.choose.2.desc')}</p></div>
                        </div>
                    </div>
                    <div class="hw-card">
                        <div class="hw-glow-overlay"></div>
                        <div class="hw-inner">
                            <span class="hw-num">/03</span>
                            <div class="hw-text-zone"><h3>{t('serv.choose.3.title')}</h3><p>{t('serv.choose.3.desc')}</p></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════ COMPARISON TABLE ════════ -->
        <section class="comparison-section">
            <div class="cmp-watermark" aria-hidden="true">{isEn ? 'Firm' : 'Firma'}</div>
            <div class="container relative-z">
                <div class="cmp-header">
                    <p class="eyebrow">{isEn ? 'EVALUATION' : 'EVALUACIÓN'}</p>
                    <h2 class="section-heading">{isEn ? 'Why a specialized firm?' : '¿Por qué una firma especializada?'}</h2>
                    <p class="section-sub">{isEn ? 'The difference between building a store and building a system that scales.' : 'La diferencia entre construir una tienda y construir un sistema que escala.'}</p>
                </div>

                <div class="cmp-scroll">
                    <div class="cmp-frame">
                        <table class="cmp-table">
                            <thead>
                                <tr>
                                    {cmpHead.map((h, i) => (
                                        <th class={i === 1 ? 'cmp-col-flouvia' : ''}>
                                            {i === 1
                                                ? <span class="cmp-flouvia-head">{h}<span class="cmp-flouvia-badge">{isEn ? 'Recommended' : 'Recomendado'}</span></span>
                                                : h}
                                        </th>
                                    ))}
                                </tr>
                            </thead>
                            <tbody>
                                {cmpRows.map((row) => (
                                    <tr>
                                        <th scope="row">{row.c}</th>
                                        {row.cells.map(([tone, text], i) => (
                                            <td class={i === 0 ? 'cmp-col-flouvia' : ''}>
                                                {i === 0 && tone === 'pos'
                                                    ? <span class="cmp-cell"><svg class="cmp-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg><span class="cmp-cell-text">{text}</span></span>
                                                    : <span class="cmp-cell-text">{text}</span>}
                                            </td>
                                        ))}
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════ FAQ ════════ -->
        <section class="faq-section">
            <div class="container">
                <div class="faq-header">
                    <p class="eyebrow">FAQ</p>
                    <h2 class="section-heading">{isEn ? 'Frequently asked questions' : 'Preguntas frecuentes'}</h2>
                </div>

                <div class="faq-list">
                    {faqs.map((f) => (
                        <details class="faq-item">
                            <summary class="faq-q">
                                <span>{f.q}</span>
                                <span class="faq-icon" aria-hidden="true"></span>
                            </summary>
                            <div class="faq-a"><p>{f.a}</p></div>
                        </details>
                    ))}
                </div>
            </div>
        </section>

        <!-- ════════ CTA FINAL (escasez) ════════ -->
        <section class="cta-final-clean">
            <div class="container">
                <div class="cta-box-refined squircle-pro">
                    <div class="texture-noise-micro"></div>
                    <div class="cta-flex relative-z">
                        <div class="cta-text">
                            <p class="eyebrow cta-eyebrow">{isEn ? 'LIMITED AVAILABILITY — Q3' : 'DISPONIBILIDAD LIMITADA — Q3'}</p>
                            <h2 class="cta-title">
                                {isEn ? '2 projects available this quarter.' : '2 proyectos disponibles este trimestre.'}
                                <span class="cta-title-soft">{isEn ? 'Does your operation qualify?' : '¿Tu operación califica?'}</span>
                            </h2>
                            <p class="cta-body">{isEn ? 'We don’t take on projects without a prior diagnosis. If your operation already has traction and you need the technical infrastructure for the next level, let’s start with a free 30-minute session.' : 'No aceptamos proyectos sin diagnóstico previo. Si tu operación ya tiene tracción y necesitas la infraestructura técnica para el siguiente nivel, comencemos con una sesión de 30 minutos sin costo.'}</p>
                        </div>
                        <a href="/contacto" class="btn-luxe-main">
                            <span>{isEn ? 'See if I qualify' : 'Ver si califico'}</span>
                            <span class="btn-arrow" aria-hidden="true">→</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <Footer />
</Layout>

<style is:global>
    *, *::before, *::after { box-sizing: border-box; }

    html, body {
        width: 100%;
        position: relative;
        -webkit-font-smoothing: antialiased;
